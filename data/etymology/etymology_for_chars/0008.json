    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用火灼龟甲或兽骨，以观察裂纹预测吉凶，即占卜。",
      "examples": [
        "卜问吉凶",
        "卜筮"
      ],
      "traditional_char": "卜"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "预料，估计，猜测。",
      "examples": [
        "预卜未来",
        "卜度"
      ],
      "traditional_char": "卜"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "选择（处所）。",
      "examples": [
        "卜宅",
        "卜邻"
      ],
      "traditional_char": "卜"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "见“萝卜”，指萝卜植物。",
      "examples": [
        "萝卜"
      ],
      "traditional_char": "蔔"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形，甲骨文字形象龟甲裂纹，表示占卜之义。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 3,
      "note": "形声字，“艹”表示植物，“卜”表声，指萝卜。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从“占卜”引申为预测、估计之意，古今文献皆有例证。"
