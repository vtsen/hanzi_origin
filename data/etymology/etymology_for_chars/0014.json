  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "‘几’字为象形字，表示有靠背的座具。甲骨文形似带靠背的小桌或坐具。"
    },
    {
      "formation_type": "loan_character",
      "original_sense_index": 3,
      "note": "‘幾’本作发问词，后借为数量词。形声，‘幺’表声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "古人以坐具接近地面引申为‘接近’、‘将近’之意。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由‘几’作为物体之端缘，引申为‘苗头，端倪’。"
