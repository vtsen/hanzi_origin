    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“触犯”进一步泛化为“涉及、关联”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "原为兵器，后用作天干名。早见于《尚书》天干地支系统。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "兵器意外引申为“涯岸、水边”，多见于古诗文。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "“干”引申为“若干”，表示数量。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "形容干燥发展为“枯竭、尽净”之意。"
    },
    {
      "source_index": 7,
      "target_index": 9,
      "evolution_type": "semantic_extension",
