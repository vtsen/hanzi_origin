    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "距离手腕一寸的地方，中医切脉部位，又称“寸口”。",
      "examples": [
        "医者以寸口诊脉。"
      ],
      "traditional_char": "寸"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "短小（用于抽象或具体事物）。",
      "examples": [
