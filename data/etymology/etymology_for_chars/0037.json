  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由物理‘小’引申为范围、程度等非物理‘小’。早见先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
