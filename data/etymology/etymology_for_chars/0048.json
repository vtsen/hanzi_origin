{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "小，细，微小的事物或次序最小者；排行最小的人；骰子或骨牌上的“一点”",
      "examples": [
        "《說文》曰：‘么，小也。’",
        "幺叔、幺妹、呼幺喝六"
      ],
      "traditional_char": "么"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用作某些词的后缀，无实义，构成疑问、程度等词",
      "examples": [
        "什么、怎么、多么"
      ],
      "traditional_char": "麽"
    },
    {
      "index": 2,
      "part_of_speech": "particle",
      "meaning": "助词，用于句尾或句中表示语气（疑问、含蓄等）",
      "examples": [
        "不让你去么，你又要去。"
      ],
      "traditional_char": "麽"
    },
    {
      "index": 3,
      "part_of_speech": "particle",
      "meaning": "同“吗”，表疑问语气",
      "examples": [
        "你去么？"
      ],
      "traditional_char": "么"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "‘么’为象形字，象丝线初生、细小的样子，表示‘小’的本义"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘麽’为形声字，从‘麻’（意符/声符），后用作词尾或助词"
    }
  ],
  "edges": [
    {
      "source_index": 0,
