  ],
  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "‘太’字本为指事，在‘大’字下加一横，表示“过于”，显示强调意思。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
