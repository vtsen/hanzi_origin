      "part_of_speech": "measure_word",
      "meaning": "计算布帛长度的单位，四丈为一匹；也指整卷的绸或布。",
      "examples": [
        "一匹布",
        "买了两匹绸子"
      ],
      "traditional_char": "匹"
    },
    {
