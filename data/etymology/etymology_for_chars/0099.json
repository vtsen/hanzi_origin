      "part_of_speech": "measure_word",
      "meaning": "用作量词，指马、骡等。",
      "examples": [
        "一匹马",
        "两匹骡子"
      ],
      "traditional_char": "匹"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "单独的人，泛指平常人或指无学识、无智谋的人。",
      "examples": [
        "国家兴亡，匹夫有责",
        "匹夫无罪，怀璧其罪",
        "匹夫之勇"
      ],
      "traditional_char": "匹"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "相当、相敌、比得上。",
      "examples": [
        "匹敌",
        "匹配"
      ],
      "traditional_char": "匹"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "本字会意，金文象山崖凹凸比喻布的折皱，原指量布的单位。"
    }
  ],
  "edges": [
    {
