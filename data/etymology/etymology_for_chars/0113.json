{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "中心；当中，指一定范围内部适中的位置",
      "examples": [
        "中心",
        "房中",
        "中间"
      ],
      "traditional_char": "中"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "中国，特指中国",
      "examples": [
        "中文",
        "中式",
        "中华"
      ],
      "traditional_char": "中"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "性质或等级在两端之间的，中等的",
      "examples": [
        "中等",
        "中级",
        "中流砥柱"
      ],
      "traditional_char": "中"
    },
    {
      "index": 3,
      "part_of_speech": "preposition",
      "meaning": "在……之中，表示处于某时、某地、某状态",
      "examples": [
