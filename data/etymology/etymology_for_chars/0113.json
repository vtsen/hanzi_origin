  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "甲骨文字形，中央竖杆，指示中心位置，属指事字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以地理‘中心’借指‘中国’为国家中心的用法，战国以后。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘中心’引申为‘中等’之意，汉代起见。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由‘一定范围内部’引申为‘在……之中’，作介词用，语法化。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "从‘中心’引申为‘正中目标’，故有‘命中’之义，古已见。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由‘正好合上’扩展为‘遭受/受到’（如中毒），语义拓展。"
    },
    {
      "source_index": 4,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由‘命中’引申为‘科举考试及第’，比喻击中目标。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由‘合乎中心’引申为‘适于、合于’。"
    }
  ]
}