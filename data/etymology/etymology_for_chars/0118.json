{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "看见，看到",
      "examples": [
        "我见青山多妩媚",
        "路人皆见"
      ],
      "traditional_char": "見"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "接触，遇到",
      "examples": [
        "怕见风",
        "一见如故"
      ],
      "traditional_char": "見"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "显现，显得出",
      "examples": [
        "见效",
        "相形见绌"
      ],
      "traditional_char": "見"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "（文字等）出现在某处",
      "examples": [
        "见上",
        "见下"
      ],
      "traditional_char": "見"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "会晤，会面",
      "examples": [
        "会见",
        "接见"
      ],
      "traditional_char": "見"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "对事物的观察、认识、理解",
      "examples": [
        "见解",
        "高见",
        "见仁见智"
      ],
      "traditional_char": "見"
    },
    {
      "index": 6,
      "part_of_speech": "particle",
      "meaning": "表示被动或对我如何用法",
      "examples": [
        "见教",
        "见谅",
        "见笑"
      ],
      "traditional_char": "見"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "出现，显现（古同“现”）",
      "examples": [
        "不见经传",
        "红日初见"
      ],
      "traditional_char": "見"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，上为“目”下为“人”，表示人在用眼看，指‘看见’之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘看到’扩展为‘接触、遇到’，见于先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘看到’引申为‘显现、显得出’，汉代用法已见。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由‘看到’转喻为‘（文字等）出现’，文献用‘见上’等结构。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由‘看到’引申为‘会晤’，可见于《论语》及以后文献。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "所见即所知，引申为‘见解、理解’。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "grammaticalization",
      "note": "由动词‘见’虚化为被动、对待我的助词功能，出现于中古汉语。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "‘见’与‘现’古音通用，出现‘出现、显现’义，周秦两汉间常用。"
    }
  ]
}