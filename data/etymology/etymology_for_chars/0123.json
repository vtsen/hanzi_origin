      ],
      "traditional_char": "毛"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，金文形象表现毛发状，表示动植物的皮毛。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "古以动植物毛比喻谷物、杂草等细小丝状之物。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "霉菌如细毛状，借喻指衣物发霉。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "未加工的织物常带有毛，故引申为“粗糙”之意。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "“毛”引申为“不纯净”，如带毛未精炼。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "毛发竖起形容人急躁不安，转为性格急躁。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由“急躁”进一步引申为“惊慌失措”。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "synecdoche",
      "note": "“毛”为细小之物，用以指细小、微小之事物，表达“小”之意。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "由“毛发零乱不值钱”引申为货币贬值的用法。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "function_word",
      "note": "细微之物用于钱币小数，转为币值量词。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "unknown",
      "note": "用于姓氏，来源不明，或与本义相关。"
    }
  ]
}