{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "动植物皮上所生的丝状物，如毛发、兽毛等",
      "examples": [
        "羽毛",
        "毛发",
        "毛笔",
        "毛囊"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "像毛一样的东西，指谷物或杂草",
      "examples": [
        "不毛之地"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "衣物上的霉菌",
      "examples": [
        "衣服都长毛了"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "粗糙，没有加工的",
      "examples": [
        "毛布",
        "毛坯",
        "毛估"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "不纯净的",
      "examples": [
        "毛利",
        "毛重"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "行动、性格急躁",
      "examples": [
        "毛躁"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "惊慌失措，主意乱了",
      "examples": [
        "把他吓毛了"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 7,
      "part_of_speech": "adjective",
      "meaning": "小；细微",
      "examples": [
        "毛病",
        "毛孩子",
        "毛毛雨"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 8,
      "part_of_speech": "verb",
      "meaning": "货币贬值",
      "examples": [
        "钱毛了"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 9,
      "part_of_speech": "measure_word",
      "meaning": "用于钱币，等于“角”，一圆钱的十分之一",
      "examples": [
        "两毛钱"
      ],
      "traditional_char": "毛"
    },
    {
      "index": 10,
      "part_of_speech": "noun",
      "meaning": "姓氏",
      "examples": [
