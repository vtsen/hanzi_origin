  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，形似人担物行走，表“挑担”之意，是早期本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "从“挑担、负担”泛化转移为天干第九位的记序用法，因“任”有承载、承受义，天干名转用。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“负荷”引申为“盛大”，比喻容量大能承担多，为诗经中引申义。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "因与“任（巧言任事）”音近义通，被假借为“奸佞、巧辩”，后专用为贬义。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由“天干第九位”引申为姓氏用法，常见以天干地支为姓氏来源。"
    }
  ]
