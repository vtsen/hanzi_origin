  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "甲骨文象人穿铠甲形，中间为人，两侧为甲片，表示防身之甲。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "由铠甲引申为坚硬外壳，古今通用，如介壳。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "synecdoche",
      "note": "由指甲甲中人一体，引申为单个人，如一介书生。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "甲为人在两物间保护之物，引申为‘在中间’。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "grammaticalization",
      "note": "‘在两者之间’进一步虚化为语法功能词‘介词’。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由铠甲防护引申为坚贞、耿直的人格气质。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "amelioration",
      "note": "铠甲为贵重坚硬之物，引申为‘大’。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "由身上的甲，转义为‘放在心上’。具体机制不明，语义演变不详。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "‘这般、如此’义作为词语语气色彩强调，相关转义路径不明。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "unknown",
      "note": "戏曲用法来源不详，直接转义。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "unknown",
      "note": "‘助’义演变机制不明，可能与原有‘辅佐’义相关但缺确证。"
    },
    {
      "source_index": 0,
      "target_index": 11,
      "evolution_type": "conversion",
      "note": "由事物名词转为人名姓氏，为常见现象。"
    },
    {
      "source_index": 0,
      "target_index": 12,
      "evolution_type": "phonetical_loan_shift",
      "note": "古音同‘芥’，用作芥菜，属假借现象。"
    }
