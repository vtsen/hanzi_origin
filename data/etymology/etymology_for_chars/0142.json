  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，甲骨文像二人一前一后之形，表示跟随、随行之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "“跟随”引申为“跟随的人”，名词化。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "“跟随”进一步引申为“参与、参加”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "“跟随”的路径比喻为来源、起点，由而引申为“自、由”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "“随行”引申为“听从、顺服”义。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "“跟随”引申为“按照、采取”。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "“随行”为主，“跟随”为次，引申为“次要的”义。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "家族关系延伸，“次亲”为‘从’。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "官品分主次，引申“从”为次级品阶。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "conversion",
      "note": "由用义转姓氏用法。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "phonetical_loan_shift",
      "note": "古代文献中借用‘从’表示‘竖、直’，即‘纵’义。"
    },
    {
      "source_index": 0,
      "target_index": 11,
      "evolution_type": "phonetical_loan_shift",
      "note": "古代文献中‘从’也假借为‘纵’之“放任”义。"
    }
  ]
}