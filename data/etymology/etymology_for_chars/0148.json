  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，上八下厶，表示与私相背，即公正、无私。本义为“公正无私”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由公正无私引申为大家共同的、不偏于个人的。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由共同、大家引申为国家、社会、大众。"
