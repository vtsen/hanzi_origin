{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "均等，平衡，无多无少。",
      "examples": [
        "水流匀而不急。",
        "两边力气很匀。"
      ],
      "traditional_char": "匀"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "使平均，使各份大致相等。",
      "examples": [
        "匀称",
        "把糖匀一匀。",
        "均匀分配。"
      ],
      "traditional_char": "匀"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "抽出一部分给别人或作别用。",
      "examples": [
        "匀兑些种子给邻居。",
        "把时间匀出来。"
      ],
      "traditional_char": "匀"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从“勹”表示包裹，“二”表示所包不多，意为“均等、少”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由“均等”引申为“使均等”，即由状态转为使动，用法转变。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“使平均”用法进一步引申为“把一部分分出来给别人或挪作别用”。"
    }
  ]
}