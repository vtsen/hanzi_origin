      "meaning": "乌鸦，一种黑色的鸟。",
      "examples": [
        "乌鸦反哺",
        "乌飞兔走",
        "乌合之众"
      ],
      "traditional_char": "烏"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "黑色的。",
      "examples": [
        "乌云密布",
        "乌亮的头发"
      ],
      "traditional_char": "烏"
    },
    {
      "index": 2,
      "part_of_speech": "adverb",
      "meaning": "无，没有。",
      "examples": [
