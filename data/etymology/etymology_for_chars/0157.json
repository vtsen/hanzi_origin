  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形，本为描绘乌鸦之形，形体像鸟，繁体为“烏”，下部像鸟，头上有点指其黑色。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "因乌鸦羽毛黑色，引申指黑色属性，周代文献已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "黑色引申为无、没有，如黑暗不可见。用于“乌有”等成语。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "unknown",
      "note": "疑问代词“乌”用法由来不明，文献多见于先秦。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "“乌”通“呜”用作叹词，属假借用法。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "以“乌”为姓氏，由动植名转为姓氏常见。"
    }
  ]
