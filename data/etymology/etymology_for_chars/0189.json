{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "惑乱，迷惑他人之心智",
      "examples": [
        "民无或胥，诪张为幻。",
        "幻，相诈惑也。"
      ],
      "traditional_char": "幻"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "虚无的，不真实的，假象的",
      "examples": [
        "皆幻也。",
        "亦真亦幻。",
        "虚幻。",
        "如梦幻泡影。"
      ],
      "traditional_char": "幻"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "奇异、迅速地变化",
      "examples": [
        "变幻莫测。",
        "幻化。",
        "奇幻儵忽，易貌分形。"
      ],
      "traditional_char": "幻"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "变幻的法术，幻术",
      "examples": [
        "幻师。",
        "能演幻术的人。",
        "老成子学幻于尹文先生。"
      ],
      "traditional_char": "幻"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "怪异，奇妙",
      "examples": [
        "幻怪。",
        "構思之幻。"
      ],
      "traditional_char": "幻"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "古文字从“幺”（细丝）与“又”，表示交缠相惑，代表使人迷惑之意。原义指惑乱、迷惑。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由惑乱引申为“不真实，虚无”，即使人心智迷乱后，分辨不清真假，故形容虚妄、假象。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由惑乱发展出“变化莫测”，因迷惑常伴随变换手段，强调不可捉摸的变化。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由惑乱引申为“以法术迷惑他人”，即幻术、变幻的法术之义。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由惑乱之不可理喻，引申为“怪异，奇妙”，描述事物出人意料的性质。"
    }
  ]
}