        "世璧"
      ],
      "traditional_char": "世"
    }
  ],
  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "指事字。金文‘世’在‘止’（表示止步、限止）上加三点，表三十年为‘一世’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由具体三十年一世引申为泛指一个年代或时期，早在先秦已出现。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "从时代意义引申为家族、世系的连续，多见于古代典籍。"
