{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "三十年为一世，表示一个三十年为单位的时代。",
      "examples": [
        "人生有几世？",
        "三十年为一世。"
      ],
      "traditional_char": "世"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "一个时代，有时泛指年代或时期。",
      "examples": [
        "流芳百世",
        "世代相传"
      ],
      "traditional_char": "世"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "一辈一辈相传的，表示家族世系、世袭。",
      "examples": [
        "世袭罔替",
        "世家大族"
      ],
      "traditional_char": "世"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "人间，与天上或宗教世界相对；社会。",
      "examples": [
        "世俗之见",
        "世故圆滑"
      ],
      "traditional_char": "世"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "自然界和人类社会一切事物的总和，或指全世界、宇宙。",
      "examples": [
        "举世皆知",
        "公之于世"
      ],
      "traditional_char": "世"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
