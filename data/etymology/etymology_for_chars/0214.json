{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "面向南时，东的一边，与“右”相对。",
      "examples": [
        "左手",
        "左方",
        "左右",
        "左膀右臂"
      ],
      "traditional_char": "左"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "地理上指东方。",
      "examples": [
        "山左",
        "江左"
      ],
      "traditional_char": "左"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "指政治思想上进步或过头的思想和行动。",
      "examples": [
        "左派",
        "左翼",
        "左倾"
      ],
      "traditional_char": "左"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "斜，偏，差错。",
      "examples": [
        "左脾气",
        "左嗓子"
      ],
      "traditional_char": "左"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "降低官职，贬谪。",
      "examples": [
        "左迁"
      ],
      "traditional_char": "左"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "辅佐，从旁帮助（古同“佐”）。",
      "examples": [
        "左证",
        "左辅"
      ],
      "traditional_char": "左"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "左丘明"
      ],
      "traditional_char": "左"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 5,
      "note": "会意字，甲骨文字形，左边为“手”，右为“工”（表示辅助之意），表示辅佐、从旁帮助。"
    }
  ],
  "edges": [
    {
      "source_index": 5,
      "target_index": 0,
      "evolution_type": "semantic_shift",
      "note": "“辅佐”义转为左手或身体左侧，古今多见。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "因面对南方时左边即东方，地理用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "政治色彩起源于法国议会座次，左边为激进派。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "常以“左”喻不正、不顺，由左手不常用演变。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "降职、贬谪用“左”，源自古代位置观念。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "function_word",
      "note": "用作姓氏，取字为氏，常见汉姓之一。"
    }
  ]
