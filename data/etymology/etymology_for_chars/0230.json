  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从皿，𧆣（虎）声，表示盛饭的器皿。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "因古代盛饭器常为黑色，故泛指黑色。《说文》《水经注》存在解释。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "以‘黑色’称呼黑色猎犬，因其色而得名。见《诗》《说苑》。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "以‘黑色’称呼黑色水鸟鸬鹚，因鸟色得名。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "metonymy",
      "note": "黑色引申为游戏中五子全黑之最高彩名。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由饭器引申为可盛物之墩。‘卢’通‘垆’，见于汉书。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "由器物之盛物抽象引申为盛人物之住所，通‘庐’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以黑色指代瞳孔中黑色部分。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "黑色相关性引申至头骨之名，通‘颅’。"
    },
    {
      "source_index": 1,
      "target_index": 9,
      "evolution_type": "function_word",
      "note": "黑色物（或器皿、房屋名）引申为氏族或地名，进而用为姓氏。"
    }
  ]
