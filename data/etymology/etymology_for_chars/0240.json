  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "此字为指事字，形体象身体正直束身之状。今多认为从丨指身体中轴，臼为束缚之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "古人用十二地支纪时、纪年，以“申”表示第九位；语言迁移。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由地支引申为小时，表示每天的一个时段。"
