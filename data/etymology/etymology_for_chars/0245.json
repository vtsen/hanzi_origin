  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 3,
      "note": "甲骨文形似植物的枝茎贯穿土地，表示‘穿通、通过’之意，是象形字，古义为“穿通出入”，与“经过”义相关。"
    }
  ],
  "edges": [
    {
      "source_index": 3,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "‘经过、通过’义扩展为‘自、从’。常见语法演变路径。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "‘经过’引申为‘凭借’，即倚赖的路径。"
    },
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "‘自、从（来源地）’转为‘原因’，即事情的起点。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "‘通过、顺从渠道’转为‘顺随、归属’。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "古作‘犹’，因声近假借，用作‘尚且、还’。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
      "note": "古作‘犹’，用作‘好像，犹如’。"
    }
  ]
}