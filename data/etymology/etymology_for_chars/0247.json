      ],
      "traditional_char": "叭"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘叭’形声字，从口，巴声，本作象声词，用以表示开合响声，兼取‘巴’开口之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由嘴唇开合声引申为将食物扒入口中的动作，比喻人嘴动吃食。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由嘴唇发声的象声转指嘴的动作，如嘴含物。"
    },
    {
      "source_index": 0,
      "target_index": 3,
