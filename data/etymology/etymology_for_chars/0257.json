      "part_of_speech": "verb",
      "meaning": "因高兴、兴奋、激动而发出长声，表达赞赏或敬佩。",
      "examples": [
        "赞叹",
        "叹服",
        "叹观止矣"
      ],
      "traditional_char": "嘆"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "吟咏、咏唱。",
