  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，甲骨文像箭形，表示箭。构形反映箭杆与箭羽。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "用“箭”引申为“发誓”，如发出的誓言不能回头，语义比喻转化。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "“矢言”从“发誓之言”扩展为“正直的话”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "“矢”本为箭，引申为整齐陈列的样子，源自排列箭矢的景象。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由箭射出引申为施布、散布。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "投壶用筹形状似箭，故借用“矢”表示。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
      "note": "“矢”假借作“屎”（粪便）字，语音借用，与本义无关。"
    }
  ]
