    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "甲骨文象日光明亮之形，本义为白色，与明亮、光亮有关，是象形字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
