  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从人，‘它’省声，‘佗’本义为‘负担’。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘他’本从佗分化而来，近现代以‘他’用作代词。‘人’表意，‘也’省声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由‘佗’原义‘负担’演变为第三人称代词，经历了语音和字义分化，约在中古以后。"
    },
    {
      "source_index": 1,
      "target_index": 2,
