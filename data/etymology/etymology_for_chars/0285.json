  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "古代印章盖印后留下痕迹，由印章转指痕迹。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由名词‘印章’引出‘加盖印章’等动作，动用为‘盖印、印刷’。"
    },
    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "印刷等动作常留下痕迹，即‘印记’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "痕迹引申为‘印象’，即事物对人的脑中所留下的形象。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "‘印’有使对齐、符合之意，引申为‘彼此符合’。"
    }
  ]
