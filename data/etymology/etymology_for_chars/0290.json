      "meaning": "古代称编串好的竹简、文书，后泛指装潢好的纸本子，如纪念册、花名册、画册等。",
      "examples": [
        "花名册",
        "画册",
        "纪念册"
      ],
      "traditional_char": "冊"
    },
    {
      "index": 1,
      "part_of_speech": "measure_word",
      "meaning": "用于书册等成册的物品。",
      "examples": [
        "一本册",
        "五十册书"
      ],
      "traditional_char": "冊"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古代帝王祭祀天地、神仙的文书或封爵的诏书。",
      "examples": [
        "册文",
        "册命",
        "册封"
      ],
      "traditional_char": "冊"
    }
  ],
  "formations": [
