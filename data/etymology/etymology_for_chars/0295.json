  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "“冬”会意字，从“夂”，表动作、尾声；下方似冰、象形，合指寒冷与时序终了。用于四季中最后一季。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "“鼕”形声字，从“鼓”作声旁，“冬”作声符，表示敲鼓声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由表示季节的词转用于姓氏，古今皆有，常见姓氏借用名词地名等。"
