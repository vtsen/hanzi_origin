    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "自然界的电光因其‘一闪即逝’，以‘闪’表示雷电之光。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "人体因回避（快速动作）造成扭伤，以‘闪’表示闪伤。"
    },
