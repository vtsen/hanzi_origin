  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，难声，表示与水有关的专名，指汉水。‘漢’为古体，‘汉’为简化字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以汉水比喻天河，诗歌中以宽广之水借指银河。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以地名指代政权、朝代，因汉水流域地区建立汉王朝而得名。"
    },
    {
      "source_index": 4,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以汉代代指形成于该时期的主要族群，‘汉族’得名于汉王朝。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘汉族’引申为‘男子汉’，泛指成年男子。"
    }
