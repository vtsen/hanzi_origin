  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "小篆字形象水流曲折，表示水流长，即本义为“水流长”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由水流长久引申为时间久远，汉代后普遍用作“长久”义。"
    },
