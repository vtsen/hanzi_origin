{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用笤帚等除去尘土或垃圾，打扫。",
      "examples": [
        "扫地",
        "屋子要天天打扫"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "清除，消灭。",
      "examples": [
        "扫雷",
        "扫盲",
        "一扫而空"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "全部，尽其所有。",
      "examples": [
        "扫数"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "情绪低落，丧失兴致。",
      "examples": [
        "扫兴"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "描画。",
      "examples": [
        "扫描",
        "扫眉"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "迅速横掠而过。",
      "examples": [
        "扫射",
        "扫视",
        "目光一扫"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "结束，了结。",
      "examples": [
        "扫尾"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "祭奠。",
      "examples": [
        "扫墓",
        "祭扫"
      ],
      "traditional_char": "掃"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "扫帚，以竹枝等扎成的扫地用具。",
