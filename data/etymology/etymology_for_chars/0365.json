  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从手从帚，手持帚具以示打扫。表义明确。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由实际打扫引申为清除、消灭，多见于近现代汉语。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "表示全部、尽其所有，如一扫而空。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "情绪被打扫干净，比喻兴致低落、无趣。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "描摹动作似持帚掠过，形成‘描画’之义。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "手持扫帚横掠，喻动作、视线或枪弹扫过。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "扫尾指清除残余，以表完成结束。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "祭扫指对墓地的打扫，由动作代祭祀。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "由动作‘扫’转为名词‘扫帚’。"
