      ],
      "traditional_char": "奪"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，上为振翅之鸟，下为手，表现将要失脱之意，对应‘丧失’本义。"
    }
