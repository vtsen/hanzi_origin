      ],
      "traditional_char": "奪"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "剥夺、削除（权利、资格等）。",
      "examples": [
        "剥夺公权",
        "褫夺",
        "夺志"
      ],
      "traditional_char": "奪"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "使晃动，使目眩。",
      "examples": [
        "光彩夺目"
      ],
      "traditional_char": "奪"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "决定如何处理（裁决、裁定）。",
      "examples": [
        "请予裁夺"
      ],
      "traditional_char": "奪"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "遗漏（文字等）。",
      "examples": [
