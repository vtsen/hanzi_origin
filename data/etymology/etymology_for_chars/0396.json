{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "丧失；失掉。",
      "examples": [
        "本义：丧失。",
        "彼将有夺乎哉。（《孟子》）"
      ],
      "traditional_char": "奪"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "抢夺，强行取走。",
      "examples": [
        "抢夺财物",
        "巧取豪夺",
        "掠夺"
      ],
      "traditional_char": "奪"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "争先取得（如胜利、第一名等）。",
      "examples": [
        "夺得最后胜利",
        "夺魁",
        "夺冠"
      ],
      "traditional_char": "奪"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "冲开（门、障碍等）。",
