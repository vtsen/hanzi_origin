  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "“死”会意，从“歺”（残骨）表示尸体，从“人”，表生命与肉体分离，指生命终止。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由本义引申为不顾生死、牺牲生命，常用于战争等语境。"
