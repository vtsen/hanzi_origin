  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "本字夾，会意。甲骨文字形像左右二人夹持中间一人，表示从两边夹持。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从“夹持”发展为“位于两者之间、受限制”。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从“夹持”引申为“夹杂、混杂”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "动词“夹”转换为表示工具的名词“夹子”。"
