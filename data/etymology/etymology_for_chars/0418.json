  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 17,
      "note": "形声字。左边“田”表义，指两块田地；右边“尚”为声符。最初表示‘两田相等’之意。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 9,
      "note": "“噹”为“当”的声旁+“口”形旁，指金属撞击声，为拟声用法，由“當”分化而来。"
    }
  ],
  "edges": [
    {
      "source_index": 17,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "从‘两田相等’扩展为‘相称、相配、等同’。"
    },
    {
      "source_index": 4,
      "target_index": 11,
      "evolution_type": "semantic_extension",
      "note": "由‘相等’进一步扩展为‘抵得上，等于’。"
    },
    {
      "source_index": 4,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "‘相当’引申为‘抵御、对敌’，即能匹敌之义。"
    },
    {
      "source_index": 4,
      "target_index": 16,
      "evolution_type": "reanalysis",
      "note": "‘相当’引申为‘抵押’，因价值相当而物物交换之义。"
    },
    {
      "source_index": 4,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "‘相当’引申为‘担当、承担’，即承担与相等义有关。"
    },
    {
      "source_index": 0,
      "target_index": 1,
