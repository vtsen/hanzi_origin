  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从‘冃’表覆盖、重复义，‘口’表众口聚合，意为聚集、集合；为会意字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "从‘集合’之义转为指‘一样’，汉代文献即见此义。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘一样’引申为‘共同，一起’（共事、同行）。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "由联合、副词义进一步虚化为介词‘和’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "由形容词转为姓氏用法，常见于汉族姓氏发展规律。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘同’假借为‘胡同’（tòng）的用音，见现代汉语。"
    }
  ]
