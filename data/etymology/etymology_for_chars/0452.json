    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从“夭”和“高”省写，表示高大，与“高”有关，属于会意字，古文作“喬”。"
    },
    {
      "formation_type": "loan_character",
      "original_sense_index": 2,
      "note": "简化字“乔”后来兼表与“喬”同音的“假装、无赖”等义，属于假借。"
    }
  ],
  "edges": [
    {
