  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，上部为“垂”，下为“艹”，象花叶下垂形，本义为花。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "由名词“花”引申表示动词“开花”。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由花朵的美丽而引申为“美丽”之意。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由花盛开引申为“繁盛”，常用于人事。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "metaphor",
      "note": "花短暂美丽，比喻年华、时光。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "美丽进一步引申为奢侈、讲究外表。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "美丽外表引申为“精华”。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "amelioration",
      "note": "“华”用于尊称与美好相关事物。"
