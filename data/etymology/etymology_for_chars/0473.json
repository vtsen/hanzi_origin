{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "抬头，脸向上，与“俯”相对。",
      "examples": [
        "仰首",
        "仰望星空"
      ],
      "traditional_char": "仰"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "敬慕，仰慕。",
      "examples": [
        "久仰大名",
        "令人敬仰"
      ],
      "traditional_char": "仰"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "依赖，倚仗。",
      "examples": [
        "仰赖",
        "仰承父母"
      ],
      "traditional_char": "仰"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "旧时公文用语，上行为恭敬，下行为命令。",
      "examples": [
        "仰即尊照",
        "仰祈批准"
      ],
      "traditional_char": "仰"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "服下（毒药），多指自杀。",
      "examples": [
        "仰药自尽",
        "仰毒"
      ],
      "traditional_char": "仰"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [],
      "traditional_char": "仰"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "古同“昂”，情绪高昂。",
      "examples": [
        "气仰形扬（意为气势高扬）"
      ],
      "traditional_char": "仰"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从人，从卬，卬亦声；本义为抬头仰望，是会意兼形声字，表人抬头之状。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由抬头仰视引申为敬慕，先秦至汉代即有此用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由敬仰引申为依赖，因依赖常带敬仰之意，魏晋以后见用。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由抬头引申为公文语，表示恭敬或命令。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "仰本面部上扬，引申为服毒时抬头吞咽。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "地名、人名等转而作姓氏用。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "古同“昂”，形容情绪高昂，与卬（昂）同源。"
    }
  ]
}