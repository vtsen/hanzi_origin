  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形，古文像交错道路之形，为最初‘道路’之本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "从‘道路’引申为‘步行，道路上的移动’，见先秦用法。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘道路’引申为‘行列’，即排列如道路。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "行列与步行组队有关，扩展为步行阵列。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "行列又可为量词用途，如‘泪下两行’。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "排行本为列队顺序，‘行’由此表兄弟姐妹排行。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "营业所多沿街成行，‘行’由行列义引申为店铺。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由具体营业所转指行业门类。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由排列成行而引申为针脚成行连缀的动作。"
    },
    {
      "source_index": 8,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "由‘行走’引申为‘出行所用之物’。"
    },
    {
      "source_index": 8,
      "target_index": 10,
      "evolution_type": "semantic_extension",
      "note": "‘行走’引申为‘流通，传递’。"
    },
    {
      "source_index": 8,
      "target_index": 11,
      "evolution_type": "semantic_extension",
      "note": "‘行走’引申为‘从事、进行’之义。"
    },
    {
      "source_index": 8,
      "target_index": 12,
      "evolution_type": "semantic_extension",
      "note": "‘行走’进一步转义为‘流动性’。"
    },
    {
      "source_index": 8,
      "target_index": 13,
      "evolution_type": "metaphor",
      "note": "从‘行走’比拟为人的品德和行为。"
    },
    {
      "source_index": 8,
      "target_index": 14,
      "evolution_type": "semantic_extension",
      "note": "‘实际地做’由‘行走’引申为具体行动。"
    },
    {
      "source_index": 8,
      "target_index": 15,
      "evolution_type": "function_word",
      "note": "‘可以’为行为准许义，由行为义引申，见中古汉语。"
    },
    {
      "source_index": 8,
      "target_index": 16,
      "evolution_type": "amelioration",
      "note": "‘能干’义为近代俗用，源于‘行得通’。"
