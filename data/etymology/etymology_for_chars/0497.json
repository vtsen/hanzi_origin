{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "树木枝叶花实下垂的样子，今多指植物的花或苞。",
      "examples": [
        "白花檐外朵，青柳檻前梢。——杜甫",
        "花朵儿"
      ],
      "traditional_char": "朵"
    },
    {
      "index": 1,
      "part_of_speech": "measure_word",
      "meaning": "用于花或成团状物的计量单位。",
      "examples": [
        "千朵万朵压枝低。",
        "一朵花"
      ],
      "traditional_char": "朵"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "动。多指动腮颊，如咀嚼时颊部的运动。",
      "examples": [
        "观我朵颐。",
        "朵颐"
      ],
      "traditional_char": "朵"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "用手捉物，或以手引小儿学行。",
      "examples": [
        "以手捉物谓之朵。",
        "以手引小儿学行谓之‘多’。"
      ],
      "traditional_char": "朵"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "耳朵。也引申为两旁（如左右廊、侧楼等）。",
      "examples": [
        "朵殿（大殿的东西侧堂）",
        "朵楼"
      ],
      "traditional_char": "朵"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "明有朵汝翼。",
        ""
      ],
      "traditional_char": "朵"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "小篆字形象花实下垂于树枝之状，下为‘木’，上为花形，为象形字，指花朵。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "grammaticalization",
      "note": "由表示花朵的名词转为可用作量词，唐代已见。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "因耳垂形似花朵而引申为耳朵、两旁。中古用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由花朵下垂、动感，引申为面部肌肉或腮颊的运动。"
