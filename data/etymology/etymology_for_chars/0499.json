  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "小篆作人立于崖上，表示处高感到危险，属会意字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由高处感到危险引申为一般危机、不安全。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从“不安全”引申为造成损害、威胁。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "不安全的言论引申为使人惊奇、耸人听闻。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "高耸正直，引申为端正、正直，常见于书面语。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由危险引申指病危、垂死；实指危险至极。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "星名取其“高”义为名，指天上的高处。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "姓多取于地名、事物或抽象特质，此从“危”引申为姓氏。"
    }
  ]
