  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由身体部位胸膛引申为心胸、胸怀，用于抽象心理状态，见于先秦至汉。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由胸部喧闹鼓动，引申为喧闹纷乱的样子，见于先秦、两汉文献。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以部位名称“匈”代指北方民族“匈奴”，因古人以身体部位名词借指部族，具体机制见汉代史料。"
    }
  ]
