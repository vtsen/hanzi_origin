  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 1,
      "note": "从口夕，会意，表示以口报出名字或起名，甲骨文字形即见。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由给对象起名的动作引申为对象的称谓，早期已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "称谓进一步引申为作依据的名号、名目。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由'称谓'义引申为'说出、叫出（名字）'，见古籍。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "'称谓'转指由名气产生的'声誉'。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "'名'由名词'声誉'转为形容词'有声誉的'。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "'名'假借|'名'转为'占有'，如“不名一文”，用名指拥有。"
    },
    {
      "source_index": 0,
      "target_index": 7,
