  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "甲骨文字形象禾麦穗头平整之状，表示平整、齐一。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“平整”引申为“达到与……一样平”。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“平齐”喻及“同时、一起”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "形容“平齐无缺”，引申为“齐全”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以地名“齐”，取其平整之义。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由地名“齐国”引申为以“齐”为国号的朝代名。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "义从“平齐”转为“调齐、调和”，音通而义转。"
    },
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "调和之物引申为“药剂”。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "由“齐”引申为事物的界限、分际。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "metaphor",
      "note": "比喻事物达到‘齐’即成熟、成功。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "phonetical_loan_shift",
      "note": "通“粢”，音近为借用。"
    },
    {
      "source_index": 0,
      "target_index": 11,
      "evolution_type": "phonetical_loan_shift",
      "note": "通“斋”，音近借用为“斋戒”。"
    },
    {
      "source_index": 11,
      "target_index": 12,
      "evolution_type": "semantic_extension",
      "note": "斋戒引申为“庄敬、庄严”。"
    }
  ]
}