      ],
      "traditional_char": "齊"
    },
    {
      "index": 10,
      "part_of_speech": "noun",
      "meaning": "同“粢”，古代祭祀用的谷类",
      "examples": [
        "齐盛",
        "献齐"
      ],
      "traditional_char": "齊"
    },
    {
      "index": 11,
      "part_of_speech": "noun",
      "meaning": "同“斋”，指斋戒",
      "examples": [
        "齐三日而后行"
      ],
      "traditional_char": "齊"
    },
    {
      "index": 12,
      "part_of_speech": "adjective",
      "meaning": "庄敬，庄严",
