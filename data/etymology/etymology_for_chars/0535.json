      "part_of_speech": "noun",
      "meaning": "水中的陆地，即水环绕的小块陆地。",
      "examples": [
        "江中有州。",
        "水中之州。"
      ],
      "traditional_char": "州"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代的一种行政区划，辖区范围随历史变迁有异，后多用于地名。",
      "examples": [
        "徐州、冀州、豫州。",
        "杭州市。"
      ],
      "traditional_char": "州"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "中国的一种民族自治行政区划，如“自治州”。",
      "examples": [
        "海南省黎族苗族自治州。",
        "楚雄彝族自治州。"
      ],
      "traditional_char": "州"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，甲骨文象水中陆地，两侧为水流，中间为陆地，为“州”的本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由表示水中陆地引申为特定行政区划，先以水系分疆，逐渐泛指一地方政区。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "在现代行政体系中，“州”扩展为包括民族自治州的新用法。"
