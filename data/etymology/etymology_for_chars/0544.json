  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由‘起来’引申为‘举办、发动’，因为举办大事常需动员。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "‘起来’引申为‘旺盛、繁荣’，因事物兴起则发展盛旺。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由‘旺盛’引申为‘流行、盛行’，流行指广泛且旺盛。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "reanalysis",
      "note": "‘兴’作‘准许’用，原出于‘流行、施行’，再转化为‘准许’新用法。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "由‘准许’语气虚化，作‘或许’解释，口语词。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "由‘兴起’引申为情绪‘勃发’，即对事物感觉喜爱。"
    }
  ]
