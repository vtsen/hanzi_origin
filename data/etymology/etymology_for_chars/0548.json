  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 7,
      "note": "会意兼形声字，从宀表示屋内，从子表示婴儿，意为在屋内生孩子，子也作声旁。"
    }
  ],
  "edges": [
    {
      "source_index": 7,
      "target_index": 6,
      "evolution_type": "semantic_narrowing",
      "note": "“生子”之义引申为仅指女子出嫁，古代用法。"
    },
    {
      "source_index": 7,
      "target_index": 0,
      "evolution_type": "metaphor",
      "note": "“生子”之义，由生育引申为“产生文字”，文字象征从母体诞生；后专指记录语言的符号。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“字”引申为“字音”，即单个汉字的发音。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从记录语言的符号引申为字体、书体等不同写法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由字体之义引申为书法作品，尤指书写出来的字画。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由“名”及“字”分用，字常为本名之外的别名，古人冠名礼习俗。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "“字”又引申为契约文书，借指所写之物。"
    }
  ]
