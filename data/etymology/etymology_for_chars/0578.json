  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘如’为会意字，从女从口，表示女子听从口令，有遵从、依照之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "从“顺从、依照”引申为“像……一样”，如按照某物标准而为"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "“像”的基础上，进一步用于比较含义“及、比得上”"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "从“依照”引申为“前往”，如“如厕”为去厕所"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "reanalysis",
      "note": "“假如”的假设引申为“如何”的疑问义"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "synecdoche",
      "note": "将“如”的‘比况’义推广用作假设条件连词"
    },
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "reanalysis",
      "note": "“与”义发展为“或者”，表示列举选择"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "reanalysis",
      "note": "形容词后‘如’带狀態意义，后转虚词"
    },
    {
      "source_index": 1,
      "target_index": 9,
      "evolution_type": "function_word",
      "note": "由‘比况’义进而用作举例介词"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "grammaticalization",
      "note": "动词‘依照’引申为辅助义，应当、应该"
    },
    {
      "source_index": 0,
      "target_index": 11,
