  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从‘辵’（行走）表义，‘军’表声；本义为移动、运行、转动。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘移动、运行’引申为‘搬运、运输’，可见于先秦至汉语文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "‘运行、移动’引申为‘运用（使方式/力量流转）’，语义比喻发展。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "‘运行、事物转动’喻为‘命运’，指人事之循环与变迁。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_narrowing",
      "note": "从一般移动之义，专指地理距离，后用于‘南北之距’。"
    },
    {
      "source_index": 0,
      "target_index": 5,
