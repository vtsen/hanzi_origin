    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从大（人）从火，表示人在火上被烤成红色，表本义‘红色’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以‘赤色’（火、血之色）喻人之真诚纯粹，常用颜色比喻心性。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "红色引申为空无所有，如‘赤手’比喻手上什么都没有。"
