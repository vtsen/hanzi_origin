{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "紫苏，一种一年生草本植物，也称为“苏子”。",
      "examples": [
        "秋黄之苏。——《七发》",
        "苏子（紫苏和白苏的种子）"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "柴草，樵苏。",
      "examples": [
        "樵苏脂烛，莫非种植之物也。——《颜氏家训》",
        "樵苏后爨。——《史记·淮阴侯列传》"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "须状下垂的饰物。",
      "examples": [
        "流苏金缕鞍。——《玉台新咏·古诗为焦仲卿妻作》"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "死而复生，苏醒，恢复生机。",
      "examples": [
        "死而复生谓之苏。——《小尔雅·广名》",
        "蛰虫昭苏。——《礼记·乐记》",
        "今始苏耳。——《聊斋志异·促织》"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "唤醒，昏迷后醒过来。",
      "examples": [
        "半夜复苏。——《聊斋志异·促织》",
        "苏省（苏醒）；苏活（苏醒；复活）"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "割草，取草，引申为取。",
      "examples": [
        "行者践其首脊，苏者取而爨之而已。——《庄子·天运》",
        "苏粪壤以充帏兮。——《离骚》"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "缓解，解除困困顿、困苦。",
      "examples": [
        "以苏其困。"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "江苏省、苏州市的简称。",
      "examples": [
        "苏剧",
        "苏绣",
        "苏杭"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "前苏联的简称，苏维埃的简称。",
      "examples": [
        "苏区",
        "中苏关系"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 9,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "苏武牧羊",
        "苏轼"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 10,
      "part_of_speech": "other",
      "meaning": "见“噜苏”，指啰嗦、琐碎。",
      "examples": [
        "噜苏"
      ],
      "traditional_char": "蘇"
    },
    {
      "index": 11,
      "part_of_speech": "verb",
      "meaning": "朝向，指面对、面向（通“肃”义）。",
      "examples": [
        "苏刃者死。"
      ],
      "traditional_char": "蘇"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从艸，稣声，形声字；本义为紫苏植物。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "本义的植物泛指其他草木柴草，古用可见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由植物的枝叶形态比喻须状下垂物。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "植物更生引申为生命苏复、复生。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_narrowing",
      "note": "由‘复生’具体到‘苏醒’。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "割取柴草动作转为‘取’。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "从生还、复生引申为解除困苦。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "metonymy",
      "note": "以地名‘苏’为据，进一步用作‘苏联’、‘苏维埃’简称。"
