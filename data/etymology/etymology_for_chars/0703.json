{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "particle",
      "meaning": "表示不然、否定、不是这样",
      "examples": [
        "否也。",
        "否，则不成。",
        "其可得而闻与？否。"
      ],
      "traditional_char": "否"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "表示不同意，不认可",
      "examples": [
        "否定",
        "不可否认"
      ],
      "traditional_char": "否"
    },
    {
      "index": 2,
      "part_of_speech": "particle",
      "meaning": "不，用于疑问句里",
      "examples": [
        "可否？",
        "能否参加？"
      ],
      "traditional_char": "否"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "不好，坏，恶",
      "examples": [
        "否极泰来",
        "未知善否"
      ],
      "traditional_char": "否"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "会意兼形声，从口表示言语，从不表示否定之意兼表音。据古文字形态，早期主要用于表示“不是这样”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由否定副词/助词转为动词表示否定某事物，常见于汉语语法演化。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "grammaticalization",
      "note": "最初“否”表示‘不然’，后发展为专用疑问否定助词，常见于问句之末。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“不是”引申为“不好、坏”，如《易经》中表示恶卦，与“泰”对举。"
    }
  ]
