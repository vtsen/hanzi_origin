  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "麦子成熟时，穗部‘下来’引申为‘来’、‘到达’。春秋战国始见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
