{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古地名",
      "examples": [
        "邮，地名。——《说文》"
      ],
      "traditional_char": "郵"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代驿站，用于传递文书或物品的机构",
      "examples": [
        "邮吏传书。",
        "邮亭待命。"
      ],
      "traditional_char": "郵"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "现代传递信件、款项、物件等的国家机构",
      "examples": [
        "邮递员送信。",
        "寄挂号邮件请到邮局办理。"
      ],
      "traditional_char": "郵"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "与邮政、邮递有关的",
      "examples": [
        "邮政业务。",
        "邮船抵港。",
        "邮购商品。"
      ],
      "traditional_char": "郵"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "邮票的简称",
      "examples": [
        "邮展中心。",
        "集邮活动。"
      ],
      "traditional_char": "郵"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从邑，由声。本义作地名，邑表示与地理、行政有关，由为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "古地名引申为此地设传递文书的驿站，汉代已有此用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "古代‘邮’指驿站，现代发展为传递物品等的国家机构。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "名词转化为修饰词，用作‘邮政’等合成词的定语。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由与邮件相关的机构转指邮件相关物品，即‘邮票’。"
    }
  ]
