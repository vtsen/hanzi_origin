        "四处吹风"
      ],
      "traditional_char": "吹"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从“口”表示用口发声，与“欠”表示出气有关，表合唇呼气之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从单纯呼气引申为吹奏乐器，见于古籍中乐器吹奏用法。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "从口中呼气到一般风的吹动动作，是外延扩展。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由吹奏乐器声大，引申为说大话、夸张，比喻性演变。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由风吹导致灭亡、消失，比喻事情失败或告吹。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "呼气传播，引申为消息、舆论、宣传的传递、鼓动作用。"
