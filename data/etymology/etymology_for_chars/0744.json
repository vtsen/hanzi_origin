{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "合拢嘴唇用力呼气",
      "examples": [
        "吹气球",
        "吹灯",
        "吹灰之力"
      ],
      "traditional_char": "吹"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用口发声或用风使乐器响起（引申为吹奏乐器）",
      "examples": [
        "吹鼓手",
        "吹笛子",
        "吹唢呐"
      ],
      "traditional_char": "吹"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "说大话，夸耀自己",
      "examples": [
        "不要吹牛",
        "他很会吹"
      ],
      "traditional_char": "吹"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "类似吹的动作，如风吹动事物",
