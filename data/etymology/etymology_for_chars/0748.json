  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，上为囗表示疆域，下为跪坐之人形，合指有统治和人口的邦国，甲骨文作‘国’，表城邑与邦国。"
    }
  ],
