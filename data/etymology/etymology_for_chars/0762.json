  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "上下两手整理丝的象形，会意字，反映初义为理丝。传统字形为亂。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从理顺丝的动作引申为丝线杂乱，再泛化为事物整体的无序。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由事物无序比喻社会动荡、战乱局势，战国及汉以降普及。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由杂乱引申为伦理道德被混淆，史见‘乱伦’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "无序引申为任意妄为，随意行为。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "semantic_narrowing",
      "note": "伦理关系混乱下具体指向男女关系不正当。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "‘乱流’本指水乱，转指横渡水流。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "原意理丝，后引申为治理、整治秩序。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "metonymy",
      "note": "乐章材料繁复无序，因而置于末章总结段落称‘乱’。"
    }
  ]
