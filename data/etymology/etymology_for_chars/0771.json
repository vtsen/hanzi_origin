{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "pronoun",
      "meaning": "疑问代词，用于提出问题，如什么、为什么、哪样、哪里等，也用于反问。",
      "examples": [
        "何人？",
        "何必如此？",
        "何故？",
        "何往？",
        "何乐而不为？"
      ],
      "traditional_char": "何"
    },
    {
      "index": 1,
      "part_of_speech": "adverb",
      "meaning": "表示程度之高，多么。",
      "examples": [
        "何其壮哉！"
      ],
      "traditional_char": "何"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "何先生",
        "何氏"
      ],
      "traditional_char": "何"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "古同“呵”，指斥责、呵责。",
      "examples": [
        "何咎之有？（古义，见于部分文献）"
      ],
      "traditional_char": "何"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "古同“荷”，指担、背负。",
      "examples": [
        "何其重也（古义，通“荷”）"
      ],
      "traditional_char": "何"
    }
  ],
