  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从人，从乍，表示人起身的动作。甲骨文字形像人衣领初作。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘起身’引申为‘兴起、发起’，已见先秦。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘兴起’引出‘开始做事、劳动’的意义。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "从‘做事’引申为‘举行、进行’。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "‘做工’一义引申为‘制造、表现出行为’。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "‘做’的动作可作‘充当’、‘当作’讲。"
