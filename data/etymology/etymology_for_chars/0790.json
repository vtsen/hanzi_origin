{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "烟囱，炉灶出烟气用的通道。",
      "examples": [
        "烟囱冒烟。",
        "灶上有一根高高的烟囱。"
      ],
      "traditional_char": "囪"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古指屋顶上的通孔，通风采光用。",
      "examples": [
        "晴囱咽日肝肠暖，古殿朝真屦袖香。",
        "在屋曰囱。——《说文》"
      ],
      "traditional_char": "囪"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "“窗”的古字，用于墙上的采光通孔。",
      "examples": [
        "窗助户为明。",
        "囱，古作窗。"
      ],
      "traditional_char": "窗"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "形容急急忙忙的样子（囱囱）。",
      "examples": [
        "囱囱忙忙。",
        "囱囱如也。"
      ],
      "traditional_char": "囪"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 1,
      "note": "象形字，描画房屋顶部的通孔形状，早期指屋顶天窗或通风孔。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "‘窗’字由‘穴’表义，‘囱’表音，后演变为专指墙上采光孔。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_narrowing",
      "note": "由泛指屋顶通孔演变为专指灶上的烟囱，见明清之后。"
    },
    {
      "source_index": 1,
      "target_index": 3,
