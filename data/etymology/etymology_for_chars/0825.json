  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 3,
      "note": "古文字为会意，从爪、丝，表示以手拉丝，象悬挂或系缚之意，是本义。‘系’常简化用于表关系、类别。"
    },
    {
      "formation_type": "loan_character",
      "original_sense_index": 6,
      "note": "‘係’本为系缚，引申为‘是’等用法，多属借用字形表示新义，常用于文言指‘是、为’等。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 8,
      "note": "‘繫’本义为结、扣，为‘系’的异体，形声字，左‘糸’表示系结、缀连义，右‘系’表声。"
    }
  ],
