{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "栅栏，设置在门中的木制或竹制结构",
      "examples": [
        "曲阑干外天如水"
      ],
      "traditional_char": "閑"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "防御，防备",
      "examples": [
        "防闲",
        "闲却外人"
      ],
      "traditional_char": "閑"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "没有事做，空着，与“忙”相对",
      "examples": [
        "游手好闲",
        "没有闲工夫"
      ],
      "traditional_char": "閒"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "使房屋、器物等空着不用，或物品空着不用",
      "examples": [
        "闲置",
        "机器别闲着"
      ],
      "traditional_char": "閒"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "空闲时间",
      "examples": [
        "农闲",
        "忙里偷闲"
      ],
      "traditional_char": "閒"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "与正事无关的",
      "examples": [
        "闲谈",
        "闲人免进",
        "闲话"
      ],
      "traditional_char": "閒"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从门中有木，表示门内有木即栅栏。"
    },
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 2,
      "note": "閒：本字作‘閒’，门中有月，后引申为有空隙，引申至空闲。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由栅栏本义引申为防御，引申类型为器物防护功能。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "门有栅栏之阻隔，引申为人与事务分隔，象征无事、空闲的状态。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "形容词空闲可用作动词表示‘使物品空闲’。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "空闲的状态可转化为名词，表示空闲的时间。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由空闲引申为与正事无关的。"
    }
  ]
