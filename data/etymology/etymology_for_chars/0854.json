{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "顺序，次第",
      "examples": [
        "弟，次也。（《说文》）",
        "以弟挧舟。"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "同父母（或只同父、只同母）的比自己年纪小的男子",
      "examples": [
        "兄弟",
        "小弟"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "亲戚或亲族间辈分相同的比自己年纪小的男子",
      "examples": [
        "堂弟",
        "表弟"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "称同辈比自己年纪小的男性",
      "examples": [
        "老弟",
        "师弟"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "学生对老师自称或别人指称",
      "examples": [
        "弟子",
        "门弟"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "古同“第”，表示顺序",
      "examples": [
        "弟一",
        "弟二"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 6,
      "part_of_speech": "conjunction",
      "meaning": "古同“第”，但，然而",
      "examples": [
        "弟虽百辟，犹得为卿。"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 7,
      "part_of_speech": "adjective",
      "meaning": "古同“悌”，孝悌，和顺",
      "examples": [
        "孝弟也者，其为仁之本与。"
      ],
      "traditional_char": "弟"
    },
    {
      "index": 8,
      "part_of_speech": "adjective",
      "meaning": "〔弟靡〕颓唐；柔顺",
      "examples": [
        "弟靡之风",
        "志意弟靡"
      ],
      "traditional_char": "弟"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "甲骨文字形象绳绕弋示次第。‘弟’初表‘次第’之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "reanalysis",
      "note": "‘次第’抽象表示顺序，后与‘第’混用。战国后常互通。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由顺序义引申为语气转折，古时“第”“弟”通用。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "次第、顺序引申为排行，专指排行在兄之下的男性亲属。西周金文已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "语义由同父母扩展到亲族间晚辈男性。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "再泛指所有比自己年幼的同辈男性。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "再用为学生自称或别人称指称，见于古典文献。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘弟’本义外，假借为‘悌’义(孝悌)。属于古代用字通假现象。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘弟’假借用于‘弟靡’，本作‘靡’，取音通用。"
    }
  ]
}