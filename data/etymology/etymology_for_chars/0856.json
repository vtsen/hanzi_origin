  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，木声，表示与水有关的动作，最初指洗头发。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“洗头发”泛化为“一般洗涤”，见于《诗经》《文选》等。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "洗头须用米汁，因此“沐”引申为“米汁”。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由洗涤意转喻润泽、受润泽，如“沐恩”。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“洗涤”引申为“芟除”等清理之义。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "芟除进一步引申为“整治”。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "由洗涤、洗浴引申为“洗浴日”，后专指“休假日”，汉晋官制用法。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "水相关义项，被用为河流名称。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "动词转用作姓氏，用法如《三国志》所载。"
    }
  ]
