      "traditional_char": "沐"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "润泽，沾润；受润泽，引申为蒙受恩惠。",
      "examples": [
        "京师冬无宿雪，春不燠沐。",
        "逮奉圣朝，沐浴清化。"
      ],
      "traditional_char": "沐"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "芟除，去除枝叶等。",
      "examples": [
