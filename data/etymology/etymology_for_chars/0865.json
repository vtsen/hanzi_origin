  "edges": [
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "从漂浮扩展为水漫流；已见于古汉语中。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以漂浮为喻，引申为色彩、光等外表浮现。"
