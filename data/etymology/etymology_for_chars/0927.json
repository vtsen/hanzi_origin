{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "particle",
      "meaning": "文言助词，用于句末表示动作已完成、事情已然发生，相当于“了”。",
      "examples": [
        "骨尽矣，而两狼之并驱如故。",
        "有颜回者好学，不迁怒，不贰过，不幸短命死矣。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 1,
      "part_of_speech": "particle",
      "meaning": "文言助词，表示推测、将然，说明事情将要实现。",
      "examples": [
        "孔子曰：‘诺，吾将仕矣。’",
        "天雨，子将败矣。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 2,
      "part_of_speech": "particle",
      "meaning": "文言助词，表示肯定、判断，相当于“也”。",
      "examples": [
        "虽曰未学，吾必谓之学矣。",
        "吾老矣。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 3,
      "part_of_speech": "particle",
      "meaning": "文言助词，用于命令，表示命令语气，相当于“吧”。",
      "examples": [
        "王许我，汝可疾去矣。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 4,
      "part_of_speech": "particle",
      "meaning": "文言助词，表示感叹，相当于“啊”。",
      "examples": [
        "甚矣，吾衰也！",
        "大矣哉。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 5,
      "part_of_speech": "particle",
      "meaning": "文言助词，用于句末表示停顿，引起下文，相当于“也”。",
      "examples": [
        "汉之广矣，不可泳思。",
        "江之永矣，不可方思。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 6,
      "part_of_speech": "particle",
      "meaning": "文言助词，表示限制或语句的结束，相当于“耳”。",
      "examples": [
        "献公之子九人，唯君在矣。"
      ],
      "traditional_char": "矣"
    },
    {
      "index": 7,
      "part_of_speech": "particle",
      "meaning": "文言助词，与疑问词结合，表示疑问、反问、推测，相当于“了”、“呢”、“乎”。",
      "examples": [
        "危而不持，颠而不扶，则将焉用彼相矣？",
        "德何如，则可以王矣？"
      ],
      "traditional_char": "矣"
    }
  ],
