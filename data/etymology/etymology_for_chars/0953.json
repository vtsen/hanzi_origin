  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，末声，表示用手进行涂抹、搽敷的动作。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从“涂、抹”泛化为“擦、拭”，见于用手的动作关联。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "由原意“擦拭”引申为“脸面上无法抹去”，比喻心理状态。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由“抹去涂抹的东西”引申为“取消、去除”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "synecdoche",
      "note": "部分代整体，由“抹涂”引出“一抹痕迹”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_narrowing",
      "note": "专指“涂上泥灰并弄平”，常用于建筑。"
    },
    {
      "source_index": 4,
      "target_index": 5,
