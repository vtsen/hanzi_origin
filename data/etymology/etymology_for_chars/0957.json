      ],
      "traditional_char": "拓"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "形声字，从手，石声，本义为用手推动，古文多作推动义。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由用手推动引申为开辟、扩展，见于先秦，汉代广泛用于“开拓”义。"
    },
    {
      "source_index": 1,
      "target_index": 3,
