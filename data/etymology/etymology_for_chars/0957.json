      "traditional_char": "拓"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "在刻有文字或图像的器物上敷墨加纸，用击打方法使文字或图像显现出来（如拓印、拓本）",
      "examples": [
        "碑文拓印",
        "请制一份拓本"
      ],
      "traditional_char": "拓"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "拾取，捡取（古同“摭”）",
