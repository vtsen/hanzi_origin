{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用手抽出或拉出，连根拽出。",
      "examples": [
        "拔草",
        "拔牙",
        "拔苗助长",
        "拔腿"
      ],
      "traditional_char": "拔"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用武力攻占据点或城池。",
      "examples": [
        "连拔数城"
      ],
      "traditional_char": "拔"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "吸出（如毒素或气体）。",
      "examples": [
        "拔毒",
        "拔火罐儿"
      ],
      "traditional_char": "拔"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "选举或提升人才。",
      "examples": [
        "提拔",
        "拔擢"
      ],
      "traditional_char": "拔"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "高出、超出（他人或环境）。",
      "examples": [
        "海拔",
        "挺拔",
        "拔地而起",
        "拔尖儿",
        "出类拔萃"
      ],
      "traditional_char": "拔"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "把东西放在凉水里使变凉。",
      "examples": [
        "把西瓜放在冰水里拔一拔"
      ],
      "traditional_char": "拔"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "改变、移除（如移除艰难或改变意志）。",
      "examples": [
        "坚韧不拔",
        "心志不可拔"
      ],
      "traditional_char": "拔"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手表意，犮为声符，原意为用手把物品拉出或拔起。"
    }
  ],
  "edges": [
    {
