{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用肩膀挑，使物品承载于肩上。",
      "examples": [
        "担水",
        "担柴"
      ],
      "traditional_char": "擔"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "承当责任或负担。",
      "examples": [
        "担负",
        "担当",
        "担任",
        "担待"
      ],
      "traditional_char": "擔"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "挑东西的用具，多为竹、木制成。",
      "examples": [
        "扁担"
      ],
      "traditional_char": "擔"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "一挑所挑的东西。",
