  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，甲声，本义为在文书上签名或画记号，‘手’表示与手的动作有关，‘甲’表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "从文书上画记作为凭证，引申为财物作抵押保证，见中古至今。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从审核文书、契约引申至对人身自由的限制和管控。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由拘留进一步衍生为实际跟随看管、押送等义。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "用作“压”的近音通假，多见于近现代词如‘押宝’‘押韵’。"
    }
  ]
