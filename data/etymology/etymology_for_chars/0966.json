  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“拔出”引申为“取一部分”的动作，古至今常见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由拔出、吸取引申为“吸入”，如抽烟。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "将“抽出”抽象为思想上的‘提炼、概括’。"
