  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，包声。表义部件“手”表示与手的动作有关，“包”作声旁，原指用手臂围住。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以手臂环抱之动作比喻自然环境的围绕。如“山环水抱”。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由实际动作转义为内心怀抱志向（胸怀理想）。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由物理性环抱引申为心理上怀有情感或事物。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由手臂围住引申为物体彼此密合。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "以环抱、持有引申为收养他人子女。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "grammaticalization",
      "note": "由动作名词化，作为表示合抱量词使用。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "由用手臂拥抱引申为鸟禽环抱孵卵。"
    }
  ]
