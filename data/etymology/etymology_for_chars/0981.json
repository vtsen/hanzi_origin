  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，立声，表示手的动作，原指摧折、折断。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“摧折”到“牵、扯”，动作范围由破坏转为牵引。多见于中古及后代。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "牵、扯发展为用车载运，有“拉运”的动作关联。现代汉语。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "牵扯动作引申为使事物延长。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以“拉”喻指人排便时的拉扯动作。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "以手拉引申为“联络、拉拢”。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "引申为带领、转移，多见于军事用语。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "用于拉动乐器部分致使发声。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "以“拉”指父母努力抚养子女成人，重在经历拉扯。"
    },
    {
      "source_index": 1,
      "target_index": 9,
      "evolution_type": "metaphor",
      "note": "“拉一把”指帮助别人脱困，比喻自物理动作引申而来。"
    },
    {
      "source_index": 1,
      "target_index": 10,
      "evolution_type": "unknown",
      "note": "“割、切开”一义可能为口语用法借音，流变机制不明。"
    },
    {
      "source_index": 1,
      "target_index": 11,
      "evolution_type": "metaphor",
      "note": "“拉话”从拉动作引申为谈论、闲聊，形象生动，现代口语。"
    }
  ]
