{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用两手分别抓住物体的两端，向相反方向用力旋转。",
      "examples": [
        "拧毛巾",
        "把瓶盖拧开"
      ],
      "traditional_char": "擰"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用两个手指扭住皮肉使劲转动。",
      "examples": [
        "妈妈拧了他一下",
        "拧耳朵"
      ],
      "traditional_char": "擰"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "扭转，用力旋转物体的一部分。",
      "examples": [
