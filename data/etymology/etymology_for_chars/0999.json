      "meaning": "苦菜，一种味道苦的野菜。",
      "examples": [
        "采苦以食",
        "《诗经·小雅·鹿鸣》：我有嘉宾，鼓瑟吹笙，吹笙鼓瑟，和乐且湛，采苦以食。"
      ],
      "traditional_char": "苦"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "像胆汁或黄连的滋味，味道苦涩，与“甘”相对。",
      "examples": [
        "苦瓜",
        "甘苦与共"
      ],
      "traditional_char": "苦"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "感到难受、痛苦，多指精神或处境上的痛苦。",
      "examples": [
        "苦闷",
        "含辛茹苦",
        "苦海无边"
      ],
      "traditional_char": "苦"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "因为某事而感到痛苦或困扰。",
      "examples": [
        "苦于奔波",
        "苦雨连绵"
      ],
      "traditional_char": "苦"
    },
    {
      "index": 4,
      "part_of_speech": "adverb",
      "meaning": "尽力地、用心地（多含辛苦意）。",
      "examples": [
        "苦口婆心",
        "苦劝"
      ],
      "traditional_char": "苦"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "使受苦。",
      "examples": [
        "那件事可苦了你啦！"
      ],
      "traditional_char": "苦"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘苦’为形声字，从艸（与植物有关），古声表音，最初指苦菜。"
