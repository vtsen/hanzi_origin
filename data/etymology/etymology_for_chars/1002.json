  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "“顺从”引申为条件关系，假设语气。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "“顺从”进一步比喻为“相似、像”，如顺应其形为相似。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "“像、如”进一步虚化为指人称代词“你”。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由“像”引申为约计，数量模糊用法。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由“像、如”用为“如此、这般”。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "“若”用于专名，“海若”为神名。"
    },
    {
      "source_index": 2,
