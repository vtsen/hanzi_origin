      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以茅草盖屋引申为屋舍，古今皆有例证。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "分封时用白茅裹土，引申为爵位和封地。"
    },
