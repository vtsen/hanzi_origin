  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘松’为形声字，左‘木’表意（指树木），右‘公’表音，最初指松树。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘鬆’为形声字，‘糹’表意（指松散状态），‘公’表音，后用作‘稀疏’、‘不紧’等意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由松树针叶稀疏，引申为整体稀疏、松散之意，见于中古已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "‘稀疏不紧’进一步发展为‘放开’、‘松开’。"
    },
