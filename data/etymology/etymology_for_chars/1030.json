    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由渡船作为交通工具，引申为由船搭成的浮桥。“杭”作浮桥始见于魏晋南北朝地志类文献。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "unknown",
      "note": "由地名“杭州”产生姓氏，具体机制不详。历史上由地而姓移用普遍。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "“杭”由“渡船”“舟”地名化，成为地理名词，后简称“杭”指杭州。"
    }
