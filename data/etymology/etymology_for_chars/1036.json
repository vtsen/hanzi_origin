  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "“畫”本为会意兼指事，上部“聿”象手执笔，下部象田界，表示持笔划分田界，本义为‘划分’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "持笔划界引申为一般的‘绘画、描绘’。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "动作为‘绘画’，其结果为名词‘图画’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "描绘动作转喻为各种身体动作，比如‘指手画脚’。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "‘划界’转为‘签押’，即写名字等含义。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "画出的线引申为汉字一笔称‘画’。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
      "note": "与‘划’音通，部分地区及义项中混用，本义转迻为‘划动’。"
    }
  ]
