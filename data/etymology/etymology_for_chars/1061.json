  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从车，仑声，本义为车轮。‘车’表示与运输工具相关，‘仑’表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从车轮扩展至一切可旋转之机械部件，属近现代工业文化影响。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "形状类比，由原本的车轮引申为任何圆形的事物，如日轮、月轮。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以“轮”代轮船，因轮船以大型桨轮推进得名，19世纪末沿用。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "‘轮’的旋转及交替概念，比喻为轮流、交替。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "由名词‘轮’转化为动词‘转动’。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "conversion",
