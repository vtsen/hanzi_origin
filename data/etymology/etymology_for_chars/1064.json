  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "指事造字。“非”象两翅相背，表示违背、本义为不合，与现代否定义接近。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“不是”引申为“过错、错误”；汉代用法渐普及。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“不是”引申为反对、责难的动词义，后用作“非难”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "“非”与“不”连用，虚化为连词，表示“必须”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "音译外来地名，现代简称“非洲”为“非”，属借用。"
    }
  ]
