    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "过错，错误",
      "examples": [
        "痛改前非",
        "文过饰非",
        "习非成是"
      ],
      "traditional_char": "非"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "责怪，反对",
      "examples": [
