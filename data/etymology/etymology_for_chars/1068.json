{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "人和动物口中咀嚼食物的器官，牙齿。",
      "examples": [
        "牙齿",
        "齿龈",
        "齿轮",
        "笑必开口，笑的时间长了，牙齿就会感到冷。"
      ],
      "traditional_char": "齒"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "排列像牙齿形状的东西（如锯齿、齿轮等）。",
      "examples": [
        "锯齿",
        "齿轮",
        "梳子齿儿"
      ],
      "traditional_char": "齒"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "因幼马每岁生一齿，用以计算牲畜年龄，后亦指人的年龄。",
      "examples": [
        "马齿徒增"
      ],
      "traditional_char": "齒"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "并列、同列。",
      "examples": [
        "不齿"
      ],
      "traditional_char": "齒"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "提及，谈到。",
      "examples": [
        "齿及",
        "不足齿数"
      ],
      "traditional_char": "齒"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "触，碰触（如齿剑）。",
      "examples": [
        "齿剑"
      ],
      "traditional_char": "齒"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "甲骨文象口中牙齿之形，为象形字。后加“止”作声符演变为形声字，但传统形体与原始象形关系明显。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "因牙齿形状整齐，故用以指排列如牙齿之物，早见于器物名。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由动物牙齿自然增长的客观特征，引申为岁数、年龄。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由牙齿并列之形，引申为并列、同列之意。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由张口露齿引申为提及、谈到，语义向抽象发展。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "以齿碰触其他物，引申为‘触’义，多见于文学用语。"
    }
  ]
}