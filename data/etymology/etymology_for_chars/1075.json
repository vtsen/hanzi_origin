  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“还、尚且”引申为“尊崇、推崇”，重在保留‘未完’或‘在上’之意味。"
    },
    {
      "source_index": 1,
      "target_index": 2,
