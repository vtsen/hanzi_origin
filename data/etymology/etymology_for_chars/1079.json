  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以“果实”为喻，引申为“事情的结果”，古籍先秦即已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由“事情的结果”引申转变为“坚决、决断”，取决于结果之必然性。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“必然的结果”，引申为“确实，真的”，语气副词用法。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "果实能充饱肚子，“果腹”指以果实充实肚腹，为转喻。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "reanalysis",
      "note": "由本义转为用作姓氏，无实际语义演变，乃词汇化。"
    }
