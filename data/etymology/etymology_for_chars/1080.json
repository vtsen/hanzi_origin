  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由“共同，一起”引申为“后代子孙”，如家族的延续。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“并肩同行”引申为兄长之义，指同辈中的年长者。"
    },
