  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从辵，由声，本义为道、道路。‘辵’表行走，道路之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由道路、道理引申为指引他人走上正道，即开导。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由道路、道理而引申为践行、顺行（行为）。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "从践行、实行引申为进用、进（使进入官职等）。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由道路引申为行走、出走（具体移动）。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由道、道路引申为‘继承’即走前人的道路。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "grammaticalization",
      "note": "本作‘道路’，后虚化为语气助词。"
