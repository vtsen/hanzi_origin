{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "坚固，牢固；结实、稳固之意。",
      "examples": [
        "筋骨欲其固也。",
        "荆州与国邻接，江山险固。",
        "良马固车。",
        "城郭沟池以为固。",
        "国可以固。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "使坚固、巩固、安定；加固。",
      "examples": [
        "固国不以山溪之险。",
        "臣闻求木之长者，必固其根本。",
        "固垒。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "坚定不变、固执；专一。",
      "examples": [
        "汝心之固，固不可彻。",
        "独夫之心，日益骄固。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "鄙陋，见识浅陋。",
      "examples": [
        "鄙人固陋，不知忌讳。",
        "奢则不逊，俭则固。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 4,
      "part_of_speech": "adverb",
      "meaning": "坚决地，执意，必然，本来，确实，已经等语气或状语用法。",
      "examples": [
        "蔺相如固止之。",
        "臣固知王之不忍也。",
        "吾不能变心以从俗兮，固将愁苦而终穷。",
        "天下分裂，而唐室固以微矣。",
        "生乎吾前，其闻道也固先乎吾。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "险固的地方，险要之地。",
      "examples": [
        "秦孝公据殽函之固。",
        "地形险阻，所以为固也。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "春秋晋有固乘。",
        "姓固。"
      ],
      "traditional_char": "固"
    },
    {
      "index": 7,
      "part_of_speech": "adjective",
      "meaning": "疾病经久难治（后作“痼”用）。",
      "examples": [
        "国多固疾。",
        "商言有固疾。"
      ],
      "traditional_char": "固"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从囗（表示围绕、包围，含‘坚固’语义），‘古’为声符，初义为‘四周围绕，坚牢’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由‘坚固’的形容词作使动用法，义为‘使……坚固’。见《孟子》《谏太宗十思疏》等。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "坚固引申为态度坚定、固执、专一，见《列子》《阿房宫赋》。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "由‘坚固、不变’引申为思想闭塞、鄙陋，见《论语》《盐铁论》及训诂。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "grammaticalization",
      "note": "形容词‘坚固’通过句法演变用作副词，取‘确实、本来、必然’之义，广见于古今文献。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "从‘坚固’的性质指称‘险要之地、坚固之处’，如‘殽函之固’。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "‘坚固’引申为‘牢不可去’，指疾病久治不愈，后写作‘痼’。"
    }
  ]
