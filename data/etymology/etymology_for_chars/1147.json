  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由表示‘旁边’引申为‘斜着’，因在一侧常表现为倾斜。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "‘侧’作为边旁引申为偏僻、简单及地位低下之意，常见于‘侧陋’。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "‘侧’引申作‘仄’，即‘不平、不正’之意，义项重合。"
    },
