  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代系在衣带上的玉饰",
      "examples": [
        "身佩玉珮。",
        "君子无故，玉不去身。——《礼记》"
      ],
      "traditional_char": "佩"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "挂在身上，佩带",
      "examples": [
        "佩剑。",
        "佩戴徽章。"
      ],
      "traditional_char": "佩"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "心悦诚服、敬仰",
      "examples": [
        "敬佩他的勇气。",
        "可佩之处。"
      ],
      "traditional_char": "佩"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘佩’为会意字，从‘人’表示与人相关，从‘巾’表示布带。本义为系在衣带上的玉石装饰。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由名词“带饰”引申为佩挂、佩戴行为，早见先秦文献。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由佩戴实物引申为“佩服”，即将德行等视同佩饰，表示认同或钦敬，通过比喻义发展。"
    }
  ]
}