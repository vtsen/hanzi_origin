{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代以贝壳为货币，五贝为一串，两串为一朋，作为货币单位。",
      "examples": [
        "以贝为货，五贝为一系，两系为一朋。"
      ],
      "traditional_char": "朋"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "彼此友好的人。",
      "examples": [
        "朋友",
        "宾朋满座"
      ],
      "traditional_char": "朋"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "结党：为私利而互相勾结、排斥异己的一帮人。",
      "examples": [
        "朋党之争"
      ],
      "traditional_char": "朋"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "成群聚集。",
      "examples": [
        "群居朋飞"
      ],
      "traditional_char": "朋"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "比拟，匹敌。",
      "examples": [
        "硬大无朋"
      ],
      "traditional_char": "朋"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [],
      "traditional_char": "朋"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，形声为两组贝相对，表示古代货币单位的系与朋。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "货币同等可以交换，引申为平等相交的人，春秋战国已有此用法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由朋友集体，引申为结党，往往含贬义。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由人结朋，泛指成群。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由朋本义“并列成对”，比喻匹敌、对等。"
