  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“舟两旁夹木”比喻人身体两侧的覆盖物，引申为“衣裳”。"
    },
    {
      "source_index": 1,
      "target_index": 2,
