  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘疙’从疒（病）表义，从吉表音，最早表癡呆或癡貌之病态。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由癡呆（痴貌）引申為因病痛導致的頭上突起物，由病態形象轉為病理現象。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由皮膚硬塊隱喻至一般小球形或塊狀物。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "從物理結塊比喻至思想等難題，比喻抽象難解之事。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由小塊或結塊比喻語句不順（有阻礙）。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "實體名詞轉為計量單位，作為量詞。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由身體結塊隱喻聯想到麻煩、別扭。"
    }
  ]
