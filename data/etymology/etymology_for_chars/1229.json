  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从邑，奠声，表示与地名、邦域相关；最初用作周代诸侯国之名。"
    },
    {
      "formation_type": "loan_character",
      "original_sense_index": 5,
      "note": "简化字“郑”，由“鄭”简化，现代通用。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由郑国引申为郑国的音乐，后泛指俗乐或淫靡之音。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "以国名作为姓氏的来源，常见于中国古姓氏的发展。"
