  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，且声。‘沮’最初作河流水名，用水表意，‘且’表音；后义多由水名引申。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "水流阻断为阻止、遏止之意，秦汉时已有此用法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘阻止’引申为‘破坏、败坏’。先秦两汉普遍见。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "‘阻挠’带来恐吓的意味，互有混用；多见于儒家经典。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "‘阻挠’进一步发展为‘诋毁、诽谤’，此为语义扩展。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "‘败坏’引申为‘丧气、颓废’，语义转化清楚。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由水名引申为水多而低湿的地貌、湿润之意。《诗经》用法。"
    }
