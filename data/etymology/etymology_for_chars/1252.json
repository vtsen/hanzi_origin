  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，主声，表示水流入。本义为灌入、注入。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘水流注入’引申为‘精神力量汇聚’；类似流注于一处。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由‘水注入’转为‘加入文字说明’，即信息灌注。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "动词‘注’解释文句转为该文字本体，成为名词‘注’。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "登记、记载引申为‘数据流入’之义。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "由‘注入’引申至赌资下注，喻金钱流入赌局。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "conversion",
      "note": "由名词‘下注’发展为作量词使用，如‘一注’。"
    }
  ]
