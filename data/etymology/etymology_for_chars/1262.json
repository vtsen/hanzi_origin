  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，发声，表示水流外洒。‘潑’为正体。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由猛力泼洒水引申为性格粗野、放纵，多见于宋元以后。"
