  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "審为会意字，从宀、番。宀表屋，番表示兽足，意为屋内分辨兽足印，象征详细考察。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "简化字审从宀申声，以声旁简化表示，意义沿用本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由动词‘详细考察’引申为形容词‘详细、周密’，见现代汉语。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘仔细考察’转喻为‘审问案件’，表判断、推理过程，汉魏已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从‘详查’引申为‘明了’，古汉语具备。"
    },
    {
      "source_index": 2,
      "target_index": 3,
