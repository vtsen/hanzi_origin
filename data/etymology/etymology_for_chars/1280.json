      "original_sense_index": 0,
      "note": "形声字，从宀表房屋，由声取声，最初表示栋梁。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由‘栋梁’引申为‘居处’、‘舟车所到之处’，汉代以前已有。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由房屋之梁引申喻为时间的支撑、无始无终的‘长’，见先秦哲学文献。"
