    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "栋梁，屋内支撑屋顶的横梁。",
      "examples": [
        "宙，舟舆所极覆也。——《说文》",
        "宙，栋梁也。——高诱注《淮南子·览冥》"
      ],
      "traditional_char": "宙"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古往今来的时间；无限的时间。",
      "examples": [
        "往古来今谓之宙，四方上下谓之宇。——《淮南子·齐俗》",
        "有实而无乎处者宇也，有长而无本剽者宙也。——《庄子·庚桑楚》"
      ],
      "traditional_char": "宙"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "天空。",
      "examples": [
        "功烛上宙，德耀中天。——《南齐书》",
        "霜凝碧宙，水莹丹霄。——王勃《七夕赋》"
      ],
      "traditional_char": "宙"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "舟车所到之处；居处。",
      "examples": [
        "宙，舟舆所极覆也。——《说文》",
        "宙，居也。——《广雅·释诂二》"
      ],
      "traditional_char": "宙"
    }
  ],
  "formations": [
    {
