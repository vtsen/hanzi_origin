  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 3,
      "note": "会意字，从宀（屋）与贯（财物），本义为屋内充满财物，表示富足。‘实’为‘實’的简化。"
    }
  ],
  "edges": [
    {
      "source_index": 3,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "富足之意引申为一般充满、内容充实的意思，见于先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由充实、无虚假引申为真实、真诚，比喻由实引申为真。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "植物开花后内容充实之物，即果实，由“充实”引申。"
    }
  ]
