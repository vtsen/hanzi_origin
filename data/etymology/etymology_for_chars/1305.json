{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "逮捕；追及。",
      "examples": [
        "隶，及也，从又从尾省。又持尾者从后及之也。——《说文》"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "附属，从属；属于。",
      "examples": [
        "直隶中央。",
        "隶而从者。——唐·柳宗元《至小丘西小石潭记》"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "低级官吏、差役，特指衙役。",
      "examples": [
        "皂隶之事。《左传》",
        "隶卒。"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "地位低下而被奴役的人，奴仆。",
      "examples": [
        "人皆得以隶使之。——明·张溥《五人墓碑记》",
        "甿隶之人。——汉·贾谊《过秦论》"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "汉字的一种字体，即隶书。",
      "examples": [
        "隶书，汉字的一种书体。",
        "乃令群臣习隶。——《史记·刘敬叔孙通列传》"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "检查，查阅。",
      "examples": [
        "关东吏隶郡国出入关者。——《史记·酷吏列传》"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "练习（书写），学习。",
      "examples": [
        "迺令群臣习隶，会十月。"
      ],
      "traditional_char": "隸"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "通“离”，流离失所。",
      "examples": [
        "饿馑流隶，饥寒道路。——《汉书·叙传·王命论》"
