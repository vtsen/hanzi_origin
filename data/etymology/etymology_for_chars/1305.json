      "traditional_char": "隸"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从‘又’（手）与省作的‘尾’，表示手持尾巴从后追及；反映‘追及、逮捕’之本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘及、逮捕’引申为‘附属、归属’；古汉语词义外延扩大。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "附属于官府的低级役吏由‘附属’义转出，形成对低级官差的称谓。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由‘役吏’泛化指被奴役、地位低下者。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "‘隶’义引申为‘隶书’，因此类书写体系源于官方文书，具有‘从属官府’之意。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "‘及’义引申为‘查检、检查’，强调达到并审查。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "及、捕捉过程引申为‘练习、实践’。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘隶’通‘离’，用于‘流离’，为假借义。"
    }
  ]
}