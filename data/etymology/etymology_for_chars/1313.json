    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从弓，尔声，表示放松弓弦。彌为本字，最初相关于弓弦动作。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 4,
      "note": "瀰，形声字，从水，彌声，强调水满、弥漫之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "从弦放松扩展为“满、遍”的抽象意义；常见于先秦至汉代。"
    },
    {
      "source_index": 1,
      "target_index": 2,
