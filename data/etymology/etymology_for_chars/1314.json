{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "弓上两端系着、用以发箭的绳状物，本义弓弦。",
      "examples": [
        "弓弦",
        "应弦而倒",
        "佩弦以戒缓"
      ],
      "traditional_char": "弦"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "乐器上可以发声的线或绳。",
      "examples": [
        "琴弦",
        "续弦",
        "弦歌"
      ],
      "traditional_char": "弦"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "月亮半圆时形状似弓弦，指农历初七、八或二十二、三的月相。",
      "examples": [
        "上弦月",
        "下弦月"
      ],
      "traditional_char": "弦"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "中国古代称不等腰直角三角形的斜边。",
      "examples": [
        "弦长",
        "直角三角形的弦"
      ],
      "traditional_char": "弦"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "中医脉象名，形容脉象紧直如弦。",
      "examples": [
        "弦脉"
      ],
      "traditional_char": "弦"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "左‘弓’右‘玄’（“丝”），表示用丝做的弓弦，是会意字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由弓弦扩展指一切可发声的线，主要指乐器弦，见古代乐器如琴、瑟。"
    },
    {
      "source_index": 0,
      "target_index": 2,
