      ],
      "traditional_char": "孤"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从子，表示与儿童相关，瓜为声符，最初指幼年丧父的孩子。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "“孤”由指没有父母的孩子，引申为一般孤单无依。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "帝王自称“孤”，取其高处无援，类似‘孤独’之意，先见于战国秦晋等国。"
