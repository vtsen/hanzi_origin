      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "由动作‘煮丝’指代结果‘白绢’。见古代文献语境。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "从‘反复处理使丝洁白’引申为‘反复练习’。过程类比。"
