  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "左为土上树象，右为手（寸），表示以树明确界限。本义为疆界、田界。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "“疆界”引申为分封诸侯、授予疆域，为先秦、秦汉常用义。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由“分封”引申为帝王特定祭祀活动，历史沿革中汉武帝以后常见。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“设界限、划分”喻为“封闭、隔绝”，为后起义。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "用作装信纸、金钱的封套，因“封闭”引申。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "由“封闭”引申至“限制”，如“故步自封”。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "conversion",
      "note": "名词“封”引申为量词用法，如“一封信”。"
