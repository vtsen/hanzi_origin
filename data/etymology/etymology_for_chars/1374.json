      ],
      "traditional_char": "挾"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，夹声；本义为用胳膊夹住。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "“夹持”抽象化为“借助权势威胁他人”，语义转移，出现于先秦两汉。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由外在夹持转义为内心夹带、怀有怨恨等情感，多见于书面语。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“用胳膊夹住”扩展为“从两边夹紧”，义项扩展，见于古文。"
