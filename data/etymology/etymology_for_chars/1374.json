      "meaning": "用胳膊夹着。",
      "examples": [
        "他挟着包裹走进来。",
        "挟持"
      ],
      "traditional_char": "挾"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "倚仗势力或抓住人的弱点强迫人服从。",
      "examples": [
        "要挟",
        "挟制",
        "挟势"
      ],
      "traditional_char": "挾"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "心里怀着（怨恨等）。",
      "examples": [
        "挟恨",
        "挟怨",
        "挟嫌"
      ],
      "traditional_char": "挾"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "从物体两边钳住（古同“夹”）。",
      "examples": [
