  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“甩出”扩展为所有舞动、摇摆手的动作，用于描述手部大幅动作。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“甩出”抽象引申为情感、气势等的“发散”，古今皆用。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由“摇摆、舞动手势”引申为“发号施令、指挥”，因为指挥动作常以手势表达。"
