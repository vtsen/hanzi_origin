{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "长满野草，或无人耕种，荒芜。",
      "examples": [
        "荒芜",
        "荒地",
        "开荒"
      ],
      "traditional_char": "荒"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "年成不好，收成不好，荒年。",
      "examples": [
        "灾荒",
        "荒年",
        "防荒",
        "备荒"
      ],
      "traditional_char": "荒"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "废弃，不耕作，疏于管理。",
      "examples": [
        "荒废",
        "荒疏",
        "荒置",
        "业精于勤，荒于嬉"
      ],
      "traditional_char": "荒"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "冷落偏僻。",
      "examples": [
        "荒村",
        "荒郊",
        "荒落",
        "荒颓"
      ],
      "traditional_char": "荒"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "严重缺乏，不够用。",
      "examples": [
        "煤荒"
      ],
      "traditional_char": "荒"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "不实在的，不正确的，荒唐。",
      "examples": [
        "荒信",
        "荒唐"
      ],
      "traditional_char": "荒"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "放纵，迷乱。",
