      ],
      "traditional_char": "荒"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从“丱”作形旁，“巟”表声，初指土地荒芜。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由荒芜的土地引申为歉收的年份。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由形容词转为动词，指土地被荒废。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由土地荒芜引申为冷落偏僻之地。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "荒指资源荒芜引申为缺乏。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "由实物荒芜转喻为言论思想的荒谬。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由实物荒芜转喻为行为放纵迷乱。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "远地多为荒芜之地，故引申为边远。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "unknown",
      "note": "“荒”作“扩大”义，多见于古文，引申关系待考。"
    },
    {
      "source_index": 8,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "由扩大引申为包有，占有。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "semantic_extension",
      "note": "工业用语，指未经加工之物，取其“荒芜”“未成”之意。"
    }
  ]
