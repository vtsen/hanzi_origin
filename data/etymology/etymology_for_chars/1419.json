  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从肉，古声，初指兽颈下垂肉。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘鬍’为后起形声字，从髟，胡声，本指嘴周围的胡须，区分于其他‘胡’义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "因动物颈下垂肉形象转指嘴边的须毛（即后为‘鬍’），形成形象联想。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以特征引申为北方民族，古时以貌特征（须发旺盛、肤色）称异族为‘胡’。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由特指北方民族扩展为所有外族、外来事物。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由他族、异域事物引申为‘杂乱’、‘不合常理’的意思。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "或为假借，疑问词义在文言出现，具体联系有争议。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "unknown",
      "note": "‘胡同’义来源不明，或与地名、外族称呼相关。"
    },
    {
      "source_index": 0,
