    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由器物的把手比喻连结植物器官的部分，见《本草纲目》等。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "grammaticalization",
