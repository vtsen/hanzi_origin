  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由腰——躬身以求，引申为索取。汉代已见用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由索取引申为希望获得。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由索取发展为请求他人。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "要件比喻人体腰部为身体之要，故为事物之重。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "grammaticalization",
      "note": "由形容词“要（重要）”语法化为“应该、必须”。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "grammaticalization",
      "note": "“要”助动用法引申为将要、快要。"
    },
    {
      "source_index": 5,
      "target_index": 7,
      "evolution_type": "function_word",
      "note": "由助动向条件连词“如果”发展。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "function_word",
      "note": "作为连词引申出选择关系‘要么/要不’。"
    },
    {
      "source_index": 1,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "由索取引申为有所依恃的强求。"
    },
    {
      "source_index": 1,
      "target_index": 10,
      "evolution_type": "phonetical_loan_shift",
