  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "‘面’为象形字，甲骨文像人脸，有‘目’，外形为脸廓，表示面部。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 7,
      "note": "‘麵’为形声字，从‘麥’得义，‘面’为声，最初指面粉相关。"
    }
