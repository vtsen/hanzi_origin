      "part_of_speech": "noun",
      "meaning": "形容敲击声（象声词）。",
      "examples": [
        "《儿女英雄传》：“把两只小脚儿点的脚踏儿哆哆哆的乱响。”"
      ],
      "traditional_char": "哆"
    },
