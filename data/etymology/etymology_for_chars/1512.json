      ],
      "traditional_char": "咬"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "正确地读字音，或过分计较字句意义。",
      "examples": [
        "咬字儿",
        "咬文嚼字"
      ],
      "traditional_char": "咬"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "追赶进逼，紧追不舍。",
      "examples": [
        "双方比分咬得很紧"
      ],
      "traditional_char": "咬"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从口，交声，本义为用牙齿夹住或压碎。"
