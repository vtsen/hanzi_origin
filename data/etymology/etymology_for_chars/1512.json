{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用上下牙对住、压碎或夹住东西。",
      "examples": [
        "咬啮",
        "咬噬",
        "咬紧牙关"
      ],
      "traditional_char": "咬"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "钳子等夹住或螺丝齿轮等卡住。",
      "examples": [
        "咬合",
        "咬住扣"
      ],
      "traditional_char": "咬"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "（喻）话说定了不再改变，或指受责难或审讯时诬陷无关的人。",
      "examples": [
        "一口咬定",
        "乱咬好人"
      ],
      "traditional_char": "咬"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "动物叫，特指狗叫。",
      "examples": [
