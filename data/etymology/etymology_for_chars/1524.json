  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘幽’由两个‘幺’和‘山’组成，取藏于山中之意，形声字，声旁‘幺’表示音，意旁‘山’呈现隐蔽的概念。"
    }
