  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“隐藏”引申为环境幽深、光线昏暗，偏僻静谧。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由环境幽静比喻人的性格沉静安闲。"
