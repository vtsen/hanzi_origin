  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从黍、甘。表示粮食作物（黍）释放的甜美气（甘），指五谷的香气。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由形容气味好闻扩展为泛指有香味的物品。见先秦、汉代用法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_narrowing",
      "note": "专指祭祀用的香料或香条。佛教传播后尤常。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由气味好闻比喻食物味道好，有“美味”义。"
    },
