{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "播撒种子或幼苗于土地中以使其生长。",
      "examples": [
        "种地",
        "栽种"
      ],
      "traditional_char": "種"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "动植物果实中能够繁殖后代的部分，泛指遗传繁殖的物质。",
      "examples": [
        "种子",
        "撒种",
        "配种"
      ],
      "traditional_char": "種"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "在生态和形态等方面有不同特征的生物分类基本单位。",
      "examples": [
        "物种",
        "种差"
      ],
      "traditional_char": "種"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "具有共同起源和遗传特征的人群。",
      "examples": [
        "人种",
        "种族"
      ],
      "traditional_char": "種"
    },
    {
      "index": 4,
      "part_of_speech": "measure_word",
      "meaning": "用于表示种类、类别、式样。",
      "examples": [
        "两种人",
        "三种方法"
      ],
      "traditional_char": "種"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "胆量、骨气。",
      "examples": [
        "有种",
        "没种"
      ],
      "traditional_char": "種"
    },
    {
      "index": 6,
      "part_of_speech": "other",
      "meaning": "姓氏。",
      "examples": [
        "种师道"
      ],
      "traditional_char": "種"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从禾，重声，表示与谷物、播种相关之义。"
    }
  ],
  "edges": [
