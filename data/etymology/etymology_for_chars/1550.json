  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 1,
      "note": "甲骨文为蟋蟀形，或加禾、火，表示庄稼成熟的秋季。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 6,
      "note": "鞦（秋千专用字），形声：‘革’旁，‘秋’为声，指系绳于架上可荡的器具。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由‘庄稼成熟的时期’泛指到‘一年四季中的秋天’。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "以一年中某季代指整个一年。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由季节时期泛指任何时期，尤其指不好的时期。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以秋水喻美人之目，转指眼睛。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "以秋为姓氏。"
