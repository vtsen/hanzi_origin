  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "“須”（本字“须”）为会意兼象形字，从页（头）与彡（须毛），表示人面上的毛发，原指胡须。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以须的形态引申为类似胡须的丝状物。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "“须臾”原暗指胡须移动的片刻，引申为很短的时间。"
