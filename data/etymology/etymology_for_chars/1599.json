    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "力量不足而尽力做，勉强为之",
      "examples": [
        "丧事不敢不勉。——《论语·子罕》",
        "曰勉升降以上下兮。——《楚辞·离骚》",
        "后勉一幸金明，所谓龙舟，非独不登，亦终不观也。——宋·陆游《老学庵笔记》"
      ],
      "traditional_char": "勉"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "尽力，努力",
      "examples": [
        "尔其勉之。——《左传·昭公二十年》",
        "愿子勉为寡人治之。——《韩非子·外储说左下》",
        "勤勉。——常用搭配"
      ],
      "traditional_char": "勉"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "劝勉，鼓励",
      "examples": [
