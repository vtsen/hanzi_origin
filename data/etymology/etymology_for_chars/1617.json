  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘將’为形声字，从寸，酱省声；“寸”象征与手有关，原指军队中带兵的人，后泛化。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“将领”引申为“统率、指挥”兵众，见先秦至汉用例。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“统率、指挥”扩展到一般性的带领、扶助。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "“带领”转为“拿、持”，以“带持物”表示。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "grammaticalization",
      "note": "由实义动词“拿”语法化为介词，引出动词宾语。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "“带领”引申为“快要”，表示事件即将发生。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "动物“带领”幼崽，引申为“生子”，见《诗经》。"
    },
    {
      "source_index": 2,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "“扶助”转为“保养”，调养身心，语义扩大。"
    },
    {
      "source_index": 2,
      "target_index": 8,
      "evolution_type": "semantic_shift",
      "note": "由“带领、顺随”转为“顺从、迁就”。"
    },
    {
      "source_index": 5,
      "target_index": 9,
      "evolution_type": "grammaticalization",
      "note": "“将”作连词用，表示并列，语法化产物。"
    },
    {
      "source_index": 3,
      "target_index": 10,
      "evolution_type": "grammaticalization",
      "note": "“将”虚化为结构助词，用于动词和趋向补语中间。"
    },
    {
      "source_index": 5,
      "target_index": 11,
      "evolution_type": "semantic_narrowing",
      "note": "“将要”进一步专指“刚刚、刚才”之意。"
    },
    {
      "source_index": 0,
      "target_index": 12,
      "evolution_type": "analogy",
      "note": "象棋用语“将军”，借用军衔名称，明清以后普遍。"
    },
    {
      "source_index": 3,
      "target_index": 13,
      "evolution_type": "semantic_extension",
      "note": "“将”由持之意引申为刺激、引发，较现代。"
    }
  ]
