  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 6,
      "note": "“差”字从羊，旁有工，形声字，本义为差遣、派遣，有任务分派之意。"
    }
  ],
  "edges": [
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由“差遣”引申为受差遣的人或差事，见于汉代文献。"
    },
    {
      "source_index": 6,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "“差”由分派义转为区分、分别，引申出“差别、差距”等义。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "从“差别”引申出数学上“两个数之差”，为近现代用法。"
    },
    {
      "source_index": 4,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由区别、差别义引申为“不相当、不合”等义。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由不相当、差距义产生“缺欠、不足”之义。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "差距引申为“水平低、不符合标准”等义。"
    },
    {
      "source_index": 4,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由差别、不同引申为“错误、过失”。"
