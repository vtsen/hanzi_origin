  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "“婁”为形声字，从女，娄声；本义为“中空”，后引申出其他义。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "“娄”为“婁”的简化字，承袭其全部义项。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "星宿名“娄宿”来源于古代星象分区名，可能与“中空”之义有关。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "“空”“中空”引申指“虚弱”，因空虚而弱。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "“空”引申为“小高地”，即土中空起之貌。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "由‘收缩变空’引申用作‘收敛’。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "瓜果过熟内里空，故引为‘过熟而变质’。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "因母猪腹大如空，借指母猪。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "semantic_shift",
      "note": "古音通假，“牵曳”义可能由‘空’本义旁生。"
    },
    {
      "source_index": 8,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "由“牵曳”引申为“拴系”。"
    },
    {
      "source_index": 1,
      "target_index": 10,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘婁’借用作‘屡’用，意思转作多次。"
    }
  ]
