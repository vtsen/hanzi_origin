{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "古代烹饪法，用泥包裹食物后用火烧烤。",
      "examples": [
        "以泥包物而炙之，曰炮。",
        "炮炙以为膳。"
      ],
      "traditional_char": "炮"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "烧、烤、烙，如“炮炙”、“炮烙”、“炮制”。",
      "examples": [
        "炮炙草药。",
        "炮烙以刑人。"
      ],
      "traditional_char": "炮"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "把物品放在器物上烘烤或焙干。",
      "examples": [
        "把湿衣服搁在热炕上炮干。"
      ],
      "traditional_char": "炮"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "在旺火上急炒（一种烹调方法）。",
      "examples": [
        "炮羊肉。"
      ],
      "traditional_char": "炮"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "重型武器，例如迫击炮、高射炮、火箭炮等。",
      "examples": [
        "炮兵。",
        "高射炮。"
      ],
      "traditional_char": "炮"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "爆竹。",
      "examples": [
        "鞭炮。",
        "花炮。"
      ],
      "traditional_char": "炮"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "用于爆破土石等的爆炸装置。",
      "examples": [
        "在岩石中打炮眼。"
      ],
      "traditional_char": "炮"
    }
  ],
