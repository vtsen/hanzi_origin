      "part_of_speech": "verb",
      "meaning": "感染疾病、沾上坏习惯或接触到不好的事物",
      "examples": [
        "染病",
        "传染",
        "沾染恶习",
        "一尘不染"
      ],
      "traditional_char": "染"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，杂声；一说会意，从木、水、九，指加工植物染料于水，反复浸染。本义为使物着色。"
    }
  ],
  "edges": [
