      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以水名代指河畔都市，因洛阳位于洛水之阳，西周以降开始。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以所居水得名部族，用水名代民族名，春秋时期文献见载。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "由水名转为水竭义，可能因地理特征引申，具体时代不详。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以河名指代古籍名《洛書》，与《河圖》对举，见于典籍。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "《馬王堆帛書》，‘洛’通‘露’，同音假借义。"
