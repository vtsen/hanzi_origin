  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从“冖”表示覆盖，从“元”表示头，从“寸”表示手，表示用手把布帛等物加在头上，即帽子的意思。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由帽子的本义引申为形状像帽子的或位于顶部的事物。汉代已见此用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由名词“冠”（帽子）转化为动词“戴帽子”；名动用法，古今皆有。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由帽子居于头部引申为处于顶部、首位，进一步引申为“居第一位”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "reanalysis",
      "note": "以“冠”为姓，属于以物为氏的习惯，近古发展。"
    }
