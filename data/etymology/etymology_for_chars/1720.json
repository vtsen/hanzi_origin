        "退伍",
        "退休"
      ],
      "traditional_char": "退"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "送还，不接受，撤销。",
      "examples": [
        "退还",
        "退货"
      ],
      "traditional_char": "退"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
