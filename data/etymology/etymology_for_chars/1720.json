{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "向后移动，与“进”相对。",
      "examples": [
        "退步",
        "倒退",
        "退路"
      ],
      "traditional_char": "退"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "离开，辞去。",
      "examples": [
