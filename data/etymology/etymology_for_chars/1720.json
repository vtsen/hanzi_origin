  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从彳表示行走，从攵表示反转，表“向后走”。小篆形体明确。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从“向后移动”引申为“离开、辞去”，东汉以后已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "以“退”为“送回”，“撤销”含义，意为将物返还原处。中古以降。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "“退色”“退毛”属属性引申，比喻物理上逐渐消失、脱落。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "用“退”的行为特性比喻态度温和，见《左传》。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "“迟缓、畏缩”源于行动上的“后退”心理延伸，见先秦文献。"
    }
  ]
}