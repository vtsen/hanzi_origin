      "meaning": "姓氏。传说为虞舜的后裔所用。",
      "examples": [
        "姚，虞舜居姚虚，因以为姓。——《说文》",
        "虞思妻之以二姚。——《左传》"
      ],
      "traditional_char": "姚"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "美好的样子，秀美、妖艳貌。",
      "examples": [
        "窕冶。——《荀子·礼论》。注：“姚冶，妖美也。”",
        "姚，好也。——《方言十三》",
        "美哉德乎!姚姚者乎!——刘向《说苑·指武》"
      ],
      "traditional_char": "姚"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "远，引申为长，通“遥”。",
      "examples": [
        "其功盛姚远矣!——《荀子·荣辱》",
        "雅声远姚。——《汉书·礼乐志》",
        "民将姚去。——《睡虎地秦简·为吏之道》"
      ],
      "traditional_char": "姚"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "轻佻、迟缓，通“窕”“佻”。",
      "examples": [
        "楚师轻姚。——《春秋传》",
        "姚佚，姚易。"
      ],
      "traditional_char": "姚"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "勇猛迅疾貌（如“剽姚”、“票姚”），形容劲疾有力。",
      "examples": [
        "去病为票姚校尉。——《汉书·霍去病传》",
        "贾问大将谁，恐是霍嫖姚。（杜甫《新丰》）"
      ],
      "traditional_char": "姚"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从女，兆声。本为姓氏用字，符号女旁表人或女性相关，兆作声旁，六书属形声字。"
    }
