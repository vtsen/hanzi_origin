{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "昆虫，赤褐色，善跳跃，寄生在人和畜的身体上，吸血液，能传染鼠疫等疾病。通称“跳蚤”、“虼蚤”。",
      "examples": [
        "夏日蚤甚多，人畜皆受扰。"
      ],
      "traditional_char": "蚤"
    },
    {
      "index": 1,
      "part_of_speech": "adverb",
      "meaning": "古同“早”，时间在前，清晨，早晨。",
      "examples": [
        "蚤起，整衣冠。",
        "君子蚤作。"
      ],
      "traditional_char": "蚤"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古同“爪”，指爪子。",
      "examples": [
        "其蚤锐利。",
        "虎有利蚤。"
      ],
      "traditional_char": "蚤"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“蚤”形声字，从虫，早声。本义指跳蚤一类的昆虫。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "phonetical_loan_shift",
      "note": "“蚤”后借为“早”，用其音。汉代已见音转假借。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "phonetical_loan_shift",
      "note": "“蚤”又假借为“爪”。见于部分古文献。"
    }
  ]
}