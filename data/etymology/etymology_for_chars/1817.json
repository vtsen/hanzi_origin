  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由描述耳贴颊之状，形象引申为光明（明亮），由于“烓”作声兼义。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由'光明'转喻为心地光明、正直，古今常用。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "由明亮引申至内心状态，形容心中有牵挂、忧愁不安。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "地名、国名多取字义正面光明蕴意，用作地名。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "用作姓氏，取义光明正大。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "形容筋脉高耸突出，明亮之状比拟筋脉突出的外观。"
    }
