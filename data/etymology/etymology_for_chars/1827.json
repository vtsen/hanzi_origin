  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "獲为形声字，从犬，蒦声，甲骨文从隹从又，表示用手捉禽鸟，原指所捕猎得的禽兽。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 4,
      "note": "穫为形声字，从禾，蒦声，义为收获庄稼，禾表意与农业生产相关。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由具体‘猎获’引申为一般意义上的‘取得、得到’，汉代已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "以被获之人类类喻禽兽，后指‘臧获’即奴婢，贬义用法，见于先秦文献。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由‘取得’进一步引申为‘获得机会或空闲’的抽象意义。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由‘获得’引申为‘农业收获’，‘穫’字专指庄稼，义项分化于农业社会。"
    }
  ]
}