{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "光洁似玉的美石，或指宝石、类似玉的石头。",
      "examples": [
        "如玉之莹。",
        "尚之以琼莹乎而。",
        "有匪君子，充耳琇瑩。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "珠玉的光采，光泽。",
      "examples": [
        "良珠度寸，虽有白仞之水，不能掩其莹。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "光洁透明，晶莹洁白。",
      "examples": [
        "色泽莹润。",
        "莹玉。",
        "此人之水镜，见之莹然。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "引申为心地纯净、明白。",
      "examples": [
        "心瑩紅蓮水，言忘綠茗杯。",
        "其論尚多未莹者。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "使明洁、使生光泽。",
      "examples": [
        "乃其剖而莹之，弛而试之，玉石驽骥然后始分。",
        "瑩之以發其光。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "使明白、明晰。",
      "examples": [
        "開帙瑩所疑。",
        "曉天下之瞶瞶、瑩天下之晦晦者， 其唯玄乎。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "装饰、涂饰。",
      "examples": [
        "文彩瑩丹漆。",
        "常瑩其蹄角。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 7,
      "part_of_speech": "other",
      "meaning": "闪烁、（借用义）迷惑、微光（通“熒”）。",
      "examples": [
        "淚光熒熒然，猶瑩于茵席而已。",
        "其談說足以飾邪瑩眾。"
      ],
      "traditional_char": "瑩"
    },
    {
      "index": 8,
      "part_of_speech": "other",
      "meaning": "“瑩”的简化字（现代使用），义同“瑩”。",
      "examples": [
        "晶莹。",
        "莹白。",
        "莹洁。"
      ],
      "traditional_char": "莹"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘瑩’为形声字，从玉，荧声，表示珠玉之光采。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 8,
      "note": "‘莹’为‘瑩’的简化字，形声结构，语音及意义承自‘瑩’。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
