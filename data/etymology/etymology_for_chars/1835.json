      "meaning": "桂树，一种常绿小乔木或灌木，叶椭圆形，开白色或暗黄色小花，香气浓郁。通称“木犀”。",
      "examples": [
        "桂花香满园。",
        "金桂、银桂。"
      ],
      "traditional_char": "桂"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "“桂花”的简称，亦可指以桂花为象征的事物，如“桂轮”指月亮。",
      "examples": [
        "桂子飘香。",
        "桂轮高挂。"
      ],
      "traditional_char": "桂"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "广西壮族自治区的别称。",
      "examples": [
        "桂剧起源于广西。",
        "桂系军阀。"
      ],
      "traditional_char": "桂"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "桂林",
        "桂平"
      ],
      "traditional_char": "桂"
    }
  ],
