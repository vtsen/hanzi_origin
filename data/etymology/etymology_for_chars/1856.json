    },
    {
      "index": 9,
      "part_of_speech": "noun",
      "meaning": "鸟名，鹰属，鹫类",
      "examples": [
        "马融曰：贾，乌也。",
        "《庄子》曰：雅，贾矣。"
      ],
      "traditional_char": "賈"
    },
    {
      "index": 10,
      "part_of_speech": "noun",
      "meaning": "姓氏",
      "examples": [
        "贾余庆献谄于后。",
        "贾董（贾谊和董仲舒的并称）"
      ],
      "traditional_char": "賈"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从贝，襾（音符）声，贝表货财，初本指做买卖之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "“做买卖”引申为“商人”，古已有此用。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“经营买卖”泛指“卖”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "买卖本是一体，用作“买”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由买卖引申为谋求、求取。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "从经商、交易引申为招致、引起。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_narrowing",
      "note": "指涉与市买相关的古官名。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "conversion",
      "note": "由买卖行为引申表示“价格”。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "unknown",
      "note": "用作古国名，详细联系未详，可能为地名引申义。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "unknown",
      "note": "名称用作鸟名，渊源不详，或为音转假借。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "conversion",
      "note": "作为姓氏，多由地名或官名而来。"
