{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "做买卖，经营贸易",
      "examples": [
        "长袖善舞，多财善贾。",
        "贾，市也。——《说文》"
      ],
      "traditional_char": "賈"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "商人，特指坐商，后泛指商人",
      "examples": [
