  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "“監”会意，本义为监督察看，甲骨文形象为人以目俯视器皿中的水，以水为镜，具有视察含义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由行监督职责的处所转指为关押犯人的场所，用作“牢狱”。汉以后常见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "监督者或监察机关的名称引申为官名或官府名，表示行使监督、检查的机构或人员。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由照见（镜）引申为借鉴、参考，即“以他人之镜为监”。成语“以人为鉴”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "synecdoche",
      "note": "由用水为镜监督自身面容，器皿之义转为镜子本身。"
    }
  ]
