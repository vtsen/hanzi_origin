{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "蝌蚪：青蛙、蟾蜍等两栖动物的幼虫，形状头大尾细，生活在水中。",
      "examples": [
        "池塘里有许多蝌蚪。",
        "蚪者，蛙子也。"
      ],
      "traditional_char": "蚪"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "比喻像蝌蚪形状的文字，如“蝌蚪文”。",
      "examples": [
        "古书有蝌蚪文，形如蚪。"
      ],
      "traditional_char": "蚪"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "通“斗”，用于地名，如“蚪峰”。",
      "examples": [
        "蚪峰，地名。"
      ],
      "traditional_char": "蚪"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘蚪’为形声字，从虫，斗声，最初指蝌蚪，即两栖动物的幼虫。"
    }
  ],
  "edges": [
    {
