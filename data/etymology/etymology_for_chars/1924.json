  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_narrowing",
      "note": "由‘残害、伤害’具体化为‘偷东西的人、盗匪’；先秦两汉已常用。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由原指‘残害者’，扩展为‘有危害的人’，如‘国贼’。"
