  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从'大'（人）从'木'，表示人登上木（树），表“登，上”之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“登上”引申为“上（马、车等）”进而发展为“乘坐、骑”。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“乘坐”转为“把握机会”，如乘势而上。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_narrowing",
      "note": "由“乘坐”交通工具引申专指古代兵车单位。"
    },
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "以“兵车四马为一乘”进而代表“四”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "“登、合”意引申为数的倍增操作，逻辑为“数上加数”。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "佛教用“乘”比喻“交通工具”，引申为“教法”。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "unknown",
      "note": "作为姓氏，来源不详，或与本义无关。"
    },
    {
      "source_index": 6,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "由“兵车”转指“史书”，比喻其承载历史。"
    }
  ]
