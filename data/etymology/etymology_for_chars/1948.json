  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由表示量器扩展为“称量”动作，东周至汉已见"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由称量引申为“叫、叫做”，即对人事的“衡量、命名”，东汉已见"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "称谓、名号等抽象用法，三国六朝开始"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由“叫做”发展为“说、陈述”"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "说，引申为“称赞、赞美”，语气加强"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由“提起（称量）”转为“举起”"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "称量之义比拟为“相当、适合”，后作形容词修饰"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "semantic_shift",
      "note": "原作‘称’（器具），后期为避免混淆，多专写作‘秤’。"
