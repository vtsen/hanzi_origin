  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从人，奇声，本义为斜靠着；“人”表意，描述人体的斜靠动作，“奇”表声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“靠着”引申为“依靠、仗恃”，用于抽象依赖，多见于中古及后世用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "物理上倾斜‘靠着’引申为偏斜、歪斜，见于结构描述。"
