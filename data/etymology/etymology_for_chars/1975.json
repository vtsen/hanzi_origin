  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "从“步行”引申为“空手，无所持”。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从“空，无所获”引申出“白白地”。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“空”引申为“仅仅、只”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "由“步行随行”转义为“随从、弟子等随行之人”。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "从“门徒”扩大泛指为同一派系或信仰的成员。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "semantic_extension",
