      "evolution_type": "metaphor",
      "note": "古时以鸟类颈羽形象比喻人类长者的白发或形貌，产生‘老人’义。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
