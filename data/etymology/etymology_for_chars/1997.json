      "meaning": "腋下，腋窝。",
      "examples": [
        "胳谓之腋。——《广雅》",
        "胳，腋下也。——《说文》"
      ],
      "traditional_char": "胳"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "上肢，肩膀以下手腕以上的部分。又称“胳膊”、“臂”。",
      "examples": [
        "他的胳膊受伤了。",
        "伸出胳膊。"
      ],
      "traditional_char": "胳"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "牲畜的后胫骨。",
      "examples": [
        "介俎、脊、脅、胳、肺。——《仪礼·乡饮酒礼》",
        "膊、胳也。——郑玄注"
      ],
      "traditional_char": "胳"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "腋下与上臂之间的空隙，即胳肢窝。",
      "examples": [
        "他的汗从胳肢窝流出来。"
      ],
      "traditional_char": "胳"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "用手在别人身上抓挠，使其发痒而笑（多用于“胳肢”一词）。",
      "examples": [
        "小孩喜欢互相胳肢。"
      ],
      "traditional_char": "胳"
    }
  ],
