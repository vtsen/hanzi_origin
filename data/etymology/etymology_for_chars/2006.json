{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代飨食、宴饮。",
      "examples": [
        "卿，飨食也。——《说文》"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代高级官员或爵位的名称，如六卿、九卿。",
      "examples": [
        "五大夫三卿。——《史记》",
        "卿大夫豹饰。——《管子》"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "将领，军队中高级将佐的称谓。",
      "examples": [
        "卿无共御，立军尉以摄之。——《左传》"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古代对人的尊称或敬称，如‘荀卿’。",
      "examples": [
        "司马迁名士列传：‘荀卿，赵人。’"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "古代表达亲昵、爱慕的称呼，常用于夫妇、情人间。",
      "examples": [
        "卿但暂还家，吾今且报府。——《玉台新咏》"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 5,
      "part_of_speech": "pronoun",
      "meaning": "古代君对臣、上级对下级、或尊长对晚辈的称谓，亦为谦称‘你’、‘您’。",
      "examples": [
        "今卿廓开大计，正与孤同。——《资治通鉴》"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "吉祥、庆贺的意思，通“庆”。",
      "examples": [
        "百工相和而歌卿云，帝乃倡之曰：卿云烂兮。——《尚书大传》"
      ],
      "traditional_char": "卿"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "卿仲辽（《后汉书》人物）"
      ],
      "traditional_char": "卿"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "卿为会意字，甲骨文字形像二人向食之形，表达‘飨食’的意象，逐步引申为高级官名与尊称。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘宴饮’引申为主宴之人，即履行重要职务的高级官员，殷商周初即有此用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "官职用法扩展至将帅军官，见于先秦文献。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "官职名引申为对有德者、贤达者的敬称，战国汉代已见。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由尊称引申为亲密关系中的爱称，特指夫妇、情人间。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "grammaticalization",
      "note": "高级官员词汇转变为尊称代词，用于上对下、长辈对晚辈等。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "官名发展为姓氏，反映职业世袭、身份固化。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘卿’假借为‘庆’，“卿云”等专名场合见于古籍，为通假用法。"
    }
  ]
}