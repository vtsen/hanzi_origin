    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "因创伤或病变导致的身体疾患，本义即因受伤或生病而造成的不适。",
      "examples": [
        "疾，病也。——《说文》",
        "讳疾忌医。——《韩非子·喻老》"
      ],
      "traditional_char": "疾"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "一般的痛苦或苦难。",
      "examples": [
        "疾苦",
        "救民于水火之疾。"
      ],
      "traditional_char": "疾"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "疼痛。",
      "examples": [
