      "original_sense_index": 0,
      "note": "“閲”形声字，从门，说省声，表示在门内清点事物。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "“閱”后起繁体，形声字，与“閲”本义对应，后多借为“察看”之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
