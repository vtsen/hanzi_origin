  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "“煩”会意字，从页表示头部，从火表示发烧，表示头部发热的不适。本义即是头痛发热。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由身体发热、头痛的不适，引申为心理上苦闷、急躁。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由心情烦恼引申为事物繁杂，使人生烦。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由心烦意乱引申为他人被搅扰而感烦。"
