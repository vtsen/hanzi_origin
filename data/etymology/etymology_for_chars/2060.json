{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "使东西着火；点燃或者焚毁物品。",
      "examples": [
        "焚烧垃圾。",
        "大火烧毁了房屋。"
      ],
      "traditional_char": "燒"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用火或高温使物体发生变化或加热。",
      "examples": [
        "烧水。",
        "烧饭。",
        "烧焊金属。"
      ],
      "traditional_char": "燒"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "用火加热的烹饪方法。",
