    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "洞察，明察。",
      "examples": [
        "洞烛其奸",
        "烛理明辞"
      ],
      "traditional_char": "燭"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "灯泡亮度单位的通俗称呼，如“十五烛的灯泡”。",
      "examples": [
