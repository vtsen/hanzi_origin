{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "水边，河岸，江岸。",
      "examples": [
        "率彼淮浦。",
        "江浦之橘。",
        "浦，濒也。"
      ],
      "traditional_char": "浦"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "小河流入江海的入口处或江河与支流的汇合处。",
      "examples": [
        "至广陵寻亲旧，还遇风，停浦中。",
        "入漵浦余儃佪兮，迷不知吾所如。",
        "还为越王禽于三江之浦。"
      ],
      "traditional_char": "浦"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "指池、塘、江、河等水面。",
      "examples": [
        "浦月（谓江河水中之月）"
      ],
      "traditional_char": "浦"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "指人工修建的向江河排水的沟渠、水渠。",
      "examples": [
        "循古遗迹，或五里七里而为一纵浦，又七里或十里而为一横塘。"
      ],
      "traditional_char": "浦"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "可停泊船只的水湾、港汊。",
      "examples": [
        "把船快放入浦里去躲这大风。"
      ],
      "traditional_char": "浦"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "明有浦源。"
      ],
      "traditional_char": "浦"
    }
  ],
  "formations": [
    {
