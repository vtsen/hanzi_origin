  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "由‘消除、灭掉’引申为‘溶化，散失’；‘消’作使事物消失之意。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "‘消除’、‘消散’引申为‘消磨时间’，用于耗尽、度过某过程。"
