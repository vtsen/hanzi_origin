  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘流’为会意字，从水，从㐬，表示水流动的状态。本义为水流动。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由水的流动引申为事物如水流般移动或飘散。汉代已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由水流引申为信息、名声等的传播。"
    },
    {
      "source_index": 0,
      "target_index": 3,
