  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "賓（宾）为形声字，金文从“冖”（屋形）、“贝”（财物），冥声，本指贵客。甲骨文字形会意，表示屋下有贵客，所以为‘客人’之义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由贵宾、客人引申为特指担任典仪之人，古代‘傧相’之义，见于先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由‘宾客’引申为‘服从、归顺’，即如宾客般臣服，用作动词，常见于古文。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "由‘宾’作为名词用作姓氏，常见于汉姓演变。"
    }
  ]
