  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“能包容物体”转喻为“心胸能容人”，汉至近现代用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“能盛纳”引申为“允许、准许”，意为空间上的容纳到抽象上的容忍。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由“含纳”引申为“容貌、仪表”，意为外在呈现的状态，汉代后见。"
