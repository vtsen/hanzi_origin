{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "依照文字念出声音，如读书、阅读。",
      "examples": [
        "读书",
        "朗读诗文",
        "宣读通知"
      ],
      "traditional_char": "讀"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "看书，阅览，不一定出声。",
      "examples": [
        "速读",
        "默读小说",
        "阅读新闻"
      ],
      "traditional_char": "讀"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "求学，上学。",
      "examples": [
