{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "恳切、诚恳；形容教诲耐心、反复、不倦的样子",
      "examples": [
        "诲尔谆谆。",
        "谆，告晓之熟也。",
        "不必谆谆。",
        "谆谆教导。"
      ],
      "traditional_char": "諄"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "忠诚、忠厚、诚恳的样子",
      "examples": [
        "谆谆忠谨之貌也。",
        "吾嫉惰游者，怜子愚且谆。"
      ],
      "traditional_char": "諄"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "佐、辅助",
      "examples": [
        "以谆赵鞅之故。",
        "曾孙蒯聩以谆赵鞅之故。"
      ],
      "traditional_char": "諄"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "繁琐冗长，絮叨（引申义）",
      "examples": [
        "閒文之諄，三十倍於正文，非佛語也。"
      ],
      "traditional_char": "諄"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘諄’为形声字，从言，亶声，本义为恳切教诲；声符异写为‘谆’，简化字沿用。"
    }
  ],
  "edges": [
    {
