  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声兼会意字，从阜表地形，从臽表示坠入坑中并表声，金文作人掉进陷阱状，本义即“掉进，坠入”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以动作“掉进”所入之物引申为“用以捕兽的坑”，早见先秦用例。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从掉进、沉入引申至“凹进”的状态描述。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "将“掉入陷阱”引申为“被设计陷害”，取比喻义。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "“失守、沦陷”本义为被攻入如同陷落比喻地失守。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "由“陷坑”引申为“缺点”，即整体中之“坑洞”，为比喻义。"
    }
  ]
