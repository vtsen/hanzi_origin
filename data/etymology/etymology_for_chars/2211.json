{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "一年生水生草本植物，浮生于水面，叶片平展，根须下垂，俗称“浮萍”、“青萍”、“紫萍”。",
      "examples": [
        "浮萍无根，飘泊不定。",
        "池塘中长满了萍。"
      ],
      "traditional_char": "萍"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "比喻飘泊不定的生活或行踪。",
      "examples": [
        "萍踪无定。",
        "萍水相逢。"
      ],
      "traditional_char": "萍"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“萍”为形声字，从艹，平声，表示水草植物，最初本义即指浮萍植物。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以浮萍无根漂浮之特性比喻人生、行踪飘泊不定，多见于先秦以来文学语境。"
    }
  ]
