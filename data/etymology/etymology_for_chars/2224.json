{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "梧桐树，一种落叶乔木，木材质轻且坚韧，可用于制作乐器、棺材等。",
      "examples": [
        "鳳翱翔于千仞兮，非梧不棲。",
        "暢，臼以椈，杵以梧。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "屋梁上两头起支架作用的斜柱，支柱。",
      "examples": [
        "梧，柱也。",
        "桁梧複疊，勢合神離。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "支撑、用作支柱。",
      "examples": [
        "炳乃故升茅屋，梧鼎而爨。",
        "梧，支也。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古地名，如河南荥阳县附近、江苏徐州西部。",
      "examples": [
        "晋师城梧及制。",
        "楚国，县七…梧。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "违逆，抵触，与“迕”通。",
      "examples": [
        "甚多疏略，或有抵梧。",
        "梧讀曰迕，相觸迕也。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "魁梧，体貌高大雄伟。",
      "examples": [
        "余以为其人计魁梧奇伟。",
        "魁梧，丘墟壮大之意。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "春秋田敬仲的后裔。见汉王符《潜夫论·志氏姓》。"
      ],
      "traditional_char": "梧"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "乐器名，敔，古代打击乐器。",
      "examples": [
        "梧，乐器。",
        "樂器椌楬也。敔或作梧。"
      ],
      "traditional_char": "梧"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从木，吾声。本义为梧桐树，即树名。形声字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以梧桐树干直立，比喻支柱。汉代已见。"
    },
