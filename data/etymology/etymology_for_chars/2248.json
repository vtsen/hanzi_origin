      "meaning": "题有字的横额牌匾，常挂于门上或墙壁上作为标志或装饰。",
      "examples": [
        "光荣匾",
        "门上悬挂着匾额"
      ],
      "traditional_char": "匾"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用竹篾编成、下底略圆而边框很浅的器具，多用于养蚕或盛放粮食等物。",
      "examples": [
        "养蚕要用匾",
        "匾里盛满了稻谷"
      ],
      "traditional_char": "匾"
    }
  ],
  "formations": [
    {
