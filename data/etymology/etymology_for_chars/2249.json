{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "由天空中水汽冷却凝结成的六角形白色结晶体，从空中飘落下来，称为雪。",
      "examples": [
        "雪花",
        "瑞雪兆丰年",
        "雪山",
        "大雪纷飞"
      ],
      "traditional_char": "雪"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "洗去、消除冤屈、耻辱等。",
      "examples": [
        "为国雪耻",
        "报仇雪恨",
        "平反昭雪"
      ],
      "traditional_char": "雪"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "擦拭（多用于古文）。",
      "examples": [
        "公雪涕而顾晏子",
        "雪泪"
      ],
      "traditional_char": "雪"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "姓氏。",
      "examples": [
        "雪芹",
        "雪涛"
      ],
      "traditional_char": "雪"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从“雨”表示自然现象，从“彗”表示扫除，兼作声旁，原意指空气中冷凝而落的冰晶。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "用本义的“雪”纯洁、覆盖、消除之意，引申为洗去仇恨、冤屈等。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由洗去引申为擦拭，多用于古文。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "由本义转为姓氏用法，常见于汉字。"
    }
  ]
}