  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从“虎”从“彡”，会意字，彡象形斑纹之文，表示虎皮上的条纹。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以虎身斑纹引申为文采、文饰；比喻义，西汉以后常见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "以斑纹代指虎，尤其是幼虎，古已有之。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由“显眼的虎斑”比喻事物显著、彰明；用作修饰意义，多见中古以后。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "从“显著”进一步比喻体格魁梧健壮，有现代色彩。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "由“文采鲜明”转为“明悟、使明白”，以文采象征开悟。出现于汉代文辞。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "function_word",
      "note": "以动物名称为姓，古代姓氏来源用法。"
    },
    {
      "source_index": 2,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "用虎、兽群形象比喻队伍集中威猛，古典小说、戏曲中见。"
    }
  ]
