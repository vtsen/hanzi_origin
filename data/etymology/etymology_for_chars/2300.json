      "part_of_speech": "adjective",
      "meaning": "高起，突起的样子；山势高耸。",
      "examples": [
        "崛，山短高也。——《说文》",
        "洪台崛其独出兮。——《文选·扬雄·甘泉赋》",
        "心山陵之高，非削成而崛起也。——王符《潜夫论·慎微》"
      ],
      "traditional_char": "崛"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "突出、兴起（如人才、武装势力等急速出现）。",
      "examples": [
        "义军崛起于村野。",
        "泰山平地崛起。"
      ],
      "traditional_char": "崛"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从山，屈声。本义为山高突起，符合‘山’作意符，‘屈’作声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由山势高突起喻指人物、势力等异常突出或突然兴起，属意义转移，见于中古及近现代使用。"
    }
  ]
