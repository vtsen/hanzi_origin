  "edges": [
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "耳饰因形似铁链，古以借指，见北史等，南北朝后固定。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "铁链撞击发声，喻金属声。中古文献有据。"
    },
    {
