{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "管乐器名，通常为竹制，有八孔，横着吹奏。",
      "examples": [
        "横吹其笛，入于大夏。",
        "他在吹笛子。",
        "长笛、短笛。"
      ],
      "traditional_char": "笛"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "发出尖锐响声的发音器具，如汽笛、警笛。",
      "examples": [
        "汽笛声响彻夜空。",
        "警笛拉响了。"
      ],
      "traditional_char": "笛"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从竹，由声。本义为竹管乐器，表义取“竹”，表声取“由”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "19世纪后期随西方科技传入，“笛”由传统乐器名称引申为能发出类似响声的现代机械发音器。"
    }
  ]
}