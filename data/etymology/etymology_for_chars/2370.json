  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘力大、气势大’转为‘动作突然猛烈’，形成副词义。多见于近现代汉语。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "勇猛引申为对待事物非常严厉，见于古汉语及成语用法。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由‘勇猛’引申为‘凶暴’，常用于描述凶恶的动物或性格。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "用以称呼一种古代体型巨大、力量威猛的哺乳动物‘猛犸’，以其性格特征命名。"
