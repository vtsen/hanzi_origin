  "formations": [
    {
      "formation_type": "loan_character",
      "original_sense_index": 1,
      "note": "‘着’为‘著’的俗体，原作‘著’，小篆体表接触、附着，后通用作‘着’。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "由‘接触、附着’引申为‘穿着（衣服）’，古今皆有用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘附着’义扩展为‘使附着于…’，即使动用法。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "接触到下落，引申为‘下落、来源’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由‘接触’义衍生为‘派遣’，公文语。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "grammaticalization",
      "note": "接触引申为书面命令语气助词。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "‘着’为被动，‘受到’接触，感受到某种状态。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "物体受热到达燃点即‘着火’，由接触而作燃烧义。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "接触‘睡眠’，引申为‘入睡’。"
    },
    {
      "source_index": 1,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "结果接触目标，‘达到’、‘有结果’。"
    },
    {
      "source_index": 1,
      "target_index": 10,
      "evolution_type": "semantic_extension",
      "note": "使别人接触物体，引申为‘使、派’。"
    },
    {
      "source_index": 1,
      "target_index": 11,
      "evolution_type": "reanalysis",
      "note": "棋子‘下着’，后引申为‘计策’等。"
    },
    {
      "source_index": 1,
      "target_index": 12,
      "evolution_type": "semantic_extension",
      "note": "放某物于某处即使接触。"
    },
    {
      "source_index": 1,
      "target_index": 13,
      "evolution_type": "conversion",
      "note": "由动词‘得着’到感叹应和语。"
    },
    {
      "source_index": 1,
      "target_index": 14,
      "evolution_type": "grammaticalization",
      "note": "从‘附着’虚化为进行助词。"
