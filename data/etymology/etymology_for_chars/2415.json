  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，“氵”表意（水），“奄”表声，本义指浸没于水之中。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由整体被水浸没扩展到局部被液体（如汗）浸湿。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "以知识渊博如被水淹没为喻，引申为“渊博”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由被水淹没引申为“滞留、久留”，如被阻碍难以前进。"
