  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，斩声。本义为水名。‘水’表义，‘斩’表声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由水流渐进、流动引申为“慢慢地、一点一点地”，汉代以后普及。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "‘渐’在表示发展变化时，可引申为‘程度加剧’。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "从水相关，由水的流动引申为‘疏导’水流。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由水的作用，引申为‘浸泡、沾染’。"
    },
    {
      "source_index": 0,
      "target_index": 5,
