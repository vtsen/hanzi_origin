  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由水中鱼聚之处引申为人或事物聚集之地，比喻义，常见于先秦及《左传》。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“深潭”喻为事理、知识等之深奥或渊博，见于《汉书》等。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "由名词用作姓氏，中国古代姓氏多取地名或自然物。"
