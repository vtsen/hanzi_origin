  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "“淵”本为会意字，古形象深水潭和打漩涡的水，外围为水，内为漩流。简化字“渊”承袭其义。"
    }
