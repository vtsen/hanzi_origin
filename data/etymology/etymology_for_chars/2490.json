      "meaning": "宽大，宽裕，宽松；不紧。",
      "examples": [
        "宽兮绰兮，倚重较兮。（《诗经·卫风·淇奥》）",
        "～～有余"
      ],
      "traditional_char": "綽"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "舒缓，柔美，姿态优美。",
      "examples": [
        "柔情绰态，媚于语言。（曹植《洛神赋》）",
        "绰约"
      ],
      "traditional_char": "綽"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "外号，诨名。",
      "examples": [
