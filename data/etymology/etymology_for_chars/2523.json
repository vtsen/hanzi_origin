  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以“高兴、快乐”之情指代可庆贺的事件，尤其婚事，早见于汉代。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "“有喜”用可庆事转指妇女怀孕，语义转移见于日常俗语。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“高兴、快乐”引申为“爱好、喜欢”，情感向好物倾斜。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由“喜欢”引申为“适于”，类比生物对某种环境的“喜欢”。"
    }
