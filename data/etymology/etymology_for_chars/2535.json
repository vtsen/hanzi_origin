{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用双臂抱拢，把人或物搂在怀里。",
      "examples": [
        "把孩子搂在怀中",
        "母亲轻轻地搂着女孩"
      ],
      "traditional_char": "摟"
    },
    {
      "index": 1,
      "part_of_speech": "measure_word",
      "meaning": "指用两臂能抱住的东西的量词。",
      "examples": [
        "一搂粗的大树",
        "抱了一搂柴火"
      ],
      "traditional_char": "摟"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "用手或工具把东西聚集起来。",
      "examples": [
        "搂柴火",
        "搂麦子"
      ],
      "traditional_char": "摟"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "搜刮财物。",
      "examples": [
        "搂钱",
        "把账搂一搂"
      ],
      "traditional_char": "摟"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "往怀里的方向拨或拢起。",
      "examples": [
        "搂火",
        "把裤子搂起来"
      ],
      "traditional_char": "摟"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "形声字，从手，娄声，表示用手拉拢、聚集；摟为繁体，搂为简体。"
    }
  ],
  "edges": [
    {
      "source_index": 2,
      "target_index": 0,
      "evolution_type": "metaphor",
      "note": "由“用手聚集”比喻为“用手臂抱拢”，语义转向更加具体的搂抱动作。"
    },
    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由动作义抽象为量词用法，表示一次用手臂能抱起的量。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "“搂聚”引申为“搜刮”，多指财物。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "从“聚拢”引申为“拨、提起之意”，如搂火、搂起裤腿。"
    }
  ]
}