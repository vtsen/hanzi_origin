      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由朝廷义引申为王朝时代。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "以国名指民族。"
