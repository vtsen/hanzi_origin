    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "花椒（芸香科，落叶灌木或小乔木）的植株，本义。",
      "examples": [
        "焚椒兰也。——唐·杜牧《阿房宫赋》",
        "琴鼓之山，其木多榖柞椒柘。——《山海经·中山经》"
      ],
      "traditional_char": "椒"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "花椒的果实，常用于调味或入药。",
      "examples": [
        "貽我握椒。——《诗经·陈风·东门之枌》",
        "芼以椒与橙。——唐·韩愈《初南食貽元十八協律》",
        "椒盐、椒酒"
      ],
      "traditional_char": "椒"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "胡椒的植株及其果实。",
