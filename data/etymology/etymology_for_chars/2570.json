  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从木，叔声，表示与树木相关，初指花椒树。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_narrowing",
      "note": "由指花椒树引申为其果实，先秦已见。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以椒木丛生高处比喻山顶，汉代及后世文献可见。"
    },
    {
      "source_index": 0,
      "target_index": 5,
