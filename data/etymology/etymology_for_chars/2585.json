  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "会意兼形声字，从“酉”表示与酒有关，从“甘”表意兼表声，本义为‘酒喝得很畅快’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由酒喝得畅快引申为事物盛美、浓烈，唐宋起见。"
