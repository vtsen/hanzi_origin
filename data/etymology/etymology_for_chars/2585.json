{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "酒喝得很畅快或尽兴的状态；未醉未醒之间的心情舒畅。",
      "examples": [
        "酒酣，上击筑自歌。",
        "代君至酒酣。",
        "半酣呼鹰出远郊。",
        "酒酣气益振。"
      ],
      "traditional_char": "酣"
    },
    {
