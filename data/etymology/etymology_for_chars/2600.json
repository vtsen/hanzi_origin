  "edges": [
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "《诗经》中因“雅”为重要乐歌类别名称，由鸟名转用为乐歌的名称。"
    },
    {
      "source_index": 7,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "“雅”作为朝庭乐歌，逐渐引申为“标准、规范”。"
    },
    {
      "source_index": 7,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由典雅的乐歌引申为“高尚、美好、不俗”。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "“高雅、美好”引申为“平素、素来”（称赞品行等的固定用法）。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "“美好”极致引申为“极、甚”，用作副词。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由平素、素来之意引伸作对交往、往来的记载。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "美好、高尚之意转用于酒器之名，酒量称‘雅量’。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "古同“鸦”，直接作为同义异体使用。"
    }
  ]
