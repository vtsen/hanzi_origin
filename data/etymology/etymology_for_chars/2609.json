{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "地位高的人或长辈给予地位低的人或晚辈财物，奖赏，赏赐。",
      "examples": [
        "赏金",
        "赏赐",
        "奖赏",
        "赏罚分明"
      ],
      "traditional_char": "賞"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "因爱好某种东西而观看、欣赏。",
      "examples": [
        "赏花",
        "赏月",
        "赏析",
        "赏心悦目"
      ],
      "traditional_char": "賞"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "认识到人的才能或作品的价值而给予重视，赞赏。",
      "examples": [
        "赏识",
        "赞赏"
      ],
      "traditional_char": "賞"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "敬辞（如请别人参加某事）：赏脸，赏光。",
      "examples": [
        "请您赏光",
        "给个赏脸"
      ],
      "traditional_char": "賞"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [],
      "traditional_char": "賞"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "古同“尚”，尊重。",
      "examples": [
        "礼赏有加"
      ],
      "traditional_char": "賞"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从贝，尚声，本义为赏赐、奖给。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由“给予奖赏”推广到“赏玩、欣赏”，产生于文化艺术欣赏行为。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“欣赏事物”进一步引申为“赞赏才能、价值”。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "function_word",
      "note": "“赏”作为敬辞用于社交场合请对方参与时，带有礼貌色彩。"
    },
