      "meaning": "瞳仁不正，斜视",
      "examples": [
        "睐，目瞳子不正也。《说文》",
        "力代反，目不正"
      ],
      "traditional_char": "睞"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "旁视，斜着看",
      "examples": [
