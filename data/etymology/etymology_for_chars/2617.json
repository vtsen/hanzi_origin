  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由古代炊器泛指为一般锅具，时间在中古以后。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "因鼎被认定为国之重器，转为政权象征，见于先秦。"
