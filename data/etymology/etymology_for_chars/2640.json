    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "鸟名，即杜鹃，一种常见的鸟，也称为郭公、杜宇、布谷、子规。",
      "examples": [
        "啼鵑苦竹裏，爭道不如歸。",
        "桐葉落而天下驚秋，聽鵑聲而知氣運。",
        "時適二月，子鵑鳥鳴，故蜀人悲子鵑鳥鳴也。"
      ],
      "traditional_char": "鵑"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "映山红，即杜鹃花。",
      "examples": [
        "蜀國曾聞子規鳥，宣城還見杜鵑花。"
      ],
      "traditional_char": "鵑"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从鸟，肙声，本意为鸟名杜鹃。"
    }
  ],
  "edges": [
    {
