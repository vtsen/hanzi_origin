      "meaning": "喉咙、舌，有时泛指说话的器官（如“喉舌”）。",
      "examples": [
        "报纸是人民的喉舌",
        "以为喉舌之任"
      ],
      "traditional_char": "喉"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "比喻险要的地方或咽喉要地。",
      "examples": [
        "居庸关乃扼守京城之喉",
        "此地为川蜀咽喉"
      ],
      "traditional_char": "喉"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古代指国家的重臣，特指御史等谏官（比喻为国家代言人）。",
      "examples": [
        "谏官为朝廷之喉",
        "国家之喉，须忠直之士担任"
      ],
      "traditional_char": "喉"
    }
  ],
