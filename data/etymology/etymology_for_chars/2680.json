    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "方形的盛物竹器，后泛指用竹篾、柳条、荆条等编成的盛东西的器具。",
      "examples": [
        "筐子",
        "载筐及筥。",
        "老王右手拿着一束散发着清香的梅花，到了门口，左手提着那筐沉甸甸的广柑，一步一步吃力地走去。"
      ],
      "traditional_char": "筐"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "（借）小簪。",
      "examples": [
        "柱不可以摘齿，筐不可以持屋。"
      ],
      "traditional_char": "筐"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "同“匡”，框架，某些限定形状、大小的物件的外框。",
      "examples": [
        "大夫不里椁，士不虞筐。"
      ],
      "traditional_char": "筐"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "方正、方形。",
      "examples": [
