      ],
      "traditional_char": "筐"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "盛满，装满。",
      "examples": [
        "筐泽泻以豹鞹兮。"
      ],
      "traditional_char": "筐"
    }
  ],
