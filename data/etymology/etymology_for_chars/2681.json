{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "整齐的竹简，古时书写材料。",
      "examples": [
        "等，齐也。——《说文》",
        "令史治簿书，司等简。"
      ],
      "traditional_char": "等"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "数量、程度相同，或地位相同。",
      "examples": [
        "平等",
        "等同"
      ],
      "traditional_char": "等"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "表示数量或程度的级别。",
      "examples": [
        "等级",
        "等次"
      ],
      "traditional_char": "等"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "台阶（级数）的级。",
      "examples": [
