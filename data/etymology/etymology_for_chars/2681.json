  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "会意兼形声字：从竹，表示与竹简有关；寺，表示读音，并带行政分等之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从简册平齐，引申为事物或人的齐平、同等，汉代已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由同等引申为等级、级别，汉以降常见。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "级别、顺序用在“台阶级数”含义上。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "同等、分类，引申为种类。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "用于指一群同等的人，语法化为人称代词。"
    },
    {
      "source_index": 4,
      "target_index": 6,
      "evolution_type": "grammaticalization",
      "note": "由类别义语法化为列举的煞尾助词。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "平齐，引申为时间等候。具体机制有争议，故判为semantic_shift。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "等待动作引申为“到某时、待到”语气用法。"
