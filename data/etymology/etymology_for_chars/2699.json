{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "春秋时期的国名，汉代置皖县，在今安徽省潜山县北。",
      "examples": [
        "秋七月，妖巫李广等群起据皖城。——《后汉书·光武帝纪》",
        "顾祖禹《读史方舆纪要》：‘禹贡’扬州之域，春秋时为皖国，战国属楚，秦属九江郡，二汉属庐江郡。"
      ],
      "traditional_char": "皖"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "安徽省的简称，源于安徽西部的皖山（天柱山）。",
      "examples": [
        "皖派（清代经学派系之一。）",
        "皖公山（又名潜山、皖山、天柱山）"
      ],
      "traditional_char": "皖"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古地名，用于地理实体，如皖口、皖北、皖城、皖南、皖县等。",
      "examples": [
        "攻没皖城。——《后汉·马援传》",
        "今桐城曰皖江、皖桐。"
      ],
      "traditional_char": "皖"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "明亮的样子或明星。古义。",
      "examples": [
        "明星也。——《广韵》",
        "明皃。——《集韵》"
      ],
      "traditional_char": "皖"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘皖’为形声字，从白，完声。‘白’表明与白色或明亮相关，‘完’为声符。最初用于地名皖，为春秋时国家名。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由皖国、皖山延伸为安徽省的简称，因地名被广泛借用，约始于清代。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "国名、山名之‘皖’被用为相关地理实体名称，如皖口、皖城、皖江等，用作一般地名。"
    },
    {
      "source_index": 3,
      "target_index": 0,
      "evolution_type": "unknown",
      "note": "‘皖’作‘明亮’及‘明星’之义源流不详，或与‘白’本义有关，后转用于地名。两义之间联系存疑，历史资料未详。"
    }
