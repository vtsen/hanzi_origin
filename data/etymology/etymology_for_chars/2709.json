  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "小篆形象兽足，下为田，示兽踏地之印。后义派生丰富。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘兽足更替踏印’喻为轮流、更替。汉至六朝出现"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "grammaticalization",
      "note": "‘轮流’义抽象为表示次数的量词，早见先秦文献"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "‘轮流’转指外族、外国，原指非中心区域‘轮番更替者’引申为边地民族"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "‘次数’引申为‘倍数’，现代用法如‘翻番’"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由次数量词引申为片、枚、张等计量单位"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "借音通‘藩’，义为篱笆，见先秦典籍"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "phonetical_loan_shift",
      "note": "借音通‘蕃’，义为茂盛，见汉碑文"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由基本名词义引申作地名用字，如‘番禺’"
    }
  ]
}