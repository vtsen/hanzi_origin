  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从言，从羊，会意；“言”表表达，“羊”古为吉祥象征，合指吉祥美好。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“吉祥”引申为善良仁爱的品质，古今多见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“善良”进一步指代具体的善行。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“善良”泛化为“良好、高明”的意思。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "“高明良好”引申为“关系友好”。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "因熟悉而被认为是美好，易于亲近。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由“良好”引申为“办好某事”的用法。"
    },
    {
      "source_index": 3,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由“高明良好”引申为“擅长”。"
    },
    {
      "source_index": 3,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "由“好”转为“认为...为好”，即“赞许”。"
    },
    {
      "source_index": 3,
      "target_index": 9,
      "evolution_type": "grammaticalization",
      "note": "“好”衍生出“好好地”，副词用法。"
    },
    {
      "source_index": 3,
      "target_index": 10,
      "evolution_type": "semantic_shift",
      "note": "“好”引申为容易、易于；如“善变”。"
    },
    {
      "source_index": 0,
      "target_index": 11,
      "evolution_type": "conversion",
      "note": "美好吉祥作为姓氏用法，常见汉姓。"
    }
  ]
