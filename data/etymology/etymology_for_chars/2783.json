  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘竄’为会意字，从穴，从鼠，表示老鼠进出洞穴，引申为躲藏、逃跑。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘窜’为简化字，从穴，‘串’声，以形声方式简化‘竄’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "逃遁引申为被流放，古代常以贬谪为‘窜’。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由‘乱跑’引申为‘改动’，比喻对文字随意改动。"
