  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“连接”引申为“类别”，多物或人因连接形成类。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "家族、亲族为有血缘联系的群体，由连接义发展。"
