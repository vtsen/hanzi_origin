  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "本义为上车，象形，下部为足，上部为豆形，表示登上。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“上”引申为用脚踩踏，古今通用，义项扩展"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“登高”引申为“名登册”，即记录在册，唐宋起常用"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "庄稼成长到‘高’、成熟，借用高升之意"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "grammaticalization",
      "note": "“登时”（立即）由“即时登上”发展而来"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "进用、推崇，来自“升”之意"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "踩踏引申为方言“穿（鞋靴）”"
