      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "因蓬草生长茂盛，引申为草木茂盛旺盛之意。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "草木丛生之状，引申作量词用于同类成团之物。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "借用蓬的形象用于星宿名、古地名。"
    },
    {
      "source_index": 0,
