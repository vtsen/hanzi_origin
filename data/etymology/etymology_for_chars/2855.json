      "note": "形声字，从艸，逢声，最初表示草名（蓬蒿）。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由蓬草名称引申为果实的外苞，如莲蓬等，因形似而得名。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "用蓬草编门，引申为简陋住宅，用组成材料名代实体。"
    },
