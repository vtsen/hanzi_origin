{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "多年生草本植物，叶似柳叶，遇风飞旋，亦称“飞蓬”或“蓬蒿”。",
      "examples": [
        "彼茁者蓬。——《诗·召南·驺虞》",
        "蓬生麻中，不扶自直。——《荀子·劝学》"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "某些植物果实的外苞，如莲蓬。",
      "examples": [
        "乃复蒂下生蓬，蓬中结实，亭亭独立，犹似未开之花。——明·李渔《闲情偶寄·种植部》"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "以蓬草编成的门，引申为简陋的住处。",
      "examples": [
        "花径不曾缘客扫，蓬门今始为君开。——杜甫《客至》",
        "蓬户瓮牖。"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "散乱，蓬松，多形容头发或草木。",
      "examples": [
        "蓬头垢面。",
        "蓬发。——《西山经·玉山》",
        "头蓬不暇梳。"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "茂盛，旺盛的样子。",
      "examples": [
        "蓬蓬（茂盛、蓬勃的样子）。",
        "其叶蓬蓬。——《诗·小雅》"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 5,
      "part_of_speech": "measure_word",
      "meaning": "用于蓬状、成团、成丛的草木等。",
      "examples": [
        "一蓬竹子。"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "星名，蓬星；亦为古地名。",
      "examples": [
        "妖星，一曰蓬星。——《晋书·天文志》"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "汉蓬球，北海人。"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 8,
      "part_of_speech": "onomatopoeia",
      "meaning": "象声词，形容声响。",
      "examples": [
        "蓬的一声。——鲁迅《呐喊·阿Q正传》"
      ],
      "traditional_char": "蓬"
    },
    {
      "index": 9,
      "part_of_speech": "noun",
      "meaning": "仙山蓬莱的简称。",
      "examples": [
        "从安期兮蓬莱。——《楚辞·伤时》"
      ],
      "traditional_char": "蓬"
    }
  ],
