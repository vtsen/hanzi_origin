{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "祭祀时把祭品恭敬地呈上，献祭。",
      "examples": [
        "以牲畜献于祖先。",
        "牲而献之。——《周礼·太祝》"
      ],
      "traditional_char": "獻"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "恭敬地送给（多指对上级或重要场合）：奉献、贡献、捐献、献身、献礼。",
      "examples": [
        "为祖国献出青春。",
        "捐资献校。"
      ],
      "traditional_char": "獻"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "表现出来（如才能、技巧、媚态、丑态等）：献技、献艺、献媚、献丑。",
      "examples": [
        "他在晚会上献艺。",
        "当众献丑。"
      ],
      "traditional_char": "獻"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古代指贤者，特指熟悉掌故的人：文献。",
      "examples": [
        "博览群书可成文献之士。",
        "文献资料。"
      ],
      "traditional_char": "獻"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘獻’为会意兼形声字，从犬，鬳声，犬表示祭祀进献之物，初义为献祭。"
    }
  ],
  "edges": [
    {
