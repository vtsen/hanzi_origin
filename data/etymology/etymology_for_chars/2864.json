    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "落叶灌木，亦称“牡荆”或“荆”，枝干坚劲，可做杖",
      "examples": [
        "言刈其楚。《诗·周南·汉广》",
        "楚，丛木也。一名荆。《说文》",
        "不流束楚。《诗·王风·扬之水》"
      ],
      "traditional_char": "楚"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代的刑杖，或学校扑责学生的小杖，也指用杖打",
      "examples": [
        "夏楚二物，收其威也。《礼记·学记》",
        "民无箠楚之忧。《汉书·汉延寿传》",
        "楚扑长如笴。《仪礼·乡射礼》"
      ],
      "traditional_char": "楚"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "中国古代周、战国时期的诸侯国名，疆域广泛，亦泛指今湖北、湖南一带及人事物",
      "examples": [
        "楚天。《楚地的天空》",
        "四面楚歌。",
        "樊姬，楚国之夫人也。"
      ],
      "traditional_char": "楚"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古国“楚”区域的代称，特指湖北、湖南省，尤指湖北省",
      "examples": [
        "楚剧。",
        "他来自楚地。",
        "楚人。"
      ],
      "traditional_char": "楚"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "痛苦，酸辛，悲痛",
      "examples": [
        "慷慨含辛楚。——陆机诗",
        "妇始楚而谢，终泣而对曰。《柳毅传》"
      ],
      "traditional_char": "楚"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "清晰，鲜明，整洁，齐整，华美",
      "examples": [
        "笾豆有楚。《诗·小雅·宾之初筵》",
        "衣裳楚楚。《诗·曹风·蜉蝣》",
        "楚楚可爱。"
      ],
      "traditional_char": "楚"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏",
      "examples": [
