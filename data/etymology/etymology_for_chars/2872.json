  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 7,
      "note": "形声字，从贝，剌声。‘贝’表示与财物得益有关，‘剌’为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 7,
      "target_index": 0,
      "evolution_type": "semantic_shift",
      "note": "由‘得益；赢利’转为‘依赖、仰赖’的意思，表示受益于某人或事。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "依赖引申为赖着不走，强调行为上的依附。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由依赖转义为拒不承认，取其‘拒绝切断依附关系’之意。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "不讲理、赖账行为指向为人刁钻泼辣、不讲道理。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由不承认发展为诬赖、诬陷他人。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "amelioration",
      "note": "行为不端进一步引申为事物不好、劣质。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "unknown",
      "note": "姓氏多由地名、官职或美德转借，无确切演变关系，属于专有名词用法。"
