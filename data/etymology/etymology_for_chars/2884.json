{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "云层放电时发出的巨响（即打雷的声音），或指伴随闪电出现的自然现象。",
      "examples": [
        "雷声隆隆。",
        "雷电交加。",
        "春雷乍响。"
      ],
      "traditional_char": "雷"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "军事用的爆炸武器，如地雷、水雷等。",
      "examples": [
        "布雷。",
        "排除地雷。",
        "鱼雷发射。"
      ],
      "traditional_char": "雷"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "雷池，古地名，位于今安徽省望江县，泛指限制范围。",
      "examples": [
        "不敢越雷池一步。"
      ],
      "traditional_char": "雷"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "姓氏。",
      "examples": [
        "雷先生。"
      ],
      "traditional_char": "雷"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "甲骨文为象形，下部似闪电，上圆点似雷声，小篆转为会意，从雨表天气现象，形声兼会意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "爆炸武器因爆炸声响巨大类比雷声，自清末近代始见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "地名“雷池”因地多雷暴（或因形声），后引申为比喻不可逾越的界限。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "自然现象之名用于姓氏，古已有之。"
    }
  ]
