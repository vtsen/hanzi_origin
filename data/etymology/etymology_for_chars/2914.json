    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "高跷（戏剧舞蹈中绑在脚上的木制道具）。",
      "examples": [
        "張碧秀滿頭珠翠，踩着蹺，穿一身繡花的粉紅緞子衫褲在臺上扭來扭去。"
      ],
      "traditional_char": "蹺"
    },
