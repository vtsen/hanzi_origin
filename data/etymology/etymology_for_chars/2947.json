  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘辵’表示行动，‘舌’表示言语，合表示在行动中陈述自己的诉求，原指诉讼。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“陈述诉求”引申为“告别时陈述辞别之言”。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“告别”引申为“请求离职、请辞”。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“辞让”发展出“推托、回避”之义。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "reanalysis",
      "note": "从主动请求离开到被动“被辞退”。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "诉讼需用较正式语言，引申为“辞，言辞”。"
    },
    {
      "source_index": 5,
      "target_index": 6,
      "evolution_type": "conversion",
      "note": "由“言辞”转为动词“言、讲、告诉”。"
    },
    {
      "source_index": 5,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由“言辞”为文体名“辞赋”。"
    }
