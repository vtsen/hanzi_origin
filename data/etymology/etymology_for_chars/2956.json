  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从“土”（意符，表与器物破损有关），“攴”声，最早用于指瓦器等物体的缺损。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由指器物破损扩展为泛指一切破坏、损害，汉代及以后。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_narrowing",
      "note": "泛指破坏进一步具体到用火烧毁，常用于焚烧，明确见于后世用法。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
