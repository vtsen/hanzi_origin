  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从㐭（表示领取）与禾（指粮食）会意，表示赐予谷物。禀为稟的俗字，繁体稟正体。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“赐谷”引申为一般意义的赐予、赋予，用于天赋等抽象概念。东汉以后普及。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“赐予”引申为“承受”、“领受”外来的（如命令、天命）含义。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "领受、承受进一步引申为“遵循、奉行”。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由领受、奉行官方命令，引申为“向上级报告”办理事务。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "动词“禀告”转为“报告文书”名词用法。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由“赐谷”实物操作引申为贮藏谷物之处，即“粮仓”。古书‘禀、廪’通用。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "原意中赐予的谷物本身，转为‘粮食’通称。"
