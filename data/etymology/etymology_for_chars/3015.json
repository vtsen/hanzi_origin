  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘滚’为形声字，从水，衮声。本义为大水奔流貌，‘水’表意，‘衮’表声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由水奔流转喻为风烟等翻腾，文献多见于后世。"
    },
    {
      "source_index": 0,
      "target_index": 2,
