  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘蔑’为会意字，从艸从戍，艸表示与眼相关，戍象形补充眼受伤无神之义"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 5,
      "note": "‘衊’为形声字，从血，蔑声，用于表示涂血相关行为"
    }
