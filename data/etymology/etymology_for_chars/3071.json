  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "周代采邑多以自然地名（如地草丛生）为名，借用地名为国名。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "占卜所用之大龟常采于野地，借野草为地称，转指龟。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "因地名来源于草丛，古州、山名多沿用地名。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由国名引申为姓氏，得姓于国。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "‘蔡’作为流放地，进而引申为流放动词用法。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "‘蔡’通‘杀’、‘减’，疑与赋税减免和地名的职能有关，用作动词。"
