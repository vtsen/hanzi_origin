{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "往上跳，跳跃。",
      "examples": [
        "踊，跳也。——《说文》",
        "踊躍用兵。——《诗·邶风》",
        "曲踊三百。——《左传·僖公二十八年》",
        "三踊于幕庭。——《左传·哀公八年》",
        "辟踊，哀之至也。——《礼记·檀弓》"
      ],
      "traditional_char": "踴"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "登上，高出，超出。",
      "examples": [
        "踊于棓而窥客。——《公羊传·成公二年》",
        "景公为路寝之台，成，而不踊焉。——《晏子春秋》"
      ],
      "traditional_char": "踴"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "（物价等）上涨，升起，激涌，冒出。",
      "examples": [
        "物踊腾粜。——《史记·平准书》",
        "金银之价为踊上。——《北史》",
        "踊冶（金属熔液在炉内沸滚）"
      ],
      "traditional_char": "踴"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古代受过刖刑的人的鞋。",
      "examples": [
        "屨贱踊贵。——《左传·昭公三年》",
        "踊贵而屦贱。——《韩非子·难二》"
      ],
      "traditional_char": "踴"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从足，勇声，足表示与脚的动作相关，‘勇’表音，最早指跳跃。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由跳跃引申为‘上、登上’，因为跳的动作可以导致升高。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由‘跳跃’动作引申为‘物价等高涨、升腾’，为抽象化比喻。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由跳动特征转指受刖刑者的特殊鞋，因行走或动作异于常人。"
    }
  ]
