  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由特定味美的鱼名称，转为表示味道鲜美。战国-汉代。"
    },
    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘味美’引申为‘新鲜’、‘不陈’。中古以后民间口语普及。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_narrowing",
      "note": "从‘味美’转向专指‘味美的食物’。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_narrowing",
      "note": "进一步专指‘鱼虾等水产食物’。现代用法。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "味美让人愉悦，引申为色彩明亮有光彩。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "unknown",
      "note": "作为民族名‘鲜卑’之‘鲜’，具体语源关系不明。"
