{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "情绪激昂，意气高昂不平。",
      "examples": [
        "慨当以慷，忧思难忘。——曹操《短歌行》",
        "虎踞龙盘今胜昔，天翻地覆慨而慷。——毛泽东《人民解放军占领南京》"
      ],
      "traditional_char": "慷"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "感愤，感慨。",
      "examples": [
        "感慨当以慷，忧思难忘。",
        "慨而慷。"
      ],
      "traditional_char": "慷"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "性格豪爽，大方，爽快。",
      "examples": [
        "为人慷慨大方。",
        "慷爽（大方；爽快）"
      ],
      "traditional_char": "慷"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "慷慨，不吝啬，乐于用财物帮助别人。",
      "examples": [
        "慷他人之慨。",
        "慷慨解囊。"
      ],
      "traditional_char": "慷"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从心，康声，会意表示内心激昂的情绪。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由形容词“激昂”到动词“感慨、激昂”，古今皆见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "借由激昂情绪引申为性格豪爽与直率，汉魏六朝以降。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由豪爽引申为待人慷慨、不吝啬，见于中古至近代。"
