      "meaning": "广阔的天空",
      "examples": [
        "腾驾碧寥，指麾沧溟。（范成大《望海亭赋》）",
        "今欲使天下寥廓之上。（《汉书·邹阳传》）"
      ],
      "traditional_char": "寥"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "深远；高远",
      "examples": [
        "羸马隐山道，悠然远思寥。（元·耶律楚材）",
        "寥，深也。（《广雅》）"
      ],
      "traditional_char": "寥"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "凭依、依赖（假借为“赖”，通“聊”）",
      "examples": [
