  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从宀表示房屋、空虚，廖声；本义为空虚、寂静，古作廫。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“空虚”引申为“稀少、冷落”，为空虚状态下人的感受。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "用“寥”形容广阔天空，取其空旷、深广之意。"
    },
