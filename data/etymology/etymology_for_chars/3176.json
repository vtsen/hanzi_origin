    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "空虚，寂静；空旷辽阔",
      "examples": [
        "寂兮寥兮，独立而不改。（《老子》）",
        "恣心目之寥朗。（孙绰《游天台山赋》）",
        "乃入于寥天。（《庄子·大宗师》）",
        "四面竹树环合，寂寥无人。（《小石潭记》）"
      ],
      "traditional_char": "寥"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "稀少，稀疏，冷落，孤单",
      "examples": [
        "疏星寥落。",
        "寥若晨星。",
        "寥寥无几。",
        "晓星正寥落。（谢元暉《京路夜发诗》）"
      ],
      "traditional_char": "寥"
    },
    {
