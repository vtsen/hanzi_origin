{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "measure_word",
      "meaning": "次，回，指走动或某种动作的次数",
      "examples": [
        "走一趟",
        "火车一天两趟",
        "我看你白跑这一趟"
      ],
      "traditional_char": "趟"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "行，行列",
      "examples": [
        "两趟桌子",
        "只隔一趟街"
      ],
      "traditional_char": "趟"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "步子，步伐",
      "examples": [
        "赶趟儿（赶得上，来得及）",
        "跟不上趟"
      ],
      "traditional_char": "趟"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "套，套路，特指戏曲中表演骑马的一套程式动作",
      "examples": [
        "趟马",
        "打过几趟拳"
      ],
      "traditional_char": "趟"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "从浅水中走过、踩、踏、翻土",
      "examples": [
        "趟水过河",
        "趟地",
        "趟出一条路"
      ],
      "traditional_char": "趟"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "遇，碰（方言用法）",
      "examples": [
        "都让我们李家人给趟上了"
      ],
      "traditional_char": "趟"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从走，尚声。本义为『次，回』，即一次移动。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由表示次数的量词，引申为『行，行列』。逻辑为一趟一趟排列。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由『一次移动』引申为『步伐，步子』。步为一趟。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由动作的次数再引申为『套路』。如表演中一套动作称一趟。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "量词转动词，由走动次数转为实际『走、踩、踏』等动作。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "从『走、踩中遇到』引申为『遇上、碰到』，为北方方言用法。"
    }
  ]
}