  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从三石，会意，表示众多石头。‘三’为多数意符，典型六书会意字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由堆积如山的石头引申为高大或俊伟，多见于文人用法。"
