  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字。从日，兼表晒晒之意，古文亦作曝；兼有声旁麃，表发散。‘曝’可视作‘暴’的异体，后分化。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由‘晒’引申为‘显露’。常见于暴露、暴露无遗等。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由日晒猛烈引申为‘猛烈、迅急’（如暴风、暴雨），见春秋战国时期用法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由猛烈引申为‘凶狠残酷’（如暴君、残暴），多为情感态度色彩。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "‘猛烈’引申表示人的脾气性格猛烈、易冲突。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "猛烈发展——引申为任意损害、糟蹋。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "猛烈、鼓动——引申为鼓起、突出。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "猛烈——引申为不畏强暴、勇猛徒手搏击。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "function_word",
      "note": "本义转用为姓氏。"
