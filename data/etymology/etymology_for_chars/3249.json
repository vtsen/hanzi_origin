      "part_of_speech": "noun",
      "meaning": "青蛙、蟾蜍、蠑螈等两栖动物的幼虫，头圆大，尾细长，生活在水中，最后变成蛙或蟾蜍，俗称“蝌蚪”",
      "examples": [
        "池塘里有许多蝌蚪。",
        "科斗，活东。"
      ],
      "traditional_char": "蝌"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "形状如蝌蚪的文字，指古代字体的特殊名称，如蝌蚪文、蝌蚪书。",
      "examples": [
        "孔安国皆云科斗文字是也。",
        "蝌蚪文字"
      ],
      "traditional_char": "蝌"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，虫为意符，科为声符，表示昆虫类水生幼虫，最初指蝌蚪。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "因古文字形似蝌蚪，故用以称特殊字体。见汉儒注疏。"
