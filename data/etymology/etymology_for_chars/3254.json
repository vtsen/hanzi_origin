{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古时作为仪仗用的一种旗帜，常为垂筒形，饰有羽毛、锦绣，用于军事指挥、仪仗行列等。",
      "examples": [
        "立幢为号，指挥部队。",
        "车马不疲弊于远路，旌旗不乱于大泽，雄骏不创寿于旗幢。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "支撑帐幕、伞盖、旌旗的木竿，后借指帐幕、伞盖、旌旗。",
      "examples": [
        "幢竿高耸。",
        "持幢执纛以为仪仗。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "刻着佛号或经咒的石柱，称“经幢”或“石幢”。",
      "examples": [
        "寺庙前立有经幢。",
        "幢高数丈，铭刻佛经。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古代军队的编制单位，百人为幢。",
      "examples": [
        "幢主率本幢出征。",
        "古代编制，百人一幢。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "张挂在舟、车上的帷幔或伞盖，用以遮阳、装饰。",
      "examples": [
        "舟车加盖青油幢。",
        "施之车盖童童然，以隐蔽形容也。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "量词，用于房屋等高大、独立的建筑物，如“一幢大楼”。",
      "examples": [
        "一幢大楼耸立在路旁。",
        "五七幢稻草高似金塔。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "形容愚昧无知。",
      "examples": [
        "幢愚（愚昧）。",
        "憧憧（憨愚无知的样子）。"
      ],
      "traditional_char": "幢"
    },
    {
      "index": 7,
      "part_of_speech": "adverb",
      "meaning": "形容影子摇晃的样子（如“～～”）。",
      "examples": [
        "人影幢幢。",
        "树影幢幢随风动。"
      ],
      "traditional_char": "幢"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从巾，童声，表示为仪仗所用的旗帜之意，巾表旗帜，童为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由旗帜引申为支撑旗帜的竿及帐幕、伞盖、旌旗本身。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "佛教传入后借用‘幢’指寺庙立的经幢、石幢。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由‘幢’的作为分军仪仗的旗号，用作百人编制单位名。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由仪仗旗帜的形制，引申指车、舟上的帷幔、伞盖等。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "近现代汉语用幢作量词，喻物体高大直立，因旗幢、石幢等形象。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "语义不详，或为‘憧憧’、‘幢’引申，指愚昧无知。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "旗幢飘动引申为影子摇晃的样子。"
    }
  ]
