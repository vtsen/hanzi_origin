      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "“豫”通“预”，由参与泛化到介入、预先等，属语音通用。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "“豫”因豫州（古九州之一）故成为河南省别称，地名专用。"
