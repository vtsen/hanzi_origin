  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "大象体态安然欢畅，引申为快乐、欢喜之意，早在先秦即已出现。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由快乐引申为安闲、舒适。常见于先秦、两汉用例。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "unknown",
      "note": "“豫”用作参与，与象意相关机制未详，学界或认作假借/通用。"
    },
