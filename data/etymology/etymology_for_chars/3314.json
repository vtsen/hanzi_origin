{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "缠绕，围绕；环绕；绕道而行",
      "examples": [
        "肠纷纭以缭转兮。",
        "林麓薮泽陂池连乎蜀汉，缭以周墙，四百余里。",
        "再缭四寸。"
      ],
      "traditional_char": "繚"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用针斜着缝缀，缲边",
      "examples": [
