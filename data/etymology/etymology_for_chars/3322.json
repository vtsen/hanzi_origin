{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "一种草本植物，即‘赖蒿’。",
      "examples": [
        "薛、莎、青薠。——司马相如《子虚赋》"
      ],
      "traditional_char": "薛"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用莎草编制的雨衣。",
      "examples": [
        "六韬蓑薛䔲笠，谓以莎草为雨衣也。"
      ],
      "traditional_char": "薛"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "春秋时国名。战国时为齐所灭。地在今山东省滕县南。",
      "examples": [
        "滕侯、薛侯来朝。——《春秋·隐十一年》"
      ],
      "traditional_char": "薛"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "薛氏有三：奚仲之后，以国为氏。——《通志·氏族略》"
      ],
      "traditional_char": "薛"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘薛’为形声字，从艸，𡶫声。𡶫音借表声，艸部指与草有关。最初用以指一种草本植物。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以该植物名借指用其制作的雨衣，属原材料指成品的转喻。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以地多‘薛草’或得名于草，进而用为地名，再用为国名。地名用草名命名常见于古地名习惯。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "由国名而为氏族名，常见于‘以国为氏’的中国姓氏发展机制。"
    }
  ]
