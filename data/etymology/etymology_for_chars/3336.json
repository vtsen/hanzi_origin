      "meaning": "从睡眠状态中恢复清醒，或还未入睡。",
      "examples": [
        "他刚刚醒来。",
        "如梦方醒。"
      ],
      "traditional_char": "醒"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "酒醉、麻醉或昏迷后神志恢复正常状态。",
      "examples": [
        "醒酒。",
        "他醉了一夜，现在终于醒了。"
      ],
      "traditional_char": "醒"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "泛指头脑由迷糊而清楚。",
