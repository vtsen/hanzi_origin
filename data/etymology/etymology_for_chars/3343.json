      ],
      "traditional_char": "踱"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "忽前忽退，不按顺序移动（与跮踱、躇等义相近）",
      "examples": [
        "跮踱，乍前乍却。",
        "與“躇”同，越級，不按階次。"
      ],
      "traditional_char": "踱"
    }
  ],
  "formations": [
