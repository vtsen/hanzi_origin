{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "践踏；以足踩踏。",
      "examples": [
        "余骑相蹂践争项王。",
        "蹂屍輿廝，係累老弱。",
        "蹂，履也。——《广雅》"
      ],
      "traditional_char": "蹂"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "欺压、侵袭、侵害。",
      "examples": [
        "蹂强翼弱，名四驰也。",
        "賊大出，掩追騎，還蹂王師。"
      ],
      "traditional_char": "蹂"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "搓揉、揉擦（通“揉”）。",
      "examples": [
        "或簸或蹂。",
        "毛 傳： “或簸糠者， 或蹂黍者。”"
      ],
      "traditional_char": "蹂"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "兽足踏地的痕迹，兽迹。",
      "examples": [
        "獸足蹂地也。——《说文》",
        "爾雅：貍貛貉醜其足蹂，其跡厹。"
      ],
      "traditional_char": "蹂"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从足，柔声，本义为践踏，足为义符，柔为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“踩踏、践踏”引申为“欺压、侵袭”，比喻用权力或暴力压迫。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "从以足践踏“压揉”转为用手搓揉，产生语音通假与词义转移（蹂=揉）。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由踐踏的动作引申指留下的蹤跡，即兽迹。"
    }
  ]
