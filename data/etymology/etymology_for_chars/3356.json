{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "禾的名称，一种谷类作物。",
      "examples": [
        "穆，禾也。——《说文》"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代宗庙排列的序列名，父系为昭，子系为穆，指右边。",
      "examples": [
        "辨庙祧之昭穆。——《周礼·小宗伯》",
        "只见贾府人分了昭穆，排班立定。——《红楼梦》"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "恭敬、庄严、肃敬。",
      "examples": [
        "于穆清庙。——《诗·周颂·清庙》",
        "穆穆皇皇。——《诗·大雅·假乐》",
        "肃穆（严肃恭敬）"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "和美、温和、和睦。",
      "examples": [
        "穆如清风。——《诗·大雅·烝民》",
        "而与夏侯尚不穆。——《三国志·苟彧传》",
        "穆清（和睦清明）"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "幽深、远大、幽微。",
      "examples": [
        "穆眇眇之无垠兮，莽芒芒之无仪。——《楚辞》"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "清澈、清净、清明。",
      "examples": [
        "天色澄穆，亦惟此时也。——宋·苏轼《答王敏仲》"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "静默、不语（通“默”）。",
      "examples": [
        "于是吴王穆然，俛而深惟。——东方朔《非有先生论》"
      ],
      "traditional_char": "穆"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "汉有穆生。"
      ],
      "traditional_char": "穆"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从禾，㣎声，形声字，表禾名，后引申诸义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由禾之美好形象，引申为庄严恭敬。常见于先秦典籍。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "庄严恭敬进一步扩展为温和、和睦。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由庄严肃穆引申出幽深远大。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由庄重肃穆引申为清澈、清净。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "由肃敬静重引申为静默。部分用作“默”的通假。"
    },
    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以庄重肃穆之意用于宗庙的排列名称。"
    },
    {
      "source_index": 2,
      "target_index": 7,
      "evolution_type": "function_word",
      "note": "抽取词义作姓氏用。中国古代人名用字习惯。"
    }
  ]
}