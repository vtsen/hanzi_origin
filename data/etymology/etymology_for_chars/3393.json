  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从艸，貌声，本义为小、幼；“艸”表义指草之小弱，“貌”表音兼意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘小、弱’引申为‘被轻视’，后转为主动‘轻视他人’。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "‘小’引申为‘远’（微小难见，表距离遥远）；和“邈”通假，见古文。"
    }
