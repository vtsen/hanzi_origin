{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "木名。木质坚韧，可用于制家具、乐器、车轴等。古书中所称“檀”多指黄檀、青檀、紫檀等，有时泛指坚硬良木。",
      "examples": [
        "坎坎伐檀兮。——《诗经·魏风·伐檀》",
        "树檀以五月生叶，后来彼春荣之木。——《论衡·状留》"
      ],
      "traditional_char": "檀"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "檀香。即香木“栴檀”的简称，为常绿乔木，木质坚硬，有香气，可制香料、器物或入药。",
      "examples": [
        "文均析缕，香发海檀。——《谢赉扇启》",
        "男女身上常涂香药，以檀麝等香合成。——《真腊风土记》"
      ],
      "traditional_char": "檀"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "浅红色，浅绛色。",
      "examples": [
        "檀口香腮。",
        "艳多烟重欲开难，红蕊当心一抹檀。——罗隐《牡丹》"
      ],
      "traditional_char": "檀"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "指与佛教相关之布施，施主。如“檀越”。",
      "examples": [
        "檀越（檀主，檀那。施主）",
        "檀那国（佛语。指没有邪恶凶杀，人们都好善乐施的理想国度）"
      ],
      "traditional_char": "檀"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "春秋鲁有檀弓。见《礼记·檀弓上》"
      ],
      "traditional_char": "檀"
    }
  ],
