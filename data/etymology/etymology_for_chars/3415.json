    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "禾本科植物聚生在茎顶端的花和果实，如麦穗、稻穗等，也泛指穗状花序。",
      "examples": [
        "田里麦穗金黄。",
        "稻穗饱满。",
        "玉米的花穗。"
      ],
      "traditional_char": "穗"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用丝线、布条或纸条等扎成的、挂起来往下垂的装饰品。",
      "examples": [
        "灯笼穗儿很漂亮。",
        "流苏穗。"
      ],
      "traditional_char": "穗"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "中国广东省广州市的别称。",
      "examples": [
