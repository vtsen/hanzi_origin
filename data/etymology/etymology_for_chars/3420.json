{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "三纠绳。原指用三股绳子纠成的标记物（古时用以作为符号或记号）。",
      "examples": [
        "三纠为徽。《说文》：‘徽，三纠也。’"
      ],
      "traditional_char": "徽"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "标志，符号，如国徽、校徽、徽章等。",
      "examples": [
        "中国国徽。",
        "他胸前戴着校徽。"
      ],
      "traditional_char": "徽"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "琴弦的标记，古琴上用以定音的记号，共十三徽。",
      "examples": [
        "古琴十三徽。",
        "抚琴需知徽位。"
      ],
      "traditional_char": "徽"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "美好的。",
      "examples": [
        "徽号（美好的名号）。"
      ],
      "traditional_char": "徽"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "地名。徽州，今安徽省歙县。简称“徽”。",
      "examples": [
        "徽墨。",
        "徽州古城。"
      ],
      "traditional_char": "徽"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从糸，表示与丝线、绳子有关，‘微’作声旁。本作‘三纠绳’的意思。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由三纠绳引申为一般的标志、记号，因三纠绳古时常作符号之用。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由实际的三纠绳借喻为古琴上标记琴徽的位置，有固定的符号作用。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "amelioration",
      "note": "标志逐步有美好、赞美之意，转指‘美好’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由徽章、标记转指地名‘徽州’，以徽为区域的称号或象征。"
    }
  ]
