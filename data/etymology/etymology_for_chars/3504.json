      "meaning": "小木桩，用于栓系、挂物等（今作“杙”）",
      "examples": [
        "鸡栖于弋为榤，凿垣而栖为塒。《尔雅·释宫》",
        "以钩弋压下枝，令着地。《齐民要术》"
      ],
      "traditional_char": "弋"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "系有绳子的箭，用于射猎飞鸟",
      "examples": [
        "矰弋机而在上兮，罻罗张而在下。《楚辞·九章·惜诵》",
        "孟冬鸟至，王以□弋。《穆天子传》"
      ],
      "traditional_char": "弋"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "用带绳的箭射猎飞鸟（泛指射猎）",
      "examples": [
        "弋凫与雁。《诗·郑风·女曰鸡鸣》",
        "弋白鹄。《史记·司马相如传》",
        "夫弓弩毕弋机变之知。《庄子·胠箧》"
      ],
      "traditional_char": "弋"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "取，占据，夺取",
      "examples": [
        "非我小国敢弋殷命。《书·多士》",
        "观危国过君而弋其能者。《管子·侈靡》"
      ],
      "traditional_char": "弋"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "禽鸟",
      "examples": [
        "十二月，鸣弋。弋也者，禽也。《大戴礼记》",
        "炙三弋、五卵。《晏子春秋》"
      ],
      "traditional_char": "弋"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "黑色",
      "examples": [
        "身衣弋绨。《汉书·文帝纪》",
        "弋，皁也。《汉书·文帝纪赞注》"
      ],
      "traditional_char": "弋"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏",
      "examples": [
        "美孟弋矣。《诗·鄘风·桑柔》",
