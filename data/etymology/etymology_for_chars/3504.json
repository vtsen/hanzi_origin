      ],
      "traditional_char": "弋"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，甲骨文字形，表示小木桩，类似现代“杙”，“丿”象折木锐端插于地；后指挂物、系物之用。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由木桩扩展为系物之物，进一步指系有绳子的箭。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由名词“系绳箭”转为“用弋箭射（猎）”的动词义。先秦已见用法。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由射猎猎物引申为一般意义上的“取、占有”。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "因用弋箭射鸟，借指禽鸟本身，《大戴礼记》等文献可证。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "unknown",
      "note": "“弋”通“黓”，指黑色，具体语音或文化联系不详。《汉书》有相关用法。"
    },
    {
      "source_index": 0,
      "target_index": 6,
