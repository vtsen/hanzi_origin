{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "组成《易》卦的长短横道，阳为“—”，阴为“--”，三爻为一卦，六爻为全卦，象征交错、变化。",
      "examples": [
        "爻，交也。象易六爻，头交也。——《说文》",
        "爻者，言乎变者也。——《易·系辞上》"
      ],
      "traditional_char": "爻"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "《易经》中卦爻的辞文，省称“爻”，即爻辞。",
      "examples": [
        "虽抱《中孚》爻，犹劳见锦诗。——谢灵运《初发石首城》",
        "《乾》之爻，在初者曰‘潜龙勿用’。——韩愈"
      ],
      "traditional_char": "爻"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "指交错、变动、错杂的状态或形象。",
      "examples": [
        "爻分（交错分开）",
        "爻错（交叉错杂）"
      ],
      "traditional_char": "爻"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "同“效”，效法、模仿或功用（古用法，见于今文《易》系辞、广雅）。",
      "examples": [
        "爻也者，效天下之动者也。——《易·系辞下》",
        "爻，功也。或作效、傚等。"
      ],
      "traditional_char": "爻"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，形似两‘乂’交错，表示卦中的交错横道，交错与变动为基本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由具体的卦爻形象发展为泛指交错、变动的状态，先秦至汉。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由“爻”作为卦象记号，转指“爻辞”即每一爻的卦辞。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "“爻”假借为“效”，出现义项‘效法、功效’，多见于古文、训诂文献。"
    }
  ]
