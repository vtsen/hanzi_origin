  "formations": [
    {
      "formation_type": "unknown",
      "original_sense_index": 0,
      "note": "“卞”字未见于《说文解字》原条；较早见于甲骨、金文，结构及造字原理无定论，可能为会意或转注；传世文献首义多释为‘法度’，故以此为原义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由‘法度’（严厉、规范）引申为‘性格急躁’之意，反映规范严格与性格急促的语义转化；常见于春秋战国时代。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "‘卞’作徒手搏斗，或系由‘严厉的法律、规则’引申为‘严格的比试或比赛’。亦有说法为异文转用，语源暂看作转义。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "synecdoche",
      "note": "以‘卞’泛指的规范/制度，借用为地名，或为地以法命名之例。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "地名转为姓氏，中国姓氏常由地名而来，见于周代后。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘卞’借用于‘弁’，因形近音通，在古代典籍中互通写用，如‘小弁’‘小卞’。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘卞’偶作‘辨’‘辩’的通假，属音近假借，特定语境中出现。"
