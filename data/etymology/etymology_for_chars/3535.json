  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "从一，不声，表示大、广大之意，为会意或指事构形，强调“一”之上为广大。《说文》释为大，学界多认为古文字与“大”相关。"
    }
