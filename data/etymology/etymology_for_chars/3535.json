  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由“大”的本义引申为尊奉、承继，因奉之事必大。汉、晋及后世用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "grammaticalization",
      "note": "由“大”的意义虚化为连接上下文的连词，表结果或转折。先秦文献常见。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "由连词进一步虚化成无实义的助词，常置于句首或句中。多见于《书经》等古籍。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "由形容词“大”转用为姓氏。中国古姓多由美称、形容词转化。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "古文中以“丕”借为“不”，同音通假，见《书·金縢》。后世专用“不”。"
    }
