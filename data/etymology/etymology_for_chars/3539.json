      "index": 2,
      "part_of_speech": "verb",
      "meaning": "特指对牲畜等的呵斥或使令。",
      "examples": [
        "尊客之前不叱狗。",
        "齐大夫诸子有犬，犬猛不可叱，叱之必噬人。",
        "叱！叱！羊起！（《神仙传》）"
      ],
      "traditional_char": "叱"
    },
    {
      "index": 3,
      "part_of_speech": "interjection",
      "meaning": "呵斥声、呼喝声（象声词或感叹词）。",
      "examples": [
        "叱！避！无怛化！（《庄子·大宗师》）",
        "叱的一声，吹灭了灯。"
      ],
      "traditional_char": "叱"
    }
  ],
