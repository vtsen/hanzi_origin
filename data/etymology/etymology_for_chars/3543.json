      "part_of_speech": "adjective",
      "meaning": "草木茂盛的样子（同“芊”、“阡”）",
      "examples": [
        "稻栽肃仟仟，黍苗何离离。",
        "仟眠（草木茂盛的样子）"
      ],
      "traditional_char": "仟"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从人，从千，会意。本义为军中千人之长，表示千人为一组之首。"
    }
  ],
  "edges": [
    {
