      "part_of_speech": "adjective",
      "meaning": "支离无统绪、随意、没有主见或定见的言谈。",
      "examples": [
        "卮言日出，和以天倪。",
        "卮言（随和人意，无主见的言论）"
      ],
      "traditional_char": "卮"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "紫赤色的野生植物，亦称“栀子”。",
      "examples": [
        "巴蜀，地饶卮、姜、丹沙、石、铜、铁、竹木之器。"
      ],
      "traditional_char": "卮"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，形如古代盛酒的圆形器皿，底部带有节（卩），表示盛酒仪式的器物。"
    }
  ],
