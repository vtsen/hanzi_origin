{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "中国古代的一个少数民族名，居住在今西北一带，东晋时建立过前秦、后凉。",
      "examples": [
        "自彼氐羌。——《诗·商颂·殷武》"
      ],
      "traditional_char": "氐"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "星名，二十八宿之一，东方苍龙七宿的第三宿。",
      "examples": [
        "季冬之月旦氐中。——《礼·月令》",
        "氐四星，东方法之宿。——《史记·天官书》"
      ],
      "traditional_char": "氐"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "根本；根柢。",
      "examples": [
        "尹氏大师，维周之氐。——《诗·小雅·节南山》",
        "蔓根曰根，直根曰氐。——《说文》"
      ],
      "traditional_char": "氐"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "至；抵达。",
      "examples": [
        "氐者言万物皆至也。——《史记·律书》",
        "大氐皆遇告。——《汉书·礼乐志》"
      ],
      "traditional_char": "氐"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "低下，低头。后作“低”。",
      "examples": [
        "封君皆氐首仰给焉。——《汉书·食货志下》"
      ],
      "traditional_char": "氐"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "低；低廉。",
      "examples": [
        "其价氐贱减平者，听民自与市。——《汉书·食货志下》"
      ],
      "traditional_char": "氐"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "“氐”从‘氏’声，下加一横为地义初文，意为根本、根柢，与“柢”同源。"
    }
  ],
  "edges": [
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "根本有终极、到达之意，引申为“至”。汉代用法。"
    },
    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以“根本”寓意为天上某一星的位置是苍龙之‘根本’，形成星名用法。"
    },
    {
      "source_index": 2,
      "target_index": 0,
      "evolution_type": "synecdoche",
      "note": "民族名本义为‘本地’‘根本之地’，用地名或本源表示族群。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "借音义通假，“氐”音同“低”，后引申作低下。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由“低下”引申为“低廉”，如价格低之义。"
    }
  ]
}