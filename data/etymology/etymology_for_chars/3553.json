      ],
      "traditional_char": "汀"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "稀泥，泥浆。",
      "examples": [
        "汀濘，泥淖也。"
      ],
      "traditional_char": "汀"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "小水流或水清澈的样子。",
      "examples": [
