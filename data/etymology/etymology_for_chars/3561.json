{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代的一种帽子，常用作礼帽或武帽。如爵弁（文帽）、皮弁（武帽），后泛指帽子。",
      "examples": [
        "弁，冠也。周曰覍，殷曰吁，夏曰收。——《说文》",
        "突而弁兮。——《诗·小雅·甫田》",
        "王与大夫尽弁。——《书·金縢》"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古时男子二十岁行加冠礼称弁，以示成年。",
      "examples": [
        "未几见兮，突而弁兮。——《诗·齐风 ·甫田》"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古时武官（因武官佩戴皮弁），后专指低级武官。",
      "examples": [
        "武弁；马弁；弁目"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "放在前面、居首。",
      "examples": [
        "乃书是言以弁君为诗之端。——清·龚自珍《送徐铁生序》"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "书籍或长篇文章的序文、引言（如“弁言”）。",
      "examples": [
        "各立序论，以弁其端。——《唐诗品汇·总序》",
        "弁言"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "徒手搏斗。",
      "examples": [
        "试弁，为期门，以材为爱幸。——《汉书·甘延寿传》"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "急、敏捷。",
      "examples": [
        "弁行，剡剡起屦。——《礼记·玉藻》"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 7,
      "part_of_speech": "adjective",
      "meaning": "惊惧、害怕。",
      "examples": [
        "有烈风雷雨发屋折木之变，予甚弁焉，予甚栗焉。——《汉书·王莽传下》",
        "吏皆股弁。"
      ],
      "traditional_char": "弁"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "地名、姓氏等专用名词。",
      "examples": [
        "弁人有其母死，而孺子泣者。——《礼记·檀弓》",
        "弁嚴子为卫尉。"
      ],
      "traditional_char": "弁"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "《说文》认为本字象形，古文、篆文多有类似头戴帽子的形象，象人戴帽即冠。最初表帽帽之本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "成年礼需戴弁之帽，引申为加冠礼本身。出自古代社会习俗。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以服饰（皮弁）代指佩戴其的武官，为官职名称。用帽名作官名。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "帽子居首，引申为“在前、首位”，抽象义。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "卷首、文章开头，称为“弁言”，由“居首”义而生。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "unknown",
      "note": "词义联系不明，学界有分歧。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由戴帽（整束）引申为行事敏捷、动速。"
    },
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "“急”引申为“惊惧不安”，多见于文献中形容状态。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "unknown",
      "note": "用于人名、地名，属于专名用法，无明确语义演变路径。"
    }
  ]
