    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代指耕地用的农具，形状似木叉，有曲柄和犁头，用以松土。",
      "examples": [
        "耒，手耕曲木也。——《说文》",
        "揉木为耒。——《易·系辞》",
        "天子亲载耒耜。——《礼记·月令》"
      ],
      "traditional_char": "耒"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代称犁上的木把，或指耒耜的木质曲柄部分。",
      "examples": [
        "耒耨之所刺。——《庄子·胠箧》",
        "耜其柄，耜其刃。——《后汉书·章帝纪》"
      ],
      "traditional_char": "耒"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "犁的别称，泛指古代翻土的农具。",
      "examples": [
        "因释其耒而守株，冀复得兔。——《韩非子·五蠹》",
        "耕者必有一耒一耜一銚，若其事立。——《管子·海王》"
      ],
      "traditional_char": "耒"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "水名，耒水。",
      "examples": [
        "耒水，出桂阳柳县南山。——《水经》"
      ],
      "traditional_char": "耒"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "果实时垂下的样子，一说耕地多草。",
      "examples": [],
      "traditional_char": "耒"
    }
  ],
