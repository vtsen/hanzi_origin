{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代帝王、诸侯等在重要典礼时所持用的玉制礼器，多为上端呈三角形、下端方形的长条玉器，用作瑞信、符信。",
      "examples": [
        "有孚中行，告公用圭。",
        "孰为珪璋。",
        "司马牛致其邑与珪焉。",
        "圭币俎豆。"
      ],
      "traditional_char": "圭"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代测量日影的仪器“圭表”的组成部分，主要指放在地面上的横尺，配合竖杆测定节气。",
      "examples": [
        "土圭测景。"
      ],
      "traditional_char": "圭"
    },
    {
      "index": 2,
      "part_of_speech": "measure_word",
      "meaning": "古代容量单位，一升的十万分之一，也作极微小量的喻称。",
      "examples": [
        "圭撮涉于贫友，吝情动于颜色。",
        "量多少者不失圭撮。"
      ],
      "traditional_char": "圭"
    },
    {
      "index": 3,
      "part_of_speech": "measure_word",
      "meaning": "古代重量单位，十圭重一铢，二十四铢重一两，十六两重一斤。",
      "examples": [
        "十圭重一铢，二十四铢重一两。"
      ],
      "traditional_char": "圭"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "洁净、鲜明。",
      "examples": [
        "丹青之饰，暗昧不圭。"
      ],
      "traditional_char": "圭"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "三国魏有圭泰。"
      ],
      "traditional_char": "圭"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从重土，象征玉制礼器的端正形状，反映圭最初指代的古代玉器。"
    }
  ],
