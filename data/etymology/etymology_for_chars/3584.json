  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“芗”为形声字，从艸，乡声。形旁表草类，声旁表读音。最初本义为谷物的香气。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "“薌”为形声字，从艸，襄声。形旁表植物、香气，声旁表音。“薌”后演变为“芗”的繁体，也泛指香气。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从谷物的香气泛指调味芳香的草类。先秦文献可见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由谷物的香气转为泛指一切芳香气味。“薌”为通假字，意义扩大。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由香气引申为焚香、香火。多用于宗教仪式。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以香气引申为地名，指产香米之地等。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "“薌”借作“響”，由读音近似产生。用作声音义，见中古文献。"
    }
