  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "瓦器被用作打击乐器，由容器义引申为乐器义，至少见于秦汉。"
    },
    {
      "source_index": 0,
      "target_index": 2,
