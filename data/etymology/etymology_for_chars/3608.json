  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从人，仓声，形声字，初表示‘粗俗，鄙贱’。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘伧’为简化字，‘傖’为繁体，结构相同，义本一致。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由形容词转为指称特定粗鄙之人，古已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "名词义向对特定地域异乡人的蔑称扩展，魏晋以后流行。"
