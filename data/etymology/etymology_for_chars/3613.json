{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "斷足，砍掉腳；古代一種酷刑，把人的腳砍去。",
      "examples": [
        "昔卞和献宝，楚王刖之。",
        "刖五百。",
        "刖强鉏。"
      ],
      "traditional_char": "刖"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代一種把腳砍掉的酷刑。",
      "examples": [
        "王以和为诳，而刖其左足。",
        "今法有肉刑三：黥、劓、刖。"
      ],
      "traditional_char": "刖"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "割；砍斷。",
      "examples": [
        "嚴剛毋暴，廉而毋刖。",
        "根刖殘樹，華葉落去。"
      ],
      "traditional_char": "刖"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "危，危險或不穩固之狀。",
      "examples": [
        "再刖刖危。",
        "摇刖。"
      ],
      "traditional_char": "刖"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从刀，月声；表‘断足’之意，声音取自‘月’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "动词‘断足’转为具体刑名‘刖’名词，先秦法制语境。"
