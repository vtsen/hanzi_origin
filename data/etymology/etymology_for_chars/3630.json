    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "懺为形声字，从心，僉声；原本义为怒，心之激动。后为佛教用，与忏悔相关。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "简化字忏由懺简化而来，意符为心，声符为戔（源自僉）；佛教传入后主要用于忏悔语境。"
    }
  ],
