      "meaning": "地名，古地名，现用于县名或地名简称。",
      "examples": [
        "太原县。——《说文》。为今山西省祁县",
        "安徽省祁门县，湖南省祁阳县"
      ],
      "traditional_char": "祁"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "大，盛大。",
      "examples": [
        "其祁孔有。——《诗·小雅·吉日》",
        "资冬祁寒。——《礼记·缁衣》"
      ],
      "traditional_char": "祁"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "众多的样子，舒缓的样子。",
      "examples": [
        "春日迟迟，采蘩祁祁。——《诗·豳风·七月》",
        "被之祁祁。——《诗·召南》",
        "兴雨祁祁。——《诗·小雅》"
      ],
      "traditional_char": "祁"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
