    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "说话迟钝，口齿笨拙。",
      "examples": [
        "君子欲讷于言而敏于行。",
        "论物明辨谓之辩，反辩为讷。"
      ],
      "traditional_char": "訥"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "吞吞吐吐地说，结结巴巴地说。",
      "examples": [
        "只听得差拨口里讷出一句“高太尉”三个字来。"
      ],
      "traditional_char": "訥"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "忍而少言，寡言少语。",
      "examples": [
        "能威能怀，能辨能讷。",
        "刚、毅、木、讷，近仁。"
      ],
      "traditional_char": "訥"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "河豚腹中的脂肪。",
      "examples": [
        "腹中有白曰訥，有肝曰脂。訥最甘肥，吴人甚珍之，目为西施乳。"
      ],
      "traditional_char": "訥"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "指质直之言。",
      "examples": [
        "恶闻忠訥。"
      ],
      "traditional_char": "訥"
    }
  ],
