    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "殷商时代的诸侯国名，在今甘肃泾川县，为周文王所灭。",
      "examples": [
        "侵阮徂共。——《诗·大雅·皇矣》"
      ],
      "traditional_char": "阮"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "一种古老的弦乐器“阮咸”的简称，形似月琴。",
      "examples": [
        "红线，善弹阮。——《甘泽谣》",
        "大家比较技艺，拨琴阮，笙箫嘹喨。——《桃花扇·访翠》"
      ],
      "traditional_char": "阮"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "侄的代称，源于晋代阮籍与侄阮咸并有盛名。",
      "examples": [
        "贤阮",
        "阮家会"
      ],
      "traditional_char": "阮"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
