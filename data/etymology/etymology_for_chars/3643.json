  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从牛，从厶。本义是牛叫声，“厶”象气从口出，表示声音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "从牛叫声引申为“取，谋求”，本义渐淡化，汉代起有取利意。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "phonetical_loan_shift",
      "note": "古文中用作“麰”（大麦），属于音近假借。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "用为“眸”，假借通用，与本义无直接语义联系。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "用于“侔”，取相等或等同之义，音近通假。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "“牟”通“鍪”，即头盔，音近假借。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
      "note": "“牟”通“堥”，指土釜、器皿，音近假借。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "conversion",
      "note": "由本义或假借义发展为姓氏。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "由本义转用于地名。"
    },
    {
      "source_index": 8,
      "target_index": 9,
      "evolution_type": "conversion",
      "note": "地名用于国名、封号等。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "phonetical_loan_shift",
      "note": "“牟”通“模”，用于模样等义。"
    }
  ]
}