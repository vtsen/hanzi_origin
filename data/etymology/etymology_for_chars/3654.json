      "index": 1,
      "part_of_speech": "verb",
      "meaning": "（喻）丢脸或局面不能维持而失败",
      "examples": [
        "他一着不慎就坍台了。",
        "做事要谨慎，不能坍台。"
      ],
      "traditional_char": "坍"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘坍’为形声字，从土，音符‘难’。‘土’表意义，指泥土、土地相关，‘难’表音。造字本意为土地或建筑物坍塌。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "将物理意义上的崩塌比喻为事业、局面等失败，现代汉语常用。"
