    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，夬声，本义为‘挑出，挖出’，手表示与手的动作有关，‘夬’表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从‘挑出，挖出’扩展到‘挑开，撬开’，动作对象变化。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由挖出、挑出引申为在众多中挑选，采用事物筛选的抽象动作。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由实物挑出变化为揭露、揭发隐藏的事物，用于抽象揭示。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "从挑、挖动作泛化为戳、穿，即穿破某物而达内部。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由挖出之动作引申为用手分开、掰开的动作。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "以手指动作‘抉’指代扳指器具，即因用来挑动弓弦而得名。"
    }
  ]
}