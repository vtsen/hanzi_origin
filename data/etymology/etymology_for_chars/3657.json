      "meaning": "挑出，挖出（用手挑出物体或器官）",
      "examples": [
        "抉吾眼。——《史记·伍胥传》",
        "抉人之口。——《荀子》",
        "因自皮面抉眼，自屠出肠。——《战国策·韩策二》"
      ],
      "traditional_char": "抉"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "挑开，撬开",
      "examples": [
        "郰人纥抉之以出门者。——《左传·襄公十年》"
      ],
      "traditional_char": "抉"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "挑选，选取",
      "examples": [
        "先生之作，遇景入咏，不拘奇抉异。——皮日休《郢州孟亭记》"
      ],
      "traditional_char": "抉"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "揭发，揭示",
      "examples": [
        "抉破（揭破，戳破）；抉露（揭露）",
        "追抉宿疵，则是改过不足以补愆。——《唐·陆贽》"
      ],
      "traditional_char": "抉"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "戳，穿",
      "examples": [
        "以杙抉其伤而死。——《左传·襄公十七年》"
      ],
      "traditional_char": "抉"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "掰，用手使分开",
      "examples": [
        "那半个一人抉一块儿，分着吃了。——《新儿女英雄传》"
      ],
      "traditional_char": "抉"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "扳指。古代射箭时套在右手拇指上的器具，用以钩弦",
      "examples": [
