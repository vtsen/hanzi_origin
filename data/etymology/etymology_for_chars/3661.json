    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "芸香，一种芳香植物，叶互生，羽状深裂，可用作药材、避虫或置于书中防虫。",
      "examples": [
        "芸始生。——《礼记·月令》",
        "芸，芸草也，似目宿。——《说文》",
        "芸草可以死复生。——《淮南子·王说》"
      ],
      "traditional_char": "芸"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "油菜，又称芸薹，二年生草本植物，花黄色，种子可榨油。",
      "examples": [
        "芸苔，二年生草本植物，又叫“油菜”，花黄色，种子可榨油。"
      ],
      "traditional_char": "蕓"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "除去田间杂草，与“耘”同义。",
      "examples": [
        "植其杖而芸。——《论语·微子》",
        "父子夫妇终年耕芸。——《汉书·王莽传》"
      ],
      "traditional_char": "芸"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "书籍（因芸香能防虫，置于书中，故以“芸”称书或书斋）。",
      "examples": [
        "又如：芸帙（书籍。因芸香可驱蠹虫，书卷中多置之，故名）；芸窗（书斋。古人藏书用芸香避蠹虫，故借芸以称书斋）"
      ],
      "traditional_char": "芸"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "草木枯黄的样子。",
      "examples": [
        "苕之华，芸其黄矣。——《诗·小雅·苕之华》"
      ],
      "traditional_char": "芸"
    }
  ],
