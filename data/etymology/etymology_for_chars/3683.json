  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从𣎵（草），从子，表示草木极盛茂的样子，兼有人色突变之意。造字本义指草木茂盛或形态蓬盛，后各义分化。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由草木茂盛蓬勃之貌转喻为彗星芒光四射（形状似草木蓬盛），见先秦至汉典籍。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "analogy",
      "note": "草木蓬勃兴盛，借比人面色骤变，多记为“变色”，见《论语》。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "彗星古常被视为凶兆，象征灾乱，遂引申为悖乱、冲突之意；见春秋、汉晋诸天文志。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "面色突变亦可象征情绪或局势之混乱，辞义流变，宋以后多写作“悖”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "词汇转用为姓氏，在中国古代并常见。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "function_word",
      "note": "作为结构助词或构词成分，为语法化现象，极为少用，属于次生发展。"
    }
  ]
