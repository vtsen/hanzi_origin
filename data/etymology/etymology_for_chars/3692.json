      ],
      "traditional_char": "迓"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "同“讶”；会面、相遇",
      "examples": [
        "子迓续乃命于天。——《书·盘庚》",
        "跛者迓跛者。",
        "古本皆作讶。——《尔雅》"
      ],
      "traditional_char": "迓"
    }
  ],
