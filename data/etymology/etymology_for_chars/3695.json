{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代一种青铜制酒器，椭圆形，肚大口小，有盖和提梁，常用于盛放祭祀用之香酒“秬鬯”，为礼器。",
      "examples": [
        "卣，中尊也。——《尔雅》",
        "以秬鬯二卣。——《书·洛诰》",
        "秬鬯一卣，圭瓒副焉。——《三国演义》"
      ],
      "traditional_char": "卣"
    },
    {
      "index": 1,
      "part_of_speech": "measure_word",
      "meaning": "用作量词，指装有一定容量液体的卣器，一卣、二卣之类。",
      "examples": [
        "乃命宁予以秬鬯二卣。——《书·洛诰》",
        "赐秬鬯一卣，珪瓒副焉。——《北史·于谨传》"
      ],
      "traditional_char": "卣"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "“脩”的通假字，用为祭器名。",
      "examples": [
        "廟用脩。——《周禮·春官·鬯人》",
        "脩，讀曰卣。——郑注"
      ],
      "traditional_char": "卣"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，形如两耳带提梁的青铜酒器，反映其最初本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "grammaticalization",
      "note": "由器名引申作容量量词，见于《书·洛诰》等先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "phonetical_loan_shift",
      "note": "古籍中“卣”与“脩”音近，文献中有通假用法，如《周礼·春官》。"
    }
  ]
