      "index": 0,
      "part_of_speech": "interjection",
      "meaning": "用以促使对方注意的吆喝声，常见于对白或命令场合。",
      "examples": [
        "呔，狗奴！快些拿了头来，就放你去！——《说岳全传》",
        "‘呔！’ 羿仰天大喝一声，看了片刻；然而月亮不理他。——鲁迅《故事新编·奔月》"
      ],
      "traditional_char": "呔"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "（方言）指说话带外地口音。",
      "examples": [
        "他说话有点呔。",
        "这口音太呔了，听不懂。"
      ],
      "traditional_char": "呔"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“呔”从口，台声。口旁表示与语言或发声相关，台为声旁，本用于表示突然喝声。"
    }
  ],
  "edges": [
    {
