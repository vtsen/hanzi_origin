      "examples": [
        "清青城子《志异續編•某屠牛》：群吽不絕。",
        "牛鳴亦曰吽。"
      ],
      "traditional_char": "吽"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "狗争斗时发出的声音，亦作“吽牙”、“吽呀”。",
      "examples": [
        "東方朔傳：狋吽牙者，兩犬爭也。",
        "吽牙：狗爭鬥聲。"
      ],
      "traditional_char": "吽"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "佛教咒语中“六字真言”之一，为梵语Hum的对音，表示真言的结尾音。",
      "examples": [
        "唐慧琳《一切經音義》：吽，梵文真言句也。",
        "元張昱《輦下曲》：守內番僧日念吽，御廚酒肉按時供。"
      ],
      "traditional_char": "吽"
    }
  ],
