      "part_of_speech": "noun",
      "meaning": "崖岸，陡峭的山岩。",
      "examples": [
        "未始离于岑。——《庄子·徐无鬼》",
        "山陵岑，渊泉闳流。——《管子·宙合》"
      ],
      "traditional_char": "岑"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "高，高耸，尖锐，陡峭。",
      "examples": [
