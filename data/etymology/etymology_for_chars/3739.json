{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "使人信服，获得信任。",
      "examples": [
        "小信未孚，神弗福也。",
        "深孚众望"
      ],
      "traditional_char": "孚"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "信用，信任。",
      "examples": [
        "成王之孚，下土之式。"
      ],
      "traditional_char": "孚"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "孵化（鸟禽伏卵使雏生出）。",
      "examples": [
        "孚，卵孚也。",
        "孚育"
      ],
      "traditional_char": "孚"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "俘获，俘虏。",
      "examples": [
        "孚人万三千八十一人。"
      ],
      "traditional_char": "孚"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "种子的壳（通“稃”），植物种子的外壳、萌发。",
      "examples": [
        "苟本正，则华英必得其节，以秀孚矣。"
      ],
      "traditional_char": "孚"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "付与，交付（通“付”）。",
      "examples": [
        "孚命（授命）"
      ],
      "traditional_char": "孚"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "相应，符合。",
      "examples": [
