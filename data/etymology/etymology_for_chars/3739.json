      ],
      "traditional_char": "孚"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 2,
      "note": "“孚”本为象形字，从爪，从子，表示鸟用爪抱卵孵化的形状。"
    }
  ],
  "edges": [
    {
      "source_index": 2,
      "target_index": 0,
      "evolution_type": "metaphor",
      "note": "由“孵化”引申为“使人信任”，因如鸟孵卵，按时而不失之意。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "动词“使信服”引申为名词“信用”。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "甲骨文用“孚”借指“俘”。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "用孚通“稃”，即谷壳，声音和形体借用。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "用孚通“付”，为声借义。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由孵化之应期不爽，引申为事物相应、符合。"
    }
  ]
