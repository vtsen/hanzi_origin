  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "廡为形声字，从广表示房屋，无为声，指堂下周围的廊屋，是最早的本义。"
    },
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 6,
      "note": "“廡”通“芜”，后用于指草木茂盛的意思，属假借和通用关系。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "庑为简化字，结构同廡，表示堂下周围的廊屋，本义未变。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由具体廊屋扩展为泛指房屋，出现在汉代和后世建筑语境中。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由一般房屋进一步专指大屋，见先秦典籍对屋舍等级的区分。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "synecdoche",
      "note": "以部分代整体，“廊屋”用于专指“廊”，语义具体化。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由廊屋相关结构转指屋檐，见宋代营造术语。"
