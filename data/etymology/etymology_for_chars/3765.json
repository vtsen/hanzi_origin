    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "火热之状比喻为炽热（气候、心情等）。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以烟火遮蔽引申为蒙蔽。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "烘烤进一步引申为焚烧。"
    },
    {
      "source_index": 6,
      "target_index": 7,
