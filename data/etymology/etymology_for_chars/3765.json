{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "烘烤、烤干。",
      "examples": [
        "古者民不知衣服，夏多積薪，冬則炀之。《庄子》",
        "乃斫、乃熬、乃煬、乃舂，貯於瓶缶之中。《茶经》"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "熔化金属。",
      "examples": [
        "以一铁范…密布字印…持就火炀之。《梦溪笔谈》",
        "金煬则液，水凍則堅。《周易外传》"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "向火（取暖）、烤火。",
      "examples": [
        "冬則羊裘解札，短褐不掩形而炀灶口。《淮南子》",
        "就灶煖身，则谓之煬。"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "炊（烧火做饭）。",
      "examples": [
        "炀者（灶下烧火的人）；炀器（炉灶）"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "遮蔽、蒙蔽、挡住。",
      "examples": [
        "今或者一人有煀君者乎？《韩非子》",
        "明或煬于近习，而权或溺于嬖佞。"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "焚烧。",
      "examples": [
        "诗书煬而為煙。《晋书》",
        "煬墳籍於埃塵，填儒林於坑阱。"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "炽热、热烈。",
      "examples": [
        "观天火之炎炀兮，听大壑之波声。《七谏》",
        "血氣交沴，煬然焚如。"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "照耀。",
      "examples": [
        "奔精照夜，高燎煬晨。《宋书》"
      ],
      "traditional_char": "煬"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "（古代谥法）去礼远众者称“炀”。",
      "examples": [
        "古代谥法，去礼远众称“炀”。"
      ],
      "traditional_char": "炀"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从火，昜声。本义为烘烤。"
    },
    {
      "formation_type": "loan_character",
      "original_sense_index": 8,
      "note": "‘炀’用作谥号为假借，非本义用法，指去礼远众者。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由烘烤引申为向火取暖，历见《庄子》《淮南子》。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "烘烤的火力引申为熔化金属。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
