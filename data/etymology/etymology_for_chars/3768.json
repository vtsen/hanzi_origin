{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "水名，漢水上游，在陝西省西南部；又可泛指與長江相關之水域。",
      "examples": [
        "沔彼流水，朝宗于海。——《詩·小雅·沔水》",
        "沔水出武都沮縣東狼谷。——《說文》"
      ],
      "traditional_char": "沔"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古州名、縣名，多設於水名沔流域，在今陝西、湖北、河南等地。",
      "examples": [
        "西魏置沔州，北周廢。故址在今湖北省漢川。",
        "1964年改作勉縣，在陝西省。"
      ],
      "traditional_char": "沔"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "水流滿、盈滿的樣子。",
      "examples": [
        "沔彼流水，朝宗于海。——《詩·小雅·沔水》",
        "湖水演沔，勖哉是行。——李白"
      ],
      "traditional_char": "沔"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "通“湎”，沉迷、沉溺。",
      "examples": [
        "流沔沈佚，遂往不返。——《史記·樂書》",
        "湛沔於酒。——《漢書·霍光傳》"
      ],
      "traditional_char": "沔"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形旁‘氵’表水義，聲旁‘丐’表音，最初用以記漢水上游等大水流名。"
