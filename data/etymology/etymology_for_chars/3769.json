  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘漚’从水，區声，最早表示长时间浸泡，与水有关，属于形声字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由浸泡产生的水泡隐喻物理上的泡沫。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由水泡虚浮、短暂，引申为世事虚无、幻景。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由浸泡、积水等水相关特征转指地名（水名）。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "借声用作‘鸥’以表音近，实际为通假字。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "由‘浸泡、闷在水中’引申为情绪闷在心中。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "从浸润引申为涂抹液体在皮肤上。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "浸泡延伸为柴草未完全燃尽而潮湿不燃。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "由原意‘滞留、浸’引申为‘拖延’（时间停滞）。"
    }
  ]
