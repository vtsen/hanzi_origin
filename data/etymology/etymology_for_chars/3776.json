{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "水名，即汾河，位于中国山西省，是黄河的重要支流。",
      "examples": [
        "汾水出太原晋阳山西南入河。",
        "汾、河、涑、澮以为渠。"
      ],
      "traditional_char": "汾"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古地名，如汾丘、汾阳，亦指以汾河命名的州、县名。",
      "examples": [
        "子庚帅师治兵于汾。",
        "汾阳属太原郡。"
      ],
      "traditional_char": "汾"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "大；尊贵。",
      "examples": [
        "汾王（大王）。"
      ],
      "traditional_char": "汾"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "水漫溢。",
      "examples": [
        "汾沄沸渭。"
      ],
      "traditional_char": "汾"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "繁多、纷乱（通“纷”）。",
      "examples": [
        "与夫汾沄沸渭而混混焉者兮。"
      ],
      "traditional_char": "汾"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从水，分声。本义为水名；“水”为意旁，“分”为声旁。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以河名泛指流经地的地名或行政区名，见先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由大河之意引申为‘大’‘尊贵’，早见于先秦。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "从原义‘河流’引申为‘水漫溢’，水之性相关。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "synecdoche",
      "note": "以‘水多盛’引申为‘繁多、纷乱’义，汉赋时期可见。"
    }
  ]
