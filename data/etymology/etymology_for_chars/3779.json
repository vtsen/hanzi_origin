      "original_sense_index": 0,
      "note": "形声字，从水，文声，表水名，最早用于今山东大汶河。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "同属山东地区水系名，由大汶水推广至其他流向不同的汶水分支。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "同为山东区域的水流，以主干水名引申为支流名称。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以河流名指称河流经过的地名，如汶上，汶阳等。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "reanalysis",
      "note": "与“岷”混用，部分文献出现指四川岷山或岷江，属文献混用。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
