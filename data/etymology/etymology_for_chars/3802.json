  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "地名作为所在行政区的代称；见汉代以后用作甘肃的简称。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "从具体山岭义扩展为泛指山冈、丘陵。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由山冈义引申为田埂、土丘等起伏地貌。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "synecdoche",
      "note": "田埂、高地局部特征转用为坟墩之称。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由山冈高大义，引申为“隆盛、旺盛”。"
    },
    {
      "source_index": 2,
      "target_index": 5,
