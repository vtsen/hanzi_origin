      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以地形特征指代具体地名“沙陀”，隋唐五代地理用法。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "从地势不平，引申为土石崩塌、塌落等动态现象，两汉文献可见。"
