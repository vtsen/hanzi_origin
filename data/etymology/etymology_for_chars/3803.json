  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从阜（表示与山地有关），‘它’为声，初指地势倾斜不平。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由倾斜不平引申为小丘、山冈之地貌，汉至元代多见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "根据山丘的形状，比喻为各种团状物，明清小说中常见。"
