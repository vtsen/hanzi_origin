  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从阜表地形，皮为声符，本义为山坡、斜坡。传世异体作“坡”。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由山坡沿地势聚水，扩展为积水处（池塘、湖泊），汉代已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "以池塘的边岸部分指‘水边、岸’，《诗经》明确用例。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "地势倾斜引申为“倾斜、不平、偏邪”，《易》《吕氏春秋》所载。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "function_word",
      "note": "用于地名，举凡以坡、塘为地名者取其地貌，最晚汉代形成。"
