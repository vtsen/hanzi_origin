      "examples": [
        "唐任希古《和左仆射燕公春日端居述怀》：“丰野光三杰，媯庭赞五臣。”"
      ],
      "traditional_char": "媯"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "健狡，狡黠。",
      "examples": [
        "嬀娗，僈也。《扬子·方言》嬀娗，僈也。"
      ],
      "traditional_char": "嬀"
    }
