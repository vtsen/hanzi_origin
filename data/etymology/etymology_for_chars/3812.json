    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "水名，妫河，源出北京市延庆县，流入桑干河。",
      "examples": [
        "妫汭",
        "嬀水",
        "书·尧典：釐降二女于嬀汭。"
      ],
      "traditional_char": "妫"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "姓氏，出自舜居妫汭，因以为氏。",
      "examples": [
        "春秋时陈国为妫氏。",
        "汉有妫昌。"
      ],
      "traditional_char": "妫"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古州名，辖今河北省赤城、怀来等地。",
      "examples": [
        "唐贞观间，改北燕州为嬀州。"
      ],
