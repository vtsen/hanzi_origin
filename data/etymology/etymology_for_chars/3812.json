  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘妫’本作‘嬀’，从女，为声，初本水名，后简化作‘妫’。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "‘嬀’从女，为声，初用于地名州名，与水名音义相关。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 3,
      "note": "‘媯’亦从女，舜帝所居地，取代指舜，音义同源。"
    }
