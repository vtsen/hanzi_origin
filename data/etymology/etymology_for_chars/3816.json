{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古地名，春秋时期晋邑，在今山西省垣曲县、河南省济源县一带。",
      "examples": [
        "邵，晋邑也。——《说文》",
        "戌郫邵。——《左传·襄公二十三年》"
      ],
      "traditional_char": "邵"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古州名，今福建省邵武县等地。",
      "examples": [
        "后魏改为邵郡，后周改为邵州。"
      ],
      "traditional_char": "邵"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古郡名，即邵陵郡，相当于今湖南省邵阳市及新邵、邵阳县等地。",
      "examples": [
        "齐桓公伐楚，至邵陵。——《史记·秦本纪》"
      ],
      "traditional_char": "邵"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "水名，邵水，源于湖南省宝庆县东注入资水。",
      "examples": [
        "邵水发源龙山。西流会桐江、檀江，在湖南省宝庆县东注入资水。"
      ],
      "traditional_char": "邵"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "然则良臣如王成、黄霸、龚遂、邵信臣之徒，可比郡而得也。——《潜夫论·三式》"
      ],
      "traditional_char": "邵"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "美好、高尚（与“劭”通用）。",
      "examples": [
        "公仪子、董仲舒之才之邵也。——《法言·修身》",
        "斯皆不足邵也。——章炳麟《国故论衡·论式》"
      ],
      "traditional_char": "邵"
    }
  ],
