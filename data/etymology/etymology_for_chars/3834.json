{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "羞辱；有愧，对先人或地位感到羞辱、辱没",
      "examples": [
        "无忝祖考。",
        "忝厥祖。",
        "无忝尔所生。",
        "陵不引决，忝世灭姓。"
      ],
      "traditional_char": "忝"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "荣幸（做某事）；自谦地表示受宠，常用作谦辞",
      "examples": [
        "忝在知交。",
        "忝属知己。",
        "忝列门墙。",
        "臣忝当大任，义在安国。"
      ],
      "traditional_char": "忝"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "挺起，凸出（同“腆”）",
      "examples": [
        "忝起胸膛，将左手抹腹，右手持刀。",
        "唿喇的响一声，把腹皮剖开。"
      ],
      "traditional_char": "忝"
    },
    {
      "index": 3,
      "part_of_speech": "adverb",
      "meaning": "表示愧对地承担或进行某事（用于谦辞）",
      "examples": [
        "臣忝当大任，义在安国。",
        "忝眷；忝居"
      ],
      "traditional_char": "忝"
    }
  ],
