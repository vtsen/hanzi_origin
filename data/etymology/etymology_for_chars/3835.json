  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "“匭”为形声字，从匚（表示容器）加軌声，本指“簋”古形，后引申为小箱。"
    },
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 3,
      "note": "也可能古用作“纏結”之义，或为假借，具体构形过程学界有争议。"
    }
  ],
  "edges": [
    {
      "source_index": 2,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由“簋”为盛器，引申为一般小箱、小匣子的意义，战国-汉已见。"
    },
    {
      "source_index": 0,
      "target_index": 1,
