{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "裂开，分裂",
      "examples": [
        "天旱地坼。——《淮南子·本经》",
        "干坼。",
        "天崩地坼，天子下席。——《战国策·赵策三》"
      ],
      "traditional_char": "坼"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "（特指）植物种子、花芽等外皮开裂而发芽或开花",
      "examples": [
        "百果草木皆甲坼。——《易·解》",
        "东风杏花坼。",
        "如木之坼甲。"
      ],
      "traditional_char": "坼"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "裂缝，裂纹",
      "examples": [
        "卜人占坼。——《周礼·占人》",
        "枕有小坼。",
        "灌得迟了，太阳一照，秧田会开坼。"
      ],
      "traditional_char": "坼"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "拆开，拆毁",
      "examples": [
        "坼屋伐树，以纳税钱。",
        "坼书放床头，涕与泪垂四。"
      ],
      "traditional_char": "坼"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "崩落，（光）闪动",
      "examples": [
        "中台星坼，时以为大异。",
        "忽报台星坼，仍传薤露新。"
      ],
      "traditional_char": "坼"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从土，斥声；表土裂也，形声字，‘土’表义，‘斥’表声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
