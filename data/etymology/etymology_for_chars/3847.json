  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从土，氐声。本义为水中小洲或高地。《说文》有记载。属于形声字，土表示与地形相关。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由水中小洲高地泛指为岸。用地形的高起进一步一般化。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由地理高地喻指宫殿的高台、台阶。建筑高起如地势高起。"
    },
