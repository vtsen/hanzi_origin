{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "草名，一种蔓生植物，俗称鬼目草，即白英，茎似葛，叶圆有毛，果实如耳珰，红色丛生。",
      "examples": [
        "苻，鬼目。《尔雅·释草》",
        "今江东有鬼目草，茎似葛，叶员而毛，子如耳璫也，赤色丛生。——郭璞注"
      ],
      "traditional_char": "苻"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "芦苇杆中的白色薄膜，通“莩”。",
      "examples": [
        "芦苻之厚，通于无垠。——《淮南子·俶真》",
        "苻甲，猶莩甲也。"
      ],
      "traditional_char": "苻"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "植物种子的外皮，草的莩甲。",
      "examples": [
        "甲者，言万物剖苻甲而出也。——《史记·律书》"
      ],
      "traditional_char": "苻"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。本作“蒲”，后为苻坚改为“苻”。",
      "examples": [
        "其先盖有扈之苗裔，始其家池中蒲生，后洪以谶文有‘艸付应王’，其孙坚背有‘艸付’字，遂改姓苻氏。——《晋书·苻洪传》"
      ],
      "traditional_char": "苻"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "古泽名，萑苻，泽名。",
      "examples": [
        "郑国多盗，取人于萑苻之泽。——《左传·昭公二十年》"
      ],
      "traditional_char": "苻"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "通“符”，符契、凭证或信物。",
      "examples": [
        "即上尚书，参以苻验。——汉《史晨乡孔庙后碑》",
        "精通皓穹，三纳苻银。——汉《李翕析里桥郙阁颂》"
      ],
      "traditional_char": "苻"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "通“符”，符命，预言未来的神秘文书。",
      "examples": [
        "运天苻命。——汉《北军中侯郭仲奇碑》"
      ],
      "traditional_char": "苻"
    }
  ],
