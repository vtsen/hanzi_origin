    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代门两旁竖立的木柱，用以防止车过触门，也称门楔。",
      "examples": [
        "棖，杖也。——《说文》",
        "君入门，介拂闑，大夫中棖与闑之间，士介拂棖。——《礼记·玉藻》",
        "棖谓之楔。——《尔雅》"
      ],
      "traditional_char": "棖"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "门，借指门、门柱。",
      "examples": [
        "幸得履中气，忝从拂天棖。——唐 韩愈 孟郊《城南联句》"
      ],
      "traditional_char": "棖"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "支柱，用于支持结构的木棒。",
      "examples": [
        "以绳相交络，纽木枝棖，覆以青繒，形制平圆，下容百人坐，谓之为‘伞’，一云‘百子帐’也。——《南齐书·魏虏传》",
        "今吾乡谓门后邪柱，一端当门中，一端钉地者，曰门棖。——黄侃《蕲春语》"
      ],
      "traditional_char": "棖"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "木棒。",
      "examples": [
        "弢作桔槔打官军船舰，访作长岐棖以距之。——《晋书·周访传》"
      ],
      "traditional_char": "棖"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "果名，即橙，亦称枨子。",
      "examples": [
        "欲以棖子臣樱桃，但恨不同時耳。《金城记》",
        "如：枨橘（橙橘一类果品）"
      ],
      "traditional_char": "棖"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "用东西触动、碰触，感动。",
      "examples": [
        "不棖人之所讳，不犯人之所惜。——晋 葛洪《抱朴子·疾谬》",
        "枨拨（触动；拨动）",
        "枨触（感触）"
      ],
      "traditional_char": "枨"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "传说中取人内脏的恶鬼，亦称“棖棖”。",
      "examples": [
        "京师讹言官遣棖捕人肝以祭天狗，人相恐，畿县尤甚。——《旧唐书·玄宗纪下》"
      ],
      "traditional_char": "棖"
    }
