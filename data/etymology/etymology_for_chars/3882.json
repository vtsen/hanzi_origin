{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "枋树，一种木材坚硬的树，可作车材。",
      "examples": [
        "枋，枋木也。可作车，从木，方声。——《说文》",
        "我决起而飞，枪榆枋。——《庄子·逍遥游》"
      ],
      "traditional_char": "枋"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用于筑堤堰的大木桩。",
      "examples": [
        "后背洪枋巨堰，深渠高堤者也。——《水经注》"
      ],
      "traditional_char": "枋"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "方柱形木材，如房屋中两柱之间的横木；泛指木棒。",
      "examples": [
        "夹岸累石结以为门，用代木门枋。——《水经注·沁水》",
        "突然，他抓起一根短短的木枋，站起来，走到柜台边。——谭秀牧《失去的黑金刚》"
      ],
      "traditional_char": "枋"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "通“舫”，竹木编成的筏。",
      "examples": [
        "集韵：甫妄切，去漾，通“舫”。"
      ],
      "traditional_char": "枋"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "通“柄”，器物的把手或权柄。",
      "examples": [
        "枋，柄也。——《周礼·春官·内史》",
        "宾受醴于户东，加柶面枋，筵前北面。——《仪礼·士冠礼》"
      ],
      "traditional_char": "枋"
    },
    {
      "index": 5,
      "part_of_speech": "measure_word",
      "meaning": "量词，多用于兵器。",
      "examples": [
        "并献宝刀一枋，以表忠诚。——清·夏燮《中西纪事·五口釁端》"
      ],
      "traditional_char": "枋"
    }
  ],
