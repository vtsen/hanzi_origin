    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古邑名，春秋郑地，后属楚。故地在今河南省郏县。",
      "examples": [
        "楚公子围使公子黑肱、伯州犁城犨、櫟、郟。",
        "郏，本郑邑，后已属楚。"
      ],
      "traditional_char": "郟"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代地名，周朝东都郏鄏，在今河南省洛阳市西，又称为郏鄏。",
      "examples": [
        "成王定鼎于郏鄏。",
        "王迁盟向之民于郏。"
      ],
      "traditional_char": "郟"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "县名，河南省郏县。",
      "examples": [
        "郏县在河南省平顶山市。",
        "潁川郡郏县。"
      ],
      "traditional_char": "郏"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "山名，即北邙山，因郏鄏而得名。",
      "examples": [
        "郏山即北邙山。",
        "以郏山得名。"
      ],
      "traditional_char": "郟"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏，春秋时有郏张。",
      "examples": [
        "春秋时有郏张。",
        "鄭有郏张。"
      ],
      "traditional_char": "郟"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "夹室，内堂东西厢的后室。“郟”通“夹”。",
      "examples": [
        "郏室（夹室，内堂东西厢之后室）。",
        "碑以郏为夹。"
      ],
      "traditional_char": "郟"
    }
  ],
