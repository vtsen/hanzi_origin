        "鸢衣"
      ],
      "traditional_char": "鳶"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "‘鳶’为象形字，形状描写长尾猛禽之形。"
