{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "日出明亮，太阳刚升起时光明的样子",
      "examples": [
        "其雨其雨，杲杲出日。",
        "如日之杲。"
      ],
      "traditional_char": "杲"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "明亮；光明",
      "examples": [
        "如海之深，如日之杲。",
        "是故民氣杲乎如登於天。"
      ],
      "traditional_char": "杲"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "高远",
      "examples": [
