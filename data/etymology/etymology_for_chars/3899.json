      ],
      "traditional_char": "杲"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "白，洁白",
      "examples": [
        "積曙境宇明，聯萼千里杲。"
      ],
      "traditional_char": "杲"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏",
      "examples": [
