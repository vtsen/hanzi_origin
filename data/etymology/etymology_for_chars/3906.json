  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从日，旁声。‘日’表意义，指天明；‘方’表读音。初义为日出时分，天刚亮。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘日初明’引申为‘起始’，借用自然界中一天之始比喻事务之始，东汉至两晋已见用例。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由词义转为姓氏用法，为一般汉字义用作姓氏的规律，见《百家姓》。"
