      "meaning": "含在嘴里细细品味、咀嚼",
      "examples": [
        "咀，含味也。——《说文》",
        "咀嚼菱藕。——司马相如《上林赋》",
        "含英咀华。——韩愈《进学解》"
      ],
      "traditional_char": "咀"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "体味，对事物反复体会（比喻义）",
      "examples": [
        "含英咀华（喻读书吸取精华）"
      ],
      "traditional_char": "咀"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "口、嘴的异体字",
      "examples": [
