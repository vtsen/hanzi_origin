      ],
      "traditional_char": "咀"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从口，且声，表“含味，细嚼”的本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由实际“品味、咀嚼”引申为“对事物反复体会”（比喻义），见韩愈《进学解》。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "以“咀嚼”之动作代指行此动作之嘴，故用作‘口’或‘嘴’的异体。"
