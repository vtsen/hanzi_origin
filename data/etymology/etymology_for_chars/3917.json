      "part_of_speech": "verb",
      "meaning": "（引申）猛烈地发怒或大声呼喊。",
      "examples": [
        "咆哮如雷",
        "何猛气之咆勃"
      ],
      "traditional_char": "咆"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "（比喻）水流湍急轰鸣。",
      "examples": [
        "江水咆哮，汹涌澎湃"
      ],
      "traditional_char": "咆"
    }
