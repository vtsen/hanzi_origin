{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "裙。古代妇女的下裳。",
      "examples": [
        "弘农谓裙帔也。——《说文》",
        "裙，陳魏之間謂之帔。——《方言》"
      ],
      "traditional_char": "帔"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代披在肩背上的服饰，多为女性用。",
      "examples": [
        "帔，披也，披之肩背，不及下也。——《释名·释衣服》",
        "賜其母冠帔以示寵。——《宋史·蔡襄傳》",
        "今代帔有二等，霞帔非恩賜不得服。——《事物紀原·衣裘帶服·帔》"
      ],
      "traditional_char": "帔"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "一种类似僧人袈裟的衣服。",
      "examples": [
        "其服黄帔，乃是古贤之衣。——《笑道论》"
      ],
      "traditional_char": "帔"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "戏曲中用于帝王、后妃等角色的传统服装，形制与古代帔类似。",
      "examples": [
        "女帔長僅及膝。"
      ],
      "traditional_char": "帔"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从巾，皮声。‘巾’表与布帛服饰相关，‘皮’作声旁，最早指古代裳裙之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "裳裙遮体之物，引申为盖肩背的衣物。两者为服饰部位之转。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由普通披肩引申为僧人等的袈裟式衣服，多见于佛教服饰。"
