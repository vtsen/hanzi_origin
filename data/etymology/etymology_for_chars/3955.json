{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "片刻，一会儿，瞬间（常用于“须臾”）",
      "examples": [
        "不可须臾离也。",
        "极天云一线异色，须臾成五彩。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "捆绑拖曳，用绳捆束并拖拉",
      "examples": [
        "束縛捽抴為臾曳。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "善，好",
      "examples": [
        "臾，善也。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "肥沃的（土壤），后作“腴”",
      "examples": [
        "郡县上臾之壤，守之若干。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏",
      "examples": [
        "春秋晋有臾骈。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "弱弓，一种较弱的弓",
      "examples": [
        "往体多，来体寡，谓之夹、臾之属。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "劝导、鼓动（同“慫慂”）",
      "examples": [
        "日夜縱臾王謀反事。",
        "皆懷貞輩小人從臾導之。"
      ],
      "traditional_char": "臾"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "草、竹编成的筐（同“蕢”）",
      "examples": [
        "有荷臾而過孔氏之門。"
      ],
      "traditional_char": "臾"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 1,
      "note": "从申，从乙，会意，申意为伸展、束缚，乙象弯曲之物，表示用绳捆束并拖拉。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_shift",
      "note": "“片刻、一会儿”义由动作持续时间短引申，现用于须臾中，汉魏古文。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由束缚有序、整齐引申为善好之意，见《集韵》，义属引申。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“善”进一步引申为“土地肥沃”等褒义，见《管子》，古文演变。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "由物名称用作姓氏，常见中国汉字名词化趋势，存在自春秋。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "动作相关词汇常用于器物名称，这里指弱弓，典出《周礼》。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "动作由本义引申至劝导、驱动他人，如“縱臾”，古见于《汉书》。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "由束缚义引申为盛物之器，后与“蕢”通用，多见古代典籍。"
    }
  ]
}