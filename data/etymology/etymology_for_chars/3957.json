  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 3,
      "note": "‘侗’从人，同声，形声字。‘同’为声旁，初表示‘大貌’或‘长大直貌’。"
    }
  ],
  "edges": [
    {
      "source_index": 3,
      "target_index": 4,
