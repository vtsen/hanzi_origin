  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由身材矮小引申为体型肥大，形容体态异常的情况，语义延伸。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以短小的人的特征比喻屋梁上短的柱子。见于古代注解。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "古代以身材矮小者为乐师或伶人，名称沿用。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由个体不足、短小引申为知识或能力不足，表现愚昧无所知。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由短小、不足，引申为德行不足，后来表无道。"
    },
    {
      "source_index": 6,
      "target_index": 0,
