  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从人，兆声。本义为轻薄不庄重，有与‘兆’音义相关，‘人’表示人之行为特征。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由人的轻浮不谨，引申为行为上的窃取或偷取，类似‘不庄重’→‘不守正道’。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由‘轻薄、不庄重’引申为‘轻疾、迅捷’，轻佻之人行动敏捷。"
