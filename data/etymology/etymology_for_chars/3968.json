  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，甲骨文字形像山崖边的土山阶梯，表示土山、隆起的陆地。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从具体的“土山”扩展到泛指高地、山丘，见先秦用例。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由土山隆起，引申出“高大”的抽象性质，常见于文献形容高耸之物。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由“高大”抽象转喻为“盛多”、“丰富”，如金钱、物资等“丰厚”。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "高大进一步形容生物体魄之“健壮、肥硕”，诗经例多。"
    },
    {
      "source_index": 3,
      "target_index": 5,
