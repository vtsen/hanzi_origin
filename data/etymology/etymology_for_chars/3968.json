      ],
      "traditional_char": "阜"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "丰富，盛多，富有，繁盛。",
      "examples": [
        "物阜民丰。",
        "民物阜康。——晋·常璩《华阳国志》",
        "张国势，厚民生，阜财用，广声气。"
      ],
      "traditional_char": "阜"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "强健，肥壮。",
      "examples": [
        "田车既好，四牡孔阜。——《诗·小雅·吉日》",
        "驷骐孔阜。"
      ],
      "traditional_char": "阜"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "百姓，众人。",
