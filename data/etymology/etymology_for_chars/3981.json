  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“肫”从肉，屯声。肉部表身体部位，原指面颊部位，后义扩展。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由面部部位泛指至禽类内脏部位，或因形状类比。汉代已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由面颊为外部突出之处借指臀部，也属身体部位类比。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "面颊丰满引申为性情厚实、真挚之义，《礼记》用法。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由面颊等身体部位指称祭祀用牲体部分。多见于古代礼仪文献。"
    },
    {
      "source_index": 4,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "祭祀用牲体“肫”引申为整体、完全之意。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由真挚、诚恳引申为精细致密的赞誉。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "“肫”音近“豚”，借作小猪用名。见于晋书。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "phonetical_loan_shift",
      "note": "“肫”又借为“馄饨”之“飩”，因音之转借。"
    }
  ]
