      ],
      "traditional_char": "沱"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，它声，表示与水流相关，创制初指江水支流。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "支流水道易形成湾区，可停船水湾为地理实体的延伸；见于地名用法丰富于四川等地。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_narrowing",
      "note": "由一般支流专指具体水名，如沱江等。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "本义为水流，引申形容泪水如水流般奔涌。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "本义为支流水流，引申形容雨水倾泻如流。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由流水、支流义引申为池塘、水池。见于古书‘沱’通‘池’用法。"
    }
  ]
}