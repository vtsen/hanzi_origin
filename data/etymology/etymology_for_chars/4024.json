    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "泾水，发源于甘肃流入陕西与渭水相合的河流名。",
      "examples": [
        "泾渭分明",
        "泾以渭浊。——《诗·邶风·谷风》"
      ],
      "traditional_char": "涇"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古州名，故地在今甘肃省泾川县。",
      "examples": [
        "秦之先本西戎葴姓居泾州。"
      ],
      "traditional_char": "涇"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "县名，在安徽省东南部。",
      "examples": [
