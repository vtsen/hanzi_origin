  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“阶次”引申为地面高低之隔，即田埂，常见于地形用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
