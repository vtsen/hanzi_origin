      "part_of_speech": "adjective",
      "meaning": "喻愚钝、无能，才能低下。",
      "examples": [
        "相如虽驽，独畏廉将军哉？——《史记·廉颇蔺相如列传》",
        "臣衡材駑，无以辅相善义。——《汉书·匡衡传》"
      ],
      "traditional_char": "駑"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "比喻迟钝、懒散。",
      "examples": [
