      "index": 1,
      "part_of_speech": "noun",
      "meaning": "下等家畜，泛指劣等的动物。",
      "examples": [
        "駑犬（劣犬）；駑骡（劣骡）"
      ],
      "traditional_char": "駑"
    },
    {
