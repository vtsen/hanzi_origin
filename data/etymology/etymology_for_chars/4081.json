    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代传递公文或消息所用的马，或骑马送信的人。",
      "examples": [
        "楚子乘驿。",
        "驿，置骑也。——《说文》"
      ],
      "traditional_char": "驛"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "旧时供传递公文的人或来往官员中途休息、换马的地方，驿站。",
      "examples": [
        "驿外断桥边，寂寞开无主。",
        "此驿置在古宜城内。"
      ],
      "traditional_char": "驛"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "地名用字，如“龙泉驿”。",
      "examples": [
        "龙泉驿（在中国四川省）。"
      ],
      "traditional_char": "驛"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "用驿马、驿车等传递（公文、消息、物品）的行为。",
      "examples": [
        "驰命走驿，不绝于时月。",
        "诏天下…驿至京师。"
      ],
      "traditional_char": "驛"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "计算驿路长度的单位，两个驿站之间路程为一驿。",
      "examples": [
        "凡四驿而至。",
        "不过十驿。"
      ],
      "traditional_char": "驛"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "古同“绎”，络绎不断。",
      "examples": [
        "络驿不绝。",
        "驿驿其达。"
      ],
      "traditional_char": "驛"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
