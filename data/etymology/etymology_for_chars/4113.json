      ],
      "traditional_char": "莒"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "今山东省的县名。",
      "examples": [
        "秦置莒縣，明入莒州，1931年改莒縣。"
      ],
      "traditional_char": "莒"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
