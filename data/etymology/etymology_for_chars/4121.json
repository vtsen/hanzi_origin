    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "多年生水生草本植物，叶对生圆形，漂浮水面，根生水底，夏秋开黄花，嫩茎可食，全草可入药，又称“荇菜”或“莕菜”。",
      "examples": [
        "参差荇菜，左右流之。",
        "荇乱新鱼戏。",
        "已漂新荇没，犹带断水流。"
      ],
      "traditional_char": "荇"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "汉荇不意。",
        "汉荇吾。"
      ],
      "traditional_char": "荇"
    }
  ],
