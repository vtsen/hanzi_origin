{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "戰勝，制服；壓制、克服。",
      "examples": [
        "伐背叛之國，三年乃剋。",
        "湯遂與伊尹謀伐桀，剋之。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "約束，克制自己。",
      "examples": [
        "成湯遭災，以六事剋己。",
        "歡沉難剋興，心亂誰為理。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "限定時間，多指約定期限。",
      "examples": [
        "又剋水退期日，皆如所言。",
        "剋今月二日，當西經濟黎陽。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "砍削，截斷；削減。",
      "examples": [
        "非斧不剋。",
        "剋了我的衣食。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "刻鏤，雕刻。",
      "examples": [
        "封者立石高一丈二赤，剋之曰：‘事天以禮，立身以義...’"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "苛嚴，苛刻，待人刻薄。",
      "examples": [
        "然性儉剋，少恩情。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "能夠，達成。",
      "examples": [
        "剋，能也。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "打（人），動手毆打。",
      "examples": [
        "剋架（打架）。"
      ],
      "traditional_char": "剋"
    },
    {
      "index": 8,
      "part_of_speech": "verb",
      "meaning": "申斥，嚴厲斥責、罵人。",
      "examples": [
        "小心頭兒剋你。",
        "你不是還剋過我嗎？"
      ],
      "traditional_char": "剋"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从力，克聲。本義為戰勝、克服，屬形聲字，力指與力量有關。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由對外克敵引申為克己自制。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "原為征服、壓制，引申為約定、限定時間。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由征服、制勝引申為砍削、削減。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "同音假借用於“刻”，表示刻鏤。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "征服引申為對人嚴苛、苛刻。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "從戰勝引申為能夠完成。"
    },
    {
      "source_index": 3,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "由砍削、傷害引申為打人。"
    },
    {
      "source_index": 5,
      "target_index": 8,
      "evolution_type": "semantic_shift",
      "note": "從待人苛刻進一步發展為訓斥、申斥、罵人（口語用法）。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "metonymy",
      "note": "打和訓斥常在語境中相互轉化，例如“剋人”既指打也指罵。"
    }
  ]
