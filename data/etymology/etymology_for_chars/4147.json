      "meaning": "关猛兽或其他畜兽的木笼；猛兽笼。",
      "examples": [
        "虎兕出于柙。",
        "柙，槛也，以藏虎兕。"
      ],
      "traditional_char": "柙"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用囚笼、囚车关押或押解（人或动物）。",
      "examples": [
        "遂生束缚而柙以予齐。"
      ],
      "traditional_char": "柙"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "匣子、柜等收藏物品的器具（通“匣”）。",
      "examples": [
        "柙而藏之，不敢用也。",
        "义陵，寝神衣在柙中。"
      ],
      "traditional_char": "柙"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "木名，一种树。",
      "examples": [
