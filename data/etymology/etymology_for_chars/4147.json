      ],
      "traditional_char": "柙"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从木，甲声。‘木’表示与木器有关，‘甲’为声符，最初表示关猛兽的木笼。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 3,
      "note": "同一形声结构，‘木’为义旁，‘甲’为声旁，表示木名，用于一种树。"
    }
  ],
  "edges": [
    {
