      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "柞树生长地被用作水名、地名，见水经注，历史用法早见魏晋。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "柞树为名的古国名，地以物名，方向不明但用地以木名常见。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "用柞树引申为山名，山以多柞树得名。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "名词转用为量词，用柞树长度引申具体距离单位。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "synecdoche",
      "note": "柞树用于制作竹席，席以木名。"
    },
    {
      "source_index": 3,
      "target_index": 1,
