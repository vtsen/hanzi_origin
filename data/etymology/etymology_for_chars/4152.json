{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "巡夜人巡逻时敲打以报更的木梆",
      "examples": [
        "夕击柝而比之。",
        "鲁击柝闻于邾。",
        "抱关击柝而不以为寡。",
        "朔气传金柝。",
        "候卒击柝卫太尉。"
      ],
      "traditional_char": "柝"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "泛指夜间巡更时所敲之木制器具",
      "examples": [
        "金柝"
      ],
      "traditional_char": "柝"
    },
    {
      "index": 2,
      "part_of_speech": "onomatopoeia",
      "meaning": "敲击木梆时发出的声音",
      "examples": [
