      ],
      "traditional_char": "柝"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "通“拓”，开拓，扩展疆域",
      "examples": [
        "廓四方，柝八极。",
        "武皇帝攘四夷广土柝境，面数千里。"
      ],
      "traditional_char": "柝"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从木，橐声，表示巡夜用的木梆子。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
