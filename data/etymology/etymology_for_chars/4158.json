{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "木结构屋架中顺着前后方向架在房柱上的横木，大横梁。",
      "examples": [
        "柁檩椽架全被烟火蒸气熏得油黑油黑的。——浩然《艳阳天》",
        "你看我院里的木头，三间房子全齐了，就差一根大柁。"
      ],
      "traditional_char": "柁"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "船上控制行驶方向的装置，即“舵”。",
      "examples": [
        "以文梓为船，木兰为柁。——《三辅黄图·池沼》",
        "欹帆侧柁弄风口，赴险临深绕湾浦。——唐 张说《同赵侍御乾湖作》"
      ],
      "traditional_char": "柁"
    },
    {
      "index": 2,
      "part_of_speech": "numeral",
      "meaning": "计算船只的单位，一柁代表一艘船。",
      "examples": [
        "明年至者乃四十余柁。——《新唐书·李勉传》"
      ],
      "traditional_char": "柁"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "木叶落。",
      "examples": [
        "柁，木叶落也。"
      ],
      "traditional_char": "柁"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "形容木头坚硬。",
      "examples": [
        "柁，木坚貌。"
      ],
      "traditional_char": "柁"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "形声字，从木，祋声。最初表示‘船尾用以控制方向的木制装置’（即舵）。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由实物名词“舵”引申为计量船只的单位（量词用法），宋代已有。"
    },
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由‘船舵’引申借用为‘大横梁’，因为功能上同为重要支撑结构，用于屋架。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "古籍释义，‘柁’以“木叶落”为义，可能因叶落如舵之挥动，语源模糊。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "‘柁’本为坚固之物，引申为‘木坚貌’。"
    }
  ]
}