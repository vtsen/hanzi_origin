{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "乖戾，违背常理或情理；不顺从",
      "examples": [
        "乖剌",
        "剌谬",
        "少卿乃教以推贤进士，无乃与仆私心剌谬乎！"
      ],
      "traditional_char": "剌"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "割开；划开",
      "examples": [
        "手剌破了",
        "小刀剌破了手"
      ],
      "traditional_char": "剌"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "同“拉”，做拉伸、排泄之意",
      "examples": [
        "無屁股不剌屎，無僚子不撒尿",
        "剌撒"
      ],
      "traditional_char": "剌"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "邋遢，肮脏不整洁",
      "examples": [
        "剌塔",
        "剌塌醉"
      ],
      "traditional_char": "剌"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "燥热、猛烈",
      "examples": [
        "剌剌（辣辣）",
        "风候一参差，荣枯遂乖剌"
      ],
      "traditional_char": "剌"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "谥号，古代谥法中有剌谥，表示暴戾无亲",
      "examples": [
        "暴戾无亲曰剌",
        "剌龔公"
      ],
      "traditional_char": "剌"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "声响，象声词，形容张弓、鱼跃等声音",
      "examples": [
        "彎威弦之撥剌",
        "跋剌銀盤欲飛去"
      ],
      "traditional_char": "剌"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从束从刀，表示刀割束物，引申为乖戾、违背情理（最早见于说文，意指戾逆）。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由乖戾引申为具体割开或划开的动作，束缚被刀割破。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "割开、拉开的动作引申至“拉”，“排泄”（方言用法）。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由违背常理引申为行为、形象不整洁，引申为邋遢。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由性情乖戾转喻为猛烈、燥热之感或辣感。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_narrowing",
      "note": "作为谥号，表指某人性格暴戾不仁，狭义化。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由割裂动作的声音，形容某些响亮、断裂状的物理声音，形成象声词用法。"
    }
  ]
