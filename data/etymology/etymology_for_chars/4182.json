{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "车箱下部后方或四周的横木；引申指车；亦指方形之物，如石、丘等。",
      "examples": [
        "轸，车后横木也。——《说文》",
        "丙子，诏六军发轸。——《魏书》",
        "轸石（方石）",
        "軫之方也，以象地也。——《周礼》"
      ],
      "traditional_char": "軫"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "弦乐器上系弦线的小柱，可转动以调节松紧。",
      "examples": [
        "以轸调声。——《魏书·乐志》",
        "有琴无軫，愿借子调其音。——《列女传》",
        "拂霜弄瑶軫。——李白《北山独酌寄韦六》"
      ],
      "traditional_char": "軫"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "二十八宿之一，南方朱雀七宿最末一宿，有星四颗。",
      "examples": [
        "軫为车，主风。——《史记·天官书》",
        "星分翼轸，地接衡庐。——王勃《滕王阁序》"
      ],
      "traditional_char": "軫"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "田间小路，界限。（通“畛”）",
      "examples": [
        "以翔虚无之轸。——《淮南子·要略》",
        "连轸距阡陌。——阮籍《咏怀》。注：“轸，当为畛。”"
      ],
      "traditional_char": "軫"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "疹，皮肤上出现的小疙瘩。（通“疹”）",
      "examples": [
        "轸粟（指人体因受寒而起的疙瘩）",
        "病皮痹隐軫。——《素问·四时刺逆从论》"
      ],
      "traditional_char": "軫"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "方形的，引申为方正。",
      "examples": [
        "轸，方也。——《广雅》",
        "軫丘（方形山丘）",
        "軫石（方形石头）"
      ],
      "traditional_char": "軫"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "转动。",
      "examples": [
        "轸转其道也。——扬雄《太玄·玄摛》",
