  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从车，㐱声。本作“軫”，指车后横木，声旁㐱表音，意旁车表其意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "因车軫为方木，引申为“方形”的意思，汉晋以来见。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以车軫为比拟，指琴瑟等乐器上的调弦小柱，也为可转动的“横木”，故以此称。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "星宿名，形象取义为车之部件，以整个宿象“车”之构造而名。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "通“畛”（zhěn），用于田间小路、界限，借音假借，见于古文。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "phonetical_loan_shift",
      "note": "通“疹”，指小疙瘩之意，音近通假，汉魏以来医学用。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "车部件能转动，引申为“转动”义，多见古籍。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "由车箱受压产生形变，引申为内心悲痛、愁思，楚辞等古诗文用。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "悲痛、牵挂进一步引申为忧念、牵挂和怜惜。"
    }
  ]
