  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从日，立声。本义为日光、光明，‘日’表示意义，‘立’表示声旁。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由作为光明之物名词转为描述行为动作的动词用法，常见于古汉语。"
