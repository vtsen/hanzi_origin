      "meaning": "田间小水沟",
      "examples": [
        "居于畎亩之中。",
        "畎田中之沟。",
        "一畝之閒，廣尺深尺曰畎。"
      ],
      "traditional_char": "畎"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "泛指沟渠、河流",
      "examples": [
        "縣有芹墅堰……為之開築水甽一百三十餘丈。",
        "流畎穆陵西。"
      ],
      "traditional_char": "畎"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "山谷",
      "examples": [
        "岱畎，絲，枲、鉛、松、怪石。",
        "谷是兩山之間流水之道。畎言畎去水，故言谷也。"
      ],
      "traditional_char": "畎"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "田野，田地",
      "examples": [
        "畎畮，田地；田野。",
        "子敏嗣，位新安太守，好射雉，未嘗在郡，辭訟者遷於畎焉。"
      ],
      "traditional_char": "畎"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "疏通，流注（如水渠）",
      "examples": [
        "畎引江海以灌田。",
        "及鎮河陽，部內創別業，開畎水泉，以通溉灌。",
        "長堤春水綠悠悠，畎入漳河一道流。"
      ],
      "traditional_char": "畎"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "地名、古族名（畎夷）",
      "examples": [
        "周西伯昌伐畎夷氏。"
      ],
      "traditional_char": "畎"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从田，犬声。形声字，本义‘田间小水沟’。犬为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从田间小水沟扩展为一般的沟渠、河流，用于泛指，汉魏时期已见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由流水的义转喻指山谷中有水流的地方，多见于古文。"
