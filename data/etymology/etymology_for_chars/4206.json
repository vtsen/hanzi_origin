  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由肚脐为身体连接之纽转喻为辅助、协助。春秋战国已见。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“辅助”引申为“增益、补充”义，具体语境中可通‘裨’。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由‘辅助’喻为‘连结、相邻’；辅助常伴随在侧，引申为毗邻、毗连。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "从‘连结’进一步引申为‘附和、依附’。"
    },
    {
      "source_index": 2,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "从‘辅助’引申为‘厚，篤’，因辅佐稳重义。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "‘辅助’义于特定语境中转变为‘损伤、败坏’，可能因辅佐过度或干预破坏之系。用法见于《庄子》后世注解有分歧。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
