      "part_of_speech": "noun",
      "meaning": "蜣螂，一种甲虫，又称“屎壳郎”。见于“虼蜋”。",
      "examples": [
        "虼蜋在粪堆上滚动圆球。"
      ],
      "traditional_char": "虼"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "虼鲁，古代国名。",
      "examples": [
        "虼魯，國名。至江南，馬行七月。"
      ],
      "traditional_char": "虼"
    }
  ],
