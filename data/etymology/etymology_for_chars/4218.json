    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "呼吸的声音、某些动物的叫声（主要作象声词，常叠用“咻咻”）",
      "examples": [
        "草中咻咻有寒兔，孤隼下击千丈驰。——苏轼《江上值雪》",
        "咻咻"
      ],
      "traditional_char": "咻"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "吵闹、喧嚷、乱说话",
      "examples": [
        "一齐人傅之，众楚人咻之。——《孟子·滕文公下》",
        "亲党咻曰：“生既以不孝讼……何以慟哭为？”——明·李贽《唐贵梅传》"
      ],
      "traditional_char": "咻"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "调唆、煽动",
      "examples": [
        "日咻其夫使叛其兄，乙牵于爱而听之。——宋·吴曾《能改斋漫录·記事一》"
      ],
      "traditional_char": "咻"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "嘘气、喘气",
      "examples": [
        "众口同一咻。——清·黄遵宪《纪事》"
      ],
      "traditional_char": "咻"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "悲戚之声、病中呻吟或安慰病人的声音",
      "examples": [
        "噢咻，病声。——《广韵》",
        "噢咻，痛念之声。——《玉篇》"
      ],
      "traditional_char": "咻"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "温暖、温和，用气温之",
      "examples": [
