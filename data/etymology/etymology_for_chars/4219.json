{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代帝王饲养禽兽的园林。",
      "examples": [
        "王在灵囿。",
        "文王之囿方七十里。"
      ],
      "traditional_char": "囿"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "泛指菜园、果园等四周有围栏的园子。",
      "examples": [
        "囿有韭。",
        "墟囿散红桃。"
      ],
      "traditional_char": "囿"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "萃聚、聚集之所；事物聚集的地方。",
      "examples": [
        "游乎六艺之囿。",
        "吾闻京城南，茲維群山囿。"
      ],
      "traditional_char": "囿"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "局限，拘泥，限制。",
      "examples": [
        "囿于成见。",
        "皆囿于物者也。"
      ],
      "traditional_char": "囿"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "划定的区域、领土或城池。",
      "examples": [
        "秦七攻魏，五入囿中。",
        "因古九囿以置九州。"
      ],
      "traditional_char": "囿"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "古地名，即笠泽（今吴淞江）。",
      "examples": [
        "是故败吴于囿。",
        "囿，笠泽也。"
      ],
      "traditional_char": "囿"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从‘囗’表示围绕、范围，有声，最初本义为帝王饲养禽兽的园林。"
    }
  ],
  "edges": [
