  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "动作为赏赐、赐予，引申为所赐予之物。汉魏两代文献皆有用法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "赐物引申为特指他人寄来的信件、诗文。多见于中古及后世文人书信体中。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "原为赏赐，后用作心理倾向，意指喜欢、喜悦。西周、春秋《诗经》用法。"
