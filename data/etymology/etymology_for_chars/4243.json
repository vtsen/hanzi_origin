  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字。从金，表示与金属器具有关，今为声符，表音。本义为农具，早期即有多器具义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由农具泛指为祭祀器具，具体用法见《山海经》，为金属制品的扩展。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由农具泛指为用以烘焙茶叶的金属器具，皆为金属加工之器。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "semantic_extension",
      "note": "由农具（金属制具）泛指为带刀刃的金属器具，‘鉗’类义。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由金属器具引申为‘锁’及引申义‘关键’。"
    },
    {
      "source_index": 3,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "‘锁’义引申为‘鉗持、緘禁’，即通过金属器具钳制。"
    },
    {
      "source_index": 8,
      "target_index": 9,
      "evolution_type": "metaphor",
      "note": "由‘鉗持’引申为‘威懾管束’，管束或钳制人事。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由金属器具义转为‘印章’，即古代印章多用金属制成。"
