    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "从“依从”进一步引申为“营求、谋求私利”。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "顺从到为名（或目的）牺牲，用顺从生命隐喻牺牲生命。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "phonetical_loan_shift",
