  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "以地名为氏，晋国封地后代取地名为姓氏，常见用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "phonetical_loan_shift",
      "note": "因音近大量假借为‘隙’，含孔隙、缝隙义；汉代已见。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由物理缝隙引申为人际关系中的隔阂、，即“嫌隙”。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由缝隙引申为身体有‘间隙’或‘不合’，比喻小恙、病痛之意。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "与‘却’通假，音近，功能性假借，多见于古文。"
    }
  ]
