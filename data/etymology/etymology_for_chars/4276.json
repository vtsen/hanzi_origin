  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "甲骨文象两手相援引，中间一画似玉，表示‘引，援引’。会意结构。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "‘引’引申为‘更换、改易’，如引动、迁移有变更之意。商周至汉代。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "‘引’转为‘称为、曰’，用作引介名称或事物。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "由动作为引申用作承接上下文的连词‘于是’等用法。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "grammaticalization",
      "note": "由动作‘引’发展为介词‘于’、‘在’，引入时间或处所。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "‘引’义引申作度量衡单位，表示度量所‘引’之物。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "动作的引导转化为问处所‘哪里’，又引申为‘这里/那里’。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "动词义转为姓氏用法，按中国姓氏多由名词/动词变化。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘爰’假借作‘猿猴’之‘猿’字，音近通用。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "表示动作引导的舒缓、缓慢，引申为状态形容词。"
    },
    {
      "source_index": 0,
      "target_index": 10,
      "evolution_type": "grammaticalization",
