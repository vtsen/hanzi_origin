{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "祭祀时供奉或分与人的肉。",
      "examples": [
        "王使宰孔赐齐侯胙。",
        "四时致宗庙之胙。"
      ],
      "traditional_char": "胙"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "赐予，分封（如分封土地、爵位）。",
      "examples": [
        "将军胙土分茅。",
        "考绩有成，符策乃胙。"
      ],
      "traditional_char": "胙"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "保佑；赐福。",
      "examples": [
        "天地所胙。",
        "天胙先德，而隕明忒。"
      ],
      "traditional_char": "胙"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "君位，天子或诸侯之位。（“祚”之通假字）",
      "examples": [
        "踐胙之初。",
        "复其胙位。"
      ],
      "traditional_char": "胙"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "台阶（多指东阶，古为迎宾登堂之地）。",
      "examples": [
        "登自胙阶。",
        "胙与阼同。"
      ],
      "traditional_char": "胙"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从肉，乍声，表示祭祀用的肉。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
