      "index": 1,
      "part_of_speech": "noun",
      "meaning": "旧时指开设妓院、管理娼妓的女人，鸨母。",
      "examples": [
        "她是那家妓院的鸨母。",
        "老鸨招揽生意。"
      ],
      "traditional_char": "鴇"
    }
  ],
