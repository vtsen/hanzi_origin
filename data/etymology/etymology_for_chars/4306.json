  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "形容事物“盛大”引申为“美好”“美貌”；南北朝、东汉文献可见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“大、盛”引申为“光明、鲜明”，有显赫之意，常见于汉魏六朝诗文。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由“大”引申为“重、累”，即多次、多代。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "synecdoche",
      "note": "“累世”引申泛称单个“世代”，部分与整体的转化。"
