{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "逆流而上；溯流而上。",
      "examples": [
        "溯洄从之，道阻且长。",
        "洄，溯洄也。——《说文》"
      ],
      "traditional_char": "洄"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "水流回旋，水流盘旋。",
      "examples": [
        "江有洄洑，船下必来泊。",
        "洄潭转碕岸。"
      ],
      "traditional_char": "洄"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "回旋（旋涡）的水流，旋涡。",
      "examples": [
        "峽水聲不平，碧沱牽清洄。",
        "池面波溶返照洄。"
      ],
      "traditional_char": "洄"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "追溯往昔，上溯过去。",
      "examples": [
        "游今洄古，可以鉴矣。",
        "学生虽溯洄思切。"
      ],
      "traditional_char": "洄"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "湖名、古地名，如湖北省襄阳县的洄湖。",
      "examples": [
        "蔡州大岸西，有洄湖。",
        "湖名，在湖北省襄阳县。"
      ],
      "traditional_char": "洄"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘洄’为形声字，从水，回声。本义为逆流而上，声旁‘回’表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由水逆流上溯引申为时间上的追溯，语义隐喻推移。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从逆流而上的水，扩展为水流回旋之意。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由动词‘水流回旋’转为名词‘回旋的水流、涡流’。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以地形特征命名湖泊、地名，即因水流回旋而得名。"
    }
  ]
