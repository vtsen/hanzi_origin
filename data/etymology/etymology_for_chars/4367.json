{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "福，福运，幸福",
      "examples": [
        "门衰祚薄，晚有儿息。",
        "若能类善物，以混厚民人者，必有章誉蕃育之祚。"
      ],
      "traditional_char": "祚"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "赐福，给予幸福或恩泽，保佑",
      "examples": [
        "天祚明德。",
        "皇天嘉之，祚以天下。"
      ],
      "traditional_char": "祚"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "皇位，帝位",
      "examples": [
        "往者王莽作逆，汉祚中缺。",
        "隋祚不长。"
      ],
      "traditional_char": "祚"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "流传，传代",
      "examples": [
        "传祚万世。",
        "祚灵主以元吉。"
      ],
      "traditional_char": "祚"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "年，年岁",
      "examples": [
        "初岁元祚，吉日惟良。",
        "以保年祚。"
      ],
      "traditional_char": "祚"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从示，乍声，表示与祭祀、福禄相关。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "名词“福”转为动词“赐福”，古汉语常见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由“福运”引申为“皇位”（有天命之福的统治）。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "帝位的延续意指“传代”“流传”，故转为“流传”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "将“福”比喻为“年、岁”，反映古人视丰年为福。"
    }
  ]
