{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "由低处向高处走；登高。",
      "examples": [
        "陟彼崔嵬。——《诗·周南·卷耳》",
        "汝陟帝位。——《虞书》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "出发上路；登程；远行。",
      "examples": [
        "若陟遐，必自邇。——《书·太甲下》",
        "嗟予怨行役，三陟窮晨暮。——顏延之《秋胡詩》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "晋升，提升地位或官职。",
      "examples": [
        "陟罚臧否，不宜异同。——诸葛亮《出师表》",
        "三载考绩，三考，黜陟幽明。——《书·舜典》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "帝王登基，登上帝位。",
      "examples": [
        "汝陟帝位。——《书·舜典》",
        "是用命尔继统，宜陟元后。——韩愈《顺宗实录一》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "升遐，帝王逝世升天。",
      "examples": [
        "惟新陟王，毕协赏罚。——《书·康王之诰》",
        "一百年，地裂，帝陟。——《竹书纪年》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "登高以祭；祭祀山岳。",
      "examples": [
        "陟其高山，嶞山喬嶽，允猶翕河。——《诗·周颂·般》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "高，高峻，重叠的山陵。",
      "examples": [
        "山三襲曰陟。——《尔雅·释山》",
        "我見你也有年紀了，怎挑得這重擔，過得這等的陟橋？——《醒世姻緣傳》"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "得到，应验（古音de，与得通用）。",
      "examples": [
        "三曰咸陟。——《周礼·春官》",
        "陟之言得也。——郑玄注"
      ],
      "traditional_char": "陟"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "牡马（通“騭”）。",
      "examples": [
        "四月……執陟攻駒。——《大戴礼记·夏小正》"
      ],
      "traditional_char": "陟"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从阜与步，形象爬升至高地，表示登高、上升之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由登高引申为出发、远行，见先秦用例。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "将“登高”转喻为职位上升或晋升，汉至魏晋用频繁。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由“登高”引申为帝王登基，古代政治语境。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "帝王登基再引申为升天（去世），‘登’至‘升遐’。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "以登高行动作为祭祀山岳的专用用法，周代礼制。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "表示高、高峻、山陵重叠，引申为形容词。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "古代假借为“得”（de），语音类推，语义变化。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "phonetical_loan_shift",
      "note": "通“騭”，象声假借，指牡马，语音作用。"
    }
  ]
