  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从‘也’、‘出’，表示出游、漫游之意；形体上与‘遨’相通。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从游玩的“游逛”引申为游戏、戏弄，多见于先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由人群游乐场合产生喧哗之意，常用作声音嘈杂。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "由随意游乐引申为傲慢、不拘礼法的性格特征，先秦始见。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "以地名为游乐之地得名，其意义由活动转化为实体地名。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "在楚文化中用为未成君无谥号者，身份暧昧，与边缘或闲散状态相关。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "犬长四尺比拟为游荡不羁，以‘敖’命名狗。"
    },
    {
      "source_index": 0,
      "target_index": 9,
      "evolution_type": "function_word",
      "note": "用作姓氏，源自本义之地名或职位。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘敖’与‘熬’音近，后借作“煎熬”。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘敖’与‘廒’音近，亦用于仓库之意。"
    },
    {
      "source_index": 4,
      "target_index": 1,
      "evolution_type": "semantic_extension",
