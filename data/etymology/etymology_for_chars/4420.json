    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "衰疲，年老而體力衰弱。",
      "examples": [
        "師耄，諸將無功，獨嗣業被堅數奮，為諸軍冠。"
      ],
      "traditional_char": "耄"
    }
  ],
