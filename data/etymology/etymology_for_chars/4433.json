{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "多年生草本植物，叶有长柄，开白花，果实红色，味酸甜，即“草莓”。",
      "examples": [
        "草莓味道酸甜。"
      ],
      "traditional_char": "莓"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "落叶灌木，高近二米，果实红色，由多数小核果合成，可食。亦称“山莓”、“悬钩子”，即“木莓”。",
      "examples": [
        "山莓生于山野。"
      ],
      "traditional_char": "莓"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "常绿蔓生小灌木，果实红色，到冬天才熟，可食，即“寒莓”。",
      "examples": [
        "寒莓于冬日成熟。"
      ],
      "traditional_char": "莓"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "蔓生草本植物，开淡黄绿色小花，供药用，即“乌蔹莓”。",
      "examples": [
        "乌蔹莓可入药。"
      ],
      "traditional_char": "莓"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从艸，毎声。最初表示某种植物（草莓），后泛指多种类似果实。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "植物名称从草莓扩展至类似的其它红色小果实的灌木（木莓）。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "继续用于描述类似特征的小灌木（寒莓）。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "泛指果实类似且可药用的蔓生植物（乌蔹莓）。"
    }
  ]
}