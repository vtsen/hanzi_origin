    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "芫荽，一年生草本植物，通称香菜，具强烈香气，可食用或入药。",
      "examples": [
        "蔥中亦種胡荽，尋手供食，乃至孟冬。",
        "蓼荽芬芳。"
      ],
      "traditional_char": "荽"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "薑类药用植物，通“葰”，具体植物不详。",
      "examples": [
        "荾作葰同。",
        "與葰同。"
      ],
      "traditional_char": "荽"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "药草名，通“萎”，可入药。",
      "examples": [
        "荽藥草通作萎。",
        "熒委萎葉似作表白裏青可啖。"
      ],
      "traditional_char": "荽"
    }
  ],
