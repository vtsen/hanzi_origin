{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "莎草，莎草科的多年生草本植物，其地下块根称为“香附子”，可入药。",
      "examples": [
        "田无立禾，路无莎薠。",
        "薜莎青薠。",
        "青鞦莎靡。"
      ],
      "traditional_char": "莎"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "花叶脱落，凋谢。",
      "examples": [
        "尔杞未棘，尔菊未莎，其如予何，其如予何。"
      ],
      "traditional_char": "莎"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "蓑衣、蓑笠等用莎草制成的器物。",
      "examples": [
        "莎笠（即蓑笠）；莎衣（衰衣）"
      ],
      "traditional_char": "莎"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "莎鸡，虫名，即“纺织娘”，学名螽斯。",
      "examples": [
        "六月莎鸡振羽。"
      ],
      "traditional_char": "莎"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "用于人名、地名。",
      "examples": [
        "莎车，国名。"
      ],
      "traditional_char": "莎"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从艸，沙声，表示草类，本义为‘莎草’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以莎草为材料制蓑衣、蓑笠，名称引申。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "莎草枯萎凋谢，引申为花叶脱落。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "植物名延伸用于地名、人名，多见用法，如‘莎车’。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "因昆虫多生于莎草间，取草名指虫名。"
    }
  ]
}