{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "（本义）古代立在城郭、宫殿、官署、陵墓或驿站路边的标志性木柱，后称华表。",
      "examples": [
        "桓，亭邮表也。——《说文》",
        "瘗寺门桓东。——《汉书·尹赏传》",
        "三家视桓楹。——《礼记·檀弓》"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用于门扇内面两边固定门闩的直木。",
      "examples": [
        "门关再重……及视关入桓浅深。——《墨子·备城门》"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "大；盛大。",
      "examples": [
        "玄王桓拨。——《诗·商颂·长发》",
        "桓蒲（祭祀用的大蒲席）"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "威武、威严的样子；勇武。",
      "examples": [
        "尚桓桓。——《书·牧誓》",
        "桓桓于征。——《诗·鲁颂》",
        "～～陈将军，仗钺奋忠烈。"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "山名。在今江苏省铜山县东北。",
      "examples": [
        "昔者齐燕战于桓之曲，燕不胜。——《战国策·齐策五》"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "水名。即今白龙江，发源于甘肃省西倾山。",
      "examples": [
        "西倾因桓是来，浮于潜，逾于沔。——《书·禹贡》"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "木名。即无患木，叶似柳，皮黄白色。",
      "examples": [
        "无患木，烧之极香，辟恶气，一名噤婁，一名桓。——《酉阳杂俎》"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "汉代有桓谭。"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 8,
      "part_of_speech": "verb",
      "meaning": "停留，徘徊（“盘桓”）。",
      "examples": [
        "鯢桓之审为渊。——《庄子·应帝王》",
        "抚孤松以盘桓。——陶潜《归去来辞》"
      ],
      "traditional_char": "桓"
    },
    {
      "index": 9,
      "part_of_speech": "noun",
      "meaning": "忧虑。",
      "examples": [
        "毕桓于黎民般。——《逸周书·祭公》"
      ],
      "traditional_char": "桓"
    }
  ],
