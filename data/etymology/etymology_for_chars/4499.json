    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "言语受阻，不能畅通（因情感或其他原因，喉咙发堵，说不出话）",
      "examples": [
        "闻之哽咽。",
        "他哽住了，他说不下去了。",
        "哽，语为舌所介也。"
      ],
      "traditional_char": "哽"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "食物堵塞喉咙，难以下咽；噎住",
      "examples": [
        "口不容而强吞之者必哽。",
        "初食鲙数叠，忽似哽，咯出一骨珠子。",
        "女欲寡人之哽邪？"
      ],
      "traditional_char": "哽"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "阻塞；堵住",
      "examples": [
        "凡道不欲壅，壅则哽。",
        "俯仰无少哽。",
        "忽有一口闷气，哽住胸腔。"
      ],
      "traditional_char": "哽"
    },
    {
      "index": 3,
      "part_of_speech": "interjection",
      "meaning": "叹词，表示应诺、疑问或不满等",
      "examples": [
        "哽，你先行，随后便来也。",
        "可是，几年来，鸦片之所以流毒内地，屡禁不绝，为什么？哽！"
      ],
      "traditional_char": "哽"
    },
    {
      "index": 4,
      "part_of_speech": "onomatopoeia",
      "meaning": "象声词，表示咽喉等的声音",
      "examples": [
        "鼻孔里响出了一种声音，‘哽！’过了不一会又是——‘哽，哽！’"
      ],
      "traditional_char": "哽"
    }
  ],
