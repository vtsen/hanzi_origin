  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“善、美好”引申为“开始”，如美好开端，用于古礼、诗经；西周及春秋见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "由副词“开始”转为动词“作、建造”，如“俶其城”；用法活化，与‘作’同。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由动词“作、建造”扩展为“整理”，意为开始准备、整备物品，汉以后常用。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由“善、美好”引申为“厚”，美好可比喻为厚重，见王引之注。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "“美好”在文学修辞中转为“奇异”，指超常、特殊。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "“开始”引申为“忽然”，即动作或状态突然开始，常见于文言虚词。"
    },
    {
      "source_index": 5,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "“奇异”专指品质卓绝之人，引申为“俶傥”，同“倜傥”，指洒脱不群的人格特质。"
    }
  ]
