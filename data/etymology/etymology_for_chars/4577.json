      "part_of_speech": "adjective",
      "meaning": "蒙昧无知，愚钝。",
      "examples": [
        "天降生民，倥侗颛蒙。——《法言·序》",
        "孰称古初朴蒙倥而无争。——柳宗元《贞符》"
      ],
      "traditional_char": "倥"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "绷着脸。",
      "examples": [
        "坐在高处，倥着脸，不言不语。——《西游记》第四五回"
      ],
      "traditional_char": "倥"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "事情急迫、繁忙。",
      "examples": [
