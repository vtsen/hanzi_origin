{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "箭靶；射箭的靶子。",
      "examples": [
        "臬，射準的也。——《說文》",
        "桃弧棘矢，所發無臬。——張衡《東京賦》"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "（引申）目標，准則，標準。",
      "examples": [
        "以今為臬也。",
        "統一佛教國民為臬。",
        "又如：臬極（准則；標準）"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古代測量日影的標杆，立杆以測日影。",
      "examples": [
        "陳圭置臬，瞻星揆地。——《石闕銘·序》"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "法度，刑法。",
      "examples": [
        "王曰：外事，汝陳時臬，司師茲殷罰有倫。——《書·康誥》",
        "臬，法也。"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "主管一省司法的官員（如“臬司”、“臬台”的簡稱）。",
      "examples": [
        "臬司（官名。即元的肅政廉訪司）",
        "臬宪（舊時對按察使的敬稱）"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "終極，極限。",
      "examples": [
        "其深不測，其廣無臬。——漢·王粲《游海賦》"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "安裝在船側用以支架槳的木樁。",
      "examples": [
        "如人搖櫓，臬為之礙故也。——宋·沈括《夢溪筆談》"
      ],
      "traditional_char": "臬"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "門橜，門閾。",
      "examples": [
        "在地者謂之臬。——《爾雅·釋宮》"
      ],
      "traditional_char": "臬"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "從木，自聲（自作聲符，木為意符）；本義為射箭的靶子，是形聲字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由靶子的“目標、準確之處”引申出目標、標準的涵義，東漢以後常見。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“靶子”比喻為“測日影的標杆”，皆為標的物。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以“標準”之義借指為“法度”，常見於先秦文獻。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "自“法度”名詞化為職官名，即專管法律制度的官員。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "“靶”引申為“極限、終極”，由目標義擴大至極限義。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "由標物引申為船用支樁，均為標記、定位之物，宋以後用法。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "由“靶（標的物）”延伸為“門橛”等標志性柱狀物。"
    }
  ]
}