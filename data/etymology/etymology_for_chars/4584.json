{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "到来，来到，与“往”相对。",
      "examples": [
        "天马徕，从西极。",
        "氐羌徕服。"
      ],
      "traditional_char": "徠"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "招来，使之前来（尤指招揽、吸引）。",
      "examples": [
        "徕三晋之民，而使之事本。",
        "以广招徕。"
      ],
      "traditional_char": "徠"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "慰劳，慰问劳苦之人。",
      "examples": [
        "亲自劳徕。",
        "抚循劳徕，甚得物情。"
      ],
      "traditional_char": "徠"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "劝勉，勉励。",
      "examples": [
        "通“勑”，劝勉。——《说文》",
        "于是高祖引孝孙、胄玄等，亲自劳徕。"
      ],
      "traditional_char": "徠"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从彳表行走，来声，本义为‘到来’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘来到’引申为‘招来’（使他人来到）；汉代至后世常见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘招来’进一步发展为‘慰劳’，常用于慰问、安抚。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "‘慰劳’进一步引申为‘劝勉’，古籍中与‘勑’通用。"
    }
  ]
