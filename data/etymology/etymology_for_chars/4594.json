{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "手掌或足底因长期劳动或摩擦而生成的硬厚皮，老茧、胼胝。",
      "examples": [
        "手足胼胝，面目黎黑。——《史记·李斯列传》",
        "手足胼，面目黧黑，劳有功者也。——《韩非子·外储说左上》",
        "苟无切玉刀，难除指上胼。——皮日休《鲁望昨以五百言见贻…》"
      ],
      "traditional_char": "胼"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "坚固、不容易破损。",
      "examples": [
        "参见“胼冒”。",
        "胼固也。——《太元坚》"
      ],
      "traditional_char": "胼"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "大脑两半球的底部联合大脑两半球的神经纤维组织，称为胼胝体。",
      "examples": [
        "胼胝体（医学术语）"
      ],
      "traditional_char": "胼"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "腹胀。",
      "examples": [
        "胼，腹胀也。——《篇海类编》"
      ],
      "traditional_char": "胼"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从月（肉），并声，表达皮肉变厚之义。"
    }
  ],
  "edges": [
