  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "“桀”初作㘶，本义为木桩，形声兼象形字，从木，舛为符号，形似鸡栖之木，后引申诸义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由高出的木桩比喻高出的人，古代比喻杰出之意（先秦）"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "从形容词‘杰出’泛化为称呼‘杰出的人’（两汉）"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "‘特出’引申出‘桀骜’——不服约束、野性难驯，引申为‘凶悍、凶暴’（战国、两汉见）"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "以‘特出、杰出’之义用作夏桀之名，后专指夏朝末君主"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "reanalysis",
      "note": "木桩形象与举物相联系，后与‘揭’音义通假，表示‘举起’（通假字现象）"
    }
  ]
