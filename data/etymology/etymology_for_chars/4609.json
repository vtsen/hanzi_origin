    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "茶上浮沫，煮茶时形成的厚泡沫，称为“餑”或“沫餑”。",
      "examples": [
        "凡酌，置诸碗，令沫餑均。",
        "餑恐生烟翠。"
      ],
      "traditional_char": "餑"
    }
  ],
