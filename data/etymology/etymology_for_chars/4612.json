    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "（通“恋”）爱慕不舍。",
      "examples": [
        "上所以挛顾念我者，乃以平生容貌也。——《汉书·孝武李夫人传》"
      ],
      "traditional_char": "攣"
    }
  ],
