      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古都邑名，商汤的都城，相传有三处（南亳、北亳、西亳），包括今河南商丘、偃师一带。",
      "examples": [
        "汤始居亳。",
        "从攻秦军，出亳南。"
      ],
      "traditional_char": "亳"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "地名，亳州或亳县，今位于安徽省。",
      "examples": [
        "亳，国名。春秋时陈地。汉为沛之谯县，晋为南兖州，后周为亳州。"
      ],
      "traditional_char": "亳"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "亭名，汉代京兆杜陵亭名，在今陕西西安市东南。",
      "examples": [
        "亳，京兆杜陵亭也。"
      ],
      "traditional_char": "亳"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古国名，故址在今安徽亳县。",
      "examples": [
        "亳，国名。"
      ],
      "traditional_char": "亳"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
