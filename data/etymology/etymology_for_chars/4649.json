    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "可作为黑色染料的矾石、矿物质，亦泛指黑泥、黑土。",
      "examples": [
        "以涅染缁，则黑于涅。",
        "白沙在涅，与之俱黑。",
        "女床之山，其阴多石涅。"
      ],
      "traditional_char": "涅"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "染黑、以黑色染物，或用墨涂物，亦指刺青、刺身涂墨。",
      "examples": [
        "涅而不缁。",
        "涅齿。",
        "岳武穆涅‘尽忠报国’于背上。"
      ],
      "traditional_char": "涅"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "佛教用语，指超脱生死的最高境界（涅槃），亦为僧人的代称。",
      "examples": [
        "一佛出世，二佛涅槃。",
        "智之秉情，对理斯涅。"
      ],
      "traditional_char": "涅"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古水名或地名。",
      "examples": [
        "涅水，东迳涅氏县。",
        "丹水涅池。"
      ],
      "traditional_char": "涅"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "化，孵化。",
      "examples": [
