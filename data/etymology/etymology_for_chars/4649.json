  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水、土，曰声，反映‘黑色染料的矾石’本义，‘水’和‘土’与黑泥、矿物有关，‘曰’提供声旁。"
    }
  ],
