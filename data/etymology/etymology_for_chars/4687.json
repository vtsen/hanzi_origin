  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从女，音声为‘姬’。本义为上古母系氏族之姓，‘女’表语义，‘㝵’为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由高贵姓氏引申为对妇女的美称，早在先秦就存在。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_narrowing",
      "note": "由泛指美称专指宫廷女官，多见于汉代。"
    },
