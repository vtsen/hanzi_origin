  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从女，尾声，本义为顺从。“女”表意，指顺从、柔顺；“尾”表声。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "amelioration",
      "note": "由顺从引申为美，因顺从可引申出温婉美好，东汉至南北朝常见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "顺从引申为努力做事，古人用顺应、努力有相通义。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "努力不倦的形象引申为形容谈话不倦，后用于“娓娓而谈”等成语。"
    }
  ]
