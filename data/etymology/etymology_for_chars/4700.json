      "traditional_char": "驪"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "山名。即骊山，位于陕西临潼县。",
      "examples": [
        "骊山会（西周幽王骊山烽火戏诸侯事）"
      ],
      "traditional_char": "驪"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "古邑名，在今陕西临潼县，周初骊戎所居。",
      "examples": [
        "秦置骊邑，北宋时改称临潼"
      ],
      "traditional_char": "驪"
    },
    {
      "index": 5,
      "part_of_speech": "adverb",
      "meaning": "通“丽”，并列，附丽，用两匹马驾车。",
