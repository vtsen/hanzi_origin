  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由指深黑色的马泛指黑色属性（如骊色、骊驹），属语义扩展；两汉以来见于文学。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "黑色形容词意义引申为‘黑龙’，因龙在神话体系中颜色为象征；为比喻借代。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以产地命名地名（骊山），因所在地产黑色马，故得名。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由山名‘骊山’转指古邑（骊邑），皆以地理相关性为据。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘骊’（驪）借作‘丽’，指并列、附丽，两马并驾之意，属古书通假。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "动物名转为姓氏用，是古代用动物名作氏族的情形。"
