  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "会意兼形声，从糸（表示绳索），妥声，表示登车时的绳索，带有安妥之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由登车之绳象征“使人安定”引申为“安抚安定”，见先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“安稳”引申为地理区划的名称，表示顺服于王政。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "因绳索有旌旗系带引申为旌旗和旒。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以物名借指地名，多见于中国古代地理命名习惯。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由带来安妥、稳妥的属性引申为“安好、安泰、舒缓”。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "安抚/安定——>临阵退却之“安定、止战”，含义漂移。"
    },
    {
      "source_index": 4,
      "target_index": 6,
