    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "扫帚，也作“篲”。",
      "examples": [
        "太公拥彗。——《汉书·高帝纪》",
        "彗，埽竹也。——《说文》",
        "国中以策彗卹勿驱。——《礼记·曲礼》"
      ],
      "traditional_char": "彗"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "扫；拂。",
      "examples": [
        "戈铤彗云。——班固《东都赋》",
        "高锋彗云。——《后汉书·光武帝纪下》"
      ],
      "traditional_char": "彗"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "彗星，拖有长光像扫帚的星，俗称“扫帚星”。",
      "examples": [
        "彗，所以除旧布新也。——《左传·昭公十七年》",
        "彗星者，天之旗也。——《河图帝通纪》",
        "登九天兮抚彗星。——《九歌·少司命》"
      ],
      "traditional_char": "彗"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "在阳光下曝晒。",
      "examples": [
        "日中不彗，是谓失时。——《六韬》"
      ],
      "traditional_char": "彗"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "聪慧的，智能的（通“慧”）。",
      "examples": [
        "淮南王有女陵，彗有口辨。——《史记·淮南衡山列传》"
      ],
      "traditional_char": "彗"
    }
  ],
  "formations": [
