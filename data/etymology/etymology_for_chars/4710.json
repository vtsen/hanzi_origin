    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代农具“耒耜”的下端，形状似今铁锹和铧，耒端铲土的部分，用于翻土，最早为木制，后以金属制。",
      "examples": [
        "斲木为耜。——《易·系辞》",
        "禹亲自操耜。——《庄子·天下》",
        "脩来耜。——《礼记·月令》",
        "民无悬耜，野无奥草。——《国语·周语中》"
      ],
      "traditional_char": "耜"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "泛指农具。",
      "examples": [
        "三之日于耜。——《诗·豳风·七月》"
      ],
      "traditional_char": "耜"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "用耜铲土。",
      "examples": [
        "冬日至而耜之。——《周礼·薙氏》"
      ],
      "traditional_char": "耜"
    }
  ],
