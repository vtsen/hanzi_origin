{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "两手横向对外旁击；用双手向左右击打。",
      "examples": [
        "捭，两手击也。——《说文》",
        "拉虎捭熊，予犹稚童。——庾信《竹杖赋》",
        "莫不衄锐挫芒，拉捭摧藏。——左思《吴都赋》"
      ],
      "traditional_char": "捭"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "摆弄，挥动；用手拨动。",
      "examples": [
        "角插戟，尾捭风。——卢仝《月蚀诗》",
        "捭八股，父兄师友之期许者，入学、中举、会试、做官而已。——颜元《存人编》"
      ],
      "traditional_char": "捭"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "分开，掰开，撕裂。",
      "examples": [
        "其燔黍捭豚。——《礼记·礼运》",
        "捭，开也。——《广雅》",
        "捭破我心神，至今患心风不禁。——《太平广记》"
      ],
      "traditional_char": "捭"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "排除，排去，屏退。",
      "examples": [
        "外天地，捭山川。——《淮南子·要略训》",
        "捭，屏去也。——高诱注"
      ],
      "traditional_char": "捭"
    }
  ],
