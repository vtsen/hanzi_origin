  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由埋土、下葬引申为土筑之物，成为射箭用的土墙；时间为战国至汉代。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由土墙射垛进一步比喻为分水堤坝，均为土筑结构；多见于两汉及后世水利记载。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘堋’假借‘朋’用，表示群集。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "unknown",
      "note": "“振動”之义来源尚不明确，或与土体运动有关。"
    },
    {
      "source_index": 4,
      "target_index": 5,
