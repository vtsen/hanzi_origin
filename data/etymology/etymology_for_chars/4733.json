  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 3,
      "note": "形声字，从手，夜声。本作‘腋’，指腋下、两边。后借用为动作、塞物等义。"
    }
  ],
  "edges": [
    {
      "source_index": 3,
      "target_index": 0,
      "evolution_type": "semantic_shift",
      "note": "由腋部位引申为用手搀扶至腋下，产生扶持义，见中古汉语用法。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由实际搀扶引申为比喻的帮助、扶持，常用在书面语。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "因腋下习惯用来夹藏物品，故引申为把东西塞在衣袋或夹缝里。"
