{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "抓住头发，揪持；亦泛指抓、揪住某物。",
      "examples": [
        "捽胡投何罗殿下。",
        "连肩胛只一提，右手早捽住西门庆左脚。",
        "捽下提殴之。",
        "小孩儿捽住妈妈的衣服。"
      ],
      "traditional_char": "捽"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "拔，拔取（草等）。",
      "examples": [
        "农夫父子暴露中野，不避寒暑，捽屮杷土，手足胼胝。",
        "王禹偁《种菜了雨下》诗：“废畦添粪壤，胼手捽荒芜。”"
      ],
      "traditional_char": "捽"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "投、甩、摔。",
      "examples": [
        "一只手揪住那厮衣领，一只手掐住脚腕，滴溜扑捽箇一字交。",
        "吴伟业《东莱行》：“卫尉捉头捽下殿。”",
        "往庭中一捽。"
      ],
      "traditional_char": "捽"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "抵触，冲突；相互冲撞、争斗。",
      "examples": [
        "戎夏交捽。",
        "齐人之井饮者相捽也。",
        "井养不穷，齐人尚争，乃相捽。",
        "解捽者不在于别格，在于批抌。"
      ],
      "traditional_char": "捽"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "摩擦，揉搓（方言或象声词用法）。",
      "examples": [
        "捽兀：搔摩状。",
        "捽攃，行草声。"
      ],
      "traditional_char": "捽"
    }
  ],
