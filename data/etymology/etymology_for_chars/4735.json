    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "reanalysis",
      "note": "与‘裒’混用后，假借为‘减’，属于字形混用后的意义再分析。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
