      "meaning": "用五指或工具扒土或扒物",
      "examples": [
        "今盐官入水取盐为掊。",
        "见地如钩状，掊视得鼎。",
        "先卧锄耨却燥土，然后掊坑，大如斗口。"
      ],
      "traditional_char": "掊"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "聚敛；搜括",
      "examples": [
        "掊克乃为材。",
        "峻掊亟敛，闾里为空。",
        "素殚百姓力，为吾掊怨天下。"
      ],
      "traditional_char": "掊"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "抨击；攻击",
      "examples": [
        "吾为其无用而掊之。",
        "勾践终掊而杀之。",
        "自掊击于世俗。"
      ],
      "traditional_char": "掊"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "击破；损毁",
      "examples": [
        "吾为其无用而掊之。",
        "掊斗折衡。",
        "尽掊土偶五六，掷之河中。"
      ],
      "traditional_char": "掊"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "偃仆、倒倒（同“仆”，使倒下）",
      "examples": [
        "乃顾麾左右执戟者掊兵罢去。",
        "或拉髆掣胸，掊死深阱。",
        "皆仆兵罢。"
      ],
      "traditional_char": "掊"
