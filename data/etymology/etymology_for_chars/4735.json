  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从手，咅声，本指用手扒土，‘手’表义，‘咅’表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由用手取物转为搜敛聚集财物，语义转喻，汉至魏晋注解可见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由手动作引申为攻击拍击的动作感，秦汉间可见。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "攻击义进一步具体化为击破、损毁，语义细化，见《庄子》《韩愈》。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "扒倒、倒下，动作相关语义演化，见史记、汉书用例。"
