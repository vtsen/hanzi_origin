{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "耳朵长大，耳垂下垂的样子，后引申为年老之貌",
      "examples": [
        "聃耳属肩，绮眉覆颧。",
        "聃然，老旄之貌也。"
      ],
      "traditional_char": "聃"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "吐舌的样子，伸出舌头的状态",
      "examples": [
        "老子惊怪，故吐舌聃然，遂有老聃之号。"
      ],
      "traditional_char": "聃"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "迷恋，沉溺",
      "examples": [
        "方其聃於色也，屏亲昵，绝交游，逃于后庭，以昼足夜。"
      ],
      "traditional_char": "聃"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古国名“聃”",
      "examples": [
        "管、蔡…聃…文之昭也。"
      ],
      "traditional_char": "聃"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏，用作人名，常指老子字聃",
      "examples": [
        "吾闻诸老聃。"
      ],
      "traditional_char": "聃"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "“聃”字从“耳”，本义为耳朵长大（耳曼），象形耳下垂的样子。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“垂耳”形象引申为“吐舌聃然”的外貌模拟，语出道家典故。"
    },
    {
      "source_index": 0,
      "target_index": 3,
