  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从土，黄声，意指黄色的黏土。《说文》明言以‘黄’表声，‘土’表义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由黄色黏土引申为同名野生植物堇菜等，因生于黄土上或色近土。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "堇菜类泛指中某些药用植物，部分引申为乌头等有毒药材，取部分为整体。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘堇’假借为‘仅’，由声近而假借表少。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "古文中用于‘时’义，可能由土（季节、田土）引申出时机、时节。"
    },
    {
      "source_index": 0,
      "target_index": 5,
