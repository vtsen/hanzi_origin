{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代用于束缚罪人双手的木制刑具，即木手铐",
      "examples": [
        "梏，手械也。——《说文》",
        "在足曰桎，在手曰梏。——《易·蒙》疏",
        "甫愍然为之改容，乃得并解桎梏。——《汉书·范滂传》"
      ],
      "traditional_char": "梏"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "用于防止牛角触人而安在牛角上的横木",
      "examples": [
        "告，牛触人，角箸横木，所以告人也。——《说文》"
      ],
      "traditional_char": "梏"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "戴上手铐，泛指械系、拘禁",
      "examples": [
        "执而梏之。——《左传·成公十七年》",
        "帝乃梏之疏属之山。——《山海经》"
      ],
      "traditional_char": "梏"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "约束、束缚（引申为限制言论、思想等）",
      "examples": [
        "不以一流派之哲学一宗门之教义梏其心。——蔡元培"
      ],
      "traditional_char": "梏"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "大，正直（古义，见于典籍）",
      "examples": [
        "诗云：有梏德行，四国顺之。——《礼记·缁衣》"
      ],
      "traditional_char": "梏"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "分散（分、散之意，今罕用）",
      "examples": [
        "散毛族，梏羽群。——《后汉书·马融传》"
      ],
      "traditional_char": "梏"
    }
  ],
