  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“硭”为形声字，从石，芒声，本指一种矿物（硭硝），表示与石头相关的物质。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由矿物名称转用于地名，因该矿常见于某山或某山以此得名。"
