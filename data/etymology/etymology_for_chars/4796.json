    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "山上的大石，或指坚硬的石头、美石。",
      "examples": [
        "上无草木，而多硌石。——《山海经》",
        "是故不欲禄禄若玉，硌硌若石。——《老子》"
      ],
      "traditional_char": "硌"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "石块或砂砾，小石子堆。",
      "examples": [
        "对面南房上又站着一个黑粗的大汉……已把房上的瓦揭起一硌来放在身旁。——《儿女英雄传》"
      ],
      "traditional_char": "硌"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "堆叠，摞起来。",
      "examples": [
        "他却搬张桌子，又硌张椅子，坐在上面。——《儿女英雄传》"
      ],
      "traditional_char": "硌"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "身体与凸起的硬物接触，感到难受或受到损伤。",
      "examples": [
        "这条石子路真硌脚。",
        "妈妈很嚼不动那个，没的倒硌了他的牙。——《红楼梦》"
      ],
      "traditional_char": "硌"
    },
    {
      "index": 4,
      "part_of_speech": "onomatopoeia",
      "meaning": "模仿硬物碰撞的声音，如“硌吱”、“硌磴”。",
      "examples": [],
      "traditional_char": "硌"
    }
  ],
  "formations": [
    {
