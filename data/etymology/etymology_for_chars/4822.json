  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从日，希声，表示因日照而干燥。本义为晒干。‘日’表意义，‘希’表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由晒干引申为阳光晒的动作，东齐北燕之语义扩展。"
    },
    {
      "source_index": 1,
      "target_index": 2,
