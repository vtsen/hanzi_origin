  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“趺”从足声夫形，会意兼形声，表示脚背之处。“足”为意符，“夫”声符，最初表脚背。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由脚背泛指到脚。字义扩大。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "脚引申为足迹，即以局部代表相关痕迹。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "脚比喻为山脚，常见地理用法。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "脚比喻器座、碑座之脚；泛指支撑的底部。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "从脚引申为两脚交叠而坐，专指盘腿坐的动作。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "脚引申为花萼，因其位于底部。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "同音假借，部分地区“趺”借用为‘趴下’，与“俯”通。"
    }
  ]
