    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "白蛉子，一种比蚊子小的小飞虫，能吸人畜血，传播黑热病",
      "examples": [
        "白蛉子咬人很痒。"
      ],
      "traditional_char": "蛉"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "蜻蛉，昆虫名，蜻蜓之类",
      "examples": [
        "蜻蛉点水。"
      ],
      "traditional_char": "蛉"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "螟蛉，螟蛉蛾的幼虫；亦指义子、抱养的孩子",
      "examples": [
        "螟蛉有子，蜾蠃负之。",
        "他是我的螟蛉。"
      ],
      "traditional_char": "蛉"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "桑根（古语意），或指桑树根部的昆虫",
      "examples": [
        "一曰桑根。"
      ],
      "traditional_char": "蛉"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "从虫，令声，表示与虫类相关，初作蜻蛉用，后义扩展。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
