{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "某些寄生蠕虫（如绦虫、血吸虫、线虫等）的幼体，如“胞蚴”、“毛蚴”、“尾蚴”。",
      "examples": [
        "毛蚴",
        "尾蚴",
        "胞蚴"
      ],
      "traditional_char": "蚴"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "龙、蛟龙或虫蛇等动物蜿蜒曲折行进的样子，也指古文中形容龙行的词，如“蚴蟉”、“蚴虬”。",
      "examples": [
        "青龙蚴蟉于东廂",
        "龍形蜿曲貌",
        "中宵光上燭。參見“蚴蟉”"
      ],
      "traditional_char": "蚴"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "蜂的一种（土蜂、小蜂），古代燕赵间称之为“蚴蛻”或“蚴蜕”。",
      "examples": [
        "蜂之小者，燕、趙之閒或謂之蚴蛻",
        "蠭其小者謂之蚴蛻"
      ],
      "traditional_char": "蚴"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "屈曲移动、改变原状（多见于方言或文言用法）；亦作呶动。",
      "examples": [
        "宛轉生動曰蚴",
        "蚴，音牛，去聲",
        "僅僅看見人家嘴巴蚴"
      ],
      "traditional_char": "蚴"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "形声字，“虫”为意符，表示与虫类相关，“幼/黝/幽”等为声符，最早用于形容龙、虫屈曲蜿蜒的样子。"
    }
  ],
