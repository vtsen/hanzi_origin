        "闲泛晴波唼绿萍。——宋·陆游"
      ],
      "traditional_char": "唼"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "泛指咬、吃。",
      "examples": [
        "唼，咬也。《玉篇》",
        "唼食（咬，吞食）；唼啮（啃咬）"
      ],
      "traditional_char": "唼"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "吮吸；婴儿吸吮乳头的动作。",
      "examples": [
        "让他缓缓的唼着自己的乳头。——沙汀《困兽记》",
        "唼着嘴唇。——丁玲《松子》"
      ],
      "traditional_char": "唼"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "饮牲血，特指古代歃血盟誓仪式时吸血。",
      "examples": [
        "与高帝唼血而盟。《汉书·王陵传》",
        "唼血乘胜。《史记·魏豹传》"
      ],
      "traditional_char": "唼"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "谗言，说坏话。",
      "examples": [
        "灵修既信椒兰之唼佞兮。——扬雄《广离骚》"
      ],
      "traditional_char": "唼"
    }
  ],
