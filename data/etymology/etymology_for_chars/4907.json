{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "佛经中的唱词，梵语“偈陀”的省称，多指四句一偈的佛家韵文。",
      "examples": [
        "日诵千偈，偈有三十二字，凡三万二千言。",
        "僧人诵偈。",
        "偈颂、偈文、偈句"
      ],
      "traditional_char": "偈"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "勇武，勇敢有力量的样子。",
      "examples": [
        "其人晖且偈。",
        "偈偈乎揭仁义。"
      ],
      "traditional_char": "偈"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "行动急促，快速驰骋的样子。",
      "examples": [
        "偈兮若驾驷马。",
        "匪车偈兮。"
      ],
      "traditional_char": "偈"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "通“憩”，休息。",
      "examples": [
        "度三峦兮偈棠梨。",
        "偈，息也。"
      ],
      "traditional_char": "偈"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘亻’表意义（人），‘曁’表声，本义为勇武之貌，属于形声字。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由勇猛、勇武的含义引申为行动急促、疾驰，比喻动作为勇猛或迅捷，汉代已见。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "从快速动作引申为动作停止，进入休息状态，由形容词用法转为动词用法，见于古文。"
    },
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "phonetical_loan_shift",
      "note": "因音近梵语“gāthā”(颂)，所以借用“偈”表示佛经中的唱词，属于音译借用，魏晋南北朝佛教传播时期普及。"
    }
  ]
