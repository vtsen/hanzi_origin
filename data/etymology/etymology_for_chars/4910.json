    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "弯腰，曲背。",
      "examples": [
        "偻身而下声。",
        "俯偻从命。"
      ],
      "traditional_char": "僂"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "驼背的人，曲背的人。",
      "examples": [
        "齐使秃者御秃者，使眇者御眇者，使跛者御跛者，使僂者御僂者。",
        "伛偻提携，往来而不绝者，滁人游也。"
      ],
      "traditional_char": "僂"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "泛指弯曲、屈曲。",
      "examples": [
        "虽有圣人之知，未能偻指也。",
        "义为丞相时年八十余，短小无须眉，貌似老媪，行步俛僂。"
      ],
      "traditional_char": "僂"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "速度快，迅速。",
      "examples": [
        "夫人不偻，不可使入。",
        "卖之不可偻售也。"
      ],
      "traditional_char": "僂"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "绿林或盗贼的部下、仆从（用于“偻儸”）。",
      "examples": [
        "偻儸"
      ],
      "traditional_char": "僂"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "佝僂病（病症名，指脊梁弯曲的病）。",
      "examples": [
        "佝僂",
        "佝偻病"
      ],
      "traditional_char": "僂"
    }
  ],
