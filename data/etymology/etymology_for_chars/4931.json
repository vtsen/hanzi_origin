      "part_of_speech": "noun",
      "meaning": "四通八达的大路；大道。",
      "examples": [
        "馆宅充廛里，女士满庄馗。",
        "崩榛塞路，崢嶸古馗。",
        "九达道也，似龟背，故谓之馗。"
      ],
      "traditional_char": "馗"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "面颊骨。",
      "examples": [],
      "traditional_char": "馗"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "大菌（如：‘中馗’）。",
      "examples": [
        "爾雅·釋草：中馗菌。",
        "大者名中馗，小者名菌。"
      ],
      "traditional_char": "馗"
    },
    {
      "index": 3,
      "part_of_speech": "other",
      "meaning": "钟馗，传说中能驱邪捉鬼的神名。",
      "examples": [
        "臣终南山进士钟馗，除天下虚耗之孽。",
        "吴道子画钟馗像。"
      ],
      "traditional_char": "馗"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从九首，形容九条道路会合，表示大道；本义与'逵'同。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "面颊骨突出，形似九达之路，或会聚之形，用以指代面颊骨，古书有此用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "大菌形如路会合，故以'馗'称大菌或菌类群体，见古籍注释。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "function_word",
      "note": "钟馗为人名，取‘大道’广达、多头多能之意，后专指神祇。"
    }
  ]
