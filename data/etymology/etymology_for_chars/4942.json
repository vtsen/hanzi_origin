{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代用牦牛尾或兼五采羽毛饰竿头的旗子。",
      "examples": [
        "游车载旌析羽。——《说文》",
        "斿车载旌。——《周礼·春官·司常》"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代旗帜的总称，泛指旗帜。",
      "examples": [
        "旌蔽日兮敌若云。——《楚辞·九歌·国殇》",
        "舳舻千里，旌旗蔽空。"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古代使者所持的节。",
      "examples": [
        "眼望旌节至，耳听到消息。——《金瓶梅》"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "表彰，表扬。",
      "examples": [
        "旌其所为。——明·张溥《五人墓碑记》",
        "朝有进善之旌。"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "表明，标识；作标识或区别之用。",
      "examples": [
        "故为车服、旗章以旌之。——《国语·周语上》"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "识别，辨别。",
      "examples": [
        "誠应宠赏，以旌其美。——曹操《表论田畴功》",
        "旌别淑慝。——《书·毕命》"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "发挥（如：旌智，发挥智慧）。",
      "examples": [
        "旌智（发挥智慧）"
      ],
      "traditional_char": "旌"
    },
    {
      "index": 7,
      "part_of_speech": "other",
      "meaning": "通“精”，精细。",
      "examples": [
        "旌密（精密）"
      ],
      "traditional_char": "旌"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从“㫃”表旗帜相关，“生”表音，原指饰以牦牛尾羽的旗子。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由具体饰羽之旌扩展为旗帜的泛称，见于战国及秦汉。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "以旗帜权威象征权力，转指使者所持节。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "旗帜有标明、标识之功能，引申为“表明”。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由表明引申为‘识别、辨别’。"
    },
    {
      "source_index": 4,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "标志显明，引申为‘表彰’之意。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由旗帜鲜明引申为‘发挥’，见于后世词组如旌智。"
    },
    {
