      "meaning": "守门人，负责把守宫门或其他重要门禁的人。",
      "examples": [
        "吾令帝阍开关兮，倚阊阖而望予。",
        "阍者，守门之贱者也。《礼记》"
      ],
      "traditional_char": "閽"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "宫门、门户，尤指王宫、天宫等的正门或重要门禁。",
      "examples": [
        "怀帝阍而不见，奉宣室以何年？",
        "叫阍开天庭，延群神。"
      ],
      "traditional_char": "閽"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "阍寺，古代宫廷中掌守王宫门禁及杂务的官吏之称。",
      "examples": [
        "艮为阍寺。《易·说卦传》",
        "阍门者，寺人也。《谷梁传》"
      ],
      "traditional_char": "閽"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "守门，执行守门职责。",
      "examples": [
        "阍犬（看门狗）；阍吏（守门小吏）；阍侍（守门的奴仆）",
        "阍竪（守门的童仆）"
      ],
      "traditional_char": "閽"
    }
  ],
  "formations": [
    {
