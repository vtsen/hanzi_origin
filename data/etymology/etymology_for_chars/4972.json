{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "水名。主指中国安徽省、河南省境内的淠河，古水名，注入淮河。",
      "examples": [
        "淠水出汝南弋阳垂山，东入淮。",
        "淮水又东北，淠水注之。"
      ],
      "traditional_char": "淠"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "水声。",
      "examples": [
        "舟行水上，淠然有声。"
      ],
      "traditional_char": "淠"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "船行的样子。",
      "examples": [
        "淠彼涇舟，烝徒楫之。"
      ],
      "traditional_char": "淠"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "淹没。",
      "examples": [
