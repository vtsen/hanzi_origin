      ],
      "traditional_char": "淠"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "众多、茂盛的样子（常用于叠词“淠淠”）。",
      "examples": [
        "萑葦淠淠。"
      ],
      "traditional_char": "淠"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "摇动、动作的样子（叠用：淠淠）。",
      "examples": [
        "其旂淠淠。"
      ],
      "traditional_char": "淠"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，畀声；初用于指水名。"
