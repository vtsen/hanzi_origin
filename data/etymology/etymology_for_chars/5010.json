      ],
      "traditional_char": "逯"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "漢有逯並。《漢書·翟義傳》",
        "金紫光祿大夫逯明。《後趙錄》"
      ],
      "traditional_char": "逯"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "及，达到，与“逮”同用。",
      "examples": [
