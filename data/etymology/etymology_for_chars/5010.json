    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "随意行走；行步无拘束。",
      "examples": [
        "渾然而往，逯然而來。——《淮南子》",
        "逯謂無所為忽然往來也。——高誘注"
      ],
      "traditional_char": "逯"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "行步谨慎。",
      "examples": [
