  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "隗为形声字，从阜，鬼声。本义为高峻，阜表意为山岗地貌，鬼表声音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_shift",
      "note": "由“高峻”引申为高山崩塌，义转为“倒塌、倾颓”；见晋《酒赞》用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "地名引申，因地势高峻名为“隗”，用作国名。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以地或山名作为氏族姓氏，常见姓氏得名机制。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "高峻引申，专指某些著名的高山之名。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以国名为姓，历史上常见，如地名氏族化。"
    }
  ]
