{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "系结，打结，把长条形的东西盘绕起来系起来",
      "examples": [
        "绾结",
        "绾起头发",
        "绾组"
      ],
      "traditional_char": "綰"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "卷起，卷拢",
