        "辇送"
      ],
      "traditional_char": "輦"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从车，两“夫”并行，表示古时用人拉或推的车。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
