      "meaning": "用锤打等方式把楔子、钉子等嵌入物体。",
      "examples": [
        "要往墙上揳钉子，比往木头上揳个钉子花费的力气要大得多。"
      ],
      "traditional_char": "揳"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "弹奏（尤其指弹瑟、琴等乐器）。",
      "examples": [
        "鏗鍾搖虡，揳梓瑟些。",
        "趙女鄭姬設形容，揳鳴琴。"
      ],
      "traditional_char": "揳"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "敲打，打击（泛指捶击动作）。",
      "examples": [
        "尚書近臣至乃捶揳牽曳於前。"
      ],
      "traditional_char": "揳"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "堵塞（塞住孔隙、堵住）。",
      "examples": [
        "揳，塞也。"
      ],
      "traditional_char": "揳"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "度量，比较大小。",
      "examples": [
        "不揣長，不揳大。"
      ],
      "traditional_char": "揳"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "楔形的东西。",
      "examples": [
        "霹靂處得揳，如斧，謂之霹靂揳。"
      ],
      "traditional_char": "揳"
    }
  ],
