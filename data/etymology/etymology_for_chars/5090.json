      "traditional_char": "蔞"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "用于丧事的车饰，如蔞翣。",
      "examples": [
        "设蔞翣。——《礼·檀弓》"
      ],
      "traditional_char": "蔞"
    }
