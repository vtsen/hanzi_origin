    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "楮树，一种落叶乔木，叶似桑，皮可造纸，亦称“构树”或“榖木”。",
      "examples": [
        "鳥危之山其陰多檀楮。",
        "硯滴穿池小，書衣種楮多。",
        "楮即榖木。"
      ],
      "traditional_char": "楮"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "纸的代称，因多用楮皮造纸，故称。",
      "examples": [
        "即連楮為巨幅，廣二丈，大書一“屈”字。",
        "若人富天巧，春色入毫楮。",
        "方尺之楮，若限鴻溝。"
      ],
      "traditional_char": "楮"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "纸币，古时以楮皮造纸制成的钱币，如“楮帛”“楮券”。",
      "examples": [
        "值水災，捐萬楮以振之。",
        "至蔡京改行鈔法，則無復官錢，而直用空楮。",
        "其法貴少，而今多焉故也。"
      ],
      "traditional_char": "楮"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "祭祀用的纸钱。",
      "examples": [
        "不強如焚錢烈楮，滅罪消災。",
        "牲牢酒楮，祭無虛日。",
        "備了香楮，帶了兩個兄弟，去叩別了。"
      ],
      "traditional_char": "楮"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "山名，传说中的楮山。",
      "examples": [
        "又西三十里，曰楮山，多寓木。"
      ],
      "traditional_char": "楮"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [],
