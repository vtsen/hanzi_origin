      "traditional_char": "棣"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "比喻兄弟，常用于“棣友”、“棣萼”、“棣华”等词中。",
      "examples": [
        "贤棣",
        "棣友（兄弟友爱）",
        "棣萼（喻兄弟）"
      ],
      "traditional_char": "棣"
    },
    {
      "index": 2,
