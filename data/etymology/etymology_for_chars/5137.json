      "examples": [
        "惰者發憤以躒勤，懦者自強以齊壯。",
        "英才卓躒。"
      ],
      "traditional_char": "躒"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "卓越；超绝。（用于“卓躒”、“卓跞”等词）",
      "examples": [
        "卓躒，絕異也。",
        "连躒诸夏。"
      ],
      "traditional_char": "躒"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘躒’为形声字，从足，乐声，表示与走动相关。‘跞’为其简化字。"
    }
  ],
