      "meaning": "走动，跨越，行动。",
      "examples": [
        "骐骥一跞，不能千里。",
        "灵胥怒兮蛟躒舟。"
      ],
      "traditional_char": "躒"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
