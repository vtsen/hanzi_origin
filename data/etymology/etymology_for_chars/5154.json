  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘啾’从口，秋声，表示声音，形声字，最初指小儿的声音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘小儿哭声’扩展为各种细碎的动物叫声，春秋战国时期文献可见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由单一动物声音，引申为众声杂沓、群体喧杂声，见于汉魏六朝。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由众声喧杂比喻为人吟唱的声音，取其声音连绵、缭绕之意，见于《文选》。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "由歌吟声引申为‘吹奏器乐’，取“出声”之义，唐诗可见。"
    }
  ]
}