    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "封嵎山的名称，古地名。",
      "examples": [
        "封嵎之山，在吳楚之間，汪芒氏之國。",
        "防風氏守封嵎之山者也。"
      ],
      "traditional_char": "嵎"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "山势弯曲险阻的地方，山弯曲处。",
      "examples": [
        "虎负嵎。——《孟子》",
        "香蘭圍石屋，芳草映巖嵎。——《西游记》"
      ],
      "traditional_char": "嵎"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "山高的样子。",
      "examples": [
        "嵎嵎（山高的樣子）"
      ],
      "traditional_char": "嵎"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "偏僻的地方，角落，通“隅”。",
      "examples": [
        "息肩栖南嵎。——支遁《述怀》",
        "歸客遂海嵎。"
      ],
      "traditional_char": "嵎"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从山，禺声，表示山名，结构为山+禺。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由具体山名扩展为泛指山势弯曲险峻之处，出现于先秦时期。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“山弯曲险地”进一步表示“山高貌”，形容词用法，古籍中常见。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "以“山曲险地”引申为“偏僻之地，角落”，并与“隅”通用，用于文学与地理。"
