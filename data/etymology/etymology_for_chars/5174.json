{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "山名，即崦嵫，位于今甘肃省天水市西。古人以此为太阳落山之地。",
      "examples": [
        "余登嵩山，望崦嵫。",
        "日入于崦嵫。"
      ],
      "traditional_char": "嵫"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "山名，位于瑕丘（今属山东一带），与嵫阳县相关。",
      "examples": [
        "嵫山，在嵫阳县北。"
      ],
      "traditional_char": "嵫"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "日落之处，借指太阳落山的地方。",
      "examples": [
        "古代常用崦嵫指日落的地方。",
        "崦嵫为日入之所。"
      ],
      "traditional_char": "嵫"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "形容山势峻峭险峻的样子。",
      "examples": [
        "崱屴嵫釐。",
        "嵫釐峻險貌。"
      ],
      "traditional_char": "嵫"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从山，兹声。最初表示山名，后泛指具体地点。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由具体山名泛指太阳落山的地方，用作地理隐喻，产生于先秦古文。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "地名类泛化，由一地名嵫山扩展到其他同名地。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "取山之险峻引申为峻險的形容，见《鲁灵光殿赋》。"
    }
  ]
