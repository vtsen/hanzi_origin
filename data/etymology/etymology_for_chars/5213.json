{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "接引宾客或以礼迎宾",
      "examples": [
        "王命诸侯，则傧。",
        "乃退，儐于东序。"
      ],
      "traditional_char": "儐"
    },
    {
