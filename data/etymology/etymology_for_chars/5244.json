{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代盛行于商代和西周的一种青铜酒器，喇叭形口，细腰，高足，腹和足部各有四条棱角。",
      "examples": [
        "子曰：“觚不觚，觚哉!觚哉!”",
        "汝窑美人觚"
      ],
      "traditional_char": "觚"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古代用来写字的木简，有棱角，多为六面或八面。",
      "examples": [
        "或操觚以率尔，或含毫而邈然。",
        "觚牍"
      ],
      "traditional_char": "觚"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "有棱角的器物或直角。",
      "examples": [
        "破觚而为圜。",
        "甘泉泰畤紫坛，八觚宣通象八方"
      ],
      "traditional_char": "觚"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "剑柄。",
      "examples": [
        "操其觚，招其末，则庸人能以制胜。",
        "令提劍鋒而掉劍觚，必刎其指。"
      ],
      "traditional_char": "觚"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "法则，规则。",
      "examples": [
        "自削以觚。",
        "占之以其觚。"
      ],
      "traditional_char": "觚"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "通“孤”，独特、特立不群。",
      "examples": [
        "与乎其觚而不坚也，张乎其虚而不华也。",
        "言行奇觚，为世希有。"
      ],
      "traditional_char": "觚"
    }
  ],
  "formations": [
    {
