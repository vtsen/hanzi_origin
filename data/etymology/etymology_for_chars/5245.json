      ],
      "traditional_char": "猱"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "旧时杂剧中的一种角色名，多指妓女之总称。",
      "examples": [
        "杂剧院本，皆有正末、副末、狚、孤、靚、鴇、猱、捷讥、引戏九色之名……猱，妓女之总称。——明·朱权《太和正音谱》"
      ],
      "traditional_char": "猱"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "古琴弹奏的一种指法，左手按弦往复移动，使琴声微颤且圆润。",
      "examples": [
        "吟猱",
        "猱法是在徽分的下方作较大距离的往复摆动。"
      ],
      "traditional_char": "猱"
    }
  ],
