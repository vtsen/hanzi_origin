    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "中医指胸腹间气机阻塞不舒的一种自觉症状，有的仅有胀满的感觉，称“痞块”、“痞积”。",
      "examples": [
        "病者但满而不痛，名曰痞。"
      ],
      "traditional_char": "痞"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "恶棍，流氓。",
      "examples": [
        "地痞流氓横行街头。",
        "他满身痞气。"
      ],
      "traditional_char": "痞"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从疒表病，与“否”声。本义为中医的胸腹闷结病症。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由病症引申比喻性格粗鄙、无赖，有闹腾、不顺的意味，进而指流氓恶棍。"
    }
  ]
