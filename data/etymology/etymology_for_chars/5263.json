  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“止于某物，仅此”引申为“剩余、余”。古籍偶见，义较生僻。"
    },
    {
      "source_index": 0,
