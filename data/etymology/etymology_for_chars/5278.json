{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "淘井、除去污泥。",
      "examples": [
        "井渫不食，为我心恻。（《易·井》）",
        "群山既略，百川潜渫。"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "疏通，排出气体或液体；泄漏。",
      "examples": [
        "渫之以尾闾。（《文选·江赋》）",
        "归塘尾闾，渫何所到？"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "散布，消散，发散。",
      "examples": [
        "富人有爵，农民有钱，粟有所渫。（《汉书》）",
        "精神越渫，百病咸生。"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "污浊，卑污。",
      "examples": [
        "去卑辱奧渫而升本朝。（《汉书》）",
        "渫恶吏忍于鬻狱，无责也。"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "止歇，停止。",
      "examples": [
        "为欢未渫，白日西颓。（曹植《七启》）",
        "扬子《方言》：渫，歇也。"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "再次，重复。",
      "examples": [
        "今侯渫过而弗辞？（《吕氏春秋》）"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "把食物放在沸水中涮熟。",
      "examples": [
        "汤中渫出之，著大瓮中。（《齐民要术》）"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "水名。",
      "examples": [
        "渫水，出建平郡，东逕渫阳县。（《水经注》）"
      ],
      "traditional_char": "渫"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "古贤人渫子，见《韩非子》。"
      ],
      "traditional_char": "渫"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，枼声，本义为淘井、除去污泥，《说文》作‘除去也’。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从淘井、清理引申为疏通、排出或泄漏，东汉以后见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由疏通、泄出进一步引申为散发、消散。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "pejoration",
      "note": "由除去污泥义引申为污浊、卑污，含贬义。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "由发散、消散引申为止歇，见魏晋用例。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "由分散扩展为“再次、重复”之意，见汉、魏文献。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "metonymy",
      "note": "由涉水、排水转喻为把食物“涮水”。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "以本义为地名、水名，因水体需清理得名。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "地名或官名转为姓氏，用于人名，典见先秦。"
    }
  ]
}