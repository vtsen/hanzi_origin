      ],
      "traditional_char": "湎"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，面声，表示沉溺于酒中的状态，水表意义，面表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由饮酒引申为一切沉迷、沉溺，对象范围扩展，汉代已见。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由液体沉溺转借为水流视觉形象，形成“水流貌”。"
