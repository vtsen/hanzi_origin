      "evolution_type": "semantic_extension",
      "note": "由‘用水调和’引申为‘淘洗’，因同包涵用水操作。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "以水流动作比喻排泄（尤其小便），语义转化古已有之。"
