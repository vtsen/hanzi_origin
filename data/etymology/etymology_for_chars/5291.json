  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，屋声，表示沾湿、润泽之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由具体的沾润引申为抽象的优厚、丰盛。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由表面润泽、湿润转喻为色泽光润。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由沾湿引申为浸泡，后与“漚”通用。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metonymy",
      "note": "以沾润之水作地名、水名。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "地方用法，由渗润引申为用热物使变暖（“焐”）。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_shift",
      "note": "地方用法，形容陷入泥泞，含有湿润、泥泞之意。"
    }
  ]
