      ],
      "traditional_char": "渥"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "浓厚；优厚；丰盛",
      "examples": [
        "渥恩（厚恩）；渥惠；渥盛",
        "蒙圣皇之渥惠兮，当日月之盛明。——《汉书·班倢伃传》"
      ],
      "traditional_char": "渥"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "光润，光泽",
      "examples": [
        "颜如渥丹。——《诗·秦风·终南》",
        "透叶红梨渥。——宋·曾巩"
