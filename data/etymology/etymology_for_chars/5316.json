  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字：从孨在尸下。本义为狭窄，以屋下孤儿喻空间狭小。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘空间狭窄’引申为‘气力、体质瘦弱、微弱’，比喻义。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由体质弱‘孱弱’进一步转喻为‘性格懦弱’。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由‘瘦弱虚弱’转喻为‘卑微’，联系社会地位。"
    },
    {
      "source_index": 1,
      "target_index": 4,
