  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由矫正弓弩器具引申为辅助、辅正官员，比喻性移用；周秦至汉代。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由动词“辅佐”引申为“辅佐君王的大臣”，如“良弼”；汉晋以后。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "器具原用于纠偏——引申为“矫正”之意，后引申为“违背”，“相戾”；史籍中亦见。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由辅助工具义派生为‘高’‘重叠’等抽象用法，出于古方言和训诂。"
    }
  ]
