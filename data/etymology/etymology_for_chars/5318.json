  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 2,
      "note": "小篆作会意字，从丌，意指具备、持物，含有“具”的基本含义，后义扩展。"
    }
  ],
  "edges": [
    {
      "source_index": 2,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“具备”引申为“消散”，物质展布可理解为散布。"
    },
    {
      "source_index": 2,
      "target_index": 0,
      "evolution_type": "metaphor",
      "note": "从“齐备、持”引申为“风”八卦，风能遍及、无处不在，有所包容之义。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "由“具备”转为“谦让、顺从”，似以物之顺应物以成备之意。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "从“谦让、顺从”引申为性格表述“卑顺、恭顺”。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "“具备”引申为“履、践行”，即付诸实行。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "unknown",
      "note": "作为姓氏用，具体用法不详，属名词化转移。"
    }
  ]
