{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "八卦之一，代表风，亦指东南方。",
      "examples": [
        "巽为木，为风。——《易·说卦》",
        "其上乌龙峰，独聳文笔于西南，木家院南峰，迴峙雄关于巽位。——《徐霞客游记》"
      ],
      "traditional_char": "巽"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "消散，扩散。",
      "examples": [
        "巽，散也，物皆生布散也。——《释名·释天》"
      ],
      "traditional_char": "巽"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "持、具备。",
      "examples": [
        "巽，具也。——《说文》"
      ],
      "traditional_char": "巽"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "谦让，退让，顺从。",
      "examples": [
        "巽，逊也。——《书·尧典》",
        "顺以巽也。——《易·蒙》"
      ],
      "traditional_char": "巽"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "卑顺，谦逊，恭顺。",
      "examples": [
        "位望益尊，谦巽滋甚。——韩愈《答魏博田僕射书》",
        "柔巽隐伏。——王安石《易泛论》"
      ],
      "traditional_char": "巽"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "履，践行。",
      "examples": [
        "朕在位七十载，汝能庸命巽朕位。——《书·尧典》"
      ],
      "traditional_char": "巽"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
