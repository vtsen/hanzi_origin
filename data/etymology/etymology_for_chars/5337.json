  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由钓鱼用绳泛指为其他用绳，特别是串钱用绳，见先秦、汉用法。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由串钱的绳索转指作为钱的计量单位，一缗即一串钱。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "由名词“钓绳”转为动词“钓鱼”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "将系弦如同缠绳，故引申为安弦。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "以衣物包覆如绳相缠，义伸自主线。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "由绳的“缠绕合一”引申为哲学上的混合、合流义，《庄子》为代表。"
