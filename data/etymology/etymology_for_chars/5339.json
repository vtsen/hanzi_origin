      "part_of_speech": "noun",
      "meaning": "用荆条或藤条编成的长方形农具，用来平整土地，松土保墒。又名“耱”或“盖”。",
      "examples": [
        "橯，摩田器。或从耒。——《集韵》",
        "农民用耢平整土地。"
      ],
      "traditional_char": "耮"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用耢平整土地。",
      "examples": [
        "耖之然后耢之。——清·倪倬《农雅·释器》"
      ],
      "traditional_char": "耮"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "“耮”的简化字。",
