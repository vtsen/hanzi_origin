    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代天子所执的玉，用以覆诸侯的圭，作为礼仪用器。",
      "examples": [
        "太保承介圭，上宗奉同瑁。",
        "天子执瑁四寸。",
        "瑁，所以冒诸侯圭，以齐瑞信，方四寸，邪刻之。"
      ],
      "traditional_char": "瑁"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "玳瑁，一种海龟，甲壳有美丽花纹，可用作装饰品。",
      "examples": [
        "双珠玳瑁簪，用玉绍绕之。",
        "瑇瑁，生南海，可作器。",
        "见“玳瑁”"
      ],
      "traditional_char": "瑁"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从玉，冒声。本义为覆盖、合诸侯圭的玉器。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "因玳瑁海龟的甲壳有光泽花纹，形似美玉，用玉名转指乌龟种。"
    }
  ]
