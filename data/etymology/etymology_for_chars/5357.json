  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“搋”形声字，从手，隹声，本义为用手揉压之意，手旁表意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由揉压动作引申为藏物于怀，因为动作相似，宋元已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "揉压义引申到疏通工具，因其动作为对物体用力压揉通畅，现代义。"
    },
