{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "刺、扎、戳，用尖锐物体穿入或插入。",
      "examples": [
        "林冲举手，肐察的一枪，先搠倒差拨。",
        "有那走得遲的，盡被搠死了七八個。",
        "豈不是就搠破土豪劣紳的詭計麼？"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "插入，竖立（物件）。",
      "examples": [
        "只見女墻邊虛搠旌旗，無人守護。",
        "這廝強賴人錢財，高築座營和寨，斜搠面杏黃旗。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "用力推、摔。",
      "examples": [
        "那妇人将盘一搠，且不收拾。",
        "自敦搠。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "掉换、调包。",
      "examples": [
        "搠包儿（调包。暗易人之物以骗财）。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "执，持。",
      "examples": [
        "小将军搠戟在手，勒马阵前，高声大叫。",
        "搠笔巡街。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "寻访。",
      "examples": [
        "似尋吳文政搠如相知。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "蘸、沾，涂抹。",
      "examples": [
        "又不要蘸盐搠酱，只吃一碗淡粥。",
        "搠，塗也。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "装痴作呆，装傻。",
      "examples": [
        "你妝憨，咱塑渰，影羞慚。"
      ],
      "traditional_char": "搠"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "古代兵器，长矛。",
      "examples": [
        "人人都帶雁翎刀，個個盡提鴉嘴搠。"
      ],
      "traditional_char": "搠"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“搠”从手，朔声。表示用手持物刺、插入，为形声字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“刺入”引申为“插入”，“竖立”等动作，源于动作的相似性。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“刺入”引申为“用力推、摔”，动作有猛力推进的共同点。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "“换包”本义无直接动作联系，取其迅速、突然之意，属比喻转义。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "“持”多指持兵器，以刺、扎义为基础概念延伸。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "“寻访”含有主动寻找、深入查探之意，动作上转喻为“刺探”。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "“涂抹”转自物体贴近物体，有类似“刺入”的动作感。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "reanalysis",
      "note": "与“搠渰/塑渰”关系密切，由假装痴呆的“装”动作重新分析得来。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "由动作为名，指以“搠”为主要用途的兵器，即长矛。"
    }
  ]
