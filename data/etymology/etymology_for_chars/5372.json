  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“陈草复生”引申为做成席垫的草，后专指草席。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由草席涵盖通‘褥’，泛指各种寝具上的垫子。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "草席、草垫比喻为蚕蔟，其形态和用途类似。"
