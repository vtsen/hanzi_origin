    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "蓖麻，一年生或多年生草本植物，种子称“蓖麻子”，可榨油，广泛用于医药和工业。",
      "examples": [
        "蓖麻油是一种重要的工业原料。",
        "蓖麻子可作药用。"
      ],
      "traditional_char": "蓖"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "蒿类植物名。古籍中指某种蒿草。",
      "examples": [
        "蓖，蒿也。——《说文》"
      ],
      "traditional_char": "蓖"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "雨衣、蓑衣。",
      "examples": [
        "雨衣，一曰蓑衣。——《玉篇》"
      ],
      "traditional_char": "蓖"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "草名，萆薢，为一种药草。",
      "examples": [
        "萆薢，药草。——《类篇》"
      ],
      "traditional_char": "蓖"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "通“蔽”，遮蔽，遮掩。",
      "examples": [
        "从閒道萆山而望赵军。——《汉书·韩信传》"
      ],
      "traditional_char": "蓖"
    }
  ],
