{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "食物中夹杂着沙子或异物，咀嚼时感觉不适。",
      "examples": [
        "牙碜",
        "倒睫拳毛內刺眼，皮松弦緊癢兼疼，磣澀難開胞臉爛，肝風脾熱兩相壅。"
      ],
      "traditional_char": "磣"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "丑陋，难看，令人难堪。",
      "examples": [
        "寒碜",
        "你別磣了！",
        "寨兒令•戒嫖蕩：若提着娶呵我到磣。"
      ],
      "traditional_char": "磣"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "用作“惨”，凄惨可怕。",
      "examples": [
        "碜可可",
        "宝剑记：比梅花又瘦的磣。"
      ],
      "traditional_char": "磣"
    },
    {
      "index": 3,
      "part_of_speech": "adverb",
