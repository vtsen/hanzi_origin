  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "磣为形声字，从石，音声‘忱’（或‘甚’），本义为石中有杂质（沙粒），即食物夹沙发音近‘疵’；简化字‘碜’承袭字形及音义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由夹沙令人不适、难受，引申为丑陋、难看。汉宋已见用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘丑陋难堪’进一步引申为‘惨’的意思，多见于方言及俚语，时间较晚。"
    },
