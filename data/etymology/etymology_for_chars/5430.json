{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "神话传说中的兽名，即“驺虞”",
      "examples": [
        "《山海经》：其兽似虎而文，名曰‘驺虞’。"
      ],
      "traditional_char": "虞"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "预料，料想",
      "examples": [
        "不虞有变",
        "未可虞料"
      ],
      "traditional_char": "虞"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "忧虑，担忧",
      "examples": [
        "无冻馁之虞",
        "无后顾之虞"
      ],
      "traditional_char": "虞"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "欺骗，蒙骗",
      "examples": [
        "尔虞我诈"
      ],
      "traditional_char": "虞"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "古代诸侯国名，在今山西省平陆县东北",
      "examples": [
        "虞国灭于晋"
      ],
      "traditional_char": "虞"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "安乐，娱乐（古同“娱”）",
      "examples": [
        "虞乐",
        "自虞其乐"
      ],
      "traditional_char": "虞"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "古代掌管山泽的官员",
