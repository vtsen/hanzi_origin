    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "斜视，用斜着眼睛看。",
      "examples": [
        "睨，视也。——《说文》",
        "相如持其璧睨柱。——《史记·廉颇蔺相如列传》",
        "其顙有泚，睨而不视。——《孟子·滕文公上》",
        "他斜过眼睛睨着道静，半天才小声地从牙齿缝里喊道。"
      ],
      "traditional_char": "睨"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "视、望，泛指看。",
      "examples": [
        "余与褐之父睨之。——《左传·哀公十三年》",
        "陟升皇之赫戏兮，忽临睨夫旧乡。——《楚辞·离骚》",
        "睨明也。——《方言十三》"
      ],
      "traditional_char": "睨"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "顾视，回视。",
      "examples": [
        "北睨舍城池尚在，南睎尊岭穴犹存。——唐·慧净",
        "睨玉石之㠁嵯。——《楚辞·惜贤》"
      ],
      "traditional_char": "睨"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "寻视，观察。",
      "examples": [
        "虑也者，以其知有求也，而不必得之，若睨。——《墨子》",
        "世无智愚，得睨而知之。——陈三立"
      ],
      "traditional_char": "睨"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "窥伺，偷偷观望。",
      "examples": [
        "睨望（窥望）",
        "参之赀日益，窖而藏者数万计。然弗子，仅有女，女所适者某，睨其藏久之。——明·李诩"
      ],
      "traditional_char": "睨"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "偏斜，倾斜。",
      "examples": [
        "日方中方睨，物方生方死。——《庄子》",
        "睨，侧视也。——《庄子天下》"
      ],
      "traditional_char": "睨"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "通“婗”，小儿。",
      "examples": [
        "睨者小五尺，不可卒者，为署吏。——《墨子·杂守》",
        "《广雅·释亲》：‘婗，儿子也。’此睨即婗之假借字。"
      ],
      "traditional_char": "睨"
    }
  ],
