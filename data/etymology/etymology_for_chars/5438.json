{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "雎鸠，古书上记载的一种鸟，又称“王雎”，即鱼鹰，常在水边捕食鱼。",
      "examples": [
        "关关雎鸠，在河之洲。——《诗·周南》",
        "雎鳩，王雎也。——《释文》"
      ],
      "traditional_char": "雎"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "水名。在湖北省中部偏西，与漳水汇合为沮漳河，于江陵西入长江。",
      "examples": [
        "己卯，楚子取其妹季羋畀我以出，涉雎。——《左传·定公四年》",
        "雎水出新城昌魏县，东南至枝江县入江。——杜预注"
      ],
      "traditional_char": "雎"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "中医学病名，通“疽”，指癰疽。",
      "examples": [
        "毋赦者，痤雎之矿石也。——《管子·法法》"
      ],
      "traditional_char": "雎"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "明洪武御史雎稼，请立学宫卧𥓓。"
      ],
      "traditional_char": "雎"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从隹（短尾鸟）表意，且声，表示鸟类名称，最初指雎鸠（鱼鹰）。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以鸟栖息地或活动地命名水流，用鸟名借指地名。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "phonetical_loan_shift",
      "note": "字形借用作“疽”之通假用，因音近而通假。"
    },
