      "meaning": "斜视，用眼斜着看。",
      "examples": [
        "睥睨一切",
        "俾倪邪视",
        "引燭窺洞穴，凌波睥天琛。"
      ],
      "traditional_char": "睥"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "窥视，偷偷地看。",
      "examples": [
        "侧睥又复心瑟缩。"
      ],
      "traditional_char": "睥"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "城上的小墙（垣），用于窥视或射击。",
      "examples": [
