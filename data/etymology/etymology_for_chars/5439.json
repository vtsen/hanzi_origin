      ],
      "traditional_char": "睥"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古代皇帝仪仗用的持葢杠者（仪仗的一种器物）。",
      "examples": [
        "俾倪㦸中環持葢杠者也。"
      ],
      "traditional_char": "睥"
    }
  ],
