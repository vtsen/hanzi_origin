{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "哺乳动物，外形像狐，犬科动物，又名“貉子”，毛为珍贵皮毛。",
      "examples": [
        "貉踰汶則死矣。（《列子·汤问》）",
        "一丘之貉。"
      ],
      "traditional_char": "貉"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "取自貉的皮毛，常见于“貉子”、“貉绒”等词中。",
      "examples": [
        "貉绒衣。",
        "貉子皮。"
      ],
      "traditional_char": "貉"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古代东北地区的民族名称，亦指北方古族或古国名。",
      "examples": [
        "干越夷貉之子，生而同声，第而异俗。（《荀子·劝学》）",
        "辨其邦国、都鄙、四夷八蛮七闽九貉五戎六狄之人民。（《周礼·夏官·职方氏》）"
      ],
      "traditional_char": "貉"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "安静、静止的意思（古义，罕用）。",
      "examples": [
        "貉，静也。（《尔雅·释诂》）"
      ],
      "traditional_char": "貉"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "古代军队祭名，通“禡”。",
      "examples": [
        "表貉，立表而貉祭也。（《周礼·夏官·大司马》郑玄注）"
      ],
      "traditional_char": "貉"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "牵引用的细绳，通“綸绳”。（古义）",
      "examples": [
        "貉，缩綸也。（《尔雅·释诂》）"
      ],
      "traditional_char": "貉"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从豸（动物义符），各声，本义为犬科动物“貉”。"
    }
  ],
