      "meaning": "小风，微风。",
      "examples": [
        "微风曰飕，小风曰飕。——《初学记》",
        "小风曰颼。——《初学记》卷一"
      ],
      "traditional_char": "颼"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "风或物体迅速通过时的声音，象声词。",
      "examples": [
        "飕飕（风声）；飕的（形容行动如风）",
        "只听得门外颼的一声，一个弹子飞了进来。——《儒林外史》",
        "那汉颼的把那口刀掣将出来。——《水浒传》"
      ],
      "traditional_char": "颼"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "寒冷，清凉。",
      "examples": [
        "论今星灿灿，考古寒飕飕。——唐·杜牧《中送冀处士东游》",
        "这东风晓渐颼，为甚的珠帘不下钩。——明·梅孝己《洒雪堂·香闺窥趣》",
        "背上有些冷飕飕了"
      ],
      "traditional_char": "颼"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "风吹，使变干或变冷（多用于方言）。",
      "examples": [
        "洗的衣服被风飕干了。",
        "小心点，别让风颼干了。"
      ],
      "traditional_char": "颼"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "箭离弦之声。",
      "examples": [
        "飕地一箭，只见翻筋斗射下马去。——《水浒全传》",
        "从马上颼的一声响，狗头从垛上落下地来。——《花月痕》"
      ],
      "traditional_char": "颼"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘颼’（飕）为形声字，从风，叟声，表示小风。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由实际小风引申为风声、事物快速经过的声音，汉魏晋已有用法。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由风声喻为箭离弦的声音，两者均为锐快之响。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "小风常带有清凉、寒冷之感，古汉语中风与冷感密切相关。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "从小风名词转为动词，表示‘被风吹（使干或冷）’。"
