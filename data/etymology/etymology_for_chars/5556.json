      "meaning": "以谷物在圈中饲养猪、狗等牲畜",
      "examples": [
        "豢，以谷圈养豕也。——《说文》",
        "夫豢豕为酒。——《礼记·乐记》",
        "豢之而俞瘠者，交也。——《荀子·荣辱》"
      ],
      "traditional_char": "豢"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "泛指饲养、喂养动物",
      "examples": [
        "凡畜养禽兽，皆曰豢。——《正字通》",
        "豢池（养鱼池）；豢牢（兽圈）；豢畜（犹豢养）"
      ],
      "traditional_char": "豢"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "以利益诱使、收买（贬义）",
      "examples": [
        "豢文臣帷幄无谋，豢武夫疆场不猛。——孔尚任《桃花扇》",
        "是豢吴也夫！——《左传·哀公十一年》"
      ],
      "traditional_char": "豢"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "贪图（享乐、富贵等），沉溺其中",
      "examples": [
        "豢于游戏酒食之间。——宋·苏轼《教战守》",
        "而豢于富贵，安于顺境。——俞文豹《吹剑三录》"
      ],
      "traditional_char": "豢"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "供养、养育",
      "examples": [
        "豢养（养育，供养）",
        "嬰冠帶，豢妻子，吏得以乘陵之。——唐 刘禹锡《海阳湖别浩初师并引》"
      ],
      "traditional_char": "豢"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "以谷类饲养的家畜如猪、狗，以别于吃草的牛、羊",
      "examples": [
        "民食刍豢。——《庄子·齐物论》",
        "玄熊素膚，肥豢膿肌。——曹植《七启》"
      ],
      "traditional_char": "豢"
    }
  ],
