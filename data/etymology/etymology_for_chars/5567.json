    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古河名，在今中国河南省、湖南省等地均有称溱的水流。",
      "examples": [
        "溱与洧，方涣涣兮。（《诗经·郑风·溱洧》）",
        "褰裳涉溱。（《诗经·郑风·褰裳》）"
      ],
      "traditional_char": "溱"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "州名，历史上的溱州，位于河南等地。",
      "examples": [
        "河南汝宁府，汉曰汝南，后周曰溱州。"
      ],
      "traditional_char": "溱"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "众多，繁盛的样子。",
      "examples": [
