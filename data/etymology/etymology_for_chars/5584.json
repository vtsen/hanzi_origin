  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，旁声；本义为水势浩大涌流。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "将“大水涌流”引申比喻为“雨量极大”，常见于古文修辞。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "以“水涌流”喻泪、血等液体大量流下。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "以水势之盛形容气势盛大。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由水流之广，比喻事物或恩泽广泛流布。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "水的旺盛、充盈引申为事物的旺盛、充溢。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "conversion",
      "note": "由表示状态转为动词“浇灌”，水流之意引申。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "以水势浩大之义用作水名。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "metonymy",
      "note": "以“滂”引申作职官名，用以掌理池泽。"
    }
  ]
