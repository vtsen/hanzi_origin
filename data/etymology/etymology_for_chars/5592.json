      "part_of_speech": "verb",
      "meaning": "亏损，损坏",
      "examples": [
        "如南山之寿，不骞不崩。——《诗·小雅·天保》",
        "外无骞污之名。——《汉书·晁错传》"
      ],
      "traditional_char": "騫"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "高举，飞起；展翅高飞",
