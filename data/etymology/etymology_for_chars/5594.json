{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "鸟类、禽兽等动物筑于地洞中的巢穴。",
      "examples": [
        "空中曰窠，树上曰巢——《说文》",
        "鸟鸢争食雀争窠。——白居易《问鹤》",
        "茅中狐兔窠，四面乌鸢巢。"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "借指人安居或聚会的处所；简陋住所。",
      "examples": [
        "抛却山中诗酒窠。——辛弃疾《鹧鸪天·三山道中》",
        "我今天要不是看你的面子，早把那小鳖蛋的窠毁掉了。——《官场现形记》"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "物聚集或集中之处、团簇之物；或比喻其集合之形态。",
      "examples": [
        "五藏六府之精气，皆上注于目而为之精。精之窠为眼，骨之精为瞳子。——《灵枢经·大惑》",
        "荒草成窠。——《牡丹亭·拾画》",
        "金银窠里。——《醒世恒言·杜子春三入长安》"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "书法或刻印时划分横直的界格（即“擘窠大字”中的“窠”）。",
      "examples": [
        "擘窠大字",
        "金窠篆字红屈盘。——李贺《沙路曲》"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "洞、孔、坑、凹陷低洼的地方。",
      "examples": [
        "凹为窠，凸为陇。——《北苑别录》",
        "绿窠攒剥藓，尖顶坐鸬鹚。——岑参《送李卿赋得孤岛石》"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "量词，用于一堆、一团（多指动植物、颗粒等），或为“棵”、“颗”的通假。",
      "examples": [
        "八九枝共为一窠，烧下头二寸。——贾思勰《齐民要术》",
        "这窠鸡卵都没用了。——《平妖传》",
        "眼前无奈蜀葵何，浅紫深红数百窠。——陈标《蜀葵》",
        "六窠只佩诸侯印。——黄滔"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "指陈旧格调、老套、文章格式（常见于“窠臼”）。",
      "examples": [
        "文章所依据的老套子，陈旧的格调。见“窠臼”"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "古同“颗”；颗粒状物体。",
      "examples": [
        "六窠只佩诸侯印，争比从天拥册归？——黄滔",
        "多用‘窠’为‘颗’的假借"
      ],
      "traditional_char": "窠"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "古同“棵”；草木等植物的单位。",
      "examples": [
        "浅紫深红数百窠。——陈标《蜀葵》",
        "帘外芭蕉三两窠。——李煜《长相思》"
      ],
      "traditional_char": "窠"
    }
  ],
