    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "剑套，鞘，弓袋，弓衣，用于收纳和保护武器的皮套。",
      "examples": [
        "韬，剑衣也。——《说文》",
        "彤弓弨兮，受言櫜之。毛传：櫜，韬也。",
        "陆德明《经典释文》：弓衣也。"
      ],
      "traditional_char": "韜"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "掩藏，隐藏，收敛，不使外露。",
      "examples": [
        "韬光养晦。",
        "韬舌辱壮志，叫阍无助声。——杜牧《感怀诗一首》",
        "韬光晦迹"
      ],
      "traditional_char": "韜"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "用兵的谋略，策略。",
      "examples": [
        "不劳孙子法，自得太公韬。——李德裕《李文饶集》",
        "公负经纶之器，韬王霸之略。"
      ],
      "traditional_char": "韜"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "纳弓于弓袋，将弓或剑收入囊套中。",
      "examples": [
        "韬，弓藏也。——《广雅·释器》",
        "罗抽刃出，已复韬之。——清《聊斋志异·罗祖》"
      ],
      "traditional_char": "韜"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "包容，包含，容纳。",
      "examples": [
        "有韬世之量。——潘岳《寡妇赋》",
        "韬古今于胸怀，包道德之机要。——《三国志·管宁传》",
        "君子明于此十者，则韬乎其事，心之大也。——《庄子·天地》"
      ],
      "traditional_char": "韜"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "古代护臂的皮套。",
      "examples": [
        "臂鷹小兒雲錦韜。——元稹《陰山道》"
      ],
      "traditional_char": "韜"
    }
  ],
