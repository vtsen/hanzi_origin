  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "从‘髟’表头发，从‘毛’表细长，表示毛发中的长毫。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "本指毛发中的长毫，引申为动物颈上的长毛，如马鬃。见《礼记·曲礼》。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_narrowing",
      "note": "指毛发中的长毫，引申为幼儿前额下垂的发式，局部特指。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "从长毛之义扩展至以毛发为显著特征的动物‘牦牛’。"
