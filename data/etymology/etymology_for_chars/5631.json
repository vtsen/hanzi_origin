    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用手击、捶，捶胸。",
      "examples": [
        "寤辟有摽。",
        "长木之斃，无不摽也。",
        "雷歎穨息，掐膺擗摽。"
      ],
      "traditional_char": "摽"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "落下，坠落。",
      "examples": [
        "摽有梅，其實七兮。",
        "摽落灼灼之花。"
      ],
      "traditional_char": "摽"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "捆绑、紧紧地缠绕、使物体相连。",
      "examples": [
        "椅子腿活动了，用铁丝摽住。",
        "把口袋摽在车架子上。"
      ],
      "traditional_char": "摽"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "用胳膊紧紧地勾住，互相搂抱或团结在一起。",
      "examples": [
        "他俩摽着胳膊走。",
        "咱们摽着劲干。"
      ],
      "traditional_char": "摽"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "亲近，依附，多含贬义。",
      "examples": [
        "他们摽在一块儿。",
        "駱明和金廠長摽成把了。"
      ],
      "traditional_char": "摽"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "对比，较量，用力比拼。",
      "examples": [
        "摽着劲干。",
        "那是他存心和拖拉机摽着劲儿种的。"
