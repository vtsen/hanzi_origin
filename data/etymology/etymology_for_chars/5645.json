    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "音乐名，古代中国东方少数民族的音乐。",
      "examples": [
        "東方曰《靺》，南方曰《任》。"
      ],
      "traditional_char": "靺"
    }
  ],
