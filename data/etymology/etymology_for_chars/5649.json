  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从瓦，梦省声，表示屋脊、屋栋之意。‘瓦’为义符，表与瓦有关，是房屋结构；‘梦’为声符。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "屋脊作为屋顶最高部分，语义扩展指及屋檐等屋顶边沿部分。见唐代文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "synecdoche",
      "note": "以局部（屋脊/屋栋）指整体（房屋），中古以降多见。"
