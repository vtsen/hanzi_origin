      "part_of_speech": "noun",
      "meaning": "多年生草本植物，茎细圆而长，中有白髓，可编席，亦称“灯心草”。",
      "examples": [
        "蔺席。",
        "莖可編席和蓑衣。"
      ],
      "traditional_char": "藺"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "马蔺（马莲、马兰），多年生草本植物，叶坚韧可系物，根可制刷子，可造纸。",
      "examples": [
        "马蔺，根茎粗，叶线形，花蓝紫色。",
        "亦称马莲、马兰。"
      ],
      "traditional_char": "藺"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "用于垫席、帐帷、幢等编织物的植物总称（包括马蔺、灯心草等）。",
      "examples": [
        "蒲蒻藺席帳帷幢。"
      ],
      "traditional_char": "藺"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "蔺石，指城墙上的石雷。",
      "examples": [
        "具蔺石。",
        "城上雷石也。"
      ],
      "traditional_char": "藺"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "通“躏”，指车辆碾压，践踏。",
      "examples": [
        "徒车之所蔺轹。",
        "耕輒藺之。"
      ],
      "traditional_char": "藺"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "战国赵有蔺相如。",
        "廉颇蔺相如列传。"
      ],
      "traditional_char": "藺"
    }
  ],
