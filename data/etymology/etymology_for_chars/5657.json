  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从斗，倝声。本义为蠡柄（勺把），形旁表义，声旁表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由“勺把”引申为小车轮子，因形状与运作类似。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“勺把”执柄能旋转，引申为“旋转、转动”之意。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "“旋转、运转”引申为“调解、扭转局面”意，常用作抽象运作。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "“运转”引申为“挑起、负担”等动作，取旋动作感。"
    },
    {
      "source_index": 2,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "旋动作转为“挖取、掏取”，动作由旋转而来。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由车轮部件义引申为轮轴上的金属套。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘斡’借音通‘管’，表示‘主管’、‘掌管’。音读guǎn。"
    }
