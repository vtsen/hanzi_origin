  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "由民族名称转指流放该地，产生‘流放’义。汉魏等时期文献可见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
