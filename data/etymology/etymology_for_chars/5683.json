{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "停柩待葬，将灵柩暂时安放，等待出殡或下葬",
      "examples": [
        "晋文公卒，庚辰，将殡于曲沃。",
        "死者殡在屋内。"
      ],
      "traditional_char": "殯"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "被停放的灵柩",
      "examples": [
        "使杜洩告於殡曰：‘子固欲毁中军，既毁之矣，故告。’"
      ],
      "traditional_char": "殯"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "殡葬事务，泛指丧葬之事",
      "examples": [
        "道秩长殡，法筵久埋。",
        "群以为烈，谋敛资作殡。"
      ],
      "traditional_char": "殯"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "运送灵柩出葬的队伍",
      "examples": [
        "命手下人掩乐停音，将殡过完，方让北静王过去。"
      ],
      "traditional_char": "殯"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "通“宾”，指宾客",
      "examples": [
        "而后辞于殡，遂修葬事。（郑玄注：殡，当为宾，声之误也。）"
      ],
      "traditional_char": "殯"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "通“擯”，摒弃",
      "examples": [
        "道帙长殡，法筵久埋。（殡，一本作“擯”）"
      ],
      "traditional_char": "殯"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从歹，宾声，表示与死亡相关，‘歹’为义部，‘宾’为声部"
    }
  ],
