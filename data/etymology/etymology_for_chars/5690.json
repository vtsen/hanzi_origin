{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "张开嘴露出牙齿，露齿而笑或露齿而怒。",
      "examples": [
        "龇牙咧嘴",
        "小鬍子吼叫的時候，嘴裏齜出兩顆大金牙。",
        "李春山說完，四隻眼睛對望着。忽然這個嘴巴一咧，那個牙齒一齜，發出一陣得意的獰笑。"
      ],
      "traditional_char": "齜"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "牙齿不整齐或突出。",
      "examples": [
        "齒相齘也。",
        "齒不正也。",
        "齒不齊。"
      ],
      "traditional_char": "齜"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "齜为形声字，从齒， 此声。表示张嘴露齿之貌。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "“龇”为“齜”的简化字，简化沿用本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由齜牙为本义，进一步引申指牙齿外露、不整齐，用于描述牙齿的状态，见于《广韵》、《集韵》等。"
    }
  ]
