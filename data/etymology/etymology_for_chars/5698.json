      "traditional_char": "嘁"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "慚愧、忸怩的样子；感到羞愧。",
      "examples": [
        "嘁咨慚也。",
        "嘁，忸怩慙愧貌。"
      ],
      "traditional_char": "嘁"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "叹息。",
      "examples": [
        "戚嗟若，子夏傳作嘁。"
      ],
      "traditional_char": "嘁"
    }
  ],
  "formations": [
