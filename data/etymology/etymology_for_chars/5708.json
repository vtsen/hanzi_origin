      "index": 0,
      "part_of_speech": "noun",
      "meaning": "蜥蜴，一种爬行动物，体表有细小鳞片，四肢粗短，有长尾，亦作石龙子、四脚蛇。",
      "examples": [
        "哀今之人，胡为虺蜴。（《诗·小雅》）",
        "石龙子亦蜴也。",
        "守宫亦蜴属。"
      ],
      "traditional_char": "蜴"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "轻慢欺骗的话，楚地方言用法。",
      "examples": [
        "楚谓欺慢为脉蜴。"
      ],
      "traditional_char": "蜴"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从虫，声旁为易，表示与爬虫相关，最初本义为爬行动物蜥蜴。"
    }
  ],
  "edges": [
