    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "猛禽名，隼的一种。喙短宽有齿状突起，翅膀窄而尖，飞行迅速，能捕食其他鸟类。",
      "examples": [
        "而山上栖鶻，聞人聲亦驚起。",
        "斯须领健鹘，痛愤寄所宣。"
      ],
      "traditional_char": "鶻"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古书记载的一种鸟，短尾，青黑色。",
      "examples": [
        "鹘鶵"
      ],
      "traditional_char": "鶻"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "船的一种，形状前高后低，如旗。",
      "examples": [
        "飛車跨山鶻橫海，風枝露葉如新採。",
        "海鶻頭低尾高，前大後小，如旂之狀。"
      ],
      "traditional_char": "鶻"
    }
  ],
