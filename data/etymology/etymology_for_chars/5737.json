      "original_sense_index": 0,
      "note": "形声字，从金，臿声，表示与金属器物（针、锹）相关，最初指长针。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "繁体“鍤”与简体“锸”同源，均为形声结构。"
    }
  ],
  "edges": [
