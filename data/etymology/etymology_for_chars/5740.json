  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由刚铁泛指为金刚钻等坚硬材料，见先秦文献。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由坚铁引申为金属锅（釜），‘可刻镂’的特性转指器皿。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由可供雕刻的铁，引申为雕刻本身的动作。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "雕刻引申到专指金属器物的雕花、装饰。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "雕刻动作延伸为‘开凿’、‘疏通’等工艺行为。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "由雕刻动作喻指铭记于心，如‘镂骨铭心’。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
