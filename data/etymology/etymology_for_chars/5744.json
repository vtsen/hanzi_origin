{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "小箱子，用于盛放和收藏物品的容器，尤其多指竹制或藤制的方形箱。",
      "examples": [
        "负箧曳屣。（明·宋濂《送东阳马生序》）",
        "家书一箧。（清·梁启超《谭嗣同传》）",
        "左傳：衛人使屠伯，饋叔向羹與一篋錦。"
      ],
      "traditional_char": "篋"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "山名，古地名。",
      "examples": [
        "高城東北五十里有篋山。"
      ],
      "traditional_char": "篋"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "小竹籍，古时指用竹片编成的书册或简牍。",
      "examples": [
        "当余之从师也，负箧曳屣，行深山巨谷中。"
      ],
      "traditional_char": "篋"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从竹，夹声；原指竹制的小箱，篋为本字，箧为简化。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "藏书或装简的容器，进而指“竹籍”；见《送东阳马生序》。"
    }
  ]
}