  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从未成年人引申为未成年仆役，进而泛指仆役。《史记》时已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
