    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "雄性動物生殖器官的一部分，位於陰囊內，能產生精子。又稱“精巢”、“外腎”。",
      "examples": [
        "睾丸",
        "隱睾",
        "睾丸酮"
      ],
      "traditional_char": "睾"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "木名，睾蘇（一種植物名，又名白䓘）。",
      "examples": [
        "睾蘇，木名，一名白䓘。"
      ],
      "traditional_char": "睾"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "高，大（廣大貌）。",
      "examples": [
        "睾睾廣廣，孰知其德。"
      ],
      "traditional_char": "睾"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "沼澤、澤地（用作“皋”的通假字）。",
      "examples": [
        "望其壙，睾如也。",
        "皋牢陵山。"
      ],
      "traditional_char": "睾"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "伺視、監視。",
      "examples": [
        "司視也。",
        "今吏將目捕辠人也。"
      ],
      "traditional_char": "睾"
    }
  ],
