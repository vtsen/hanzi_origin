    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "瘌痢，头上生疮引起秃发的皮肤病，亦称疥疮、癩。",
      "examples": [
        "瘌子（淮汉一带称因头生疮而发秃的人为瘌子）"
      ],
      "traditional_char": "瘌"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "疤瘌，疤、瘡痕。",
