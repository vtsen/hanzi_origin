  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从穴，音声，原指地窖。‘穴’表示地下、窖藏义，‘音’表音。六书学说主流观点。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由表示地窖的名词，引申为窖藏、深藏之动作。中古、近代汉语见用。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "从藏于地窖引申为内心思忖、深藏心中，元明文献可见。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由‘藏’义引生为‘封闭’（使不能开启），宋代《營造法式》。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "‘深’由物理空间转为形容颜色深黑，声近义移，见《集韻》。"
    },
    {
      "source_index": 1,
      "target_index": 5,
