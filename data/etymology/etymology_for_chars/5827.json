  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘日初见’引申为‘及，和’，兼容原本界限交接之意，古人合会之象。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "从日初见引申为‘至、到’，由时间起点到时间界限的隐喻。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由界限（太阳初现边界）引申为‘限制、限度’。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "unknown",
      "note": "果毅貌，多为声符转用，语义关系待考。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "由’到界‘反意发展为‘不及、未到’，常见于古汉语。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "作古地名，或与边界相关特性转用相关。"
