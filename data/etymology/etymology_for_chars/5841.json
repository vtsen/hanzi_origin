  "edges": [
    {
      "source_index": 2,
      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "由特指马的品种引申为马快速奔跑的样子，用马种的形象特征指代动作状态。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由形容马奔跑迅速，比喻人的勇猛矫健，常用于褒义人的勇敢。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "用代表性动物名称借指国家名称，进入地名用法，如骠国。"
