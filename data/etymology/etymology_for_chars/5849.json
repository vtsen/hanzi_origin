{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "两个人并肩耕地；二人一组耕作。",
      "examples": [
        "长沮、桀溺耦而耕。（《论语·微子》）",
        "耦，耒广五寸为伐，二伐为耦。（《说文》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "成对、配偶、两人一组。",
      "examples": [
        "射者三耦。（《左传·襄公二十九年》）",
        "人各有耦。（《左传·桓公六年》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "偶像，如木耦、土耦，古代用来作陪葬的俑像。",
      "examples": [
        "木耦；土耦；耦人（土木等制成的人俑）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "和谐、合、协调。",
      "examples": [
        "齐心耦意。（严复《论中国之阻力与离心力》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 4,
      "part_of_speech": "numeral",
      "meaning": "双，成双，双数，与“奇”相对。",
      "examples": [
        "阳卦奇，阴卦耦。（《易系辞下》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "躯体。",
      "examples": [
        "嗒焉似丧其耦。（《庄子》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "遇，逢。",
      "examples": [
        "燕成双，鸾对影，耦新知。（宋·孙光宪《酒泉子》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "合，符合。",
      "examples": [
        "名实耦，合也。（《墨子·经说上》）"
      ],
      "traditional_char": "耦"
    },
    {
      "index": 8,
      "part_of_speech": "verb",
      "meaning": "匹敌，相对，对等。",
      "examples": [
        "耦国（对等之国）；耦象（指箭耙）；耦语（相对私语）"
      ],
      "traditional_char": "耦"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从耒（表示与农耕关联）+禺声，本义为二人并肩耕地，是最早的意义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由并肩耕作引申为两人成对、配偶一组，即二人为一耦；见于《左传》。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由配偶、成对引申为偶像、俑像，即模拟配对人的形象。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由配对引申为合、和谐，强调协调一致的特性。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由成对引申为双数或一对，与奇数相对。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "耦由为配对的人，转喻为人的主体、躯体（如《庄子》用法），系身体作为成对之物。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "从成对、配对义引申为偶遇、相遇。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "从成对、配对之义引申为合、符合的义项。"
    },
    {
      "source_index": 1,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "由配对之人引申为匹敌、对等、相对等含义。"
    }
  ]
}