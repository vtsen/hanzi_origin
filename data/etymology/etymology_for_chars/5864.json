{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "用手顺着物体的表面捋下来，多指用手把树叶等捋下；或用手摸、抹。",
      "examples": [
        "把树枝上的叶子撸下来。",
        "紫鵑又把鐲子連袖子輕輕的擼起，不叫壓住了脈息。——《紅樓夢》",
        "從腦門上他擼下一把冷汗。"
      ],
      "traditional_char": "擼"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "撤职、解除职务。",
      "examples": [
        "把他的队长给撸了。",
        "主任還是個副的，不定哪一天就擼下來了。",
        "只有那些犯了錯誤的幹部才會連擼幾級。"
      ],
      "traditional_char": "擼"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "用手掌击打（多指轻打脸、身体等部位）。",
      "examples": [
        "那人恼羞成怒的狠狠撸了他几嘴巴子。",
        "那人惱羞成怒的狠狠擼了他幾個嘴巴子。——《政治委員》"
      ],
      "traditional_char": "擼"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "批评或训斥。",
      "examples": [
        "挨了一顿撸。",
        "我是大錯不犯，小錯不斷，有錯兒你只管擼我好咧。",
        "我先狠擼他一頓，叫他清醒清醒。"
      ],
      "traditional_char": "擼"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "拿，取，用手取走。",
      "examples": [
        "你長大了也考個講武吧，可別再擼鋤把子了！"
      ],
      "traditional_char": "擼"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "磨练、锻炼（多指在实践中成长）。",
      "examples": [
        "在活计里头，才能撸出把好手来。"
      ],
      "traditional_char": "擼"
    }
  ],
