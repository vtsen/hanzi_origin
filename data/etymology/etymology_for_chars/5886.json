{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "樗树，即臭椿，一种苦木科落叶乔木，木材粗硬，多被视为无用之木。",
      "examples": [
        "吾有大樹，人謂之樗。其大本擁腫而不中繩墨，其小枝卷曲而不中規矩。（《莊子·逍遙遊》）",
        "采荼薪樗，食我農夫。（《詩·豳風·七月》）"
      ],
      "traditional_char": "樗"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "以“樗”借指无用之材，或用作自谦之辞。",
      "examples": [
        "常恐樗身，坐缠冠盖蔓。（蘇軾《和穆父新凉》）",
        "編篷半載亦吾廬，寂寞誰憐朽似樗。（清·周亮工）"
      ],
      "traditional_char": "樗"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "樗蚕，一种以樗树叶为食的蚕类，幼虫绿色，成虫灰白色，亦称“椿蚕”。",
      "examples": [
        "樗蚕以樗叶为食。"
      ],
      "traditional_char": "樗"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "樗蒲，古代一种类似掷骰子的赌博游戏，后亦泛指赌博。",
      "examples": [
        "比夫格弈樗塞之戲，猶曰愈於飽食。（元稹《敘詩寄樂天書》）"
      ],
      "traditional_char": "樗"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "明宣德中合水縣學訓導樗本直。"
      ],
      "traditional_char": "樗"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "“樺”的异体。",
      "examples": [],
      "traditional_char": "樗"
    }
