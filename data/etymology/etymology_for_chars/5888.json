{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "篱笆；用于围绕院落、园圃或起隔离作用的栅栏。",
      "examples": [
        "折柳樊圃，狂夫瞿瞿。",
        "营营青蝇，止于樊。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "筑篱围绕，用篱笆围住。",
      "examples": [
        "折柳樊圃，狂夫瞿瞿。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "关鸟兽的笼子，亦引申为囚禁、束缚之意。",
      "examples": [
        "泽雉十步一啄，百步一饮，不蕲畜乎樊中。",
        "久在樊里，复得返自然。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "领域、范围。",
      "examples": [
        "盖学虽粗涉其樊，其为说不能无弊而已。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "旁，边际。",
      "examples": [
        "夏则休乎山樊。",
        "大隐住朝市，小隐入丘樊。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "纷杂，混乱的样子。",
      "examples": [
        "樊然淆乱。",
        "顾见卢敖，樊然下其臂，遁逃乎碑下。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "樊哙，汉时刘邦的勇将。"
      ],
      "traditional_char": "樊"
    },
    {
      "index": 7,
      "part_of_speech": "noun",
      "meaning": "古地名：①春秋时邑名，在今河南省济源县东南；②樊城的简称，在今湖北省襄阳市。",
      "examples": [
        "时刘备屯樊，琮不敢告备。",
        "仲山甫，樊侯也。"
      ],
      "traditional_char": "樊"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从木，棥声，本义为篱笆，'棥'亦兼有篱笆之意；木表意指栅栏结构。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由名词作动用，语法化为“围绕、围住”的动作。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“篱笆”引申为“关鸟兽的笼子”，两者均有围障、阻隔之意。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "笼子的“空间限制”意义引申为“范围”、“领域”。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "篱笆有“边界”属性，引申为“旁、边际”。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "篱笆重叠纵横，引申为事物“纷杂、混乱”的状态。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "以地名“樊”得名，因古时以篱笆围护为特征，地名“樊”由此得名。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "conversion",
      "note": "地名、封号转用为姓氏，为常见社会现象。"
    }
  ]
}