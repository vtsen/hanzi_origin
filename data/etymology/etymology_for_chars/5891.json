      "examples": [
        "盘飧市远无兼味，樽酒家贫只旧醅。——杜甫",
        "恰似葡萄初醱醅。——李白"
      ],
      "traditional_char": "醅"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "泛指酒。",
      "examples": [
        "醅酎（美酒）",
        "醅瓮（酒坛子）",
        "醅面（浮在酒面上的绿色泡沫）"
      ],
      "traditional_char": "醅"
    }
  ],
  "formations": [
