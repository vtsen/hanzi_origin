      "part_of_speech": "verb",
      "meaning": "满足（多指欲望、需求）。",
      "examples": [
        "以险徼幸者其求无餍。",
        "不变之说，遂不足久饜学者之心也。",
        "循良慈惠，深饜人心。"
      ],
      "traditional_char": "餍"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "饱、充盛（引申义）。",
      "examples": [
        "姦之食上也，取资乎众，籍信乎辩，而以类饰其私。人主不饜忿而待合参，其势下也。"
      ],
      "traditional_char": "餍"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "终止，止息（引申义）。",
      "examples": [
        "故虽治国，劝之无饜，然后可也。"
      ],
      "traditional_char": "餍"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "厌恶（罕见旧义）。",
      "examples": [
        "朕甚饜之，甚苦之。"
      ],
      "traditional_char": "餍"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "吃饱；满足。",
      "examples": [
