  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘磔’为形声字，从‘石’（意符，表示与石头裂开等动作有关），‘桀’为声旁。最初指分裂牲畜肢体祭祀，与“裂”之意相关。"
    }
  ],
