  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由名词‘大雨’引申为雨、雪盛大的样子，东汉至唐常见。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "‘大雨’喻为帝王的恩泽，唐宋文献中出现。"
