      "traditional_char": "瞋"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "佛教术语，三毒之一——瞋（嗔），指愤怒、嗔恚、怨恨之心。",
      "examples": [
        "佛教以贪、瞋、痴为三毒。",
        "佛言：瞋习交冲，发于相忤。"
      ],
      "traditional_char": "瞋"
