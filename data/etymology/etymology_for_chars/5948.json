  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由破木工具引申为“雕刻、镂刻”这一动作，因工具用途而生。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由雕刻引申，比喻在言语上规劝、雕饰，语义比喻，见晚古汉语。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
