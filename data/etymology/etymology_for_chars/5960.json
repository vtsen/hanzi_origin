  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从片（木片）、户（门窗）和甫声，表示穿壁为窗。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由名词“窗户”引申为动词“开窗、通明”，出现于古文。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由“明窗”引申为“开导、启发”，即明心之意，属比喻义。"
