{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代五声音阶“宫商角徵羽”中的“徵”，对应简谱“5”或工尺谱“六”。",
      "examples": [
        "闻徵者，使人乐善而好施。",
        "古之佩玉，左宫右徵，以节其步，声不失序。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "预兆；迹象，或表现、象征。",
      "examples": [
        "是其徵也。",
        "亡之徵也。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "证明；证验；应验。",
      "examples": [
        "欒郤为徵。",
        "足，则吾能徵之矣。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "召、征召、徵聘（多指国家、君主召集）。",
      "examples": [
        "齐徵诸侯而戍周。",
        "非教士不得从徵。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "征收（课税、收束），索取，搜集。",
      "examples": [
        "程课物徵。",
        "四十万斛不徵。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "招致、招惹（如招致灾祸）。",
      "examples": [
        "违之徵死。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "成、完成（如婚礼纳币的“纳徵”）。",
      "examples": [
        "纳徵。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "质问；问罪；追究。",
      "examples": [
        "寡人是徵。",
        "崟入门……徵于小僮。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 8,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "三国时吴国有徵崇。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 9,
      "part_of_speech": "noun",
      "meaning": "地名，古地名（今陕西澄城）。",
      "examples": [
        "师古曰：卽今澄城县。",
        "穿渠，自徵引洛水。"
      ],
      "traditional_char": "徵"
    },
    {
      "index": 10,
      "part_of_speech": "verb",
      "meaning": "同“懲”，警戒、惩戒、惩罚。",
      "examples": [
        "且徵其未也。"
      ],
      "traditional_char": "徵"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 1,
      "note": "从“微”省，或有“壬”意，表示事物初露端倪，以“徵兆”为最初意义。‘徵’构形反映微小而闻达之义。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_shift",
      "note": "由迹象、徵兆引申为能够验证、证明之义。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "由徵兆、徵示事物，引申为徵召人事、征发等抽象意义。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由召集引申为征收、索取。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "由召集，进一步用作‘招致’不幸等情形。"
    },
    {
      "source_index": 3,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "‘召’的义项在婚礼等仪式语境中延伸为‘成’。"
    },
    {
      "source_index": 3,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由‘召’引申为追问、质问。"
    },
    {
      "source_index": 3,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "职业、官名或地望转为姓氏用。"
    },
    {
      "source_index": 9,
      "target_index": 8,
      "evolution_type": "metonymy",
      "note": "古地名徵与姓氏互有关联，或因地名得姓。"
    },
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "metaphor",
      "note": "由‘徵兆’意象比附为五音名，因五音对事物之象征。"
    },
    {
      "source_index": 1,
      "target_index": 10,
      "evolution_type": "phonetical_loan_shift",
      "note": "‘徵’借作‘懲’，古代文献中“懲”与“徵”通用。"
    }
  ]
