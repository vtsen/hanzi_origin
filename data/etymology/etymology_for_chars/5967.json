    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "县名，在山东省。",
      "examples": [],
      "traditional_char": "滕"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从水，朕声，表示水势上涌。'水'表义，'朕'表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由水腾涌引申比喻言词奔放，见于《易·咸》。“口说”如水奔涌。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "conversion",
      "note": "以地理特征命名地名；水名→地名为常见词类转换。"
