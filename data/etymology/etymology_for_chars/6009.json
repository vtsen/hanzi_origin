  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从穴，㼌声。表示与洞穴、下陷相关，本义指凹陷、低下。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以凹陷、低下为喻，形容东西不坚实、不结实，进而为粗劣之意。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由物之粗劣，引申为制度、品德等领域的败坏、腐败。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "粗劣引申为品质不佳，进一步形容人不勤快，即懒惰。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "物之不坚强，比喻人之瘦弱。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "synecdoche",
      "note": "由坑洼不实引申为器中空虚。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "analogy",
      "note": "与“窊”字义通用，均指凹陷、低下。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "metonymy",
      "note": "地名用字，取本义凹陷、低下地形而名。"
