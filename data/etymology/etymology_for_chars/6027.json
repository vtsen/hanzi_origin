{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代锄草的农具，小手锄或锄草器具。",
      "examples": [
        "垂作耨。",
        "见冀缺耨，其妻饁之。",
        "释其锄耨而下泪。"
      ],
      "traditional_char": "耨"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "锄草，田间除草或泛指耕作。",
      "examples": [
        "人耨必以旱，使地肥而土缓。",
        "耕之耰之，锄之耨之。",
        "务耕而不耨，维草其宅之。"
      ],
      "traditional_char": "耨"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "比喻清除杂念、去除邪恶。",
      "examples": [
        "修礼以耕之，陈义以种之，讲学以耨之。",
        "存是去非类也。"
      ],
      "traditional_char": "耨"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "训斥、责骂。",
      "examples": [
        "早忘了咒，不记得低低耨。"
      ],
      "traditional_char": "耨"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "呻吟。",
      "examples": [
        "一个姿情的不休，一个哑声儿厮耨。"
      ],
      "traditional_char": "耨"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "（方言）男女狎昵、纵情相悦的情态。",
      "examples": [
        "有耨处散诞松宽着耨，有偷处宽行大步偷。"
      ],
      "traditional_char": "耨"
    },
    {
      "index": 6,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [],
      "traditional_char": "耨"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 1,
      "note": "会意字，从‘耒’、‘辱’。‘耒’为农具，‘辱’本从‘辰’、‘寸’，表示用手操作器具除草。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由名词农具耨，引申为动词‘用耨锄草’，使用农具为动作。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由现实锄草引申为清除杂念、去除邪恶，出自儒家义理。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_shift",
      "note": "动作粗野，引申为斥责、骂人。明清及方言用。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "声音低沉粗重，与农事声音类比，用于“呻吟”。戏曲、俗语中。"
    },
    {
      "source_index": 4,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "通过声音、行为转移表意，引申为形容男女狎昵的情态，多见于明清方言和戏曲。"
