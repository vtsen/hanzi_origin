{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "不听取他人意见；不接受别人的意见。",
      "examples": [
        "聱，不入人语也。《广雅》",
        "彼诮为聱者，为其不相从听。《元结·自释》"
      ],
      "traditional_char": "聱"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "文词艰涩，读来不顺口。",
      "examples": [
        "周诰殷盘，佶屈聱牙。《韩愈·进学解》",
        "某尝患《尚书》难读,后来先将文义分明者读之,聱讹者且未读。《朱子语类》"
      ],
      "traditional_char": "聱"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "凹凸不平，参差不齐。",
      "examples": [
        "山石磽聱车碌碌。《欧阳修·盘车图》",
        "百年蟠木老聱，偃蹇春风不肯花。《朱熹·枯大》"
      ],
      "traditional_char": "聱"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "众多的杂音。",
      "examples": [
        "鱼鸟聱耴。《左思·吴都赋》"
      ],
      "traditional_char": "聱"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从耳，敖声，‘耳’表声音、听觉义，‘敖’作声旁，本指不听取意见。"
    }
