{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代打击乐器，多用石或玉制成，状如曲尺，悬挂于架上敲击发声",
      "examples": [
        "笙磬同音。",
        "钟磬置于水中。"
      ],
      "traditional_char": "磬"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "佛寺中使用的一种钵状打击乐器，多以金属铸成，用以念经或集合僧众",
      "examples": [
        "但馀钟磬声。",
        "寺内常闻空中应时有磬声，依而集众。"
      ],
      "traditional_char": "磬"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "适宜制磬的美石",
      "examples": [
        "泗滨浮磬。"
      ],
      "traditional_char": "磬"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "弯腰表示谦恭，身体如磬状弯曲",
      "examples": [
        "西门豹簪笔磬折，向河立待良久。",
        "立则磬折垂佩。"
      ],
      "traditional_char": "磬"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "以绳悬挂勒杀，古代的一种死刑",
      "examples": [
        "公族其有死罪，则磬于甸人。"
      ],
      "traditional_char": "磬"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "放马疾驰，奔跑",
      "examples": [
        "抑磬控忌，抑纵送忌。"
      ],
      "traditional_char": "磬"
    },
    {
      "index": 6,
      "part_of_speech": "adjective",
      "meaning": "空，尽，罄尽",
      "examples": [
        "金积折廉，璧袭无理，磬龟无腹，蓍策日施。"
      ],
      "traditional_char": "磬"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "此字甲骨文象手持槌击悬挂之磬，为象形字，描绘乐器实物。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由古乐器泛指至佛寺金属钵状法器，佛教传入后出现。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "因制作磬的特定美石以“磬”为名，取材物与成品乐器的联系。"
