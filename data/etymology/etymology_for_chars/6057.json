{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "短木桩，小木橛子，用作固定或作界限的木柱。",
      "examples": [
        "苗高二三尺，每路打橛。",
        "吾处也，若橛株驹。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "树木或庄稼的残茎、桩根。",
      "examples": [
        "至孟春，土长冒橛，陈根可拔而事之。",
        "橛株驹（树桩）"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "马口中所衔的横木，即马嚼子。",
      "examples": [
        "无捶策之威，衔橛之备，虽造父不能以服马。",
        "前有橛饰之患，而后有便荚之威。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "门中竖立以作限隔的短木。",
      "examples": [
        "闑，一名橛也。",
        "布席于门中闑西。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "一小段木料或物体，比喻为某物分成的一截。",
      "examples": [
        "汝从南岳负一橛柴来，岂不是有力？",
        "朱自清《论雅俗共赏》：不是不相理会的两橛了。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "翘起，鼓起；物体上翘突出。",
      "examples": [
        "伙计本来是势利鬼，眼睛生在额角上的，早就橛着狗嘴的了。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "倒，颠仆。",
      "examples": [
        "参见“橛痿”。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "折断。",
      "examples": [
        "树本浅，根垓不深，未必橛也；飘风起，暴雨至，拔必先矣。",
        "乍如沙场大战后。断枪橛箭皆狼籍。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 8,
      "part_of_speech": "verb",
      "meaning": "敲，打击。",
      "examples": [
        "以其皮为鼓，橛以雷兽之骨，声五百里，以威天下。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 9,
      "part_of_speech": "verb",
      "meaning": "掘地，挖掘。",
      "examples": [
        "先橛区，用糞土相合内区中，水调成稀泥，植栽于内。"
      ],
      "traditional_char": "橛"
    },
    {
      "index": 10,
      "part_of_speech": "adjective",
      "meaning": "倔强，直性。",
      "examples": [
        "汉儒说经，舌本强橛，似儿强解事者。",
        "两个橛老头子，你一言我一语。"
      ],
      "traditional_char": "橛"
    }
  ],
