      "part_of_speech": "verb",
      "meaning": "直视，瞪着眼睛看",
      "examples": [
        "瞠，直视也。《集韵》",
        "夫子奔逸绝尘，而回瞠若乎后矣。《庄子·田子方》",
        "忠烈乃瞠目曰：‘我史阁部也。’《梅花岭记》",
        "可惜我去问他，他们都瞠着眼不说话。"
      ],
      "traditional_char": "瞠"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "惊视，吃惊地张眼看",
      "examples": [
        "众目亦益瞠，口亦益张。《鲁迅·集外集拾遗》",
        "‘啊，吴嫗不几吓杀耶？’李媼又大惊叫，众目亦益瞠，口亦益张。《鲁迅·怀旧》"
      ],
      "traditional_char": "瞠"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "定视，专注地注视",
      "examples": [
        "定视也。与“𥊼”同。"
      ],
      "traditional_char": "瞠"
    }
  ],
