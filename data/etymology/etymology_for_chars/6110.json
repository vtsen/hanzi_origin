{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "围绕，环绕",
      "examples": [
        "圜流九十里。",
        "圜视而起。"
      ],
      "traditional_char": "圜"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "天体，天空",
      "examples": [
        "圜，天体也。",
        "乾为天，为圜。"
      ],
      "traditional_char": "圜"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "牢狱，监狱",
      "examples": [
        "司圜中士六人。",
        "圜土，狱城也。"
      ],
      "traditional_char": "圜"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "圆形，圆的事物",
      "examples": [
        "刓方以为圜兮。",
        "圜，一中同长也。"
      ],
      "traditional_char": "圜"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "圆的，圆形的",
      "examples": [
        "冬日至于地上之圜丘奏之。",
        "圜者中规，方者中矩。"
      ],
      "traditional_char": "圜"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "钱币",
      "examples": [
