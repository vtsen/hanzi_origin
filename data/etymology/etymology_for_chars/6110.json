        "圜钱（古代钱币）"
      ],
      "traditional_char": "圜"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "圜为形声字，从囗，睘声，初指天体（圆形的天空），围绕、周全之意。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由天体为圜，引申为一般圆形事物，见《墨子》。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "由“圆形（名词）”直接转为“圆的（形容词）”。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "圆形引申为“钱币”，因古钱多为圆形，见汉代用法。"
    },
    {
      "source_index": 3,
      "target_index": 0,
      "evolution_type": "semantic_extension",
      "note": "由圆的形，进一步表“围绕”，本义即“围绕为圆”，古文用法。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "圆形的围墙引申为“牢狱”，“圜土”为圆形监狱。"
    }
  ]
}