{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "收获谷物，亦泛指耕作。",
      "examples": [
        "土爰稼穑。",
        "不稼不穑，胡取禾三百廛兮？",
        "稼穑艰难。",
        "良农能稼而不能为穑。"
      ],
      "traditional_char": "穑"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "收获的谷物，谷类的穗。",
      "examples": [
        "曾孙之穑，以为酒食。",
        "所艺禾穑特大。"
      ],
      "traditional_char": "穑"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "通“啬”，指节俭、爱惜。",
      "examples": [
        "贬食省用，务穑劝分。",
        "大国省穑而用之。"
      ],
      "traditional_char": "穑"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "通“啬”，指互相钩连（物体之间互相连接）。",
      "examples": [
        "树以荆棘，上相穑著者，所以为固也。"
      ],
      "traditional_char": "穑"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从禾，啬声；禾表谷物、农业意，啬兼表音与‘节俭’语义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由动词‘收获谷物’引申作名词‘收获的谷物’。先秦即见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "phonetical_loan_shift",
      "note": "因形声兼通啬，引申为‘节俭’、‘爱惜’意义，汉至中古文献有见。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "phonetical_loan_shift",
      "note": "亦因通‘啬’，音近而假借指物体互相钩连，见《管子》。"
    }
  ]
}