{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "哺乳动物的一类，身长脚短，嘴尖耳小，捕食蛇、蟹等，如蟹獴、蛇獴、赤颊獴，即獴属动物。",
      "examples": [
        "蟹獴捕食蟹类。",
        "蛇獴以捕蛇著名。"
      ],
      "traditional_char": "獴"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "与“蒙”通用，指贵重、尊贵等义。",
      "examples": [
        "蒙贵（獴貴）"
      ],
      "traditional_char": "獴"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从犬，蒙声，犬指兽类，蒙作声符，原指猫科动物獴。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "phonetical_loan_shift",
      "note": "以獴假借为‘蒙’，为通假用法，见于古文。"
    }
  ]
}