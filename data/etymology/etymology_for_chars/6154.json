    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "頸部等處淋巴結因結核菌等感染而腫大的疾病，即瘰癧（俗稱癧子頸、老鼠瘡等）。",
      "examples": [
        "頸項間瘰癧。",
        "瘰癧多見於耳後、頤項。"
      ],
      "traditional_char": "瘰"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "泛指皮膚筋結處發生腫瘍或癧塊之疾。",
      "examples": [
        "筋結病也。",
        "瘍繞頸項絫絫也。"
      ],
      "traditional_char": "瘰"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "肌膚肥厚病或疥病等皮膚病。",
      "examples": [
        "瘯瘰，皮肥也。",
        "一曰疥病。"
      ],
      "traditional_char": "瘰"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "同“𤻳”，一類皮膚病。",
      "examples": [],
      "traditional_char": "瘰"
    }
  ],
