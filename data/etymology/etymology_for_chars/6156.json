      "part_of_speech": "noun",
      "meaning": "中医指颈部的赘生物病症，多因气郁、缺碘等引发，亦称“瘿病”。",
      "examples": [
        "气瘿、肉瘿、石瘿。",
        "颈有肿物曰瘿。"
      ],
      "traditional_char": "癭"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "病理学上指因多种刺激（如病菌、寄生虫等）导致动植物局部组织增生而成的囊状赘生物。",
      "examples": [
        "树木受虫害后常形成瘿。",
        "植物枝叶生瘿。"
      ],
      "traditional_char": "癭"
    }
  ],
