{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "病愈，恢复健康。",
      "examples": [
        "其伤于缚者，即幸留，病数月乃瘳。",
        "若药弗瞑眩，厥疾弗瘳。",
        "染此者十不一二，或随有瘳。",
        "癘疫忽潛遘，十家無一瘳。",
        "病體全瘳。"
      ],
      "traditional_char": "瘳"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "减少，减损。",
      "examples": [
        "君不度而贺大国之袭，于己也何瘳?",
        "斯与彼其何瘳。",
        "走萬里路汔小休，閉門風雨百感瘳。"
      ],
      "traditional_char": "瘳"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "治理，救治（国家、事务获得解决或康复）。",
      "examples": [
        "愿以所闻思其则，庶幾其国有瘳乎。",
        "养民瘳国脉。",
        "竊哀今世之病，搜得孔子舊方，庶幾中國有瘳，而大地群生俱起乎？"
      ],
      "traditional_char": "瘳"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "快乐，安乐。（见于《诗经》《郑风·风雨》“既见君子，云胡不瘳”）",
      "examples": [
        "既见君子，云胡不瘳。"
      ],
      "traditional_char": "瘳"
    }
  ],
