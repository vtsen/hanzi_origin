  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "《说文解字》：“嬴，帝少昊之姓也。从女，贏省声。”‘女’示女性，'贏'作声符。最早造字为古族姓氏。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "秦国因君族为嬴姓而得名，本义的引申。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "古邑由嬴姓族所居而得名，春秋战国见。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "与‘赢’同用。因嬴族昌盛，引申为‘胜利’。见古籍假借。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "与‘盈’音同，古多通用，引申为‘有余’、‘满’。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_shift",
      "note": "义同‘担负’，源自族人作用的动词化。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "metaphor",
      "note": "盈余之义转指土地肥美，见古地名解。"
    },
    {
      "source_index": 7,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "盈余引申为增益、增加。"
    },
    {
      "source_index": 7,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "盈满、包容义再扩为环绕，见《淮南子》。"
    }
  ]
}