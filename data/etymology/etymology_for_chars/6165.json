      "examples": [
        "壅，蔽也。——《战国策·齐策》注",
        "主安得无壅，国安得无患乎？——《晏子春秋》",
        "被壅故也。——《旧唐书》"
      ],
      "traditional_char": "壅"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "堆积，凝聚；聚集",
      "examples": [
