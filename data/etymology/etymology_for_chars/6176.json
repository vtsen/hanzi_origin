      ],
      "traditional_char": "潞"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "江名，即云南省的怒江，又称潞江。",
      "examples": [
        "永昌军民府城北有潞江。"
      ],
      "traditional_char": "潞"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "瘦弱，疲病。",
      "examples": [
        "士民罢潞，国家空虚。——《吕氏春秋·不屈》"
      ],
      "traditional_char": "潞"
    }
