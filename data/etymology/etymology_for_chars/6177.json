{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "澧水，河流名，主要指发源于湖南、流入洞庭湖的河流，也泛指其他名为澧的水系。",
      "examples": [
        "又东至于澧。——《书·禹贡》",
        "捐余玦兮江中，遗余佩兮澧浦。——《楚辞·九歌·湘君》"
      ],
      "traditional_char": "澧"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "古州名，指以澧水为中心的行政区，今湖南省澧县一带。",
      "examples": [
        "自汉而南，州之美者十七八，莫若澧，澧之佐理，莫踰于长史。——唐 柳宗元《送南涪州量移澧州序》"
      ],
      "traditional_char": "澧"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "通“醴”，形容水泉甘美。",
      "examples": [
        "甘露降，澧泉涌。——《列子·汤问》"
      ],
      "traditional_char": "澧"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [],
      "traditional_char": "澧"
    },
    {
      "index": 4,
      "part_of_speech": "onomatopoeia",
      "meaning": "象声词，形容波浪起伏的声音。",
      "examples": [
        "波澧澧而扬澆兮。——《楚辞·灵怀》"
      ],
      "traditional_char": "澧"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从水，豊声，会意兼形声，最初指水名，汉字结构形旁为表义，声旁为表音。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "以河流名称借指流域地区，常见地名生成方式。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由实际河流名称，因与“醴”音通用，可引申为甘美之义，多用于泉水等语境。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "conversion",
      "note": "地名、水名演变为姓氏，为古代常见用法，见于《汉书》。"
