      "part_of_speech": "noun",
      "meaning": "古湖泊或水名、地名。指古代的澶淵、水名或與其相關的地點。",
      "examples": [
        "宋御遼于澶淵",
        "澶淵聚卽其地"
      ],
      "traditional_char": "澶"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "水流平靜的樣子，水靜止不動。",
      "examples": [
        "澶湉漠而無涯",
        "水澶湉然"
      ],
      "traditional_char": "澶"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "寬廣、廣大；形容事物的廣闊或長遠。",
      "examples": [
        "案衍澶漫",
        "澶漫靡迤陵原之形"
      ],
      "traditional_char": "澶"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "放縱，豪放，縱逸的樣子。",
      "examples": [
        "澶漫為樂",
        "性情澶蕩"
      ],
      "traditional_char": "澶"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从水，亶聲；本義指水名、湖名，用水部表意、亶表音。"
