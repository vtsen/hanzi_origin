{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "水名，江西濂江的舊名。",
      "examples": [
        "濂江，江西南部之水。",
        "濂水，今名濂江。"
      ],
      "traditional_char": "濂"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "湖南濂溪，水名。",
      "examples": [
        "濂溪，湖南之水。"
      ],
      "traditional_char": "濂"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "淺水，中流斷絕；小水流或薄水。",
      "examples": [
        "所謂濂，則水之淺薄者爾，故中絕也。",
        "濂𣿙也。"
      ],
      "traditional_char": "濂"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "學派名，即“濂溪學派”，以宋代理學家周敦頤（號濂溪）為首。",
      "examples": [
        "濂洛關閩。",
        "北宋周敦頤為首的“濂溪學派”。"
      ],
      "traditional_char": "濂"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "宋濂",
        "濂洛"
      ],
      "traditional_char": "濂"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "輕薄貌。",
      "examples": [
        "濂涑，輕薄兒也。"
      ],
      "traditional_char": "濂"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "形声字，从水，兼声。表淺水、小水或水流中斷的意思。"
