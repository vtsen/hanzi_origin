      ],
      "traditional_char": "隰"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "地名，用作县、州或古邑名。",
      "examples": [
        "春秋齐邑名，即犂丘。",
        "古州名。在今山西省隰县。",
        "重耳居蒲，卽隰川州。"
      ],
      "traditional_char": "隰"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
