    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "绳圈；绞索，用于套在颈上加以勒杀或自缢。",
      "examples": [
        "投缳自缢",
        "投缳道路",
        "虹蜺为缳"
      ],
      "traditional_char": "繯"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用绳索缠绕、系结、围绕。",
      "examples": [
        "缳山于有牢",
        "缳橐"
      ],
      "traditional_char": "繯"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "系在旗上的结或饰带。",
      "examples": [
        "青云为纷，虹蜺为缳"
      ],
      "traditional_char": "繯"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "捕兽网，与罗网同类。",
      "examples": [
        "繯网罝罦不敢出於门"
      ],
      "traditional_char": "繯"
    }
  ],
  "formations": [
