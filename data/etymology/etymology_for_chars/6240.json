      "part_of_speech": "noun",
      "meaning": "山名。指九嶷山，舜安葬之处，在湖南省，也叫九疑山。",
      "examples": [
        "九嶷山在湖南省境内。",
        "祀虞舜于九疑。"
      ],
      "traditional_char": "嶷"
    },
