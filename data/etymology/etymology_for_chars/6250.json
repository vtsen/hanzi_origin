      "part_of_speech": "noun",
      "meaning": "一种用铁制成的凿冰工具，尖头如锥，有倒钩，称为“冰镩”。",
      "examples": [
        "他用冰镩凿开了河面上的冰。"
      ],
      "traditional_char": "鑹"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "用冰镩凿冰或进行加工。",
      "examples": [
        "镩冰取水。"
      ],
      "traditional_char": "鑹"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "短矛，一种古代兵器。",
      "examples": [
        "黃家賊用鑹刀利，白水郞行旱地稀。",
        "鑹，小矟也。"
      ],
      "traditional_char": "鑹"
    }
  ],
  "formations": [
