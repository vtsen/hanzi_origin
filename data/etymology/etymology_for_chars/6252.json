      "meaning": "古代盛熟食的器皿，形似高足盘或有盖，也称瓦豆。",
      "examples": [
        "实于镫，宰右执镫，左执盖，由门入。"
      ],
      "traditional_char": "鐙"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "照明用具，灯，油灯。",
      "examples": [
        "兰膏明烛，华镫错些。",
        "青鐙獨照暗壁，胍胍羈魂寂。"
      ],
      "traditional_char": "鐙"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "挂在鞍两旁的脚踏，马镫。",
      "examples": [
        "龙驹雕镫白玉鞍。",
        "金鐙下山紅日晚。"
      ],
      "traditional_char": "鐙"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "听骨之一，形状像马镫。",
      "examples": [],
      "traditional_char": "鐙"
    }
  ],
  "formations": [
    {
