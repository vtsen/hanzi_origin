{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "遥远；空间距离大",
      "examples": [
        "吴水深万丈，楚山邈千重。",
        "邈若山河。"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "久远；指时间长",
      "examples": [
        "汤禹久远兮，邈而不可慕。",
        "大圣踵武，邈将千载。"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "疏远，远离",
      "examples": [
        "昔君之来兮，友兹山而谁儔？今君之去兮，邈兹山乎何求？",
        "邈姱俗而遗身。"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 3,
      "part_of_speech": "adjective",
      "meaning": "渺茫，模糊不清",
      "examples": [
        "幽蹤邈難得，聖路嗟長堙。",
        "千載眇邈，非所詳耳。"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "高远，超卓",
      "examples": [
        "邈矣先生，应天淑灵，孝友是备，上德是经。",
        "俋俋耕不顾，斯情邈难儔。"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "超越，胜过",
      "examples": [
        "何调翰之乔桀，邈稠类而殊才。",
        "功邈稽古。"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "轻视，小看（通“藐”）",
      "examples": [
        "说大人则邈之。",
        "高眄邈四海，豪右何足陈！"
      ],
      "traditional_char": "邈"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "描绘，摹写（通“貌”）",
      "examples": [
        "邈其夫人灵在金牌之上。",
        "有人邈得吾真否？"
      ],
      "traditional_char": "邈"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从辵，貌声。表示空间距离遥远之意。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "空间遥远引申为时间上的久远。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由空间上的远，引申为人与人、事物之间的疏远与远离。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "空间远不可及，引申为模糊不清、渺茫；常用于形容抽象事物。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由空间的高远比喻为人格、志向等的高远与超卓。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "遥远与超越意有联系，从超越空间引申到超越他人。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "synecdoche",
      "note": "“远观”“小视”通义，演变为轻视、小看（通‘藐’）。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "phonetical_loan_shift",
      "note": "以声借义，通“貌”，用于描绘、摹写之义。"
    }
  ]
}