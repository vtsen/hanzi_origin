      "index": 1,
      "part_of_speech": "noun",
      "meaning": "泛指绳索。",
      "examples": [
        "乃奋长縻，是轡是鑣。——晋·刘琨《答卢谌诗》",
        "縻锁之迹，仍今存焉。——《水经注》",
        "广备縻索，多聚勇力。——《集异记》"
      ],
      "traditional_char": "縻"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "捆绑、拴系，牵制、束缚。",
      "examples": [
        "是谓縻举。——《孙子·谋攻》",
        "吾当以长策縻之。——《晋书·文帝纪》",
        "须知此身縻官籍。——明·沈鲸《双珠记》"
      ],
      "traditional_char": "縻"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "消耗、损失，浪费（通“靡”）。",
      "examples": [
        "坐縻廪粟。——明·刘基《卖柑者言》",
        "今縻岁月，捐父母，弃室家。——宋·叶适《陈民表墓志铭》"
