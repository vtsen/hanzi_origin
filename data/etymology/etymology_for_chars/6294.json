      "examples": [
        "及庸、蜀、羌、髳、微、盧、彭、濮人。（《书·牧誓》）",
        "麇人率百濮聚于选，将伐楚。（《左传·文公十六年》）"
      ],
      "traditional_char": "濮"
    },
