{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "烙饼用的平底铁锅，俗称鏊子或鏊盘。",
      "examples": [
        "如热鏊上蚂蚁，没走一头处。",
        "餅鏊。今烙餅平鍋曰餅鏊亦曰烙鍋。"
      ],
      "traditional_char": "鏊"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "烧器，一种加热或烧烤用的器具。",
      "examples": [
        "【集韻】燒器。",
        "鏊砚（鏊形的砚台）"
      ],
      "traditional_char": "鏊"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "山名。《山海經》中记载大荒之中有山，名曰鏖鏊鉅。",
      "examples": [
        "《山海經》大荒之中有山，名曰鏖鏊鉅。"
      ],
      "traditional_char": "鏊"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "通“鏖”，指激烈战斗。",
      "examples": [
        "鏊戰。"
      ],
      "traditional_char": "鏊"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "通“熬”，指加热、煎熬。",
      "examples": [
        "鏊頭。",
        "鏊有熬音也。"
      ],
      "traditional_char": "鏊"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
