{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "篱笆，用以围障、分隔的用木枝等编成的障碍物。",
      "examples": [
        "羝羊触藩。（《易·大壮》）",
        "藩，篱也。（《广雅·释室》）"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "屏障、保护物，比喻保卫国家的力量或重臣。",
      "examples": [
        "藩翰。（喻保卫国家的重臣）",
        "以道德为藩，不以袭险为屏也。（晋·左思《魏都赋》）"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "封建时代称属国、属地或分封的土地，借指边防重镇等。",
      "examples": [
        "藩属、藩国、藩镇、藩邦。",
        "东平王苍罢归藩。（《后汉书·明帝纪》）"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "疆界、领域、边界。",
      "examples": [
        "吾愿游其藩。（《庄子·大宗师》）",
        "藩服（旧指离开京城最远的边远地区）；藩篱（指边疆、边界）。"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "有屏围的车，古代一种四周有帘幕的车。",
      "examples": [
        "以藩载栾盈及其士。（《左传·襄公十二年》）"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 5,
      "part_of_speech": "noun",
      "meaning": "草名，指“知母”等药草。",
      "examples": [
        "莐藩，药草名，即知母。（《尔雅·释草》）"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "护卫，捍卫。",
      "examples": [
        "舍诸边境，使卫藩焉！（《左传·哀公十六年》）",
        "藩辅（捍卫；辅佐）；藩翼（捍卫）。"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 7,
      "part_of_speech": "verb",
      "meaning": "遮蔽，遮掩。",
      "examples": [
        "以相藩饰。（《荀子·荣辱》）",
        "藩蔽（古代用施漆的苇席制成的车蔽）。"
      ],
      "traditional_char": "藩"
    },
    {
      "index": 8,
      "part_of_speech": "verb",
      "meaning": "用篱笆等围起来，围绕。",
      "examples": [
        "吴人藩卫侯之舍。（《左传·哀公十二年》）",
        "藩盾（用大盾临时构筑的屏藩）。"
      ],
      "traditional_char": "藩"
    }
  ],
