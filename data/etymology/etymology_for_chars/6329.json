  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从日，熏声，表示“日落时的余光”，意符日表光明时间，‘熏’表达声音及部分意象。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由“日落的余光”扩展为“傍晚、黄昏”等时间段名称，用于时间概念，魏晋南北朝起见。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由“傍晚、黄昏”环境引申至“昏暗”的状态，晚唐文献已见。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "余光色彩感受引申为具体颜色“赤黄色”，见于医书及色彩形容。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "由‘昏暗’转喻为‘醉态’（神志不清），明清用法，有类比色态、状态之义。"
    }
