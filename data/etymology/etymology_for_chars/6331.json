      "part_of_speech": "noun",
      "meaning": "日光；明亮的光辉。",
      "examples": [
        "日出有曜。",
        "晨光初散，则延曜入石。"
      ],
      "traditional_char": "曜"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "照耀；发出光芒。",
      "examples": [
        "扬晖吐火，曜野蔽泽。",
        "明镫曜闺中。"
      ],
      "traditional_char": "曜"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "炫耀；显示。",
      "examples": [
        "若无越，则吾何以春秋曜吾军士？",
        "各曜辞锋。"
      ],
      "traditional_char": "曜"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "日、月、五大行星等天体的通称；古代称日、月、火、水、木、金、土为七曜。",
      "examples": [
        "七曜周旋。",
        "日曜日。"
      ],
      "traditional_char": "曜"
    }
  ],
