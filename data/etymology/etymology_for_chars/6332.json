      "part_of_speech": "verb",
      "meaning": "踐踏、行走的樣子。",
      "examples": [
        "峭刻巖面穫，磴窮螺紋旋；徑裊珠絲躇，行具藤葛纏。",
        "若躇步蹔蹈。"
      ],
      "traditional_char": "躇"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "超越階次，不按順序而進。",
      "examples": [
        "趙盾知之，躇階而走。",
        "晉獒搏而躇。"
      ],
      "traditional_char": "躇"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "纏繞、盤旋的樣子。",
