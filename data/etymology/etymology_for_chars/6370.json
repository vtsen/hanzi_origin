  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "从革，𤰈声，表示覆盖在车上的皮制饰物，属于形声字。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由覆盖物引申为给马车装备马具，古汉语常见的名转动用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由皮制覆盖物泛指皮囊、盛箭囊，属于材质和用途方面的引申。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "由盛箭皮囊引申为皮制鼓风器，二者同为皮革作成之囊，因形制功能近似而转类。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "由名词‘鼓风器’转为动词‘鼓风’，常规的器官转使作动用法。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "以鼓风激流为喻，引申指水流受压如鞴鼓风般喷涌，见于文学中。"
    }
  ]
