{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古代在冠礼、婚礼等仪式中，用酒进行的敬酒礼仪，尊者酌酒，卑者饮尽，不需回敬。",
      "examples": [
        "若不醴則醮用酒。——《仪礼·士冠礼》",
        "父亲醮子而命之迎。——《礼记·昏义》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "祭祀、祈祷神灵的仪式，后多指道士或和尚设坛念经做法事。",
      "examples": [
        "醮，祭也。——《广雅》",
        "醮诸神。——宋玉《高唐赋》",
        "专意斋醮。——清·张廷玉《明史》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "女子出嫁，特指再嫁。",
      "examples": [
        "未嫁而丧二夫，故十九犹未醮也。——《聊斋志异》",
        "无改醮之礼。——宋·孙光宪《北梦琐言》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "独自饮酒而醉。",
      "examples": [
        "主人进酒于客曰酬，客酌主人曰酢，独酌而醉曰醮。——明·郎瑛《七修类稿》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 4,
      "part_of_speech": "adjective",
      "meaning": "尽，尤指水尽、酒饮尽。",
      "examples": [
        "利爵之不醮也。——《荀子·礼论》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "贫穷，财物用尽（方言用法）。",
      "examples": [
        "丢这们些银子，弄得手里醮醮的，我有不替你买得么?——《醒世姻缘传》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "用，蘸（方言用法，与“蘸”同）。",
      "examples": [
        "试以手探之，痛不甚剧，遂醮油涂体，果无损。——清·吴騫《拜经楼诗话》"
      ],
      "traditional_char": "醮"
    },
    {
      "index": 7,
      "part_of_speech": "adjective",
      "meaning": "憔悴，烦恼（通“憔”，罕用）。",
      "examples": [
