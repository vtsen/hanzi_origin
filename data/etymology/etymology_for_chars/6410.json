  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "形声字，从羊，表示与瘦弱相关；羊为意符，表示瘦羊为病，以瘦弱为本义，声旁为𦟀。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由瘦弱引申为疲困，常见形容人或军队，先秦已见。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "瘦弱进一步泛化为衰弱，如精神、势力等的弱。"
