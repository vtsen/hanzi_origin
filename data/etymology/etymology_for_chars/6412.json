{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "北方的大湖或海，古代指‘瀚海’，后常指贝加尔湖、蒙古高原等北方广大水域或地区；后泛指北方戈壁大沙漠。",
      "examples": [
        "校尉羽书飞瀚海，单于猎火照狼山。——唐·高适《燕歌行》"
      ],
      "traditional_char": "瀚"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "沙漠，尤指北方的广大沙漠地带。",
      "examples": [
        "瀚漠（北方大沙漠）"
      ],
      "traditional_char": "瀚"
    },
    {
      "index": 2,
      "part_of_speech": "adjective",
      "meaning": "广大的样子，形容水势浩大或范围广大。",
      "examples": [
        "浩浩瀚瀚。——《淮南子·俶真》",
        "浩瀚（广大辽阔的样子）"
      ],
      "traditional_char": "瀚"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "洗涤，澣。",
      "examples": [
        "寒衣三瀚客心惊。——清·宋琬诗",
        "瀚濯（洗涤数次）"
      ],
      "traditional_char": "瀚"
    }
  ],
  "formations": [
    {
