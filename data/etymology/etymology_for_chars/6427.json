      "index": 0,
      "part_of_speech": "adjective",
      "meaning": "惊惶急视，惊视，急切张望的样子。",
      "examples": [
        "震索索，视矍矍。《易·震》",
        "方山子亦矍然问余所以至此者。《苏轼·方山子传》"
      ],
      "traditional_char": "矍"
    },
    {
      "index": 1,
      "part_of_speech": "adjective",
      "meaning": "年老而精神矍铄的样子。",
      "examples": [
        "矍铄哉，是翁也。《后汉·马援传》"
      ],
      "traditional_char": "矍"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "唐有矍璋。"
      ],
      "traditional_char": "矍"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "地名，如‘矍相’。",
      "examples": [
        "孔子射于矍相之圃。《礼·射义》"
      ],
      "traditional_char": "矍"
    }
  ],
  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从‘又’（手）和‘隹’（鸟），表示手捉鸟时的惊视状态，象征急切张望。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘惊惶急视’之貌引申为‘矍铄’，形容年高而精神矍然，多见于后汉、魏晋。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "reanalysis",
      "note": "古人以常用字作为姓氏，‘矍’作为姓氏多见于《通志·氏族》。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "reanalysis",
      "note": "‘矍相’等地名源自人名或以该字音、义为地名用字，属再分析用法。"
