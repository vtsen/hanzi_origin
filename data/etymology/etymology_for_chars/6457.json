    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "一种传说中的一足怪兽，形如龙或牛，常见于商周青铜器装饰。",
      "examples": [
        "《山海经·大荒东经》：其上有兽，状如牛，苍身而无角，一足……其名曰夔。",
        "商周铜器上多夔状纹饰"
      ],
      "traditional_char": "夔"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "山林、木石中的精怪，怪异之物。",
      "examples": [
        "《国语·鲁语下》：木石之怪曰夔、蝄蜽。",
        "《说文》：夔，神魖也。"
      ],
      "traditional_char": "夔"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "古代传说中的乐官，舜时人名。",
      "examples": [
        "《礼记·乐记》：夔始制乐，以赏诸侯。",
        "夔，舜时典乐者也。"
      ],
      "traditional_char": "夔"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "古地名、国名，如夔国、夔州，今四川奉节等地。",
      "examples": [
        "《春秋·僖公二十六年》：楚人灭夔。",
        "唐改信州为夔州，治在四川奉节。"
      ],
      "traditional_char": "夔"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "夔，姓氏用字。"
      ],
      "traditional_char": "夔"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "敬惧、敬畏的样子。",
      "examples": [
        "《书·大禹谟》：夔夔齐慄。",
        "夔夔悚惧之容。"
      ],
      "traditional_char": "夔"
    },
    {
