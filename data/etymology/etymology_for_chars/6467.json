      "part_of_speech": "noun",
      "meaning": "鸟类名，羽毛灰白色或黑色，嘴长而直，形似白鹤，生活在江、湖、池沼的近旁，捕食鱼虾等。",
      "examples": [
        "白鹳、黑鹳常见于湿地。",
        "《尔雅·释鸟》：鸛，大鸟也。"
      ],
      "traditional_char": "鸛"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "鸛为形声字，从鸟，雚声，表示水边的大鸟。鹳为其简化形式。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "鹳为简化字，从鸟，官声，表示同义。"
    }
