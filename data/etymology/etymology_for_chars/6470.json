{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "传说中的凶恶贪食的野兽，如“饕餮”；古代铜器常用其头部为饰。",
      "examples": [
        "饕餮之徒，见食忘生。",
        "饕餮之兽，祸乱为灾。"
      ],
      "traditional_char": "饕"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "比喻凶恶贪婪的人。",
      "examples": [
        "吏饕民困。",
        "此乃饕之徒也。"
      ],
      "traditional_char": "饕"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "比喻贪吃之人。",
      "examples": [
        "老饕好美食。",
        "饕餮放横。"
      ],
      "traditional_char": "饕"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "贪财、极其贪婪。",
      "examples": [
        "貪財為饕，貪食為餮。",
        "饕貪而無厭。"
      ],
      "traditional_char": "饕"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "特指贪婪地享用美食，贪吃。",
      "examples": [
        "老饕饕餮。",
        "饕殘地吞食。"
      ],
      "traditional_char": "饕"
    },
    {
      "index": 5,
      "part_of_speech": "adjective",
      "meaning": "形容猛烈（多作风、雪等自然现象的修饰）。",
      "examples": [
        "雪虐风饕。",
        "霜饕。"
      ],
      "traditional_char": "饕"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 3,
      "note": "形声字，从食，號声，本义为极其贪婪。"
    }
  ],
  "edges": [
    {
      "source_index": 3,
      "target_index": 0,
      "evolution_type": "metaphor",
      "note": "由极贪意引申为贪食的怪兽形象，见“饕餮”；先秦已见。"
    },
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "以饕餮比喻贪婪凶恶之人，用于人物，古已有之。"
    },
    {
      "source_index": 3,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "“贪”之意专指贪食，直接泛化为贪吃之人。"
    },
    {
      "source_index": 3,
      "target_index": 4,
      "evolution_type": "semantic_narrowing",
      "note": "本义为一般贪婪，狭化为对食物的贪婪。"
    },
    {
      "source_index": 3,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "因贪的无度，形容猛烈的自然之物，如风雪。唐宋已见。"
    }
  ]
}