  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "从人，及声。初指‘善思、思考敏捷’，后引申为人名。常见于古人名和少量形容词用法。"
    }
  ],
  "edges": [
    {
      "source_index": 1,
      "target_index": 0,
      "evolution_type": "metonymy",
      "note": "古代多用该字表达有智慧或善思者的人名，因德行特征而得名。"
