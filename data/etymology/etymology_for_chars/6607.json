{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "verb",
      "meaning": "飞扬，飘扬；随风升起或散开。",
      "examples": [
        "风飏电激。",
        "曳红采之流离兮，飏翠气之宛延。"
      ],
      "traditional_char": "颺"
    },
    {
      "index": 1,
      "part_of_speech": "verb",
      "meaning": "（通“扬”）举起、抬起。",
      "examples": [
        "江风飏帆急，山月下楼迟。"
      ],
      "traditional_char": "颺"
    },
    {
      "index": 2,
      "part_of_speech": "verb",
      "meaning": "（通“扬”）显扬，宣扬，使名声显著。",
      "examples": [
        "将美匡丑，对飏休光。"
      ],
      "traditional_char": "颺"
    },
    {
      "index": 3,
      "part_of_speech": "verb",
      "meaning": "（通“扬”）扬声，大声。",
      "examples": [
        "雄朔野以飏声。"
      ],
      "traditional_char": "颺"
    },
    {
      "index": 4,
      "part_of_speech": "verb",
      "meaning": "（用作形容词，动词化）在空中飞翔。",
      "examples": [
        "飏飏（飞翔的样子）。"
      ],
      "traditional_char": "颺"
    },
    {
      "index": 5,
      "part_of_speech": "verb",
      "meaning": "在簸米等操作中，把杂物分散扬去。",
      "examples": [
        "簸之颺之，糠粃在前。"
      ],
      "traditional_char": "颺"
    },
    {
      "index": 6,
      "part_of_speech": "verb",
      "meaning": "（现代用法）“颺”的简化字。",
      "examples": [],
      "traditional_char": "飏"
    }
  ],
  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "颺：形声字，从风，昜声，表示风中升腾飞扬之意。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 6,
      "note": "飏：‘颺’的简化字，用‘飠’（食的异体）代替‘风’旁，由现代简化字方案产生。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "原意‘飞扬’引申为事物向高处举起，如布帆、船帆等。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "由‘飞扬’引申出‘名声飞扬、显扬’的抽象意义。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metonymy",
      "note": "事物飘扬时常伴随声音扬起，以致‘飏’用于‘扬声’。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "conversion",
      "note": "‘飞扬’作为形容词或动词用来描述物体飞翔状态。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "synecdoche",
      "note": "‘飏’泛指飞扬，本义延伸至分散杂物等具体动作，如‘簸颺’。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "reanalysis",
      "note": "‘飏’为‘颺’的简化字，现代官方推广。"
    }
  ]
}