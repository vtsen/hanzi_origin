{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "noun",
      "meaning": "古地名。为春秋时期秦邑名、汉代有上邽、下邽县，今甘肃省天水市及陕西省渭南县等地名使用。",
      "examples": [
        "秦武公十年，伐邽、冀戎，初县之。（《史记·秦本纪》）",
        "徙于下邽，今为下邽人焉。（《旧唐书·白居易传》）"
      ],
      "traditional_char": "邽"
    },
    {
      "index": 1,
      "part_of_speech": "noun",
      "meaning": "姓氏。",
      "examples": [
        "孔子弟子有邽巽。（《史记·仲尼弟子列传》）"
      ],
      "traditional_char": "邽"
    },
    {
      "index": 2,
      "part_of_speech": "noun",
      "meaning": "通“圭”。玉器名，宝玉。",
      "examples": [
        "郕伯卒，郕人立君。太子以夫钟与郕邽来奔。（《左传·文公十二年》）"
      ],
      "traditional_char": "邽"
    },
    {
      "index": 3,
      "part_of_speech": "noun",
      "meaning": "鸟名，即子规，杜鹃鸟。",
      "examples": [
        "南方鸟名曰邽，生而食其翼。（《太平御览》引《鲁连子》）"
      ],
      "traditional_char": "邽"
    },
    {
      "index": 4,
      "part_of_speech": "noun",
      "meaning": "“邦”的异体字（见于古籍用字习惯，不算独立普遍用法）。",
      "examples": [],
      "traditional_char": "邽"
    }
  ],
