  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "树木泛指为木质材料和木制品，属于材料和制品的引申。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "metonymy",
      "note": "由木料作为特定用途，特指棺材，汉语常见名物指代。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "以树木质朴比喻人品朴实，古代常用物象喻品质。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "metaphor",
      "note": "以树木无动作为呆笨象征，义项属于比喻。"
