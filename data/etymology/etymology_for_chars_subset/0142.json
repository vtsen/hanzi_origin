  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意，从二人相随形，表示‘跟随’。‘從’为本字，‘从’为简化。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metonymy",
      "note": "随行之人，西周至汉。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由跟随义引申为参与、投身。先秦至今。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "随行引申为‘依顺，听从’。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "grammaticalization",
      "note": "由跟随引申为介词‘由，自’。汉代之后。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "‘从’引申为次要或附属之义。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "宗族中次亲，属附属于本家的引申。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "‘从品’官阶，表示非正阶，附属于正品。"
    },
    {
      "source_index": 0,
      "target_index": 8,
      "evolution_type": "conversion",
      "note": "用作姓氏，为名词化用法。"
    },
    {
      "source_index": 0,
      "target_index": 9,
