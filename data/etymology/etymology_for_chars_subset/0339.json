  "formations": [
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘發’为形声字，发（殳声）表示放箭，‘殳’指兵器，声符‘癶’。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 13,
      "note": "‘髮’为形声字，从‘髟’（表头发），‘發’声，最初表示头发。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "metaphor",
      "note": "由‘放箭’引申为‘送出’、‘交付’，比喻如箭离弦。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "从‘射’引申出‘发表’、‘阐述’，有“发言如箭”的喻义。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "由集中射出引申为分散、散开。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "由物体放射扩展为事物扩展、发展。"
