    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metaphor",
      "note": "由‘射’或‘放开’引申为‘打开’、‘揭露’。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "由‘射出’进一步引申为‘产生’、‘出现’。"
    },
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "metaphor",
      "note": "‘出现’引申为发酵后食物膨胀、显现。"
    },
    {
      "source_index": 6,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "‘出现’‘显出’意义相关，直接引申。"
