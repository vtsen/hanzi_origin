  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "会意字，从女从子，表示美好。‘女’与‘子’合，象征和谐美好。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由‘貌美’引申为一般意义上的‘好’、‘善’。出现在先秦时期。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由‘美好’引申为‘健康、幸福’。"
    },
    {
      "source_index": 1,
      "target_index": 3,
      "evolution_type": "semantic_extension",
      "note": "‘好’从美好引申至‘友爱和睦’。"
    },
    {
      "source_index": 1,
      "target_index": 4,
      "evolution_type": "semantic_shift",
      "note": "‘好’转为表示‘容易’，原为‘令…美好’，后义移。"
    },
    {
      "source_index": 1,
      "target_index": 5,
      "evolution_type": "conversion",
      "note": "由形容词转为动词，表示‘完成’（事变好）。"
    },
    {
      "source_index": 1,
      "target_index": 6,
      "evolution_type": "grammaticalization",
      "note": "‘好’用作感叹词，表应允、赞成，语气化用法。"
    },
    {
      "source_index": 1,
      "target_index": 7,
      "evolution_type": "grammaticalization",
      "note": "‘好’用作副词，表示‘很、甚’。如“好快”。"
    },
    {
      "source_index": 4,
      "target_index": 8,
      "evolution_type": "grammaticalization",
      "note": "‘容易’义语法化为表示‘便于、为了’的连词。"
    },
    {
      "source_index": 1,
      "target_index": 9,
      "evolution_type": "semantic_shift",
      "note": "正话用作反话，语境变换下的意义转变。"
    },
    {
      "source_index": 1,
      "target_index": 10,
      "evolution_type": "semantic_extension",
      "note": "由‘美好’引申为‘喜爱’。早期就有。"
    },
    {
      "source_index": 10,
      "target_index": 11,
      "evolution_type": "semantic_extension",
      "note": "‘喜爱’引申为‘常常（喜欢做某事）’，再转为‘容易发生’。"
    }
  ]
