{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "名词",
      "meaning": "小麦的意思。",
      "examples": [
        "昔有神农，教民稼穑，五谷来备。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 1,
      "part_of_speech": "动词",
      "meaning": "由其他地方到这里，与“去”相对。",
      "examples": [
        "他来了。",
        "来回。",
        "归来。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 2,
      "part_of_speech": "名词",
      "meaning": "从过去到现在的过程。",
      "examples": [
        "从来如此。",
        "向来好学。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 3,
      "part_of_speech": "名词",
      "meaning": "将来的时间，未来。",
      "examples": [
        "来年再说。",
        "来日方长。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 4,
      "part_of_speech": "助词",
      "meaning": "用在数词或数量词后，表示约略估计。",
      "examples": [
        "二百来头猪。",
        "三十来岁。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 5,
      "part_of_speech": "动词",
      "meaning": "做某个动作，或试着做。",
      "examples": [
        "胡来。",
        "你来弹一弹。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 6,
      "part_of_speech": "助词",
      "meaning": "用在动词前面，表示要做某事。",
      "examples": [
        "大家来动脑筋。",
        "来一碗面。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 7,
      "part_of_speech": "助词",
      "meaning": "用在动词后，表示曾经发生过（通常可与“来着”连用）。",
      "examples": [
        "昨天他哭来。",
        "你说什么来着？"
      ],
      "traditional_char": "來"
    },
    {
      "index": 8,
      "part_of_speech": "助词",
      "meaning": "用在动词后，表示趋向。",
      "examples": [
        "上来。",
        "进来。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 9,
      "part_of_speech": "动词",
      "meaning": "表示事物发生。",
      "examples": [
        "暴风雨来了。",
        "事情突然就来了。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 10,
      "part_of_speech": "助词",
      "meaning": "在数字“一、二、三”后面用作列举理由。",
      "examples": [
        "我买这个手机，一来便宜，二来实用。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 11,
      "part_of_speech": "助词",
      "meaning": "用做诗、歌词中的衬字。",
      "examples": [
        "八月里来桂花香。"
      ],
      "traditional_char": "來"
    },
    {
      "index": 12,
      "part_of_speech": "语气词",
      "meaning": "表示感叹、祈使等语气。",
      "examples": [
