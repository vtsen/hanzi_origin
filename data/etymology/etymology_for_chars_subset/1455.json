{
  "senses": [
    {
      "index": 0,
      "part_of_speech": "名词",
      "meaning": "头的前部，脸，面部。",
      "examples": [
        "脸面",
        "颜面",
        "面目",
        "面面相觑"
      ],
      "traditional_char": "面"
    },
    {
      "index": 1,
      "part_of_speech": "动词",
      "meaning": "用脸对着，向着。",
      "examples": [
        "面对",
        "面壁"
      ],
      "traditional_char": "面"
    },
    {
      "index": 2,
      "part_of_speech": "名词",
      "meaning": "事物的外表。",
      "examples": [
        "地面",
        "面友",
        "面额"
      ],
      "traditional_char": "面"
    },
    {
      "index": 3,
      "part_of_speech": "名词",
      "meaning": "方位，部分。",
      "examples": [
        "前面",
        "反面",
        "片面",
        "全面"
      ],
      "traditional_char": "面"
    },
    {
      "index": 4,
      "part_of_speech": "量词",
      "meaning": "用于扁平物件的量词。",
      "examples": [
        "一面鼓"
      ],
      "traditional_char": "面"
    },
    {
      "index": 5,
      "part_of_speech": "动词",
      "meaning": "会见，直接接头。",
      "examples": [
        "当面",
        "面议",
        "面晤",
        "耳提面命"
      ],
      "traditional_char": "面"
    },
    {
      "index": 6,
      "part_of_speech": "名词",
      "meaning": "几何学上指线移动所生成的形迹，有长有宽没有厚的形。",
      "examples": [
        "平面",
        "曲面"
      ],
      "traditional_char": "面"
    },
    {
      "index": 7,
      "part_of_speech": "名词",
      "meaning": "粮食磨成的粉，特指小麦磨成的粉。",
      "examples": [
        "面粉",
        "面食",
        "面包"
      ],
      "traditional_char": "麵"
    },
    {
      "index": 8,
      "part_of_speech": "名词",
      "meaning": "粉末。",
      "examples": [
        "药面儿"
      ],
      "traditional_char": "麵"
    },
    {
      "index": 9,
      "part_of_speech": "名词",
      "meaning": "由面粉和水做成的条状食物。",
      "examples": [
        "面条"
      ],
      "traditional_char": "麵"
    },
    {
      "index": 10,
      "part_of_speech": "形容词",
      "meaning": "食物含纤维少而柔软。",
      "examples": [
        "这种瓜很面"
      ],
      "traditional_char": "麵"
    }
  ],
  "formations": [
    {
      "formation_type": "pictograph",
      "original_sense_index": 0,
      "note": "象形字，甲骨文形象为含“目”之脸部，整体外形代表人的面部。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 7,
      "note": "‘麵’为形声字，从‘面’，‘麥’声，指由麦子做成的食物及其粉末。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "conversion",
      "note": "由“面部”名词用法转化为“用脸对着”等动词用法。"
    },
    {
      "source_index": 0,
      "target_index": 2,
      "evolution_type": "metaphor",
      "note": "“面”引申为事物的外表，古已有之，表现为表面。"
    },
    {
      "source_index": 2,
      "target_index": 3,
      "evolution_type": "metaphor",
      "note": "“面”作为外表进一步引申为方位与部分。"
    },
    {
      "source_index": 2,
      "target_index": 4,
      "evolution_type": "reanalysis",
      "note": "外表作为独立计量单位，语法化为量词。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "metonymy",
      "note": "会见时以‘面’相对，遂引申为“会见”。"
    },
    {
      "source_index": 2,
      "target_index": 6,
      "evolution_type": "metaphor",
      "note": "表面意义抽象为数学几何学的“面”。"
    },
    {
      "source_index": 0,
      "target_index": 7,
      "evolution_type": "semantic_shift",
      "note": "简化字‘面’代指‘麵’，原本为不同字，现代归于一体。"
    },
    {
      "source_index": 7,
      "target_index": 8,
      "evolution_type": "semantic_extension",
      "note": "“面”指小麦粉，引申为一般粉末。"
    },
    {
      "source_index": 7,
      "target_index": 9,
      "evolution_type": "semantic_extension",
      "note": "面粉做成的条状食物，成为“面条”。"
    },
    {
      "source_index": 9,
      "target_index": 10,
      "evolution_type": "semantic_extension",
      "note": "因面食品柔软细腻之感，引申为食物口感柔软。"
    }
  ]
}