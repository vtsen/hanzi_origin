  "formations": [
    {
      "formation_type": "simple_indicative",
      "original_sense_index": 0,
      "note": "小篆字形由下面一横表示位置界线，上面短横表在上方，指事符号表示“高处；上面”的本义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "由具体空间的“上面”引申为空间次序和时间次序的“在前”。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "由时间与次序的提前引申为等级和质量的高。"
