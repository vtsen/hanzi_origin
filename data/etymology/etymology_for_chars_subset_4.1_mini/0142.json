  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "甲骨文象两人并行，表现随行意象，会意造字，表示“跟随”“随行”的基本意义。"
    }
  ],
  "edges": [
    {
      "source_index": 0,
      "target_index": 1,
      "evolution_type": "semantic_extension",
      "note": "从‘跟随’发展为‘依顺’的引申义，符合从属关系的语义扩展。"
    },
    {
      "source_index": 0,
      "target_index": 3,
      "evolution_type": "synecdoche",
      "note": "由行为派生出行为者，即‘跟随的人’。"
    },
    {
      "source_index": 1,
      "target_index": 2,
      "evolution_type": "semantic_extension",
      "note": "‘依顺’进一步引申为‘采取’、‘按着某法则行事’。"
    },
    {
      "source_index": 0,
      "target_index": 4,
      "evolution_type": "semantic_extension",
      "note": "‘跟随’延伸为‘参与’某事如‘从政’、‘从业’。"
    },
    {
      "source_index": 0,
      "target_index": 5,
      "evolution_type": "semantic_extension",
      "note": "表示起始点‘由、自’，由跟随行为语义延伸而来。"
    },
    {
      "source_index": 6,
      "target_index": 8,
      "evolution_type": "semantic_narrowing",
      "note": "‘次要的’义引申至官品等级中的‘从品’，含次一级的具体指称。"
    },
    {
      "source_index": 0,
      "target_index": 6,
      "evolution_type": "semantic_extension",
      "note": "‘从属’含义演变为‘次要’的意思。"
    },
    {
      "source_index": 6,
      "target_index": 7,
      "evolution_type": "semantic_extension",
      "note": "由‘次要’引申指亲属中次于至亲的成员。"
    },
    {
      "source_index": 9,
