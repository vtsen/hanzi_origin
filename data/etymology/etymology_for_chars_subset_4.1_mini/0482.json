    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 7,
      "note": "‘後’从‘人’与‘口’，象征君主发号施令，是君主的象形和会意字，代表帝王的本义。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 0,
      "note": "‘后’为‘君’的简化字，用作表示古代君主，含有从‘口’的象征，表达命令的含义。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 1,
      "note": "‘后’用以指帝王的妻子，意义由君主义引申而来，形成音义兼备的形声结构。"
    },
    {
      "formation_type": "phono_semantic_compound",
      "original_sense_index": 2,
      "note": "‘后’表示空间方位（背面），从空间位置意义引申，结构具有指示性意义成分。"
    }
  ],
