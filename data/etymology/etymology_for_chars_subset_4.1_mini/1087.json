  "formations": [
    {
      "formation_type": "compound_ideograph",
      "original_sense_index": 0,
      "note": "‘明’字会意字，甲骨文以‘日’和‘月’组合表示光明，取二者发光之义。小篆形体进一步以‘月’和‘囧’表示窗户的光亮，核心含义即为明亮清晰。"
    }
  ],
